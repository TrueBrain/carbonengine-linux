+// ---------------------------------------------------------------------
+// AKPLATFORM: platform helpers used by the low-level IO layer
+// ---------------------------------------------------------------------
+namespace AKPLATFORM
+{
+	inline size_t OsStrLen( const AkOSChar* str ) { return str ? ::strlen( str ) : 0; }
+	inline size_t AkUtf16StrLen( const AkUtf16* str )
+	{
+		size_t len = 0;
+		if( str )
+			while( str[len] != 0 )
+				++len;
+		return len;
+	}
+
+	inline void SafeStrCpy( AkOSChar* dest, const AkOSChar* src, size_t maxDestChars )
+	{
+		if( !dest || maxDestChars == 0 )
+			return;
+		if( !src )
+		{
+			dest[0] = 0;
+			return;
+		}
+		::strncpy( dest, src, maxDestChars - 1 );
+		dest[maxDestChars - 1] = 0;
+	}
+
+	inline void SafeStrCat( AkOSChar* dest, const AkOSChar* src, size_t maxDestChars )
+	{
+		if( !dest || !src || maxDestChars == 0 )
+			return;
+		size_t used = OsStrLen( dest );
+		if( used >= maxDestChars - 1 )
+			return;
+		::strncat( dest, src, maxDestChars - 1 - used );
+	}
+}
