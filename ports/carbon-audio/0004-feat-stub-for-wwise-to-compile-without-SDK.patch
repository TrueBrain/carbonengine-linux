@@ -0,0 +1,740 @@
+// Linux-only stand-in for the Wwise SDK. Not part of Audiokinetic's SDK.
+//
+// This header exists so CarbonAudio can compile on Linux, where the real
+// (licensed) Wwise SDK is not available. It reproduces only the surface
+// area CarbonAudio's source actually calls, with behaviorally inert bodies
+// (init calls "succeed", queries return failure/zero, nothing produces
+// audio). It is only ever selected on __linux__ builds -- see
+// CMakeLists.txt. Windows and macOS continue to use the real Wwise SDK.
+#pragma once
+
+#ifndef __linux__
+#error "AK/Core.h (the Wwise stub) must only be used on Linux builds."
+#endif
+
+#include <cstdint>
+#include <cstdio>
+#include <cstring>
+#include <cmath>
+#include <string>
+#include <functional>
+
+// ---------------------------------------------------------------------
+// Primitive typedefs
+// ---------------------------------------------------------------------
+typedef uint8_t  AkUInt8;
+typedef int8_t   AkInt8;
+typedef uint16_t AkUInt16;
+typedef int16_t  AkInt16;
+typedef uint32_t AkUInt32;
+typedef int32_t  AkInt32;
+typedef uint64_t AkUInt64;
+typedef int64_t  AkInt64;
+typedef float    AkReal32;
+typedef uint16_t AkUtf16;
+
+typedef uint64_t AkGameObjectID;
+typedef uint32_t AkUniqueID;
+typedef uint32_t AkPlayingID;
+typedef uint32_t AkBankID;
+typedef uint32_t AkPluginID;
+typedef uint32_t AkDeviceID;
+typedef uint32_t AkOutputDeviceID;
+typedef float    AkRtpcValue;
+typedef int32_t  AkTimeMs;
+typedef uint64_t AkGeomID;
+typedef uint32_t AkVertIdx;
+typedef uint32_t AkTriIdx;
+
+// AkOSChar matches this codebase's non-Windows convention (see AudSettings.h,
+// FileHelpers.h): narrow char, with std::wstring converted at call sites
+// via CW2A/CA2W where paths are involved.
+typedef char AkOSChar;
+typedef FILE* AkFileHandle;
+
+// ---------------------------------------------------------------------
+// Result codes / misc enums
+// ---------------------------------------------------------------------
+enum AKRESULT : int32_t
+{
+	AK_Success = 0,
+	AK_Fail,
+	AK_IDNotFound,
+	AK_NotCompatible,
+	AK_BankAlreadyLoaded,
+	AK_InvalidParameter,
+	AK_FileNotFound,
+	AK_FilePermissionError,
+	AK_UnknownFileError,
+	AK_InsufficientMemory,
+	AK_NotImplemented,
+};
+
+enum AkOpenMode
+{
+	AK_OpenModeRead = 0,
+	AK_OpenModeWrite,
+	AK_OpenModeWriteOvrwr,
+	AK_OpenModeReadWrite,
+};
+
+enum AkGlobalCallbackLocation
+{
+	AkGlobalCallbackLocation_EndRender = 1,
+};
+
+enum AkAudioDeviceEvent
+{
+	AkAudioDeviceEvent_Initialization = 0,
+	AkAudioDeviceEvent_Removal,
+	AkAudioDeviceEvent_SystemRemoval,
+};
+
+enum AkActionOnEventType
+{
+	AkActionOnEventType_Stop = 0,
+	AkActionOnEventType_Break,
+};
+
+enum AkDataState
+{
+	AK_DataReady = 0,
+	AK_NoMoreData,
+};
+
+// ---------------------------------------------------------------------
+// Constants / macros
+// ---------------------------------------------------------------------
+constexpr AkGameObjectID AK_INVALID_GAME_OBJECT = static_cast<AkGameObjectID>( -1 );
+constexpr AkPlayingID    AK_INVALID_PLAYING_ID   = 0;
+constexpr AkUniqueID     AK_INVALID_UNIQUE_ID    = 0;
+constexpr AkDeviceID     AK_INVALID_DEVICE_ID    = 0;
+constexpr size_t         AK_MAX_PATH             = 260;
+constexpr size_t         AK_COMM_SETTINGS_MAX_STRING_SIZE = 64;
+constexpr size_t         AK_MONITOR_DEVICENAME_MAXLENGTH  = 64;
+constexpr const char*    AK_PATH_SEPARATOR       = "/";
+constexpr AkUInt32       AKCODECID_BANK          = 0;
+constexpr AkUInt32       AKCOMPANYID_AUDIOKINETIC = 0;
+constexpr AkUInt32       AkPluginTypeNone        = 0;
+constexpr AkUInt32       AK_EndOfEvent           = 0x0001;
+constexpr AkUInt32       AK_SPEAKER_SETUP_STEREO = 3;
+constexpr AkUInt32       AK_SPEAKER_SETUP_MONO   = 1;
+constexpr AkUInt32       AK_INT                  = 0;
+constexpr AkUInt32       AK_INTERLEAVED          = 0;
+constexpr AkUInt32       AkMemID_Streaming       = 0;
+
+// AkWwiseSDKVersion.h contents (real Wwise headers define these too).
+constexpr AkUInt32       AK_WWISESDK_VERSION_MAJOR    = 2025;
+constexpr AkUInt32       AK_WWISESDK_VERSION_MINOR    = 1;
+constexpr AkUInt32       AK_WWISESDK_VERSION_SUBMINOR = 5;
+constexpr AkUInt32       AK_WWISESDK_VERSION_BUILD    = 9095;
+constexpr const char*    AK_WWISESDK_COPYRIGHT = "Linux Wwise stub (no Audiokinetic SDK present); not a real Wwise build.";
+
+#define AKMAKECLASSID( _type, _company, _index ) \
+	( (AkUInt32)( ( (AkUInt32)( _type ) ) | ( (AkUInt32)( _company ) << 8 ) | ( (AkUInt32)( _index ) << 16 ) ) )
+
+#define AKASSERT( _expr ) ( (void)0 )
+#define AK_UNUSEDVAR( _var ) ( (void)( _var ) )
+#define AKTEXT( _str ) _str
+#define AK_OSPRINTF ::snprintf
+
+// Not a real UTF-8 -> UTF-16 transcode, just enough to populate a debug-only
+// device name buffer for the (disabled in optimized builds) profiler monitor.
+#define AK_CHAR_TO_UTF16( _dest, _src, _maxLen )                                     \
+	do                                                                                 \
+	{                                                                                  \
+		size_t __akU16Len = ::strnlen( ( _src ), ( _maxLen ) - 1 );                   \
+		for( size_t __akU16I = 0; __akU16I < __akU16Len; ++__akU16I )                 \
+			( _dest )[__akU16I] = (AkUtf16)(unsigned char)( _src )[__akU16I];         \
+		( _dest )[__akU16Len] = 0;                                                    \
+	} while( 0 )
+
+template <typename T>
+inline T* AkNew( AkUInt32 /*pool*/, T value )
+{
+	return new T( static_cast<T&&>( value ) );
+}
+
+template <typename T>
+inline void AkDelete( AkUInt32 /*pool*/, T* ptr )
+{
+	delete ptr;
+}
+
+// ---------------------------------------------------------------------
+// Vector / transform math (real logic -- used for RH<->LH conversion)
+// ---------------------------------------------------------------------
+struct AkVector
+{
+	float X = 0.0f, Y = 0.0f, Z = 0.0f;
+};
+
+struct AkVector64
+{
+	double X = 0.0, Y = 0.0, Z = 0.0;
+};
+
+class Ak3DVector32
+{
+public:
+	float X = 0.0f, Y = 0.0f, Z = 0.0f;
+
+	Ak3DVector32() = default;
+	Ak3DVector32( float x, float y, float z ) : X( x ), Y( y ), Z( z ) {}
+
+	bool IsFinite() const { return std::isfinite( X ) && std::isfinite( Y ) && std::isfinite( Z ); }
+	float LengthSquared() const { return X * X + Y * Y + Z * Z; }
+	float Length() const { return std::sqrt( LengthSquared() ); }
+
+	void Normalize()
+	{
+		float length = Length();
+		if( length > 0.0f )
+		{
+			X /= length;
+			Y /= length;
+			Z /= length;
+		}
+	}
+
+	Ak3DVector32 Cross( const Ak3DVector32& other ) const
+	{
+		return Ak3DVector32( Y * other.Z - Z * other.Y, Z * other.X - X * other.Z, X * other.Y - Y * other.X );
+	}
+};
+
+struct AkTransform
+{
+	AkVector64 m_position{};
+	AkVector   m_front{ 0.0f, 0.0f, 1.0f };
+	AkVector   m_top{ 0.0f, 1.0f, 0.0f };
+
+	AkVector64 Position() const { return m_position; }
+	AkVector OrientationFront() const { return m_front; }
+	AkVector OrientationTop() const { return m_top; }
+
+	void Set( const AkVector64& pos, const AkVector& front, const AkVector& top )
+	{
+		m_position = pos;
+		m_front = front;
+		m_top = top;
+	}
+
+	void Set( const AkVector& pos, const AkVector& front, const AkVector& top )
+	{
+		Set( AkVector64{ pos.X, pos.Y, pos.Z }, front, top );
+	}
+
+	void SetPosition( const Ak3DVector32& pos ) { m_position = AkVector64{ pos.X, pos.Y, pos.Z }; }
+	void SetOrientation( const Ak3DVector32& front, const Ak3DVector32& top )
+	{
+		m_front = AkVector{ front.X, front.Y, front.Z };
+		m_top = AkVector{ top.X, top.Y, top.Z };
+	}
+};
+
+using AkListenerPosition = AkTransform;
+using AkSoundPosition = AkTransform;
+
+// ---------------------------------------------------------------------
+// Streaming / file IO types
+// ---------------------------------------------------------------------
+struct AkFileSystemFlags
+{
+	AkUInt32 uCodecID = 0;
