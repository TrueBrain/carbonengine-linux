+	void ( *fnProfilerPopTimer )() = nullptr;
+	void ( *fnProfilerPushTimer )( AkPluginID, const char* ) = nullptr;
+	void ( *fnProfilerPostMarker )( AkPluginID, const char* ) = nullptr;
+	AkOutputSettings settingsMainOutput{};
