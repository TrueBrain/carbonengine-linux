+                COMMAND ${CMAKE_COMMAND} -E copy $<TARGET_LINKER_FILE:Python3::Python> $<TARGET_FILE_DIR:VideoPlayerTest>
+                COMMAND_EXPAND_LISTS
+                VERBATIM
+        )
+    endif()
 
