From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sun, 5 Jul 2026 15:44:44 +0200
Subject: [PATCH 2/4] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 113 ++++++++++++++++++++++++++++---------------------
 vcpkg.json     |  17 +++++---
 2 files changed, 76 insertions(+), 54 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 68a7f2c..510ba35 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,6 +1,18 @@
 # Copyright © 2021 CCP ehf.
 
 cmake_minimum_required(VERSION 3.16)
+
+
+if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
+    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+else()
+    set(BUILD_TESTING OFF)
+endif()
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
+
 project(VideoPlayer VERSION 1.0.0)
 
 list(APPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_SOURCE_DIR}/cmake")
@@ -17,7 +29,6 @@ find_package(carbon-blue CONFIG REQUIRED)
 find_package(carbon-blueexposure CONFIG REQUIRED)
 find_package(carbon-trinityaudioapi CONFIG REQUIRED)
 find_package(carbon-trinity CONFIG REQUIRED)
-find_package(GTest REQUIRED)
 
 ccp_add_library(VideoPlayer SHARED
     FrameQueue.h
@@ -137,61 +148,65 @@ if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
      )
 endif()
 
+if(BUILD_TESTING)
+    enable_testing()
+    find_package(GTest REQUIRED)
+
+    ccp_add_executable(VideoPlayerTest
+        ${_SOURCES}
+        tests/TestUtilities.h
+        tests/TestFrameQueue.cpp
+        tests/TestUtilities.cpp
+        tests/TestVideoPlayerController.cpp
+        tests/TestVorbisDecoder.cpp
+        tests/TestVpxDecoder.cpp
+        tests/TestWebMParser.cpp
+        tests/main.cpp
+    )
 
