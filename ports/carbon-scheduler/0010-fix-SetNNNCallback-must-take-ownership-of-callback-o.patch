From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 21:37:27 +0200
Subject: [PATCH 10/13] fix: SetNNNCallback must take ownership of callback
 object

The function decref the old callback object, and then assigns
the new callback object without incref. This causes negative reference
counter issues.
---
 src/Channel.cpp         | 1 +
 src/ScheduleManager.cpp | 1 +
 2 files changed, 2 insertions(+)

diff --git a/src/Channel.cpp b/src/Channel.cpp
index d6856cb..a3e4bb6 100644
--- a/src/Channel.cpp
+++ b/src/Channel.cpp
@@ -505,6 +505,7 @@ PyObject* Channel::ChannelCallback()
 
 void Channel::SetChannelCallback( PyObject* callback )
 {
+	Py_XINCREF( callback );
 	Py_XDECREF( s_channelCallback ); 
 
     s_channelCallback = callback;
diff --git a/src/ScheduleManager.cpp b/src/ScheduleManager.cpp
index b448f84..8a7b32b 100644
--- a/src/ScheduleManager.cpp
+++ b/src/ScheduleManager.cpp
@@ -649,6 +649,7 @@ void ScheduleManager::SetSchedulerFastCallback( schedule_hook_func* func )
 void ScheduleManager::SetSchedulerCallback( PyObject* callback )
 {
 	// Callback is common accross threads
+	Py_XINCREF( callback );
 	Py_XDECREF( s_schedulerCallback );
 
 	s_schedulerCallback = callback;
