From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 21:21:21 +0200
Subject: [PATCH 06/13] fix: validate pointer before use

Otherwise the error why m_schedulerModule couldn't be loaded
is not made visible.
---
 tests/capiTest/InterpreterWithSchedulerModule.cpp | 14 +++++++-------
 1 file changed, 7 insertions(+), 7 deletions(-)

diff --git a/tests/capiTest/InterpreterWithSchedulerModule.cpp b/tests/capiTest/InterpreterWithSchedulerModule.cpp
index f1193af..f1e5d47 100644
--- a/tests/capiTest/InterpreterWithSchedulerModule.cpp
+++ b/tests/capiTest/InterpreterWithSchedulerModule.cpp
@@ -309,20 +309,20 @@ void InterpreterWithSchedulerModule::SetUp()
 #undef strcasecmp
 #endif
 
-	auto* sys_modules = PyImport_GetModuleDict();
-	if ( PyDict_SetItemString(sys_modules, "_scheduler", m_schedulerModule) == -1 ) {
+	if ( !m_schedulerModule )
+	{
 		PyErr_Print();
-		PySys_WriteStdout( "Failed inserting _scheduler into sys.modules" );
+		PySys_WriteStdout( "Failed to import scheduler module\n" );
 		exit( -1 );
 	}
-	Py_DecRef(sys_modules);
 
-	if ( !m_schedulerModule )
-	{
+	auto* sys_modules = PyImport_GetModuleDict();
+	if ( PyDict_SetItemString(sys_modules, "_scheduler", m_schedulerModule) == -1 ) {
 		PyErr_Print();
-		PySys_WriteStdout( "Failed to import scheduler module\n" );
+		PySys_WriteStdout( "Failed inserting _scheduler into sys.modules" );
 		exit( -1 );
 	}
+	Py_DecRef(sys_modules);
 
     // Import capsule
 	m_api = SchedulerAPI();
