From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 21:38:57 +0200
Subject: [PATCH 11/13] fix(tests): don't double-decref fooCallable

PyTuple_SetItem steals a reference to the item it stores. The manually
decref on the stolen reference causes a negative reference count.
---
 tests/capiTest/InterpreterWithSchedulerModule.cpp | 2 +-
 tests/capiTest/Tasklet.cpp                        | 8 ++++----
 2 files changed, 5 insertions(+), 5 deletions(-)

diff --git a/tests/capiTest/InterpreterWithSchedulerModule.cpp b/tests/capiTest/InterpreterWithSchedulerModule.cpp
index b3d163a..bcaec0e 100644
--- a/tests/capiTest/InterpreterWithSchedulerModule.cpp
+++ b/tests/capiTest/InterpreterWithSchedulerModule.cpp
@@ -399,8 +399,8 @@ PyTaskletObject* InterpreterWithSchedulerModule::CreateTasklet()
 	EXPECT_TRUE( m_api->PyTasklet_Check( reinterpret_cast<PyObject*>( tasklet ) ) );
 
 	// Clean
+	// Note: PyTuple_SetItem steals the reference to fooCallable, so it must not be decref'd here.
 	Py_XDECREF( taskletArgs );
-	Py_XDECREF( fooCallable );
 
     return tasklet;
 }
diff --git a/tests/capiTest/Tasklet.cpp b/tests/capiTest/Tasklet.cpp
index 21fab65..71f3013 100644
--- a/tests/capiTest/Tasklet.cpp
+++ b/tests/capiTest/Tasklet.cpp
@@ -30,9 +30,9 @@ TEST_F( TaskletCapi, PyTasklet_New )
     EXPECT_TRUE( m_api->PyTasklet_Check( reinterpret_cast<PyObject*>( tasklet ) ) );
 
     // Clean
+    // Note: PyTuple_SetItem steals the reference to fooCallable, so it must not be decref'd here.
 	Py_XDECREF( tasklet );
     Py_XDECREF( taskletArgs );
-	Py_XDECREF( fooCallable );
 
 }
 
@@ -91,9 +91,9 @@ TEST_F( TaskletCapi, PyTasklet_Setup )
 	Py_XDECREF( pythonTestValueList );
     
 	// Clean
+	// Note: PyTuple_SetItem steals the reference to fooCallable, so it must not be decref'd here.
 	Py_XDECREF( tasklet );
 	Py_XDECREF( taskletArgs );
-	Py_XDECREF( fooCallable );
 }
 
 TEST_F( TaskletCapi, PyTasklet_Setup_ReferenceCount )
@@ -131,7 +131,7 @@ TEST_F( TaskletCapi, PyTasklet_Setup_ReferenceCount )
 	EXPECT_EQ( Py_REFCNT(tasklet), 1);
 
 	// Clean
-	Py_DECREF(fooCallable);
+	// Note: PyTuple_SetItem steals the reference to fooCallable, so it must not be decref'd here.
 	Py_DECREF(taskletArgs);
 	Py_DECREF(tasklet);
 	Py_DECREF(callableArgs);
@@ -222,8 +222,8 @@ TEST_F( TaskletCapi, PyTasklet_Check )
 
 	EXPECT_FALSE( m_api->PyTasklet_Check( m_schedulerModule ) );
 
+    // Note: PyTuple_SetItem steals the reference to fooCallable, so it must not be decref'd here.
     Py_XDECREF( tasklet );
-	Py_XDECREF( fooCallable );
 }
 
 TEST_F( TaskletCapi, PyTasklet_GetBlockTrap )
