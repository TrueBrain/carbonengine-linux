From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 20:43:39 +0200
Subject: [PATCH 02/13] build: downgrade to CMake 3.28

Ubuntu 24.04 carries 3.28; after that, the cmake version of
vcpkg takes over.
---
 CMakeLists.txt                | 2 +-
 tests/capiTest/CMakeLists.txt | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 6457448..370e484 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 3.30.1)
+cmake_minimum_required(VERSION 3.28)
 project(Scheduler)
 
 include(cmake/CcpTargetConfigurations.cmake)
diff --git a/tests/capiTest/CMakeLists.txt b/tests/capiTest/CMakeLists.txt
index 69d116b..a5cfc13 100644
--- a/tests/capiTest/CMakeLists.txt
+++ b/tests/capiTest/CMakeLists.txt
@@ -1,4 +1,4 @@
-cmake_minimum_required(VERSION 3.31)
+cmake_minimum_required(VERSION 3.28)
 
 project(SchedulerCapiTest)
 
