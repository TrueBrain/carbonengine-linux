From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 23:39:53 +0200
Subject: [PATCH 3/6] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 20 +++++++++++++-------
 vcpkg.json     | 18 ++++++++++++------
 2 files changed, 25 insertions(+), 13 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 9f824a1..7c95694 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,6 +1,15 @@
 # Copyright © 2022 CCP ehf.
 
 cmake_minimum_required(VERSION 3.16)
+
+if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
+    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+endif()
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
+
 project(carbon-parser VERSION 1.0.0)
 
 include(cmake/CcpBuildConfigurations.cmake)
@@ -31,7 +40,7 @@ ccp_add_library(CcpParser STATIC
     src/scanner.re
     src/stdfunctions.cpp
     src/stringview.cpp
-        
+
     ${GENERATED_SOURCES_DIR}/scanner.cpp
 )
 target_sources(CcpParser PRIVATE
@@ -65,12 +74,9 @@ add_custom_command(
     MAIN_DEPENDENCY src/scanner.re
 )
 
-if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
-    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
-    if(BUILD_TESTING)
-        include(CTest)
-        add_subdirectory(tests)
-    endif()
+if(BUILD_TESTING)
+    include(CTest)
+    add_subdirectory(tests)
 endif()
 
 # Provide an install target iff this is the top level project only
diff --git a/vcpkg.json b/vcpkg.json
index 19c8e05..76e54f0 100644
--- a/vcpkg.json
+++ b/vcpkg.json
@@ -9,11 +9,17 @@
       "name": "lemon-parser-generator",
       "version>=": "3.39.3#1",
       "host": true
-    },
-    {
-      "name": "gtest",
-      "version>=": "1.16.0",
-      "host": true
     }
-  ]
+  ],
+  "features": {
+    "tests": {
+      "description": "Dependencies for building tests",
+      "dependencies": [
+        {
+          "name": "gtest",
+          "version>=": "1.16.0"
+        }
+      ]
+    }
+  }
 }
\ No newline at end of file
