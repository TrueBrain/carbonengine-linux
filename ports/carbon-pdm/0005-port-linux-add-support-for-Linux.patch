From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sun, 28 Jun 2026 16:32:04 +0200
Subject: [PATCH 5/5] port(linux): add support for Linux

Linux support are all stubs; it is mostly to get this compiling.
---
 CMakeLists.txt               |  24 +++++-
 include/pdm_data.h           |   2 +
 src/linux/linux_data.cpp     | 152 +++++++++++++++++++++++++++++++++++
 src/macos/macos_data.mm      |   5 ++
 src/utilities.cpp            |  24 +++++-
 src/windows/windows_data.cpp |  14 +---
 6 files changed, 204 insertions(+), 17 deletions(-)
 create mode 100644 src/linux/linux_data.cpp

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 019fc11..5438c14 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -31,11 +31,29 @@ set(SRC_FILES
 	src/output.cpp
 	src/utilities.cpp
 	src/wine/wine.cpp
-	src/windows/windows_data.cpp
-	src/windows/d3d_info.cpp
-	src/windows/vulkan_info.cpp
 )
 
+if(WIN32)
+	list(APPEND SRC_FILES
+		src/windows/windows_data.cpp
+		src/windows/d3d_info.cpp
+		src/windows/vulkan_info.cpp
+	)
+endif()
+
+if(APPLE)
+	list(APPEND SRC_FILES
+		src/macos/macos_data.mm
+	)
+endif()
+
+if(LINUX)
+	list(APPEND SRC_FILES
+		src/linux/linux_data.cpp
+	)
+endif()
+
+
 # For IDE support
 set(HDR_FILES
 	include/version.h
