From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sat, 4 Jul 2026 09:11:25 +0200
Subject: [PATCH 02/11] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 126 +++++++++++++++++++++++++++----------------------
 vcpkg.json     |  19 +++++---
 2 files changed, 82 insertions(+), 63 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index b9662f2..7d1da5e 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2,6 +2,27 @@
 
 cmake_minimum_required(VERSION 3.30)
 
+if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
+    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+
+    # Determine if/when to generate/build documentation. The rules are as follows:
+    # - If running locally - Build documentation is OFF by default
+    # - If running on a build agent (TeamCity) - Build documentation is ON by default
+    # - If -DBUILD_DOCUMENTATION=ON/OFF flag is explicitly set, use it.
+    set(BUILD_DOCUMENTATION_DEFAULT_FLAG OFF)
+    if(DEFINED ENV{TEAMCITY_VERSION})
+        set(BUILD_DOCUMENTATION_DEFAULT_FLAG ON)
+    endif()
+    option(BUILD_DOCUMENTATION "Build Documentation" ${BUILD_DOCUMENTATION_DEFAULT_FLAG})
+else()
+    set(BUILD_TESTING OFF)
+    set(BUILD_DOCUMENTATION OFF)
+endif()
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
+
 project(io VERSION 1.0.0)
 
 include(cmake/CcpTargetConfigurations.cmake)
@@ -153,70 +174,61 @@ if(WIN32)
     target_link_libraries(_select PUBLIC ws2_32.lib)
 endif()
 
-# Provide an install target if this is the top level project only
-if(CMAKE_PROJECT_NAME STREQUAL io)
-    option(BUILD_TESTING "Build tests. Enabled by default." ON)
+if(BUILD_TESTING)
     include(CTest)
+    add_subdirectory(tests)
 
-    if(BUILD_TESTING)
-        # include the C++ test suite
-        add_subdirectory(tests)
-
