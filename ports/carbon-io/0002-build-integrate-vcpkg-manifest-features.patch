-                    COMMAND ${Python3_EXECUTABLE} -m carboniotests -v ${PYTHON_TEST}
-                    WORKING_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR}/tests/python
+        if(WIN32)
+            set_tests_properties(
+                ${PYTHON_TEST}
+                PROPERTIES
