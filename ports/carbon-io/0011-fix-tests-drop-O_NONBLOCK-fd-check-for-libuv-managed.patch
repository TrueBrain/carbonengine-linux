From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sat, 4 Jul 2026 11:18:43 +0200
Subject: [PATCH 11/11] fix(tests): drop O_NONBLOCK fd check for libuv-managed
 blocking sockets

AF_INET/AF_INET6 SOCK_STREAM sockets are managed by libuv, which
intentionally keeps their fd non-blocking even when the Python API
reports blocking mode, to avoid hanging the event loop.

Windows / MacOS don't run test_SOCK_NONBLOCK, making this go unnoticed
till now.
---
 tests/python/carboniotests/test/test_socket.py | 2 --
 1 file changed, 2 deletions(-)

diff --git a/tests/python/carboniotests/test/test_socket.py b/tests/python/carboniotests/test/test_socket.py
index 37882f7..f752e8d 100644
--- a/tests/python/carboniotests/test/test_socket.py
+++ b/tests/python/carboniotests/test/test_socket.py
@@ -6052,8 +6052,6 @@ class NonblockConstantTest(unittest.TestCase):
         else:
             self.assertEqual(s.type, socket.SOCK_STREAM)
             self.assertEqual(s.gettimeout(), None)
-            self.assertFalse(
-                fcntl.fcntl(s, fcntl.F_GETFL, os.O_NONBLOCK) & os.O_NONBLOCK)
             self.assertTrue(s.getblocking())
 
     @support.requires_linux_version(2, 6, 28)
