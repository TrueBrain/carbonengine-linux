From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sat, 4 Jul 2026 21:18:05 +0200
Subject: [PATCH 1/3] build: update vcpkg registry to HTTPS

For vcpkg, it is much more common to use HTTPS for public registries.
Accessing them via SSH isn't always possible, as it requires a key pre-installed.
---
 vcpkg-configuration.json | 12 +++++++++---
 1 file changed, 9 insertions(+), 3 deletions(-)

diff --git a/vcpkg-configuration.json b/vcpkg-configuration.json
index 2fee0cc..309f12c 100644
--- a/vcpkg-configuration.json
+++ b/vcpkg-configuration.json
@@ -7,9 +7,15 @@
   "registries": [
     {
       "kind": "git",
-      "repository": "git@github.com:carbonengine/vcpkg-registry.git",
+      "repository": "https://github.com/carbonengine/vcpkg-registry.git",
       "baseline": "bcc6d146b99547f6654310495730e4cbba9ca7c3",
-      "packages": ["carbon-core", "ccp-debug-info", "tracy", "openvdb", "zlib"]
+      "packages": [
+        "carbon-core",
+        "ccp-debug-info",
+        "tracy",
+        "openvdb",
+        "zlib"
+      ]
     }
   ]
-}
+}
\ No newline at end of file
