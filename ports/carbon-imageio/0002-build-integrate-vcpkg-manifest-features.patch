From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sat, 4 Jul 2026 21:18:28 +0200
Subject: [PATCH 2/3] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 19 +++++++++++++------
 vcpkg.json     | 24 +++++++++++++++---------
 2 files changed, 28 insertions(+), 15 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 5c90e48..993cb94 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2,6 +2,16 @@
 
 cmake_minimum_required(VERSION 3.16)
 
+if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
+    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+else()
+    set(BUILD_TESTING OFF)
+endif()
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
+
 project(carbon-imageio VERSION 1.0.0)
 
 include(cmake/CcpTargetConfigurations.cmake)
@@ -75,12 +85,9 @@ target_link_libraries(CcpImageIO PUBLIC
 
 target_compile_options(CcpImageIO PRIVATE "${MATH_OPTIMIZE_FLAG}")
 
-if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
-    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+if(BUILD_TESTING)
     include(CTest)
-    if(BUILD_TESTING)
-	    add_subdirectory(tests)
-    endif()
+    add_subdirectory(tests)
 endif()
 
 # Provide an install target iff this is the top level project only
@@ -128,7 +135,7 @@ if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
 
         include(CMakePackageConfigHelpers)
 
-        configure_package_config_file(${CMAKE_CURRENT_SOURCE_DIR}/cmake/carbon-imageioConfig.cmake.in 
+        configure_package_config_file(${CMAKE_CURRENT_SOURCE_DIR}/cmake/carbon-imageioConfig.cmake.in
                                       ${CMAKE_CURRENT_BINARY_DIR}/carbon-imageioConfig.cmake
                                       INSTALL_DESTINATION share/carbon-imageio)
 
diff --git a/vcpkg.json b/vcpkg.json
index 3dd1853..e6a20e4 100644
--- a/vcpkg.json
+++ b/vcpkg.json
@@ -19,21 +19,27 @@
     {
       "name": "openvdb",
       "version>=": "10.0.0",
-      "features": [ "nanovdb-nocuda" ],
+      "features": [
+        "nanovdb-nocuda"
+      ],
       "default-features": false
-    },
-    {
-      "name": "gtest",
-      "version>=": "1.16.0",
-      "host": true
     }
-
   ],
+  "features": {
+    "tests": {
+      "description": "Build test suite",
+      "dependencies": [
+        {
+          "name": "gtest",
+          "version>=": "1.16.0"
+        }
+      ]
+    }
+  },
   "overrides": [
     {
       "name": "openexr",
       "version": "3.2.4#0"
     }
   ]
-  
-}
+}
\ No newline at end of file
