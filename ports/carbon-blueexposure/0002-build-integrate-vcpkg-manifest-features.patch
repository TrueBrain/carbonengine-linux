From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 20:17:06 +0200
Subject: [PATCH 2/4] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 9 +++++++--
 vcpkg.json     | 1 -
 2 files changed, 7 insertions(+), 3 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index edd12d4..f0f4ccd 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -2,6 +2,12 @@
 
 cmake_minimum_required(VERSION 3.21)
 
+option(BUILD_TESTING "Build tests. Enabled by default." ON)
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
+
 project(BlueExposure VERSION 1.0.0)
 
 include(cmake/CcpTargetConfigurations.cmake)
@@ -115,9 +121,8 @@ target_include_directories(BlueExposure
 )
 
 if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
-    option(BUILD_TESTING "Build tests. Enabled by default." ON)
-    include(CTest)
     if(BUILD_TESTING)
+        include(CTest)
 	    add_subdirectory(tests)
     endif()
 
diff --git a/vcpkg.json b/vcpkg.json
index 3aadd72..6b41d1a 100644
--- a/vcpkg.json
+++ b/vcpkg.json
@@ -9,7 +9,6 @@
       "version>=": "2.4.0"
     }
   ],
-  "default-features": ["tests"],
   "features": {
     "tests": {
       "description": "Build test suite",
