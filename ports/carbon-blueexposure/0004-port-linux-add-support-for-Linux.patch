From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Thu, 25 Jun 2026 20:08:51 +0200
Subject: [PATCH 4/4] port(linux): add support for Linux

---
 BlueExtractArgument.cpp             | 2 +-
 include/BlueExposureTypeSignature.h | 2 +-
 tests/CMakeLists.txt                | 8 +-------
 3 files changed, 3 insertions(+), 9 deletions(-)

diff --git a/BlueExtractArgument.cpp b/BlueExtractArgument.cpp
index d6a8618..cf6c6d0 100644
--- a/BlueExtractArgument.cpp
+++ b/BlueExtractArgument.cpp
@@ -495,7 +495,7 @@ bool BLUEIMPORT BlueExtractArgumentImpl( PyObject* argument, unsigned long& resu
 
 	return true;
 }
-#else
+#elif defined(__APPLE__)
 bool BLUEIMPORT BlueExtractArgumentImpl( PyObject* argument, long& result, unsigned int argID, std::false_type isBlueType )
 {
     if( PyLong_Check(argument) )
diff --git a/include/BlueExposureTypeSignature.h b/include/BlueExposureTypeSignature.h
index 67fd134..2129be3 100644
--- a/include/BlueExposureTypeSignature.h
+++ b/include/BlueExposureTypeSignature.h
@@ -689,7 +689,7 @@ struct TypeSignature<unsigned long>
 		return "long";
 	}
 };
-#else
+#elif defined(__APPLE__)
 template <>
 struct TypeSignature<long>
 {
diff --git a/tests/CMakeLists.txt b/tests/CMakeLists.txt
index ed1a6a0..b179fa6 100644
--- a/tests/CMakeLists.txt
+++ b/tests/CMakeLists.txt
@@ -65,7 +65,7 @@ set_target_properties(BlueExposureTest PROPERTIES
 # Construct python path for tests
 if(WIN32)
     set(PYTHONPATH_ENV "$<TARGET_FILE_DIR:BlueExposureTest>\;${CMAKE_CURRENT_SOURCE_DIR}/python")
-elseif(APPLE)
+else()
     set(PYTHONPATH_ENV "$<TARGET_FILE_DIR:BlueExposureTest>:${CMAKE_CURRENT_SOURCE_DIR}/python")
 endif()
 
@@ -93,13 +93,7 @@ foreach(PYTHON_TEST ${PYTHON_TESTS})
         COMMAND ${Python3_EXECUTABLE} -m unittest -v ${PYTHON_TEST}
         WORKING_DIRECTORY ${CMAKE_CURRENT_SOURCE_DIR}/python/BlueExposureTest/test
     )
-    if(WIN32)
     set_tests_properties(${PYTHON_TEST} PROPERTIES ENVIRONMENT "PYTHONPATH=${PYTHONPATH_ENV};BUILDFLAVOR=$<LOWER_CASE:$<CONFIG>>")
-    elseif(APPLE)
-        set_tests_properties(${PYTHON_TEST} PROPERTIES ENVIRONMENT "PYTHONPATH=${PYTHONPATH_ENV};BUILDFLAVOR=$<LOWER_CASE:$<CONFIG>>")
-    else()
-        message(FATAL_ERROR "Unsupported platform")
-    endif()
 endforeach()
 
 add_subdirectory(cpp)
