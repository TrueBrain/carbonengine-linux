+namespace
+{
+	std::mutex g_pyMemSizeMutex;
+	std::unordered_map<const void*, size_t> g_pyMemSizes;
+
+	void TrackSize( const void* ptr, size_t size )
+	{
+		if( !ptr )
+		{
+			return;
+		}
+		std::lock_guard<std::mutex> guard( g_pyMemSizeMutex );
+		g_pyMemSizes[ptr] = size;
+	}
+
+	size_t TakeTrackedSize( const void* ptr )
+	{
+		if( !ptr )
+		{
+			return 0;
+		}
+		std::lock_guard<std::mutex> guard( g_pyMemSizeMutex );
+		auto it = g_pyMemSizes.find( ptr );
+		if( it == g_pyMemSizes.end() )
+		{
+			return 0;
+		}
+		size_t size = it->second;
+		g_pyMemSizes.erase( it );
+		return size;
