@@ -162,6 +170,52 @@ static PyObject *PyGetExeFilePids( PyObject* self, PyObject* args)
 
     return list;
 }
+#elif defined(__linux__)
+static PyObject *PyGetExeFilePids( PyObject* self, PyObject* args)
+{
+	if( !PyArg_ParseTuple( args, "" ) )
+	{
+		return nullptr;
+	}
+
+	PyObject* list = PyList_New( 0 );
+
+	DIR* dir = opendir( "/proc" );
+	if( dir )
+	{
+		struct dirent* entry;
+		while( ( entry = readdir( dir ) ) != nullptr )
+		{
+			char* endptr;
+			long pid = strtol( entry->d_name, &endptr, 10 );
+			if( *endptr == '\0' && pid > 0 )
+			{
+				char commPath[64];
+				snprintf( commPath, sizeof( commPath ), "/proc/%ld/comm", pid );
+				std::ifstream commFile( commPath );
+				if( commFile )
+				{
+					std::string comm;
+					if( std::getline( commFile, comm ) )
+					{
+						if( !comm.empty() && comm.back() == '\n' )
+						{
+							comm.pop_back();
+						}
+						if( strcasecmp( comm.c_str(), "exefile" ) == 0 ||
+							strcasecmp( comm.c_str(), "exefile.exe" ) == 0 )
+						{
+							PyList_Append( list, BluePy( PyLong_FromLong( pid ) ) );
+						}
+					}
+				}
+			}
+		}
+		closedir( dir );
+	}
+
+	return list;
+}
 #endif
 #endif
 
