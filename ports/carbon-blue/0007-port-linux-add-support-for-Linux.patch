+}
+
+std::wstring BlueSysInfo::GetUserDocumentsDirectory() const
+{
+    const char* home = std::getenv("HOME");
+    if( home )
+    {
+        return std::wstring( CA2W( home ) ) + L"/.local/share";
+    }
+    return L"/tmp";
+}
+
+std::wstring BlueSysInfo::GetSharedApplicationDataDirectory() const
+{
+    // Can't use /usr/local/share, as it is unlikely the user has access to that.
+    // Instead, use the same folder as User Documents.
+    const char* home = std::getenv("HOME");
+    if( home )
+    {
