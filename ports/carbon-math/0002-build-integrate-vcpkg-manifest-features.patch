From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Fri, 3 Jul 2026 23:31:49 +0200
Subject: [PATCH 2/4] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 CMakeLists.txt | 17 +++++++++++------
 vcpkg.json     | 19 +++++++++++++------
 2 files changed, 24 insertions(+), 12 deletions(-)

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 018cb3e..09101e4 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -1,4 +1,12 @@
-cmake_minimum_required(VERSION 3.30)
+cmake_minimum_required(VERSION 3.28)
+
+if(CMAKE_SOURCE_DIR STREQUAL CMAKE_CURRENT_SOURCE_DIR)
+    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+endif()
+
+if(BUILD_TESTING)
+    list(APPEND VCPKG_MANIFEST_FEATURES "tests")
+endif()
 
 project(CcpMath)
 
@@ -68,12 +76,9 @@ target_link_libraries(CcpMath PUBLIC Microsoft::DirectXMath)
 
 target_compile_options(CcpMath PRIVATE "${MATH_OPTIMIZE_FLAG}")
 
-if(CMAKE_PROJECT_NAME STREQUAL PROJECT_NAME)
-    option(BUILD_TESTING "Build and run tests. Enabled by default." ON)
+if(BUILD_TESTING)
     include(CTest)
-    if(BUILD_TESTING)
-	    add_subdirectory(tests)
-    endif()
+    add_subdirectory(tests)
 endif()
 
 # Provide an install target if this is the top level project only
diff --git a/vcpkg.json b/vcpkg.json
index 5f11764..1e8adff 100644
--- a/vcpkg.json
+++ b/vcpkg.json
@@ -1,12 +1,19 @@
 {
   "dependencies": [
-    {
-      "name": "gtest",
-      "version>=": "1.16.0"
-    },
     {
       "name": "directxmath",
       "version>=": "2025-04-03"
     }
-  ]
-}
+  ],
+  "features": {
+    "tests": {
+      "description": "Dependencies for building tests",
+      "dependencies": [
+        {
+          "name": "gtest",
+          "version>=": "1.16.0"
+        }
+      ]
+    }
+  }
+}
\ No newline at end of file
