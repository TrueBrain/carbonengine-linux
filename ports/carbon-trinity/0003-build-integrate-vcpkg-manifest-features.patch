From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sun, 28 Jun 2026 15:19:27 +0200
Subject: [PATCH 03/16] build: integrate vcpkg manifest features

This ensures that CMake options propagate through via vcpkg.
Meaning no more installing Python3 if you are not building docs.
---
 vcpkg.json | 17 +++++++++++++----
 1 file changed, 13 insertions(+), 4 deletions(-)

diff --git a/vcpkg.json b/vcpkg.json
index 94287c30..24f1e88d 100644
--- a/vcpkg.json
+++ b/vcpkg.json
@@ -102,7 +102,7 @@
     },
     "dx11": {
       "description": "Create DirectX 11 targets",
-       "supports": "windows & x64",
+      "supports": "windows & x64",
       "dependencies": [
         {
           "name": "directx-dxc",
@@ -123,7 +123,11 @@
         {
           "name": "nvidia-streamline",
           "version>=": "2.8.0",
-          "features":["dlss-fg","dlss-sr","nis" ]
+          "features": [
+            "dlss-fg",
+            "dlss-sr",
+            "nis"
+          ]
         }
       ]
     },
@@ -154,7 +158,12 @@
         {
           "name": "nvidia-streamline",
           "version>=": "2.8.0",
-          "features":["dlss-fg","dlss-sr","nis","reflex" ]
+          "features": [
+            "dlss-fg",
+            "dlss-sr",
+            "nis",
+            "reflex"
+          ]
         },
         {
           "name": "intel-xess",
@@ -204,4 +213,4 @@
       "version": "1.15#14"
     }
   ]
-}
+}
\ No newline at end of file
