diff --git a/shadercompiler/CachingIncludeHandler.cpp b/shadercompiler/CachingIncludeHandler.cpp
index 7f215029..492b1a9e 100644
--- a/shadercompiler/CachingIncludeHandler.cpp
+++ b/shadercompiler/CachingIncludeHandler.cpp
@@ -26,10 +26,14 @@ std::string GetDirPath( const char* filepath )
 #if _WIN32
 	const char* filename = PathFindFileName( filepath );
 	return std::string( filepath, filename - filepath );
-#else
+#elif defined(__APPLE__)
 	char storage[MAXPATHLEN];
 	const char* dirName = dirname_r( filepath, storage );
 	return dirName;
+#elif defined(__linux__)
+	return dirname( (char *)(filepath) );
+#else
+#error "Unsupported platform"
