+
+bool ProfileMatchesStage( const InlineString& profile, InputStageType stage )
+{
+	if( profile == MakeInlineString( "" ) )
+	{
+		return true;
+	}
+	switch( stage )
+	{
+	case VERTEX_STAGE:
+		return profile == MakeInlineString( "vs" );
+	case PIXEL_STAGE:
+		return profile == MakeInlineString( "ps" );
+	case COMPUTE_STAGE:
+		return profile == MakeInlineString( "cs" );
+	case GEOMETRY_STAGE:
+		return profile == MakeInlineString( "gs" );
+	case HULL_STAGE:
+		return profile == MakeInlineString( "hs" );
+	case DOMAIN_STAGE:
+		return profile == MakeInlineString( "ds" );
+	default:
+		return false;
+	}
+}
+
+// Returns the register specifier in effect for this stage: an explicit register
+// with a matching profile wins over the auto-assigned one (profile "").
+const RegisterSpecifier* GetEffectiveRegister( const Symbol* symbol, InputStageType stage )
+{
+	const RegisterSpecifier* fallback = nullptr;
+	for( auto& r : symbol->registerSpecifier )
+	{
+		if( !ProfileMatchesStage( r.first, stage ) )
+		{
+			continue;
+		}
+		if( r.second.explicitRegister )
+		{
+			return &r.second;
+		}
+		fallback = &r.second;
+	}
+	return fallback;
+}
+
+uint32_t GetRegisterCount( const Type& type )
+{
+	uint32_t count = 1;
+	for( int i = 0; i < type.arrayDimensions; ++i )
+	{
+		count *= uint32_t( type.arraySizes[i] );
+	}
+	return std::max( count, 1u );
+}
+
+ConstantType TypeToConstantType( const Type& type )
+{
+	switch( type.builtInType )
+	{
+	case OP_FLOAT:
+	case OP_HALF:
+	case OP_DOUBLE:
+		return CONSTANT_TYPE_FLOAT;
+	case OP_INT:
+		return CONSTANT_TYPE_INT;
+	case OP_UINT:
+	case OP_BINDLESSHANDLETEXTURE2D:
+	case OP_BINDLESSHANDLETEXTURE3D:
+	case OP_BINDLESSHANDLETEXTURECUBE:
+	case OP_BINDLESSHANDLESAMPLER:
+		return CONSTANT_TYPE_UINT;
+	case OP_BOOL:
+		return CONSTANT_TYPE_BOOL;
+	default:
+		return CONSTANT_TYPE_OTHER;
+	}
+}
+
+// D3D constant buffer packing (fxc rules). dxc is invoked with -fvk-use-dx-layout
+// so the SPIR-V offsets match what is computed here.
+bool ComputeConstantLayout( const Type& type, uint32_t& runningOffset, Constant& constant, uint32_t& arrayStride )
+{
+	if( type.symbol != nullptr )
+	{
+		return false; // struct constants are not supported
+	}
+
+	uint32_t elementCount = 1;
+	for( int i = 0; i < type.arrayDimensions; ++i )
+	{
+		elementCount *= uint32_t( type.arraySizes[i] );
+	}
+
+	uint32_t elementSize;
+	if( type.IsMatrix() )
+	{
+		// column_major floatRxC: C column registers, each holding R components
+		elementSize = 16 * uint32_t( type.height - 1 ) + 4 * uint32_t( type.width );
+		constant.dimension = 16;
+	}
+	else
+	{
+		elementSize = 4 * uint32_t( type.width );
+		constant.dimension = uint8_t( type.width );
+	}
+
+	uint32_t offset = runningOffset;
+	if( type.arrayDimensions > 0 || type.IsMatrix() )
+	{
+		offset = ( offset + 15 ) & ~15u;
+	}
+	else
+	{
+		offset = ( offset + 3 ) & ~3u;
+		if( offset / 16 != ( offset + elementSize - 1 ) / 16 )
+		{
+			offset = ( offset + 15 ) & ~15u;
+		}
+	}
+
+	arrayStride = ( elementSize + 15 ) & ~15u;
+	uint32_t size = elementSize;
+	if( type.arrayDimensions > 0 )
+	{
+		size = arrayStride * ( elementCount - 1 ) + elementSize;
+	}
+
+	constant.offset = offset;
+	constant.size = size;
+	constant.type = TypeToConstantType( type );
+	constant.elements = type.arrayDimensions > 0 ? elementCount : 0;
+
+	runningOffset = offset + size;
+	return true;
+}
+
+bool FillDefaults( ParserState& state, ASTNode* node, void* outDefaultValues, const Type& type )
+{
+	Type expectedType = type;
+	ExpressionValue value;
+
+	if( type.IsMatrix() )
+	{
+		state.ShowMessage( node->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+		return false;
+	}
+
+	if( EvaluateInitializer( state, node, expectedType, value, nullptr ) )
+	{
+		uint32_t count = uint32_t( type.width * type.height );
+		if( count != value.size() )
+		{
+			state.ShowMessage( node->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+			return false;
+		}
+
+		if( type.builtInType == OP_FLOAT )
+		{
+			float* floatValues = (float*)outDefaultValues;
+			for( size_t i = 0; i < count; ++i )
+			{
+				*floatValues++ = float( value[i].floatValue );
+			}
+		}
+		else if( type.builtInType == OP_INT || type.builtInType == OP_UINT || type.builtInType == OP_BOOL )
+		{
+			int32_t* intValues = (int32_t*)outDefaultValues;
+			for( size_t i = 0; i < count; ++i )
+			{
+				*intValues++ = int32_t( value[i].intValue );
+			}
+		}
+		else
+		{
+			state.ShowMessage( node->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+			return false;
+		}
+
+		return true;
+	}
+
+	return false;
+}
+
+bool FlattenStructConstants( ParserState& state, StageData& stage, const std::string& prefix, const Type& structType, ASTNode* location, uint32_t& offset );
+
+// Lays out a single constant buffer field into stage.constants. Struct-typed
+// fields flatten into one Constant per leaf member (dxc lays the cbuffer out the
+// same way), so a DX9-style "struct {...} X : register(vs, cN)" binding works.
+bool AddConstant( ParserState& state, StageData& stage, const std::string& name, const Type& type, ASTNode* location, uint32_t& offset )
+{
+	if( type.arrayDimensions == 0 && type.symbol && type.symbol->definition && type.symbol->definition->GetNodeType() == NT_STRUCT )
+	{
+		return FlattenStructConstants( state, stage, name, type, location, offset );
+	}
+
+	Constant constant;
+	constant.name = g_stringTable.AddString( name.c_str() );
+	constant.isSRGB = false;
+	constant.isAutoregister = false;
+
+	uint32_t arrayStride = 0;
+	if( !ComputeConstantLayout( type, offset, constant, arrayStride ) )
+	{
+		state.ShowMessage( location->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+		return false;
+	}
+
+	stage.constants.push_back( constant );
+	return true;
+}
+
+// Flattens a struct-typed field into its leaf members. Per HLSL cbuffer packing
+// a struct (and the field following it) starts on a 16-byte boundary.
+bool FlattenStructConstants( ParserState& state, StageData& stage, const std::string& prefix, const Type& structType, ASTNode* location, uint32_t& offset )
+{
+	offset = ( offset + 15 ) & ~15u;
+
+	for( auto member : structType.symbol->definition->GetChildren() )
+	{
+		if( !member || member->GetNodeType() != NT_STRUCT_MEMBER )
+		{
+			continue;
+		}
+		ASTNode* decl = member->GetChildOrNull( 0 );
+		if( !decl || !decl->GetSymbol() )
+		{
+			continue;
+		}
+		Symbol* memberSymbol = decl->GetSymbol();
+		std::string name = prefix + "." + ToString( memberSymbol->name );
+		if( !AddConstant( state, stage, name, memberSymbol->type, decl, offset ) )
+		{
+			return false;
+		}
+	}
+
+	offset = ( offset + 15 ) & ~15u;
+	return true;
+}
+
+// Collects the members of a constant buffer, in declaration order, into
+// stage.constants. Only used members participate: the HLSL emitter skips unused
+// declarations, so this layout matches the source dxc actually compiles.
+bool CollectConstants( ParserState& state, StageData& stage, ASTNode* cbufferNode, std::map<StringReference, ParameterAnnotation>& annotations )
+{
+	uint32_t offset = 0;
+
+	std::vector<ASTNode*> declarations;
+	for( auto child : cbufferNode->GetChildren() )
+	{
+		if( !child )
+		{
+			continue;
+		}
+		if( child->GetNodeType() == NT_NAME_DECLARATION )
+		{
+			declarations.push_back( child );
+		}
+		else if( child->GetNodeType() == NT_VAR_DECLARATION_LIST )
+		{
+			for( auto decl : child->GetChildren() )
+			{
+				if( decl && decl->GetNodeType() == NT_NAME_DECLARATION )
+				{
+					declarations.push_back( decl );
+				}
+			}
+		}
+	}
+
+	for( auto declaration : declarations )
+	{
+		Symbol* symbol = declaration->GetSymbol();
+		if( !symbol || !symbol->used )
+		{
+			continue;
+		}
+
+		// "static const" globals are compile-time constants that dxc inlines; they
+		// are not laid out in the constant buffer, so skip them (they must not shift
+		// the offsets of the real members that follow).
+		if( symbol->type.storageClass == OP_STATIC )
+		{
+			continue;
+		}
+
+		const Type& type = symbol->type;
+
+		// A struct field (e.g. a "struct {...} X : register(vs, cN)" binding
+		// wrapped into a cbuffer) flattens into one Constant per leaf member.
+		if( type.arrayDimensions == 0 && type.symbol && type.symbol->definition && type.symbol->definition->GetNodeType() == NT_STRUCT )
+		{
+			if( !FlattenStructConstants( state, stage, ToString( symbol->name ), type, declaration, offset ) )
+			{
+				return false;
+			}
+			continue;
+		}
+
+		Constant constant;
+		constant.name = g_stringTable.AddString( symbol->name );
+		constant.isSRGB = false;
+		constant.isAutoregister = false;
+
+		uint32_t arrayStride = 0;
+		if( !ComputeConstantLayout( type, offset, constant, arrayStride ) )
+		{
+			state.ShowMessage( declaration->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+			return false;
+		}
+
+		// Annotations (also extracts sRGB/autoregister flags).
+		{
+			ParameterAnnotation paramAnnotations;
+			if( symbol->annotations )
+			{
+				for( auto& a : *symbol->annotations )
+				{
+					Annotation result;
+					if( MakeEffectAnnotationFromSymbolAnnotation( a, result, constant.isSRGB, constant.isAutoregister ) )
+					{
+						paramAnnotations.annotations[g_stringTable.AddString( a.name )] = result;
+					}
+				}
+			}
+			if( symbol->type.IsBindlessHandle() )
+			{
+				Annotation symbolAnnotation;
+				symbolAnnotation.type = ANNOTATION_TYPE_INT;
+				symbolAnnotation.intValue = symbol->type.builtInType == OP_BINDLESSHANDLESAMPLER ? 100 : BindlessTextureType( symbol->type.builtInType );
+				paramAnnotations.annotations[g_stringTable.AddString( "BindlessHandleType" )] = symbolAnnotation;
+			}
+			if( !paramAnnotations.annotations.empty() && annotations.find( constant.name ) == annotations.end() )
+			{
+				annotations[constant.name] = paramAnnotations;
+			}
+			if( symbol->type.IsBindlessHandle() && symbol->type.builtInType == OP_BINDLESSHANDLESAMPLER )
+			{
+				auto found = std::find_if( begin( state.m_bindlessSamplers ), end( state.m_bindlessSamplers ), [symbol]( const auto& bs ) { return bs.name == symbol; } );
+				if( found != end( state.m_bindlessSamplers ) )
+				{
+					Sampler sampler;
+					if( GetSamplerState( state, found->definition, sampler ) )
+					{
+						sampler.name = constant.name;
+						stage.samplers[uint8_t( 100 + ( found - begin( state.m_bindlessSamplers ) ) )] = sampler;
+					}
+				}
+			}
+		}
+
+		// Default value?
+		ASTNode* defaultValueNode = declaration->GetChildOrNull( 1 );
+		if( defaultValueNode )
+		{
+			stage.defaultValues.resize( std::max( stage.defaultValues.size(), size_t( constant.offset + constant.size ) ) );
+			memset( &stage.defaultValues[constant.offset], 0, constant.size );
+
+			if( type.arrayDimensions == 0 )
+			{
+				if( !FillDefaults( state, defaultValueNode, stage.defaultValues.data() + constant.offset, type ) )
+				{
+					return false;
+				}
+			}
+			else if( type.arrayDimensions == 1 )
+			{
+				Type elementType = type;
+				elementType.arrayDimensions = 0;
+				for( size_t i = 0, n = defaultValueNode->GetChildrenCount(); i < n; ++i )
+				{
+					size_t elementOffset = constant.offset + i * arrayStride;
+					if( !FillDefaults( state, defaultValueNode->GetChild( unsigned( i ) ), stage.defaultValues.data() + elementOffset, elementType ) )
+					{
+						return false;
+					}
+				}
+			}
+			else
+			{
+				state.ShowMessage( defaultValueNode->GetLocation(), EC_UNSUPPORTED_TYPE, type.ToString().c_str() );
+				return false;
+			}
+		}
+
+		stage.constants.push_back( constant );
+	}
+	return true;
+}
+
+bool HasUsedDeclarations( ASTNode* node )
+{
+	for( auto child : node->GetChildren() )
+	{
+		if( !child )
+		{
+			continue;
+		}
+		if( child->GetNodeType() == NT_NAME_DECLARATION )
+		{
+			if( child->GetSymbol() && child->GetSymbol()->used )
+			{
+				return true;
+			}
+		}
+		else if( child->GetNodeType() == NT_VAR_DECLARATION_LIST )
+		{
+			if( HasUsedDeclarations( child ) )
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+// Walks the program and populates registerInputs/textures/samplers/uavs/constants
+// for all used resources, mirroring DxReflection::ProcessReflection.
+bool CollectResources( ParserState& state, ASTNode* node, InputStageType stageType, StageData& stage, std::map<StringReference, ParameterAnnotation>& annotations, bool useStaticSamplers )
+{
+	if( !node )
+	{
+		return true;
+	}
+	switch( node->GetNodeType() )
+	{
+	case NT_CBUFFER: {
+		if( !HasUsedDeclarations( node ) )
+		{
+			return true;
+		}
+		const RegisterSpecifier* reg = GetEffectiveRegister( node->GetSymbol(), stageType );
+		if( !reg )
+		{
+			state.ShowMessage( node->GetLocation(), EC_CUSTOM_ERROR, "internal error: constant buffer \"%s\" has no register assigned", ToString( node->GetSymbol()->name ).c_str() );
+			return false;
+		}
+		if( reg->space > 0 )
+		{
+			state.ShowMessage( node->GetLocation(), EC_CUSTOM_ERROR, "register spaces other than space0 are not supported by the Vulkan backend" );
+			return false;
+		}
+		stage.registerInputs.push_back( { RT_CONSTANT_BUFFER, uint32_t( reg->registerNumber ), 1, 0 } );
+		if( reg->registerNumber == 0 )
+		{
+			if( !CollectConstants( state, stage, node, annotations ) )
+			{
+				return false;
+			}
+		}
+		return true;
+	}
+	case NT_NAME_DECLARATION: {
+		Symbol* symbol = node->GetSymbol();
+		if( !symbol || !symbol->used )
+		{
+			return true;
+		}
+		char registerType = ClassifyRegisterType( symbol->type );
+		if( !registerType )
+		{
+			return true;
+		}
+		const RegisterSpecifier* reg = GetEffectiveRegister( symbol, stageType );
+		if( !reg )
+		{
+			state.ShowMessage( node->GetLocation(), EC_CUSTOM_ERROR, "internal error: resource \"%s\" has no register assigned", ToString( symbol->name ).c_str() );
+			return false;
+		}
+		// A nonzero register space maps directly to a Vulkan descriptor set
+		// (dxc's default: HLSL space N -> descriptor set N). AssignRegisters puts
+		// each resource array in its own space, so arrays land in their own set.
+		uint32_t registerCount = GetRegisterCount( symbol->type );
+		uint32_t registerNumber = uint32_t( reg->registerNumber );
+		uint32_t registerSpace = uint32_t( reg->space );
+
+		switch( registerType )
+		{
+		case 's': {
+			Sampler sampler;
+			if( !GetSamplerState( state, symbol->definition, sampler ) )
+			{
+				return false;
+			}
+			StaticSampler staticSampler;
+			if( symbol->type.arrayDimensions == 0 && useStaticSamplers && ConvertToStaticSampler( staticSampler, sampler ) )
+			{
+				staticSampler.registerIndex = registerNumber;
+				staticSampler.registerSpace = registerSpace;
+				stage.staticSamplers.push_back( staticSampler );
+			}
+			else
+			{
+				sampler.name = g_stringTable.AddString( symbol->name );
+				stage.samplers[uint8_t( registerNumber )] = sampler;
+				stage.registerInputs.push_back( { RT_SAMPLER, registerNumber, registerCount, registerSpace } );
+
+				bool srgb, autoregister;
+				AddSymbolAnnotations( symbol, annotations, srgb, autoregister );
+			}
+			break;
+		}
+		case 't': {
+			stage.registerInputs.push_back( { TypeToRegisterInputType( symbol->type ), registerNumber, registerCount, registerSpace } );
+
+			Texture texture;
+			texture.name = g_stringTable.AddString( symbol->name );
+			texture.type = TypeToTextureType( symbol->type );
+			texture.count = registerCount;
+			AddSymbolAnnotations( symbol, annotations, texture.isSRGB, texture.isAutoregister );
+			stage.textures[uint8_t( registerNumber )] = texture;
+			break;
+		}
+		case 'u': {
+			stage.registerInputs.push_back( { TypeToRegisterInputType( symbol->type ), registerNumber, registerCount, registerSpace } );
+
+			Uav uav;
+			uav.name = g_stringTable.AddString( symbol->name );
+			uav.type = TypeToTextureType( symbol->type );
+			uav.count = registerCount;
+			bool srgb;
+			AddSymbolAnnotations( symbol, annotations, srgb, uav.isAutoregister );
+			stage.uavs[uint8_t( registerNumber )] = uav;
+			break;
+		}
+		default:
+			break;
+		}
+		return true;
+	}
+	case NT_PROGRAM:
+	case NT_VAR_DECLARATION_LIST:
+		for( size_t i = 0; i < node->GetChildrenCount(); ++i )
+		{
+			if( !CollectResources( state, node->GetChild( i ), stageType, stage, annotations, useStaticSamplers ) )
+			{
+				return false;
+			}
+		}
+		return true;
+	default:
+		return true;
+	}
+}
+
+// ----------------------------------------------------------------------------
+// Ray tracing libraries. Resources named in the [globalinput] attribute are
+// bound through descriptors like any other resource and go into the library's
+// global inputs. Everything else is local, i.e. provided per shader record;
+// Vulkan has no local root signatures, so local data is restricted to a
+// single constant buffer whose contents the runtime embeds into the shader
+// binding table record and the shader reads as shaderRecordEXT data.
+// ----------------------------------------------------------------------------
+
+// Registers are assigned for the library pseudo-stage (see AssignRegisters
+// call in the library loop); the empty shader profile matches any stage.
+const InputStageType LIBRARY_STAGE = InputStageType( 8 );
+
+// True if the constant buffer has at least one member that dxc lays out. A
+// buffer whose only members are inlined "static const" globals produces no
+// constant buffer at all, so it must not become a (local) shader record.
+bool HasLaidOutConstants( ASTNode* cbufferNode )
+{
+	for( auto child : cbufferNode->GetChildren() )
+	{
+		std::vector<ASTNode*> declarations;
+		if( child && child->GetNodeType() == NT_NAME_DECLARATION )
+		{
+			declarations.push_back( child );
+		}
+		else if( child && child->GetNodeType() == NT_VAR_DECLARATION_LIST )
+		{
+			for( auto decl : child->GetChildren() )
+			{
+				if( decl && decl->GetNodeType() == NT_NAME_DECLARATION )
+				{
+					declarations.push_back( decl );
+				}
+			}
+		}
+		for( auto decl : declarations )
+		{
+			Symbol* symbol = decl->GetSymbol();
+			if( symbol && symbol->used && symbol->type.storageClass != OP_STATIC )
+			{
+				return true;
+			}
+		}
+	}
+	return false;
+}
+
+bool IsGlobalInput( const Symbol* symbol, const std::vector<GlobalInputElement>& globalInputs )
+{
+	return std::any_of( begin( globalInputs ), end( globalInputs ), [symbol]( const GlobalInputElement& element ) {
+		return element.symbol == symbol || ( element.name == symbol->name && element.type == symbol->type );
+	} );
+}
+
+bool CollectLibraryResources( ParserState& state, ASTNode* node, const std::vector<GlobalInputElement>& globalInputs, StageData& globalStage, StageData& localStage, std::map<StringReference, ParameterAnnotation>& annotations, std::vector<InlineString>& localCBuffers )
+{
+	if( !node )
+	{
+		return true;
+	}
+	switch( node->GetNodeType() )
+	{
+	case NT_CBUFFER: {
+		if( !HasUsedDeclarations( node ) )
+		{
+			return true;
+		}
+		// A buffer that only holds inlined "static const" globals contributes no
+		// descriptor and no shader record data; turning it into a shader record
+		// yields an empty struct that dxc then indexes into (invalid SPIR-V).
+		if( !HasLaidOutConstants( node ) )
+		{
+			return true;
+		}
+		Symbol* symbol = node->GetSymbol();
+		const RegisterSpecifier* reg = GetEffectiveRegister( symbol, LIBRARY_STAGE );
+		if( !reg )
+		{
+			state.ShowMessage( node->GetLocation(), EC_CUSTOM_ERROR, "internal error: constant buffer \"%s\" has no register assigned", ToString( symbol->name ).c_str() );
+			return false;
+		}
+		// Register spaces on RT cbuffers just distinguish local (shader record)
+		// from global bindings in HLSL; the space itself carries no meaning here
+		// since local cbuffers become shader record data (not descriptors) and
+		// global ones are always placed at descriptor set 0, so it is discarded
+		// below rather than checked.
+		// PatchCBuffers wraps DX9-style bindings (e.g. "struct {...} X : register(vs, cN)")
+		// into a fresh buffer symbol, while the globalinput list still names the wrapped
+		// variable, so also match the cbuffer's member declarations.
+		bool isGlobal = IsGlobalInput( symbol, globalInputs );
+		for( auto child : node->GetChildren() )
+		{
+			if( isGlobal )
+			{
+				break;
+			}
+			if( child && child->GetNodeType() == NT_NAME_DECLARATION && child->GetSymbol() && IsGlobalInput( child->GetSymbol(), globalInputs ) )
+			{
+				isGlobal = true;
+			}
+		}
+		StageData& stage = isGlobal ? globalStage : localStage;
+		if( &stage == &localStage )
+		{
+			localCBuffers.push_back( symbol->name );
+		}
+		stage.registerInputs.push_back( { RT_CONSTANT_BUFFER, uint32_t( reg->registerNumber ), 1, 0 } );
+		return CollectConstants( state, stage, node, annotations );
+	}
+	case NT_NAME_DECLARATION: {
+		Symbol* symbol = node->GetSymbol();
+		if( !symbol || !symbol->used )
+		{
+			return true;
+		}
+		char registerType = ClassifyRegisterType( symbol->type );
+		if( !registerType )
+		{
+			return true;
+		}
+		if( !IsGlobalInput( symbol, globalInputs ) )
+		{
+			state.ShowMessage( node->GetLocation(), EC_CUSTOM_ERROR, "resource \"%s\" is not listed in [globalinput]: the Vulkan backend only supports constants as local shader record data", ToString( symbol->name ).c_str() );
+			return false;
+		}
+		// Global resources use the regular descriptor path.
+		return CollectResources( state, node, LIBRARY_STAGE, globalStage, annotations, true );
+	}
+	case NT_PROGRAM:
+	case NT_VAR_DECLARATION_LIST:
+		for( size_t i = 0; i < node->GetChildrenCount(); ++i )
+		{
+			if( !CollectLibraryResources( state, node->GetChild( i ), globalInputs, globalStage, localStage, annotations, localCBuffers ) )
+			{
+				return false;
+			}
+		}
+		return true;
+	default:
+		return true;
+	}
+}
+
+// Global inputs that no shader in the library referenced still describe the
+// pipeline's interface and are exported (mirroring the DX12 backend).
+bool AddUnusedGlobalInputs( ParserState& state, StageData& globalStage, const std::vector<GlobalInputElement>& globalInputs, std::map<StringReference, ParameterAnnotation>& annotations )
+{
+	for( const auto& input : globalInputs )
+	{
+		Symbol* symbol = input.symbol;
+		if( !symbol || symbol->registerSpecifier.empty() )
+		{
+			continue;
+		}
+		const RegisterSpecifier* reg = GetEffectiveRegister( symbol, LIBRARY_STAGE );
+		if( !reg )
+		{
+			continue;
+		}
+
+		RegisterInputDescription description = {};
+		description.registerType = reg->registerType == 'b' ? RT_CONSTANT_BUFFER : TypeToRegisterInputType( symbol->type );
+		description.registerIndex = uint32_t( reg->registerNumber );
+		description.registerCount = GetRegisterCount( symbol->type );
+		description.registerSpace = 0;
+
+		auto alreadyExported = std::find_if( begin( globalStage.registerInputs ), end( globalStage.registerInputs ), [&description]( const RegisterInputDescription& existing ) {
+			return existing.registerType == description.registerType && existing.registerIndex == description.registerIndex;
+		} );
+
+		switch( reg->registerType )
+		{
+		case 's': {
+			Sampler sampler;
+			if( !GetSamplerState( state, symbol->definition, sampler ) )
+			{
+				return false;
+			}
+			StaticSampler staticSampler;
+			if( symbol->type.arrayDimensions == 0 && ConvertToStaticSampler( staticSampler, sampler ) )
+			{
+				staticSampler.registerIndex = reg->registerNumber;
+				staticSampler.registerSpace = 0;
+				auto found = std::find_if( begin( globalStage.staticSamplers ), end( globalStage.staticSamplers ), [&staticSampler]( const StaticSampler& existing ) {
+					return existing.registerIndex == staticSampler.registerIndex && existing.registerSpace == staticSampler.registerSpace;
+				} );
+				if( found == end( globalStage.staticSamplers ) )
+				{
+					globalStage.staticSamplers.push_back( staticSampler );
+				}
+			}
+			else if( alreadyExported == end( globalStage.registerInputs ) )
+			{
+				sampler.name = g_stringTable.AddString( symbol->name );
+				globalStage.samplers[uint8_t( reg->registerNumber )] = sampler;
+				globalStage.registerInputs.push_back( description );
+
+				bool srgb, autoregister;
+				AddSymbolAnnotations( symbol, annotations, srgb, autoregister );
+			}
+			break;
+		}
+		case 't': {
+			if( alreadyExported != end( globalStage.registerInputs ) )
+			{
+				break;
+			}
+			globalStage.registerInputs.push_back( description );
+
+			Texture texture;
+			texture.name = g_stringTable.AddString( symbol->name );
+			texture.type = TypeToTextureType( symbol->type );
+			texture.count = description.registerCount;
+			texture.isSRGB = false;
+			texture.isAutoregister = false;
+			AddSymbolAnnotations( symbol, annotations, texture.isSRGB, texture.isAutoregister );
+			globalStage.textures[uint8_t( reg->registerNumber )] = texture;
+			break;
+		}
+		case 'u': {
+			if( alreadyExported != end( globalStage.registerInputs ) )
+			{
+				break;
+			}
+			globalStage.registerInputs.push_back( description );
+
+			Uav uav;
+			uav.name = g_stringTable.AddString( symbol->name );
+			uav.type = TypeToTextureType( symbol->type );
+			uav.count = description.registerCount;
+			bool srgb;
+			AddSymbolAnnotations( symbol, annotations, srgb, uav.isAutoregister );
+			globalStage.uavs[uint8_t( reg->registerNumber )] = uav;
+			break;
+		}
+		case 'b': {
+			if( alreadyExported == end( globalStage.registerInputs ) )
+			{
+				globalStage.registerInputs.push_back( description );
+			}
+			break;
+		}
+		default:
+			break;
+		}
+	}
+	return true;
+}
+
+// Prefixes the (single) local constant buffer's declaration in the generated
+// HLSL with [[vk::shader_record_ext]], turning it into shader record data.
+std::string AddShaderRecordAttribute( const std::string& code, const InlineString& cbufferName )
+{
+	const std::string declaration = "cbuffer " + ToString( cbufferName );
+	size_t at = 0;
+	while( ( at = code.find( declaration, at ) ) != std::string::npos )
+	{
+		const size_t end = at + declaration.size();
+		const char next = end < code.size() ? code[end] : ' ';
+		if( !isalnum( (unsigned char)next ) && next != '_' )
+		{
+			return code.substr( 0, at ) + "[[vk::shader_record_ext]]\n" + code.substr( at );
+		}
+		at = end;
+	}
+	return code;
+}
+
+// ----------------------------------------------------------------------------
+// Pipeline inputs. dxc assigns SPIR-V input locations in declaration order,
+// skipping system-value builtins; the same numbering is reproduced here. The
+// Vulkan runtime uses PipelineInputDescription::registerIndex directly as the
+// vertex attribute location (see trinityal/vulkan/Tr2RenderContextVulkan.cpp).
+// ----------------------------------------------------------------------------
+
+bool IsSystemSemantic( const std::string& semantic )
+{
+	if( semantic.size() >= 3 && _strnicmp( semantic.c_str(), "sv_", 3 ) == 0 )
+	{
+		return true;
+	}
+	if( _stricmp( semantic.c_str(), "vpos" ) == 0 || _stricmp( semantic.c_str(), "vface" ) == 0 )
+	{
+		return true;
+	}
+	return false;
+}
+
+void SplitSemantic( const std::string& semantic, std::string& name, uint32_t& index )
+{
+	size_t end = semantic.size();
+	while( end > 0 && isdigit( static_cast<unsigned char>( semantic[end - 1] ) ) )
+	{
+		--end;
+	}
+	name = semantic.substr( 0, end );
+	index = end < semantic.size() ? uint32_t( atoi( semantic.c_str() + end ) ) : 0;
+}
+
+bool AddPipelineInput( ParserState& state, StageInput& stage, Symbol* symbol, uint32_t& location, const FileLocation& messageLocation )
+{
+	const Type& type = symbol->type;
+
+	// Struct inputs are flattened in member declaration order.
+	if( type.symbol && type.symbol->definition )
+	{
+		for( auto member : type.symbol->definition->GetChildren() )
+		{
+			if( !member )
+			{
+				continue;
+			}
+			for( auto declaration : member->GetChildren() )
+			{
+				if( declaration && declaration->GetSymbol() )
+				{
+					if( !AddPipelineInput( state, stage, declaration->GetSymbol(), location, messageLocation ) )
+					{
+						return false;
+					}
+				}
+			}
+		}
+		return true;
+	}
+
+	std::string semantic = ToString( symbol->semantic );
+	if( semantic.empty() )
+	{
+		state.ShowMessage( messageLocation, EC_CUSTOM_ERROR, "shader input \"%s\" has no semantic", ToString( symbol->name ).c_str() );
+		return false;
+	}
+	if( IsSystemSemantic( semantic ) )
+	{
+		// Builtins do not consume an input location.
+		return true;
+	}
+
+	if( type.IsMatrix() )
+	{
+		state.ShowMessage( messageLocation, EC_CUSTOM_ERROR, "matrix shader inputs are not supported by the Vulkan backend" );
+		return false;
+	}
+
+	std::string semanticName;
+	uint32_t semanticIndex;
+	SplitSemantic( semantic, semanticName, semanticIndex );
+
+	bool found = false;
+	PipelineInputDescription input;
+	for( int n = 0; n < UC_NUM_USAGE_CODE; ++n )
+	{
+		if( _stricmp( semanticName.c_str(), GetStringForUsageCode( n ) ) == 0 )
+		{
+			input.name = uint8_t( n );
+			found = true;
+			break;
+		}
+	}
+	if( !found )
+	{
+		g_messages.AddMessage( "\\memory(0): error X0000: Shader uses unsupported input semantics \"%s\"", semantic.c_str() );
+		return false;
+	}
+
+	input.registerIndex = uint8_t( location++ );
+	input.index = uint8_t( semanticIndex );
+	input.type = TypeToConstantType( type );
+	input.dimension = uint8_t( type.width );
+	input.usedMask = uint8_t( ( 1u << type.width ) - 1 );
+	stage.pipelineInputs.push_back( input );
+	return true;
+}
+
+bool CollectPipelineInputs( ParserState& state, StageInput& stage, ASTNode* callNode )
+{
+	Symbol* entryPointSymbol = callNode->GetSymbol();
+	if( !entryPointSymbol || !entryPointSymbol->definition )
+	{
+		return false;
+	}
+	ASTNode* functionHeader = entryPointSymbol->definition->GetChildOrNull( 0 );
+	if( !functionHeader )
+	{
+		return false;
+	}
+
+	uint32_t location = 0;
+	for( size_t i = 0; i < functionHeader->GetChildrenCount(); ++i )
+	{
+		ASTNode* parameter = functionHeader->GetChild( i );
+		if( IsUniformInputArgument( parameter ) )
+		{
+			continue;
+		}
+		if( parameter->GetToken() && parameter->GetToken()->type == OP_OUT )
+		{
+			continue;
+		}
+		Symbol* symbol = parameter->GetSymbol();
+		if( !symbol )
+		{
+			continue;
+		}
+		if( !AddPipelineInput( state, stage, symbol, location, parameter->GetLocation() ) )
+		{
+			return false;
+		}
+	}
+	return true;
+}
+
+}
+
+bool EffectCompilerVulkan::Create()
+{
+	auto compilerOutput = RunProcess( ( DxcTool() + " --version" ).c_str() );
+	if( compilerOutput.first != 0 )
+	{
+		g_messages.AddMessage( "ShaderCompiler: error X0000: Could not invoke dxc (\"%s\"). Set DXC_PATH or pass /dxc <path>.\n", DxcTool().c_str() );
+		return false;
+	}
+	return true;
+}
+
+bool EffectCompilerVulkan::CompileEffect( const char* source, size_t sourceLength, const std::vector<Macro>& defines, EffectData& result, IWorkQueue* workQueue )
+{
+	ZoneScoped;
+
+	// Normalize the PLATFORM define to the numeric id so shader code can test it.
+	std::vector<Macro> newDefines = defines;
+	if( auto define = FindMacro( newDefines, "PLATFORM" ) )
+	{
+		define->value = GetPlatformIdString( PLATFORM_VULKAN );
+	}
+	else
+	{
+		newDefines.push_back( { "PLATFORM", GetPlatformIdString( PLATFORM_VULKAN ) } );
+	}
+
+	ParserState state( MakeInlineString( source, source + sourceLength ) );
+	for( auto& it : newDefines )
+	{
+		PreprocessorDefine d;
+		d.location.fileName = MakeInlineString( "" );
+		d.location.lineNumber = 0;
+		d.value = MakeInlineString( it.value.c_str() );
+		state.m_defines[MakeInlineString( it.name.c_str() )] = d;
+	}
+
+	if( !state.Parse() )
+	{
+		return false;
+	}
+
+	PatchCBuffers( state );
+	TransferSRGBToTexturesDX11( state );
+	ConvertTextureFunctionsDX11( state );
+	MergeSamplers( state );
+
+	std::vector<ASTNode*> techniqueNodes;
+	state.GetTree()->FindNodes( NT_TECHNIQUE, techniqueNodes );
+	if( techniqueNodes.empty() )
+	{
+		g_messages.AddMessage( "\\memory(0): error X0000: No technique found" );
+		return false;
+	}
+
+	YamlListing listing;
+	listing.dict();
+	listing.literal( "permutation" ).dict().literal( "platform" ).literal( "Vulkan" ).literal( "id" ).literal( "000" ).literal( "defines" ).dict();
+	for( auto& it : newDefines )
+	{
+		listing.literal( it.name ).literal( it.value );
+	}
+	listing.end();
+	listing.literal( "techniques" ).list();
+
+	for( auto techniqueNode : techniqueNodes )
+	{
+		Technique technique;
+		technique.name = g_stringTable.AddString( ToString( techniqueNode->GetToken()->stringValue ).c_str() );
+
+		listing.dict()
+			.literal( "name" )
+			.literal( techniqueNode->GetToken()->stringValue )
+			.literal( "passes" )
+			.list();
+
+		for( size_t passIx = 0; passIx < techniqueNode->GetChildrenCount(); ++passIx )
+		{
+			ASTNode* passNode = techniqueNode->GetChild( passIx );
+			if( passNode->GetNodeType() != NT_PASS )
+			{
+				// Ray tracing libraries are handled after the passes.
+				continue;
+			}
+			listing.list();
+			Pass outPass;
+			for( size_t stateIx = 0; stateIx < passNode->GetChildrenCount(); ++stateIx )
+			{
+				if( passNode->GetChild( stateIx )->GetNodeType() == NT_STATE_ASSIGNMENT )
+				{
+					unsigned stateCode = 0;
+					unsigned value = 0;
+					if( ParseStateAssignment( state, passNode->GetChild( stateIx ), g_renderStates, &value ) )
+					{
+						std::string name = ToString( passNode->GetChild( stateIx )->GetToken()->stringValue );
+						for( int i = 0; g_renderStateNames[i].name; ++i )
+						{
+							if( _stricmp( name.c_str(), g_renderStateNames[i].name ) == 0 )
+							{
+								stateCode = g_renderStateNames[i].value;
+							}
+						}
+						switch( stateCode )
+						{
+						case unsigned( -1 ):
+						case unsigned( -2 ):
+						case unsigned( -3 ):
+						case unsigned( -4 ):
+						case unsigned( -5 ):
+						case unsigned( -6 ):
+							if( value != 0 )
+							{
+								state.ShowMessage( passNode->GetChild( stateIx )->GetLocation(), EC_INVALID_STATE_VALUE, name.c_str() );
+							}
+							break;
+						case 0:
+							state.ShowMessage( passNode->GetChild( stateIx )->GetLocation(), EC_STATE_DEPRECATED, name.c_str() );
+							break;
+						default:
+							outPass.states[stateCode] = value;
+						}
+					}
+					continue;
+				}
+
+				if( passNode->GetChild( stateIx )->GetNodeType() != NT_SHADER_ASSIGNMENT )
+				{
+					continue;
+				}
+
+				ASTNode* shaderNode = passNode->GetChild( stateIx );
+
+				StageInput stage;
+				if( !ParseShaderName( shaderNode->GetToken()->stringValue, stage.type ) )
+				{
+					state.ShowMessage( shaderNode->GetToken()->fileLocation, EC_INVALID_STATE, ToString( shaderNode->GetToken()->stringValue ).c_str() );
+					return false;
+				}
+
+				switch( stage.type )
+				{
+				case VERTEX_STAGE:
+				case PIXEL_STAGE:
+				case COMPUTE_STAGE:
+					break;
+				default:
+					state.ShowMessage( shaderNode->GetLocation(), EC_CUSTOM_ERROR, "Shader type %i is not supported by the Vulkan backend", int( stage.type ) );
+					return false;
+				}
+
+				// vs_3_0 etc. from the source -> shader model 6.0 for dxc
+				std::string profile = ToString( shaderNode->GetChild( 0 )->GetToken()->stringValue );
+				profile = profile.substr( 0, 3 ) + "6_0";
+
+				if( shaderNode->GetChild( 1 )->GetSymbol() == nullptr )
+				{
+					return false;
+				}
+
+				GetThreadGroupSize( stage, shaderNode->GetChild( 1 ) );
+
+				PatchSemantics( stage.type, shaderNode->GetChild( 1 ) );
+
+				state.GetSymbolTable().ResetUsedFlag();
+				MarkUsedSymbols( shaderNode->GetChild( 1 ), state );
+
+				CreateGlobalsCB( state );
+				AssignRegisters( state.GetTree(), stage.type );
+
+				CompilerInputStream os( state, ShadingLanguage::HLSL );
+				os << HLSL{ state.GetTree(), &state.GetSymbolTable() };
+
+				std::string entryPoint = ToString( shaderNode->GetChild( 1 )->GetSymbol()->name );
+
+				std::string patchEntryPoint = entryPoint;
+				switch( PatchShader( stage.type, shaderNode->GetChild( 1 ), state, os, patchEntryPoint ) )
+				{
+				case PATCH_ERROR:
+					return false;
+				default:
+					break;
+				}
+				state.ResetPragmaUsage();
+				std::string code = os.str();
+
+				std::string shaderCacheKey = code + "\n//" + profile + ' ' + patchEntryPoint;
+
+				// Let only one thread compile this permutation.
+				bool needsToCompile = false;
+				std::shared_ptr<SyncData> syncData;
+				{
+					std::lock_guard scope( m_compiledCS );
+					auto found = m_compiled.find( shaderCacheKey );
+					if( found == end( m_compiled ) )
+					{
+						// Yep, this thread will have to compile. Make an entry into the cache.
+						syncData = std::make_shared<SyncData>();
+						m_compiled[shaderCacheKey] = syncData;
+						needsToCompile = true;
+					}
+					else
+					{
+						// Some other thread is going to compile for us. Grab his stuff from the cache.
+						syncData = found->second;
+					}
+				}
+
+				if( !needsToCompile )
+				{
+					// Let's wait for the other thread to compile for us
+					if( workQueue )
+					{
+						workQueue->OnBlocked();
+					}
+					{
+						std::unique_lock<std::mutex> lock( syncData->mutex );
+						syncData->conditionVariable.wait( lock, [&syncData] { return syncData->compiled; } );
+					}
+					if( workQueue )
+					{
+						workQueue->OnUnblocked();
+					}
+				}
+				else
+				{
+					// We need to compile, nobody else is doing it for this permutation.
+					auto compiledCode = CompileSpirv( code, profile, patchEntryPoint, stage.type );
+					syncData->compiledCode = compiledCode;
+
+					// Let's wake up everyone waiting for this permutation's compilation.
+					{
+						std::lock_guard scope( syncData->mutex );
+						syncData->compiled = true;
+					}
+					syncData->conditionVariable.notify_all();
+				}
+
+				auto compiledCode = syncData->compiledCode;
+
+				{
+					std::lock_guard scope( m_compiledCS );
+					syncData.reset();
+				}
+
+				if( compiledCode.empty() )
+				{
+					// No compiledCode on the cache entry! This means compilation must have failed.
+					return false;
+				}
+
+				stage.shaderSize = uint32_t( compiledCode.size() );
+				stage.shaderDataStr = g_stringTable.AddString( compiledCode.data(), compiledCode.size() );
+				stage.source = code;
+
+				if( !CollectResources( state, state.GetTree(), stage.type, stage, result.annotations, true ) )
+				{
+					return false;
+				}
+
+				if( !CollectPipelineInputs( state, stage, shaderNode->GetChild( 1 ) ) )
+				{
+					return false;
+				}
+
+				{
+					stage.annotations.annotations.clear();
+					Symbol* symbol = shaderNode->GetChild( 1 )->GetSymbol();
+					if( symbol && symbol->annotations )
+					{
+						for( auto a = symbol->annotations->begin(); a != symbol->annotations->end(); ++a )
+						{
+							Annotation symbolAnnotation;
+							bool isSrgb, isAutoregister;
+							if( MakeEffectAnnotationFromSymbolAnnotation( *a, symbolAnnotation, isSrgb, isAutoregister ) )
+							{
+								stage.annotations.annotations[g_stringTable.AddString( ToString( a->name ).c_str() )] = symbolAnnotation;
+							}
+						}
+					}
+				}
+
+				if( !stage.defaultValues.empty() )
+				{
+					stage.defaultValuesStr = g_stringTable.AddString( &stage.defaultValues[0], stage.defaultValues.size() );
+				}
+				else
+				{
+					stage.defaultValuesStr = INVALID_REFERENCE;
+				}
+
+				if( listing.enabled() )
+				{
+					listing.dict()
+						.literal( "profile" )
+						.literal( profile )
+						.literal( "original" )
+						.dict()
+						.literal( "entryPoint" )
+						.literal( patchEntryPoint )
+						.literal( "source" )
+						.literal( SanitizeCode( code ) );
+					listing.end();
+					listing.end();
+				}
+
+				outPass.stages.push_back( stage );
+			}
+			technique.passes.push_back( outPass );
+
+			listing.end(); // stages list
+		}
+
+		listing.end(); // passes list
+		listing.literal( "libraries" ).list();
+
+		for( size_t passIx = 0; passIx < techniqueNode->GetChildrenCount(); ++passIx )
+		{
+			ASTNode* libNode = techniqueNode->GetChild( passIx );
+			if( libNode->GetNodeType() != NT_LIBRARY )
+			{
+				continue;
+			}
+			listing.dict()
+				.literal( "name" )
+				.literal( libNode->GetToken()->stringValue )
+				.literal( "exports" )
+				.list();
+
+			Library library;
+			library.payloadSize = 0;
+			library.hitGroupName = g_stringTable.AddString( "" );
+			library.globalInputs.defaultValuesStr = INVALID_REFERENCE;
+			library.localInputs.defaultValuesStr = INVALID_REFERENCE;
+
+			std::vector<GlobalInputElement> globalInputs;
+
+			state.GetSymbolTable().ResetUsedFlag();
+
+			for( size_t i = 0; i < libNode->GetChildrenCount(); ++i )
+			{
+				auto childNode = libNode->GetChild( i );
+				if( childNode->GetNodeType() == NT_SHADER_ASSIGNMENT )
+				{
+					ShaderExport shaderExport;
+					if( auto parsed = ParseRtShaderName( childNode->GetToken()->stringValue ) )
+					{
+						shaderExport.type = parsed.value();
+					}
+					else
+					{
+						state.ShowMessage( childNode->GetToken()->fileLocation, EC_INVALID_STATE, ToString( childNode->GetToken()->stringValue ).c_str() );
+						return false;
+					}
+					listing.literal( childNode->GetChild( 1 )->GetSymbol()->name );
+					shaderExport.name = g_stringTable.AddString( ToString( childNode->GetChild( 1 )->GetSymbol()->name ).c_str() );
+					library.exports.push_back( shaderExport );
+
+					if( !ProcessGlobalInputAttribute( state, childNode->GetChild( 1 )->GetSymbol()->definition, globalInputs ) )
+					{
+						return false;
+					}
+					for( auto& gi : globalInputs )
+					{
+						if( gi.symbol )
+						{
+							gi.symbol->used = true;
+							if( auto type = gi.symbol->type.symbol )
+							{
+								const_cast<Symbol*>( type )->used = true;
+							}
+						}
+					}
+					MarkUsedSymbols( childNode->GetChild( 1 ), state );
+				}
+				else if( childNode->GetNodeType() == NT_STATE_ASSIGNMENT )
+				{
+					auto name = childNode->GetToken()->stringValue;
+					if( EqualsCaseInsensitive( name, "payloadsize" ) )
+					{
+						Type type;
+						type.FromTokenType( OP_UINT );
+						ExpressionValue value;
+						if( !EvaluateExpression( state, childNode->GetChildOrNull( 0 ), type, value, nullptr ) )
+						{
+							state.ShowMessage( childNode->GetToken()->fileLocation, EC_INVALID_STATE, ToString( name ).c_str() );
+							return false;
+						}
+						library.payloadSize = uint32_t( value[0].intValue );
+					}
+					else if( EqualsCaseInsensitive( name, "hitgroupname" ) )
+					{
+						Type type;
+						type.FromTokenType( OP_STRING );
+						ExpressionValue value;
+						if( !EvaluateExpression( state, childNode->GetChildOrNull( 0 ), type, value, nullptr ) )
+						{
+							state.ShowMessage( childNode->GetToken()->fileLocation, EC_INVALID_STATE, ToString( name ).c_str() );
+							return false;
+						}
+						library.hitGroupName = g_stringTable.AddString( value[0].stringValue.c_str() );
+					}
+				}
+			}
+			listing.end(); // exports list
+
+			CreateGlobalsCB( state );
+			AssignRegisters( state.GetTree(), LIBRARY_STAGE, globalInputs );
+
+			std::vector<InlineString> localCBuffers;
+			if( !CollectLibraryResources( state, state.GetTree(), globalInputs, library.globalInputs, library.localInputs, result.annotations, localCBuffers ) )
+			{
+				return false;
+			}
+			if( localCBuffers.size() > 1 )
+			{
+				state.ShowMessage( libNode->GetLocation(), EC_CUSTOM_ERROR, "the Vulkan backend supports at most one local constant buffer per library (it becomes the shader record)" );
+				return false;
+			}
+			if( !AddUnusedGlobalInputs( state, library.globalInputs, globalInputs, result.annotations ) )
+			{
+				return false;
+			}
+
+			if( !library.globalInputs.defaultValues.empty() )
+			{
+				library.globalInputs.defaultValuesStr = g_stringTable.AddString( &library.globalInputs.defaultValues[0], library.globalInputs.defaultValues.size() );
+			}
+			if( !library.localInputs.defaultValues.empty() )
+			{
+				library.localInputs.defaultValuesStr = g_stringTable.AddString( &library.localInputs.defaultValues[0], library.localInputs.defaultValues.size() );
+			}
+
+			CompilerInputStream os( state, ShadingLanguage::HLSL );
+			os << HLSL{ state.GetTree(), &state.GetSymbolTable() };
+			std::string code = os.str();
+			if( !localCBuffers.empty() )
+			{
+				code = AddShaderRecordAttribute( code, localCBuffers[0] );
+			}
+			library.source = code;
+
+			const std::string profile = "lib_6_3";
+			std::string shaderCacheKey = code + "\n//" + profile;
+
+			// Let only one thread compile this permutation.
+			bool needsToCompile = false;
+			std::shared_ptr<SyncData> syncData;
+			{
+				std::lock_guard scope( m_compiledCS );
+				auto found = m_compiled.find( shaderCacheKey );
+				if( found == end( m_compiled ) )
+				{
+					// Yep, this thread will have to compile. Make an entry into the cache.
+					syncData = std::make_shared<SyncData>();
+					m_compiled[shaderCacheKey] = syncData;
+					needsToCompile = true;
+				}
+				else
+				{
+					// Some other thread is going to compile for us. Grab his stuff from the cache.
+					syncData = found->second;
+				}
+			}
+
+			if( !needsToCompile )
+			{
+				// Let's wait for the other thread to compile for us
+				if( workQueue )
+				{
+					workQueue->OnBlocked();
+				}
+				{
+					std::unique_lock<std::mutex> lock( syncData->mutex );
+					syncData->conditionVariable.wait( lock, [&syncData] { return syncData->compiled; } );
+				}
+				if( workQueue )
+				{
+					workQueue->OnUnblocked();
+				}
+			}
+			else
+			{
+				// We need to compile, nobody else is doing it for this permutation.
+				auto compiledCode = CompileSpirv( code, profile, "", COMPUTE_STAGE );
+				syncData->compiledCode = compiledCode;
+
+				// Let's wake up everyone waiting for this permutation's compilation.
+				{
+					std::lock_guard scope( syncData->mutex );
+					syncData->compiled = true;
+				}
+				syncData->conditionVariable.notify_all();
+			}
+
+			auto compiledCode = syncData->compiledCode;
+
+			{
+				std::lock_guard scope( m_compiledCS );
+				syncData.reset();
+			}
+
+			if( compiledCode.empty() )
+			{
+				// No compiledCode on the cache entry! This means compilation must have failed.
+				return false;
+			}
+
+			library.shaderSize = uint32_t( compiledCode.size() );
+			library.shaderDataStr = g_stringTable.AddString( compiledCode.data(), compiledCode.size() );
+
+			technique.libraries.push_back( library );
+
+			if( listing.enabled() )
+			{
+				listing.literal( "profile" ).literal( profile );
+				listing.literal( "original" ).dict();
+				listing.literal( "source" ).literal( SanitizeCode( code ) );
+				listing.end();
+			}
+			listing.end(); // library dict
+		}
+
+		listing.end(); // libraries list
+
+		result.techniques.push_back( technique );
+		listing.end(); // technique dict
+	}
+	listing.end(); // technique list
+
+	return true;
+}
