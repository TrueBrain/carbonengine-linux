+	payload.color = material;
+}
+
+technique t0
+{
+	library p0
+	{
+		ClosestHitShader = compile lib_6_3 ClosestHit();
+		payloadsize = 16;
+		hitgroupname = "HitGroup";
+	}
+}
+)SRC";
