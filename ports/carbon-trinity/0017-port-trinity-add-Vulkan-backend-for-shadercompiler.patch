diff --git a/shadercompiler/tests/VulkanCompilerTest.cpp b/shadercompiler/tests/VulkanCompilerTest.cpp
new file mode 100644
index 00000000..99b3b137
--- /dev/null
+++ b/shadercompiler/tests/VulkanCompilerTest.cpp
@@ -0,0 +1,579 @@
+// Copyright © 2026 CCP ehf.
+
+#include "gtest/gtest.h"
+#include "EffectCompilerVulkan.h"
+#include "EffectData.h"
+#include "StringTable.h"
+#include "TesingUtils.h"
+
+extern StringTable g_stringTable;
+
+namespace
+{
+
+bool IsSpirv( const StageInput& stage )
+{
+	if( stage.shaderSize < 4 )
+	{
+		return false;
+	}
+	const uint8_t magic[] = { 0x03, 0x02, 0x23, 0x07 };
+	return memcmp( g_stringTable.GetString( stage.shaderDataStr ), magic, 4 ) == 0;
+}
+
+const Constant* FindConstant( const StageData& stage, const char* name )
+{
+	for( auto& constant : stage.constants )
+	{
+		if( strcmp( g_stringTable.GetString( constant.name ), name ) == 0 )
+		{
+			return &constant;
+		}
+	}
+	return nullptr;
+}
+
+}
+
+TEST( VulkanCompiler, CompilesTexturedQuadToSpirv )
+{
+	const char* src = R"SRC(
+float4 offsetScale;
+
+Texture2D sourceTexture;
+SamplerState sourceSampler
+{
+	MinFilter = Linear;
+	MagFilter = Linear;
+	MipFilter = Point;
+	AddressU  = Clamp;
+	AddressV  = Clamp;
+};
+
+struct VS_INPUT
+{
+	float4 position : POSITION;
+	float2 texcoord : TEXCOORD0;
+};
+
+struct VS_OUTPUT
+{
+	float4 position : SV_Position;
+	float2 texcoord : TEXCOORD0;
+};
+
+VS_OUTPUT vs( VS_INPUT input )
+{
+	VS_OUTPUT output;
+	output.position = float4( input.position.xy * offsetScale.zw + offsetScale.xy, 0.0, 1.0 );
+	output.texcoord = input.texcoord;
+	return output;
+}
+
+float4 ps( VS_OUTPUT input ) : COLOR
+{
+	return sourceTexture.Sample( sourceSampler, input.texcoord );
+}
+
+technique t0
+{
+	pass p0
+	{
+		vertexshader = compile vs_3_0 vs();
+		pixelshader = compile ps_3_0 ps();
+	}
+}
+)SRC";
+
+	auto data = Compile<EffectCompilerVulkan>( src );
+	ASSERT_EQ( data.techniques.size(), 1u );
+	ASSERT_EQ( data.techniques[0].passes.size(), 1u );
+	ASSERT_EQ( data.techniques[0].passes[0].stages.size(), 2u );
+
+	auto& vs = data.techniques[0].passes[0].stages[0];
+	auto& ps = data.techniques[0].passes[0].stages[1];
+
+	EXPECT_EQ( vs.type, VERTEX_STAGE );
+	EXPECT_EQ( ps.type, PIXEL_STAGE );
+	EXPECT_TRUE( IsSpirv( vs ) );
+	EXPECT_TRUE( IsSpirv( ps ) );
+
+	// Vertex inputs: locations are assigned in declaration order.
+	ASSERT_EQ( vs.pipelineInputs.size(), 2u );
+	EXPECT_EQ( vs.pipelineInputs[0].name, UC_POSITION );
+	EXPECT_EQ( vs.pipelineInputs[0].registerIndex, 0 );
+	EXPECT_EQ( vs.pipelineInputs[0].dimension, 4 );
+	EXPECT_EQ( vs.pipelineInputs[1].name, UC_TEXCOORD );
+	EXPECT_EQ( vs.pipelineInputs[1].index, 0 );
+	EXPECT_EQ( vs.pipelineInputs[1].registerIndex, 1 );
+	EXPECT_EQ( vs.pipelineInputs[1].dimension, 2 );
+
+	// VS uses the Globals constant buffer at b0.
+	ASSERT_EQ( vs.registerInputs.size(), 1u );
+	EXPECT_EQ( vs.registerInputs[0].registerType, RT_CONSTANT_BUFFER );
+	EXPECT_EQ( vs.registerInputs[0].registerIndex, 0u );
+
+	auto constant = FindConstant( vs, "offsetScale" );
+	ASSERT_NE( constant, nullptr );
+	EXPECT_EQ( constant->offset, 0u );
+	EXPECT_EQ( constant->size, 16u );
+	EXPECT_EQ( constant->dimension, 4 );
+	EXPECT_EQ( constant->type, CONSTANT_TYPE_FLOAT );
+
+	// PS uses the texture at t0; the clamp/linear sampler becomes a static sampler.
+	ASSERT_EQ( ps.registerInputs.size(), 1u );
+	EXPECT_EQ( ps.registerInputs[0].registerType, RT_SRV_TEXTURE2D );
+	EXPECT_EQ( ps.registerInputs[0].registerIndex, 0u );
+	ASSERT_EQ( ps.textures.size(), 1u );
+	EXPECT_STREQ( g_stringTable.GetString( ps.textures.begin()->second.name ), "sourceTexture" );
+	EXPECT_EQ( ps.samplers.size(), 0u );
+	ASSERT_EQ( ps.staticSamplers.size(), 1u );
+	EXPECT_EQ( ps.staticSamplers[0].registerIndex, 0u );
+}
+
+TEST( VulkanCompiler, ConstantBufferLayoutFollowsD3DPackingRules )
+{
+	const char* src = R"SRC(
+float2 a;
+float3 b;
+float c;
+float4x4 m;
+float4 arr[3];
+
+float4 vs() : POSITION
+{
+	return mul( float4( a, c, 1.0 ), m ) + b.xyzx + arr[1];
+}
+
+float4 ps() : COLOR
+{
+	return float4( 0.0, 0.0, 0.0, 1.0 );
+}
+
+technique t0
+{
+	pass p0
+	{
+		vertexshader = compile vs_3_0 vs();
+		pixelshader = compile ps_3_0 ps();
+	}
+}
+)SRC";
+
+	auto data = Compile<EffectCompilerVulkan>( src );
+	auto& vs = data.techniques[0].passes[0].stages[0];
+
+	// CreateGlobalsCB moves scalars to the end, so the emitted member order is
+	// a, b, arr, m, c. float3 b would cross a 16-byte boundary at 8 -> 16, the
+	// array and the matrix align to 16. Verified against the OpMemberDecorate
+	// offsets dxc emits for the same source.
+	auto a = FindConstant( vs, "a" );
+	auto b = FindConstant( vs, "b" );
+	auto c = FindConstant( vs, "c" );
+	auto m = FindConstant( vs, "m" );
+	auto arr = FindConstant( vs, "arr" );
+	ASSERT_NE( a, nullptr );
+	ASSERT_NE( b, nullptr );
+	ASSERT_NE( c, nullptr );
+	ASSERT_NE( m, nullptr );
+	ASSERT_NE( arr, nullptr );
+
+	EXPECT_EQ( a->offset, 0u );
+	EXPECT_EQ( a->size, 8u );
+	EXPECT_EQ( b->offset, 16u );
+	EXPECT_EQ( b->size, 12u );
+	EXPECT_EQ( arr->offset, 32u );
+	EXPECT_EQ( arr->size, 48u );
+	EXPECT_EQ( arr->elements, 3u );
+	EXPECT_EQ( m->offset, 80u );
+	EXPECT_EQ( m->size, 64u );
+	EXPECT_EQ( m->dimension, 16 );
+	EXPECT_EQ( c->offset, 144u );
+	EXPECT_EQ( c->size, 4u );
+}
+
+TEST( VulkanCompiler, DefaultValuesAreDerivedFromInitializers )
+{
+	const char* src = R"SRC(
+float4 tint = float4( 0.25, 0.5, 0.75, 1.0 );
+
+float4 vs() : POSITION
+{
+	return tint;
+}
+
+float4 ps() : COLOR
+{
+	return tint;
+}
+
+technique t0
+{
+	pass p0
+	{
+		vertexshader = compile vs_3_0 vs();
+		pixelshader = compile ps_3_0 ps();
+	}
+}
+)SRC";
+
+	auto data = Compile<EffectCompilerVulkan>( src );
+	auto& vs = data.techniques[0].passes[0].stages[0];
+
+	auto tint = FindConstant( vs, "tint" );
+	ASSERT_NE( tint, nullptr );
+	ASSERT_GE( vs.defaultValues.size(), size_t( tint->offset + tint->size ) );
+	const float* values = reinterpret_cast<const float*>( &vs.defaultValues[tint->offset] );
+	EXPECT_FLOAT_EQ( values[0], 0.25f );
+	EXPECT_FLOAT_EQ( values[1], 0.5f );
+	EXPECT_FLOAT_EQ( values[2], 0.75f );
+	EXPECT_FLOAT_EQ( values[3], 1.0f );
+}
+
+TEST( VulkanCompiler, CompilesComputeShaderWithUav )
+{
+	const char* src = R"SRC(
+RWTexture2D<float4> outputTexture;
+
+[numthreads( 8, 4 , 1 )]
+void cs( uint3 id : SV_DispatchThreadID )
+{
+	outputTexture[id.xy] = float4( 1.0, 0.0, 0.0, 1.0 );
+}
+
+technique t0
+{
+	pass p0
+	{
+		computeshader = compile cs_5_0 cs();
+	}
+}
+)SRC";
+
+	auto data = Compile<EffectCompilerVulkan>( src );
+	ASSERT_EQ( data.techniques[0].passes[0].stages.size(), 1u );
+	auto& cs = data.techniques[0].passes[0].stages[0];
+
+	EXPECT_EQ( cs.type, COMPUTE_STAGE );
+	EXPECT_TRUE( IsSpirv( cs ) );
+	EXPECT_EQ( cs.threadGroupSize[0], 8u );
+	EXPECT_EQ( cs.threadGroupSize[1], 4u );
+	EXPECT_EQ( cs.threadGroupSize[2], 1u );
+
+	ASSERT_EQ( cs.uavs.size(), 1u );
+	EXPECT_STREQ( g_stringTable.GetString( cs.uavs.begin()->second.name ), "outputTexture" );
+	ASSERT_EQ( cs.registerInputs.size(), 1u );
+	EXPECT_EQ( cs.registerInputs[0].registerType, RT_UAV_TEXTURE2D );
+}
+
+TEST( VulkanCompiler, CompilesLegacyDX9StyleSampling )
+{
+	const char* src = R"SRC(
+texture testTexture;
+sampler2D testSampler = sampler_state
+{
+	Texture = <testTexture>;
+	MinFilter = Linear;
+	MagFilter = Linear;
