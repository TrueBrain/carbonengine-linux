+	AddressU  = Wrap;
+	AddressV  = Wrap;
+};
+
+float4 vs() : POSITION
+{
+	return float4( 0.0, 0.0, 0.0, 1.0 );
+}
+
+float4 ps( float2 uv : TEXCOORD0 ) : COLOR
+{
+	return tex2D( testSampler, uv );
+}
+
+technique t0
+{
+	pass p0
+	{
+		vertexshader = compile vs_3_0 vs();
+		pixelshader = compile ps_3_0 ps();
+	}
+}
+)SRC";
+
+	auto data = Compile<EffectCompilerVulkan>( src );
