+// SPIR-V binding model. Must be synchronized with trinityal/vulkan/VulkanBindingModel.h:
+// descriptorSet = HLSL register space; binding = stage * STAGE_STRIDE + classOffset +
+// registerIndex. The stage index is Tr2RenderContextEnum::ShaderType, which matches
+// InputStageType. Register shifts are applied to "all" spaces so the binding formula
+// holds within every set; dxc maps HLSL space N to descriptor set N by default.
+const uint32_t VULKAN_STAGE_STRIDE = 128;
+const uint32_t VULKAN_CBV_OFFSET = 0;
+const uint32_t VULKAN_SRV_OFFSET = 32;
+const uint32_t VULKAN_SAMPLER_OFFSET = 64;
+const uint32_t VULKAN_UAV_OFFSET = 96;
+
+std::pair<int, std::string> RunProcess( const char* commandLine )
+{
+	s_fileMutex.lock();
+#ifdef _WIN32
+	FILE* process = _popen( commandLine, "r" );
+#else
+	FILE* process = popen( commandLine, "r" );
+#endif
+	s_fileMutex.unlock();
+
+	if( !process )
+	{
+		return std::make_pair( -1, "" );
+	}
+	std::string output;
+	char readBuffer[128];
+	while( fgets( readBuffer, sizeof( readBuffer ), process ) )
+	{
+		output += readBuffer;
+	}
+#ifdef _WIN32
+	return std::make_pair( _pclose( process ), output );
+#else
+	return std::make_pair( pclose( process ), output );
+#endif
+}
+
+std::string DxcTool()
+{
+	if( !g_dxcPath.empty() )
+	{
+		return g_dxcPath;
+	}
+#ifdef _WIN32
+	char dxcPath[MAX_PATH] = { 0 };
+	size_t dxcPathSize;
+	if( getenv_s( &dxcPathSize, dxcPath, "DXC_PATH" ) == 0 && dxcPath[0] )
+	{
+		return dxcPath;
+	}
+#else
+	if( auto dxcPath = getenv( "DXC_PATH" ) )
+	{
+		return dxcPath;
+	}
+#endif
+#ifdef SHADER_COMPILER_DXC_TOOL
+	return SHADER_COMPILER_DXC_TOOL;
+#else
+	return "dxc";
+#endif
+}
+
+// Compile HLSL source to SPIR-V by invoking dxc as an external process (following
+// the Metal backend's external-compiler approach). Ray tracing libraries
+// (lib_* profiles) have no single entry point and need SPIR-V 1.4+, so they
+// are compiled for the vulkan1.2 target environment.
+std::vector<uint8_t> CompileSpirv( const std::string& code, const std::string& profile, const std::string& entryPoint, InputStageType stageType )
+{
+	std::vector<uint8_t> compiledCode;
+
+	s_fileMutex.lock();
+
+#ifdef _WIN32
+	char srcFilenameTemplate[] = "vk_tmpXXXXXXX";
+	char binFilenameTemplate[] = "spvtmpXXXXXXX";
+
+	_mktemp_s( srcFilenameTemplate );
+	_mktemp_s( binFilenameTemplate );
+
+	char* srcFilename = srcFilenameTemplate;
+	char* binFilename = binFilenameTemplate;
+#else
+	char srcFilenameTemplate[] = "src_XXXXXXX.hlsl";
+	char binFilenameTemplate[] = "bin_XXXXXXX.spv";
+
+	char* srcFilename = nullptr;
+	char* binFilename = nullptr;
+
+	{
+		int srcFd = mkstemps( srcFilenameTemplate, 5 );
+		int binFd = mkstemps( binFilenameTemplate, 4 );
+
+		srcFilename = ( srcFd != -1 ) ? srcFilenameTemplate : nullptr;
+		binFilename = ( binFd != -1 ) ? binFilenameTemplate : nullptr;
+
+		close( srcFd );
+		close( binFd );
+	}
+#endif
+	s_fileMutex.unlock();
+
+	if( !srcFilename || !binFilename )
+	{
+		// Failed to generate a name for temporary file(s).
+		return compiledCode;
+	}
+
+	do
+	{
+		// Write shader source into temp file.
+		{
+			ZoneScopedN( "Write Source" );
+
+			std::lock_guard withFileMutex( s_fileMutex );
+			FILE* file = nullptr;
+			if( fopen_s( &file, srcFilename, "w" ) != 0 )
+			{
+				break;
+			}
+			size_t bytesWritten = fwrite( code.c_str(), 1, code.length(), file );
+			fclose( file );
+			file = nullptr;
+
+			if( bytesWritten != code.length() )
+			{
+				break;
+			}
+		}
+
+		// Compile shader.
+		{
+			ZoneScopedN( "Call compiler" );
+
+			uint32_t stageBase = uint32_t( stageType ) * VULKAN_STAGE_STRIDE;
+			const bool isLibrary = profile.compare( 0, 3, "lib" ) == 0;
+
+			std::ostringstream cmd;
+			cmd << DxcTool()
+				<< " -spirv"
+				<< " -T " << profile;
+			if( isLibrary )
+			{
+				cmd << " -fspv-target-env=vulkan1.2";
+			}
+			else
+			{
+				cmd << " -E " << entryPoint << " -fspv-entrypoint-name=main";
+			}
+			cmd << " -HV 2018 -Zpc -fvk-use-dx-layout"
+				<< " -fvk-b-shift " << stageBase + VULKAN_CBV_OFFSET << " all"
+				<< " -fvk-t-shift " << stageBase + VULKAN_SRV_OFFSET << " all"
+				<< " -fvk-s-shift " << stageBase + VULKAN_SAMPLER_OFFSET << " all"
+				<< " -fvk-u-shift " << stageBase + VULKAN_UAV_OFFSET << " all";
+			if( g_skipOptimization )
+			{
+				cmd << " -Od";
+			}
+			else
+			{
+				cmd << " -O" << std::min( g_optimizationLevel, 3u );
+			}
+			cmd << " -Fo " << binFilename << ' ' << srcFilename << " 2>&1";
+
+			auto compilerOutput = RunProcess( cmd.str().c_str() );
+			if( !compilerOutput.second.empty() )
+			{
+				if( compilerOutput.first != 0 || g_printWarnings )
+				{
+					g_messages.AddMessage( "%s", compilerOutput.second.c_str() );
+				}
+			}
+			if( compilerOutput.first != 0 )
+			{
+				// Shader compilation failed.
+				break;
+			}
+		}
+
+		// Read shader binary.
+		{
+			ZoneScopedN( "Read binary" );
+
+			std::lock_guard withFileMutex( s_fileMutex );
+			FILE* file = nullptr;
+			if( fopen_s( &file, binFilename, "rb" ) != 0 )
+			{
+				break;
+			}
+
+			fseek( file, 0, SEEK_END );
+			long pos = ftell( file );
+			fseek( file, 0, SEEK_SET );
+
+			size_t dataSize = pos;
+			compiledCode.resize( dataSize );
+
+			size_t readBytes = fread( compiledCode.data(), 1, dataSize, file );
+
+			fclose( file );
+			file = nullptr;
+
+			if( readBytes != dataSize )
+			{
+				compiledCode.clear();
+				break;
+			}
+		}
+	} while( false );
+
+	// Remove temp files.
+	{
+		std::lock_guard withFileMutex( s_fileMutex );
+		remove( srcFilename );
+		remove( binFilename );
+	}
+	return compiledCode;
+}
+
+bool ParseShaderName( const InlineString& name, InputStageType& type )
+{
+	if( _stricmp( ToString( name ).c_str(), "vertexshader" ) == 0 )
+	{
+		type = VERTEX_STAGE;
+	}
+	else if( _stricmp( ToString( name ).c_str(), "pixelshader" ) == 0 )
+	{
+		type = PIXEL_STAGE;
+	}
+	else if( _stricmp( ToString( name ).c_str(), "computeshader" ) == 0 )
+	{
+		type = COMPUTE_STAGE;
+	}
+	else if( _stricmp( ToString( name ).c_str(), "geometryshader" ) == 0 )
+	{
+		type = GEOMETRY_STAGE;
+	}
+	else if( _stricmp( ToString( name ).c_str(), "hullshader" ) == 0 )
+	{
+		type = HULL_STAGE;
+	}
+	else if( _stricmp( ToString( name ).c_str(), "domainshader" ) == 0 )
+	{
+		type = DOMAIN_STAGE;
+	}
+	else
+	{
+		return false;
+	}
+	return true;
+}
