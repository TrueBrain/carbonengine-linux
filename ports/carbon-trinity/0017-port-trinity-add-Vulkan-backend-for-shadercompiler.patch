+	ASSERT_FALSE( library.localInputs.registerInputs.empty() );
+	EXPECT_EQ( library.localInputs.registerInputs[0].registerType, RT_CONSTANT_BUFFER );
+	EXPECT_NE( library.source.find( "[[vk::shader_record_ext]]" ), std::string::npos );
+	EXPECT_TRUE( library.globalInputs.registerInputs.empty() );
+}
