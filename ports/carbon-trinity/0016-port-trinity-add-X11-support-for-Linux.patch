+
+void Tr2MainWindow::ClipCursor( int32_t, int32_t, int32_t, int32_t )
+{
+	if( !m_hwnd )
+	{
+		return;
+	}
+	// X11 can only confine the pointer to a window, not to an arbitrary rectangle
+	Display* display = GetXDisplay();
+	if( XGrabPointer(
+			display, Window( m_hwnd ), True,
+			ButtonPressMask | ButtonReleaseMask | PointerMotionMask,
+			GrabModeAsync, GrabModeAsync, Window( m_hwnd ), 0, CurrentTime ) == GrabSuccess )
+	{
+		m_cursorClipped_Linux = true;
+	}
+}
+
+void Tr2MainWindow::UnclipCursor()
+{
+	if( m_cursorClipped_Linux )
+	{
+		Display* display = GetXDisplay();
+		XUngrabPointer( display, CurrentTime );
+		XFlush( display );
+		m_cursorClipped_Linux = false;
+	}
+}
+
+void Tr2MainWindow::SetCursorPos( int32_t x, int32_t y )
+{
+	if( !m_hwnd || !m_state.width || !m_state.height )
+	{
+		return;
+	}
+	Display* display = GetXDisplay();
+	XWarpPointer(
+		display, 0, Window( m_hwnd ), 0, 0, 0, 0,
+		int( double( x ) / m_state.width * m_clientWidth_Linux + 0.5 ),
+		int( double( y ) / m_state.height * m_clientHeight_Linux + 0.5 ) );
+	XFlush( display );
+}
+
+std::pair<int32_t, int32_t> Tr2MainWindow::GetCursorPos() const
+{
+	if( !m_hwnd || !m_clientWidth_Linux || !m_clientHeight_Linux )
+	{
+		return { 0, 0 };
+	}
+	Display* display = GetXDisplay();
+	Window root, child;
+	int rootX = 0, rootY = 0, x = 0, y = 0;
+	unsigned int mask = 0;
+	XQueryPointer( display, Window( m_hwnd ), &root, &child, &rootX, &rootY, &x, &y, &mask );
+	return {
+		int32_t( double( x ) / m_clientWidth_Linux * m_state.width + 0.5 ),
+		int32_t( double( y ) / m_clientHeight_Linux * m_state.height + 0.5 )
+	};
+}
+
+bool Tr2MainWindow::IsKeyToggled( uint32_t keyCode ) const
+{
+	Display* display = GetXDisplay();
+	if( !display )
+	{
+		return false;
+	}
+	Window root, child;
+	int rootX = 0, rootY = 0, x = 0, y = 0;
+	unsigned int mask = 0;
+	XQueryPointer( display, DefaultRootWindow( display ), &root, &child, &rootX, &rootY, &x, &y, &mask );
+	switch( keyCode )
+	{
+	case VK_CAPITAL:
+		return ( mask & LockMask ) != 0;
+	case VK_NUMLOCK:
+		return ( mask & Mod2Mask ) != 0;
+	default:
+		return false;
+	}
+}
+
+bool Tr2MainWindow::IsKeyPressed( uint32_t keyCode ) const
+{
+	return keyCode < 256 && m_keysDown_Linux[keyCode];
+}
+
+std::string Tr2MainWindow::GetKeyName( uint32_t keyCode ) const
+{
+	if( ( keyCode >= '0' && keyCode <= '9' ) || ( keyCode >= 'A' && keyCode <= 'Z' ) )
+	{
+		return std::string( 1, char( keyCode ) );
+	}
+	if( keyCode >= VK_F1 && keyCode <= VK_F24 )
+	{
+		return "F" + std::to_string( keyCode - VK_F1 + 1 );
+	}
+	if( keyCode >= VK_NUMPAD0 && keyCode <= VK_NUMPAD9 )
+	{
+		return "Num " + std::to_string( keyCode - VK_NUMPAD0 );
+	}
+	for( const auto& desc : s_keyDescs )
+	{
+		if( desc.vk == keyCode || desc.vkSpecific == keyCode )
+		{
+			return desc.text;
+		}
+	}
+	return "";
+}
+
+void Tr2MainWindow::HandleXEvent_Linux( void* xevent )
+{
+	XEvent& event = *static_cast<XEvent*>( xevent );
+	Display* display = GetXDisplay();
+
+	auto scaleMouseX = [&]( int x ) {
+		return m_clientWidth_Linux ? int32_t( double( x ) / m_clientWidth_Linux * m_state.width + 0.5 ) : int32_t( x );
+	};
+	auto scaleMouseY = [&]( int y ) {
+		return m_clientHeight_Linux ? int32_t( double( y ) / m_clientHeight_Linux * m_state.height + 0.5 ) : int32_t( y );
+	};
+
+	switch( event.type )
+	{
+	case ButtonPress:
+	case ButtonRelease: {
+		const XButtonEvent& button = event.xbutton;
+		bool down = event.type == ButtonPress;
+		int32_t engineButton;
+		uint32_t vk;
+		switch( button.button )
+		{
+		case Button1:
+			engineButton = 0;
+			vk = VK_LBUTTON;
+			break;
+		case Button3:
+			engineButton = 1;
+			vk = VK_RBUTTON;
+			break;
+		case Button2:
+			engineButton = 2;
+			vk = VK_MBUTTON;
+			break;
+		case Button4:
+		case Button5:
+			if( down )
+			{
+				m_onMouseWheel.CallVoid( int32_t( button.button == Button4 ? 120 : -120 ) );
+			}
+			return;
+		case 8:
+			engineButton = 3;
+			vk = VK_XBUTTON1;
+			break;
+		case 9:
+			engineButton = 4;
+			vk = VK_XBUTTON2;
+			break;
+		default:
+			return;
+		}
+		m_keysDown_Linux[vk] = down;
+		auto& callback = down ? m_onMouseDown : m_onMouseUp;
+		callback.CallVoid( engineButton, scaleMouseX( button.x ), scaleMouseY( button.y ) );
+		break;
+	}
+
+	case MotionNotify:
+		m_onMouseMove.CallVoid( scaleMouseX( event.xmotion.x ), scaleMouseY( event.xmotion.y ) ).ReportException();
+		break;
+
+	case KeyPress: {
+		XKeyEvent& key = event.xkey;
+		char buffer[64];
+		KeySym lookupSym = NoSymbol;
+		int length = 0;
+		bool isUtf8 = false;
+		if( m_xic_Linux )
+		{
+			Status status = 0;
+			length = Xutf8LookupString( XIC( m_xic_Linux ), &key, buffer, int( sizeof( buffer ) ) - 1, &lookupSym, &status );
+			if( status != XLookupChars && status != XLookupBoth )
+			{
+				length = 0;
+			}
+			if( status != XLookupKeySym && status != XLookupBoth )
+			{
+				lookupSym = NoSymbol;
+			}
+			isUtf8 = true;
+		}
+		else
+		{
+			length = XLookupString( &key, buffer, int( sizeof( buffer ) ) - 1, &lookupSym, nullptr );
+		}
+
+		// The unshifted keysym matches how Windows reports virtual keys ("1" stays
+		// VK_1 with shift held); the modifier-resolved keysym is needed for the
+		// keypad, where num lock decides between digits and navigation
+		KeySym sym = XkbKeycodeToKeysym( display, KeyCode( key.keycode ), 0, 0 );
+		if( lookupSym != NoSymbol && IsKeypadKeySym( lookupSym ) )
+		{
+			sym = lookupSym;
+		}
+		uint32_t specific = 0;
+		uint32_t vk = KeySymToVk( sym, specific );
+		if( vk )
+		{
+			m_keysDown_Linux[vk & 0xff] = true;
+			if( specific )
+			{
+				m_keysDown_Linux[specific & 0xff] = true;
+			}
+			m_onKeyDown.CallVoid( int32_t( vk ), int32_t( key.keycode ) );
+		}
+
+		for( int i = 0; i < length; )
+		{
+			uint32_t codepoint = uint8_t( buffer[i] );
+			if( !isUtf8 )
+			{
+				++i;
+			}
+			else if( codepoint < 0x80 )
+			{
+				++i;
+			}
+			else if( ( codepoint >> 5 ) == 0x6 && i + 1 < length )
+			{
+				codepoint = ( ( codepoint & 0x1f ) << 6 ) | ( uint8_t( buffer[i + 1] ) & 0x3f );
+				i += 2;
+			}
+			else if( ( codepoint >> 4 ) == 0xe && i + 2 < length )
+			{
+				codepoint = ( ( codepoint & 0x0f ) << 12 ) | ( ( uint8_t( buffer[i + 1] ) & 0x3f ) << 6 ) | ( uint8_t( buffer[i + 2] ) & 0x3f );
+				i += 3;
+			}
+			else if( ( codepoint >> 3 ) == 0x1e && i + 3 < length )
+			{
+				codepoint = ( ( codepoint & 0x07 ) << 18 ) | ( ( uint8_t( buffer[i + 1] ) & 0x3f ) << 12 ) | ( ( uint8_t( buffer[i + 2] ) & 0x3f ) << 6 ) | ( uint8_t( buffer[i + 3] ) & 0x3f );
+				i += 4;
+			}
+			else
+			{
+				++i;
+				continue;
+			}
+			m_onChar.CallVoid( int32_t( codepoint ), int32_t( key.keycode ), false );
+		}
+		break;
+	}
+
+	case KeyRelease: {
+		XKeyEvent& key = event.xkey;
+		// without detectable auto-repeat the server inserts a KeyRelease before
+		// each repeated KeyPress; swallow those so keys don't flicker
+		if( XEventsQueued( display, QueuedAfterReading ) )
+		{
+			XEvent next;
+			XPeekEvent( display, &next );
+			if( next.type == KeyPress && next.xkey.time == key.time && next.xkey.keycode == key.keycode )
+			{
+				break;
+			}
+		}
+		char buffer[8];
+		KeySym lookupSym = NoSymbol;
+		XLookupString( &key, buffer, int( sizeof( buffer ) ) - 1, &lookupSym, nullptr );
+		KeySym sym = XkbKeycodeToKeysym( display, KeyCode( key.keycode ), 0, 0 );
+		if( lookupSym != NoSymbol && IsKeypadKeySym( lookupSym ) )
+		{
+			sym = lookupSym;
+		}
+		uint32_t specific = 0;
+		uint32_t vk = KeySymToVk( sym, specific );
+		if( vk )
+		{
+			m_keysDown_Linux[vk & 0xff] = false;
+			if( specific )
+			{
+				m_keysDown_Linux[specific & 0xff] = false;
+			}
+			m_onKeyUp.CallVoid( int32_t( vk ), int32_t( key.keycode ) );
+		}
+		break;
+	}
+
+	case FocusIn:
+		if( event.xfocus.mode == NotifyGrab || event.xfocus.mode == NotifyUngrab )
+		{
+			break;
+		}
+		m_hasFocus_Linux = true;
+		if( m_xic_Linux )
+		{
+			XSetICFocus( XIC( m_xic_Linux ) );
+		}
+		if( gTriDev )
+		{
+			gTriDev->ApplicationActivated( TriDevice::APP_ACTIVATED );
+			gTriDev->SetThrottling( TriDevice::WINDOW_OUT_OF_FOCUS, false );
+		}
+		g_activeFrametimeMean.SetSource( &g_ccpStatistics_frameTime );
+		g_activeFrametimeStdDev.SetSource( &g_ccpStatistics_frameTime );
+		m_onFocusChange.CallVoid( true );
+		break;
+
+	case FocusOut:
+		if( event.xfocus.mode == NotifyGrab || event.xfocus.mode == NotifyUngrab )
+		{
+			break;
+		}
+		m_hasFocus_Linux = false;
+		if( m_xic_Linux )
+		{
+			XUnsetICFocus( XIC( m_xic_Linux ) );
+		}
+		UnclipCursor();
+		memset( m_keysDown_Linux, 0, sizeof( m_keysDown_Linux ) );
+		if( gTriDev )
+		{
+			gTriDev->ApplicationActivated( TriDevice::APP_DEACTIVATED );
+			gTriDev->SetThrottling( TriDevice::WINDOW_OUT_OF_FOCUS, true );
+		}
+		g_activeFrametimeMean.SetSource( nullptr );
+		g_activeFrametimeStdDev.SetSource( nullptr );
+		m_onFocusChange.CallVoid( false );
+		break;
+
+	case ConfigureNotify: {
+		const XConfigureEvent& configure = event.xconfigure;
+		if( configure.width <= 0 || configure.height <= 0 )
+		{
+			break;
+		}
+		m_clientWidth_Linux = uint32_t( configure.width );
+		m_clientHeight_Linux = uint32_t( configure.height );
+		if( m_inSetState || m_isResizing )
+		{
+			break;
+		}
+		auto newMode = m_state;
+		newMode.width = m_clientWidth_Linux;
+		newMode.height = m_clientHeight_Linux;
+		if( m_state.windowMode == Tr2WindowMode::WINDOWED )
+		{
+			if( configure.send_event )
+			{
+				// synthetic ConfigureNotify carries root-relative coordinates
+				newMode.left = configure.x;
+				newMode.top = configure.y;
+			}
+			else
+			{
+				int x = 0, y = 0;
+				Window child;
+				XTranslateCoordinates( display, Window( m_hwnd ), DefaultRootWindow( display ), 0, 0, &x, &y, &child );
+				newMode.left = x;
+				newMode.top = y;
+			}
+		}
+		if( !( newMode == m_state ) )
+		{
+			m_pendingState_Linux = newMode;
+			m_hasPendingState_Linux = true;
+		}
+		break;
+	}
+
+	case UnmapNotify:
+		if( m_state.windowMode == Tr2WindowMode::WINDOWED && m_state.showState != Tr2WindowShowState::MINIMIZED )
+		{
+			auto newMode = m_hasPendingState_Linux ? m_pendingState_Linux : m_state;
+			newMode.showState = Tr2WindowShowState::MINIMIZED;
+			m_pendingState_Linux = newMode;
+			m_hasPendingState_Linux = true;
+		}
+		break;
+
+	case MapNotify:
+		if( m_state.windowMode == Tr2WindowMode::WINDOWED && m_state.showState == Tr2WindowShowState::MINIMIZED )
+		{
+			auto newMode = m_hasPendingState_Linux ? m_pendingState_Linux : m_state;
+			newMode.showState = Tr2WindowShowState::NORMAL;
+			m_pendingState_Linux = newMode;
+			m_hasPendingState_Linux = true;
+		}
+		break;
+
+	case ClientMessage:
+		if( event.xclient.message_type == GetXAtom( "WM_PROTOCOLS" ) &&
+			Atom( event.xclient.data.l[0] ) == GetXAtom( "WM_DELETE_WINDOW" ) )
+		{
+			bool canClose = true;
+			m_onClose.Call( canClose );
+			if( !m_onClose.IsValid() || canClose )
+			{
+				m_quitRequested_Linux = true;
+			}
+		}
+		break;
+	}
+}
+
+bool Tr2MainWindow::ProcessMessages()
+{
+	Display* display = GetXDisplay();
+	if( !display )
+	{
+		return true;
+	}
+
+	while( XPending( display ) )
+	{
+		XEvent event;
+		XNextEvent( display, &event );
+		if( XFilterEvent( &event, 0 ) )
+		{
+			continue;
+		}
+		if( event.type == MappingNotify )
+		{
+			XRefreshKeyboardMapping( &event.xmapping );
+			continue;
+		}
+		auto& registry = WindowRegistry();
+		auto it = registry.find( event.xany.window );
+		if( it != registry.end() )
+		{
+			it->second->HandleXEvent_Linux( &event );
+		}
+	}
+
+	// apply window state changes reported by the X server, coalesced per pump
+	if( m_hasPendingState_Linux && !m_inSetState && !g_renderContextIsBeingDestroyed && gTriDev )
+	{
+		auto pendingState = m_pendingState_Linux;
+		m_hasPendingState_Linux = false;
+		SetState( false, pendingState );
+	}
+
+	return !m_quitRequested_Linux;
+}
