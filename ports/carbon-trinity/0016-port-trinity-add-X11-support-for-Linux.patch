+void Tr2MainWindow::SetWindowTitle( const wchar_t* title )
+{
+	m_title = title;
+	if( m_hwnd )
+	{
+		Display* display = GetXDisplay();
+		auto utf8 = WideToUTF8( title );
+		XStoreName( display, Window( m_hwnd ), utf8.c_str() );
+		XChangeProperty(
+			display, Window( m_hwnd ), GetXAtom( "_NET_WM_NAME" ), GetXAtom( "UTF8_STRING" ), 8,
+			PropModeReplace, reinterpret_cast<const unsigned char*>( utf8.c_str() ), int( utf8.size() ) );
+		XFlush( display );
+	}
+}
