+
+bool IsKeypadKeySym( KeySym sym )
+{
+	return sym >= XK_KP_Space && sym <= XK_KP_Equal;
+}
+
+uint32_t KeySymToVk( KeySym sym, uint32_t& specific )
+{
+	specific = 0;
+	if( sym >= XK_a && sym <= XK_z )
+	{
+		return uint32_t( 'A' + ( sym - XK_a ) );
+	}
+	if( sym >= XK_A && sym <= XK_Z )
+	{
+		return uint32_t( 'A' + ( sym - XK_A ) );
+	}
+	if( sym >= XK_0 && sym <= XK_9 )
+	{
+		return uint32_t( '0' + ( sym - XK_0 ) );
+	}
+	if( sym >= XK_F1 && sym <= XK_F24 )
+	{
+		return uint32_t( VK_F1 + ( sym - XK_F1 ) );
+	}
+	if( sym >= XK_KP_0 && sym <= XK_KP_9 )
+	{
+		return uint32_t( VK_NUMPAD0 + ( sym - XK_KP_0 ) );
+	}
+	for( const auto& desc : s_keyDescs )
+	{
+		if( desc.keySym == sym )
+		{
+			specific = desc.vkSpecific;
+			return desc.vk;
+		}
+	}
+	return 0;
+}
