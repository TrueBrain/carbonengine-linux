+
+void Tr2MainWindow::UpdateWindowHints_Linux( const Tr2MainWindowState::State& state ) const
+{
+	Display* display = GetXDisplay();
+	Window window = Window( m_hwnd );
+
+	XSizeHints* hints = XAllocSizeHints();
+	hints->flags = PPosition | PSize | PMinSize;
+	hints->x = state.left;
+	hints->y = state.top;
+	hints->width = int( state.width );
+	hints->height = int( state.height );
+	hints->min_width = int( m_minimumSize.width );
+	hints->min_height = int( m_minimumSize.height );
+	if( state.windowMode != Tr2WindowMode::WINDOWED )
+	{
+		// only regular windows are user-resizable
+		hints->flags |= PMaxSize;
+		hints->min_width = hints->max_width = int( state.width );
+		hints->min_height = hints->max_height = int( state.height );
+	}
+	XSetWMNormalHints( display, window, hints );
+	XFree( hints );
+
+	// fixed windows and fullscreen windows have no decorations
+	struct
+	{
+		unsigned long flags;
+		unsigned long functions;
+		unsigned long decorations;
+		long inputMode;
+		unsigned long status;
+	} motifHints = {};
+	motifHints.flags = 1 << 1; // MWM_HINTS_DECORATIONS
+	motifHints.decorations = state.windowMode == Tr2WindowMode::WINDOWED ? 1 : 0;
+	Atom motifAtom = GetXAtom( "_MOTIF_WM_HINTS" );
+	XChangeProperty(
+		display, window, motifAtom, motifAtom, 32,
+		PropModeReplace, reinterpret_cast<const unsigned char*>( &motifHints ), 5 );
+}
+
+void Tr2MainWindow::CreateOSWindow( Tr2MainWindowState::State& state )
+{
+	if( m_hwnd )
+	{
+		return;
+	}
+	Display* display = GetXDisplay();
+	if( !display )
+	{
+		// no X server; the engine keeps running without an OS window
+		return;
+	}
+
+	int screen = DefaultScreen( display );
+	XSetWindowAttributes attributes = {};
+	attributes.background_pixel = BlackPixel( display, screen );
+	attributes.event_mask =
+		KeyPressMask | KeyReleaseMask |
+		ButtonPressMask | ButtonReleaseMask | PointerMotionMask |
+		StructureNotifyMask | FocusChangeMask | ExposureMask;
+
+	Window window = XCreateWindow(
+		display, RootWindow( display, screen ),
+		state.left, state.top,
+		std::max( state.width, 1u ), std::max( state.height, 1u ), 0,
+		CopyFromParent, InputOutput, CopyFromParent,
+		CWBackPixel | CWEventMask, &attributes );
+	if( !window )
+	{
+		return;
+	}
+	m_hwnd = Tr2WindowHandle( window );
+	WindowRegistry()[window] = this;
+
+	Atom wmDeleteWindow = GetXAtom( "WM_DELETE_WINDOW" );
+	XSetWMProtocols( display, window, &wmDeleteWindow, 1 );
+
+	UpdateWindowHints_Linux( state );
+	SetWindowTitle( m_title.c_str() );
+
+	if( state.windowMode == Tr2WindowMode::FULL_SCREEN )
+	{
+		// setting the property before mapping avoids a visible mode transition
+		Atom fullscreen = GetXAtom( "_NET_WM_STATE_FULLSCREEN" );
+		XChangeProperty(
+			display, window, GetXAtom( "_NET_WM_STATE" ), XA_ATOM, 32,
+			PropModeReplace, reinterpret_cast<const unsigned char*>( &fullscreen ), 1 );
+	}
+
+	XMapWindow( display, window );
+	if( state.windowMode == Tr2WindowMode::WINDOWED && state.showState == Tr2WindowShowState::MAXIMIZED )
+	{
+		SendNetWmState( window, true, GetXAtom( "_NET_WM_STATE_MAXIMIZED_HORZ" ), GetXAtom( "_NET_WM_STATE_MAXIMIZED_VERT" ) );
+	}
+	XSync( display, False );
+
+	XWindowAttributes actual = {};
+	if( XGetWindowAttributes( display, window, &actual ) && actual.width > 0 && actual.height > 0 )
+	{
+		m_clientWidth_Linux = uint32_t( actual.width );
+		m_clientHeight_Linux = uint32_t( actual.height );
+		if( state.windowMode == Tr2WindowMode::WINDOWED )
+		{
+			state.width = m_clientWidth_Linux;
+			state.height = m_clientHeight_Linux;
+		}
+	}
+	else
+	{
+		m_clientWidth_Linux = state.width;
+		m_clientHeight_Linux = state.height;
+	}
+
+	// input method context for text input; fall back to XLookupString without one
+	XSetLocaleModifiers( "" );
+	XIM xim = XOpenIM( display, nullptr, nullptr, nullptr );
+	if( xim )
+	{
+		XIC xic = XCreateIC(
+			xim,
+			XNInputStyle, XIMPreeditNothing | XIMStatusNothing,
+			XNClientWindow, window,
+			XNFocusWindow, window,
+			nullptr );
+		if( xic )
+		{
+			m_xim_Linux = xim;
+			m_xic_Linux = xic;
+		}
+		else
+		{
+			XCloseIM( xim );
+		}
+	}
+
+	m_quitRequested_Linux = false;
+}
+
+void Tr2MainWindow::DestroyOSWindow()
+{
+	if( !m_hwnd )
+	{
+		return;
+	}
+	Display* display = GetXDisplay();
+
+	if( m_xic_Linux )
+	{
+		XDestroyIC( XIC( m_xic_Linux ) );
+		m_xic_Linux = nullptr;
+	}
+	if( m_xim_Linux )
+	{
+		XCloseIM( XIM( m_xim_Linux ) );
+		m_xim_Linux = nullptr;
+	}
+
+	UnclipCursor();
+	WindowRegistry().erase( Window( m_hwnd ) );
+	XDestroyWindow( display, Window( m_hwnd ) );
+	XSync( display, False );
+	m_hwnd = 0;
+	m_hasFocus_Linux = false;
+	m_hasPendingState_Linux = false;
+}
+
+void Tr2MainWindow::AdjustWindow( Tr2MainWindowState::State& state )
+{
+	if( !m_hwnd )
+	{
+		return;
+	}
+	Display* display = GetXDisplay();
+	Window window = Window( m_hwnd );
+
+	UpdateWindowHints_Linux( state );
+
+	bool wasFullscreen = m_state.windowMode == Tr2WindowMode::FULL_SCREEN;
+	bool isFullscreen = state.windowMode == Tr2WindowMode::FULL_SCREEN;
+	if( wasFullscreen != isFullscreen )
+	{
+		SendNetWmState( window, isFullscreen, GetXAtom( "_NET_WM_STATE_FULLSCREEN" ) );
+	}
+	if( !isFullscreen )
+	{
+		XMoveResizeWindow( display, window, state.left, state.top, std::max( state.width, 1u ), std::max( state.height, 1u ) );
+	}
+
+	if( state.windowMode == Tr2WindowMode::WINDOWED )
+	{
+		Atom maximizedHorz = GetXAtom( "_NET_WM_STATE_MAXIMIZED_HORZ" );
+		Atom maximizedVert = GetXAtom( "_NET_WM_STATE_MAXIMIZED_VERT" );
+		switch( state.showState )
+		{
+		case Tr2WindowShowState::MAXIMIZED:
+			SendNetWmState( window, true, maximizedHorz, maximizedVert );
+			break;
+		case Tr2WindowShowState::MINIMIZED:
+			XIconifyWindow( display, window, DefaultScreen( display ) );
+			break;
+		default:
+			SendNetWmState( window, false, maximizedHorz, maximizedVert );
+			XMapWindow( display, window );
+			break;
+		}
+	}
+	XSync( display, False );
+
+	XWindowAttributes actual = {};
+	if( XGetWindowAttributes( display, window, &actual ) && actual.width > 0 && actual.height > 0 )
+	{
+		m_clientWidth_Linux = uint32_t( actual.width );
+		m_clientHeight_Linux = uint32_t( actual.height );
+	}
+}
