+Display* GetXDisplay()
+{
+	static Display* s_display = []() -> Display* {
+		Display* display = XOpenDisplay( nullptr );
+		if( display )
+		{
+			// With detectable auto-repeat the server stops sending the synthetic
+			// KeyRelease between repeated KeyPress events, which matches how
+			// Windows reports key repeats
+			XkbSetDetectableAutoRepeat( display, True, nullptr );
+		}
+		return display;
+	}();
+	return s_display;
+}
+
+Atom GetXAtom( const char* name )
+{
+	return XInternAtom( GetXDisplay(), name, False );
+}
+
+std::unordered_map<Window, Tr2MainWindow*>& WindowRegistry()
+{
+	static std::unordered_map<Window, Tr2MainWindow*> s_registry;
+	return s_registry;
+}
+
+// _NET_WM_STATE client message, understood by EWMH compliant window managers
+void SendNetWmState( Window window, bool add, Atom state1, Atom state2 = 0 )
+{
+	Display* display = GetXDisplay();
+	XEvent event = {};
+	event.xclient.type = ClientMessage;
+	event.xclient.window = window;
+	event.xclient.message_type = GetXAtom( "_NET_WM_STATE" );
+	event.xclient.format = 32;
+	event.xclient.data.l[0] = add ? 1 : 0;
+	event.xclient.data.l[1] = long( state1 );
+	event.xclient.data.l[2] = long( state2 );
+	event.xclient.data.l[3] = 1; // source: normal application
+	XSendEvent( display, DefaultRootWindow( display ), False, SubstructureRedirectMask | SubstructureNotifyMask, &event );
+}
