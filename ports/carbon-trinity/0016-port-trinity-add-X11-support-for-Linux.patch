+Tr2MainWindow::Rect Tr2MainWindow::GetDesktopRect() const
+{
+	Display* display = GetXDisplay();
+	if( !display )
+	{
+		return { 0, 0, 0, 0 };
+	}
+	int screen = DefaultScreen( display );
+	return { 0, 0, DisplayWidth( display, screen ), DisplayHeight( display, screen ) };
+}
