diff --git a/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp b/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp
new file mode 100644
index 00000000..e69c4e9b
--- /dev/null
+++ b/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp
@@ -0,0 +1,341 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2ShaderProgramALVulkan.h"
+#include "Tr2ShaderALVulkan.h"
+#include "Tr2SamplerStateALVulkan.h"
+#include "Tr2PrimaryRenderContextVulkan.h"
+#include "VulkanBindingModel.h"
+#include "VulkanContext.h"
+
+#include <atomic>
+
+using namespace Tr2RenderContextEnum;
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+std::atomic<uint64_t> g_nextProgramId( 1 );
+
+VkShaderStageFlags ToVkShaderStage( ShaderType type )
+{
+	switch( type )
+	{
+	case VERTEX_SHADER:
+		return VK_SHADER_STAGE_VERTEX_BIT;
+	case PIXEL_SHADER:
+		return VK_SHADER_STAGE_FRAGMENT_BIT;
+	case COMPUTE_SHADER:
+		return VK_SHADER_STAGE_COMPUTE_BIT;
+	case GEOMETRY_SHADER:
+		return VK_SHADER_STAGE_GEOMETRY_BIT;
+	case HULL_SHADER:
+		return VK_SHADER_STAGE_TESSELLATION_CONTROL_BIT;
+	case DOMAIN_SHADER:
+		return VK_SHADER_STAGE_TESSELLATION_EVALUATION_BIT;
+	default:
+		return 0;
+	}
+}
+
+VkDescriptorType GetSrvDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::SRV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::SRV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE;
+	}
+}
+
+VkDescriptorType GetUavDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::UAV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::UAV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_STORAGE_IMAGE;
+	}
+}
+
+}
+
+Tr2ShaderProgramAL::Tr2ShaderProgramAL() :
+	m_pipelineLayout( VK_NULL_HANDLE ),
+	m_isValid( false )
+{
+}
+
+Tr2ShaderProgramAL::~Tr2ShaderProgramAL()
+{
+	Destroy();
+}
+
+ALResult Tr2ShaderProgramAL::Create( ::Tr2ShaderAL* shaders, size_t count, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	if( count == 0 )
+	{
+		return E_INVALIDARG;
+	}
+
+	uint32_t mask = 0;
+	for( size_t i = 0; i < count; ++i )
+	{
+		if( !shaders[i].IsValid() )
+		{
+			return E_INVALIDARG;
+		}
+		uint32_t bit = 1 << shaders[i].GetType();
+		if( ( mask & bit ) != 0 )
+		{
+			return E_INVALIDARG;
+		}
+		mask |= bit;
+		m_shaders[shaders[i].GetType()] = shaders[i].m_shader;
+	}
+
+	m_registerMap = Tr2RegisterMapAL( shaders, count );
+
+	ALResult result = CreateLayouts();
+	if( FAILED( result ) )
+	{
+		Destroy();
+		return result;
+	}
+
+	m_uniqueId = g_nextProgramId++;
+	m_isValid = true;
+	return S_OK;
+}
+
+ALResult Tr2ShaderProgramAL::CreateLayouts()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	// Collect one descriptor binding per register declared in the shader
+	// signatures, following the binding model in VulkanBindingModel.h. Each
+	// HLSL register space becomes its own descriptor set; layout bindings are
+	// grouped per set. A static sampler tracks (set, index-in-set) so its
+	// immutable-sampler pointer can be attached after m_staticSamplers settles.
+	std::vector<std::vector<VkDescriptorSetLayoutBinding>> setBindings;
+	std::vector<std::pair<uint32_t, size_t>> staticSamplerBindingIndex;
+	m_bindings.clear();
+
+	auto ensureSet = [&setBindings]( uint32_t set ) -> std::vector<VkDescriptorSetLayoutBinding>& {
+		if( set >= setBindings.size() )
+		{
+			setBindings.resize( set + 1 );
+		}
+		return setBindings[set];
+	};
+
+	for( int stageIndex = 0; stageIndex < SHADER_TYPE_COUNT; ++stageIndex )
+	{
+		if( !m_shaders[stageIndex] )
+		{
+			continue;
+		}
+		const ShaderType stage = (ShaderType)stageIndex;
+		const VkShaderStageFlags stageFlags = ToVkShaderStage( stage );
+		const Tr2ShaderSignatureAL& signature = m_shaders[stageIndex]->GetSignature();
+
+		for( const Tr2ShaderRegisterAL& reg : signature.registers )
+		{
+			BindingInfo info = {};
+			info.descriptorSet = reg.registerSpace;
+			info.descriptorCount = std::max<uint32_t>( reg.arrayCount, 1 );
+			info.stage = stage;
+			info.registerType = reg.registerType;
+			info.registerIndex = reg.registerIndex;
+			info.isStaticSampler = false;
+
+			if( reg.registerType == Tr2ShaderRegisterAL::CONSTANT_BUFFER )
+			{
+				info.binding = VulkanBindingModel::GetCbvBinding( stage, reg.registerIndex );
+				info.descriptorType = VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER;
+			}
+			else if( reg.registerType == Tr2ShaderRegisterAL::SAMPLER )
+			{
+				info.binding = VulkanBindingModel::GetSamplerBinding( stage, reg.registerIndex );
+				info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+			}
+			else if( reg.IsSrv() )
+			{
+				info.binding = VulkanBindingModel::GetSrvBinding( stage, reg.registerIndex );
+				info.descriptorType = GetSrvDescriptorType( reg.registerType );
+			}
+			else if( reg.IsUav() )
+			{
+				info.binding = VulkanBindingModel::GetUavBinding( stage, reg.registerIndex );
+				info.descriptorType = GetUavDescriptorType( reg.registerType );
+			}
+			else
+			{
+				continue;
+			}
+
+			VkDescriptorSetLayoutBinding layoutBinding = {};
+			layoutBinding.binding = info.binding;
+			layoutBinding.descriptorType = info.descriptorType;
+			layoutBinding.descriptorCount = info.descriptorCount;
+			layoutBinding.stageFlags = stageFlags;
+			ensureSet( info.descriptorSet ).push_back( layoutBinding );
+			m_bindings.push_back( info );
+		}
+
+		// Static samplers become immutable samplers in the layout.
+		for( const Tr2StaticSamplerAL& staticSampler : signature.samplers )
+		{
+			VkSampler sampler = VK_NULL_HANDLE;
+			CR_RETURN_HR( CreateVkSampler( staticSampler.sampler, sampler ) );
+			m_staticSamplers.push_back( sampler );
+
+			BindingInfo info = {};
+			info.descriptorSet = staticSampler.registerSpace;
+			info.descriptorCount = 1;
+			info.stage = stage;
+			info.registerType = Tr2ShaderRegisterAL::SAMPLER;
+			info.registerIndex = staticSampler.registerIndex;
+			info.isStaticSampler = true;
+			info.binding = VulkanBindingModel::GetSamplerBinding( stage, staticSampler.registerIndex );
+			info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+
+			VkDescriptorSetLayoutBinding layoutBinding = {};
+			layoutBinding.binding = info.binding;
+			layoutBinding.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+			layoutBinding.descriptorCount = 1;
+			layoutBinding.stageFlags = stageFlags;
+			std::vector<VkDescriptorSetLayoutBinding>& bindingsForSet = ensureSet( info.descriptorSet );
+			staticSamplerBindingIndex.push_back( { info.descriptorSet, bindingsForSet.size() } );
+			bindingsForSet.push_back( layoutBinding );
+			m_bindings.push_back( info );
+		}
+	}
+
+	// Attach the immutable sampler pointers now that m_staticSamplers is
+	// fully populated (its storage will not move anymore).
+	for( size_t i = 0; i < staticSamplerBindingIndex.size(); ++i )
+	{
+		const auto& location = staticSamplerBindingIndex[i];
+		setBindings[location.first][location.second].pImmutableSamplers = &m_staticSamplers[i];
+	}
+
+	// A pipeline layout needs a contiguous list of set layouts from set 0.
+	// Spaces are allocated densely (space0 plus one per array), but create an
+	// empty layout for any set that ended up with no bindings just in case.
+	if( setBindings.empty() )
+	{
+		setBindings.resize( 1 );
+	}
+	m_descriptorSetLayouts.resize( setBindings.size(), VK_NULL_HANDLE );
+	for( size_t set = 0; set < setBindings.size(); ++set )
+	{
+		VkDescriptorSetLayoutCreateInfo layoutCreateInfo = {};
+		layoutCreateInfo.sType = VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO;
+		layoutCreateInfo.bindingCount = (uint32_t)setBindings[set].size();
+		layoutCreateInfo.pBindings = setBindings[set].data();
+		VK_CR_RETURN_HR( vkCreateDescriptorSetLayout( context->GetDevice(), &layoutCreateInfo, nullptr, &m_descriptorSetLayouts[set] ) );
+	}
+
+	VkPipelineLayoutCreateInfo pipelineLayoutCreateInfo = {};
+	pipelineLayoutCreateInfo.sType = VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO;
+	pipelineLayoutCreateInfo.setLayoutCount = (uint32_t)m_descriptorSetLayouts.size();
+	pipelineLayoutCreateInfo.pSetLayouts = m_descriptorSetLayouts.data();
+	VK_CR_RETURN_HR( vkCreatePipelineLayout( context->GetDevice(), &pipelineLayoutCreateInfo, nullptr, &m_pipelineLayout ) );
+
+	return S_OK;
+}
+
+void Tr2ShaderProgramAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		if( m_pipelineLayout != VK_NULL_HANDLE )
+		{
+			vkDestroyPipelineLayout( context->GetDevice(), m_pipelineLayout, nullptr );
+		}
+		for( VkDescriptorSetLayout layout : m_descriptorSetLayouts )
+		{
+			if( layout != VK_NULL_HANDLE )
+			{
+				vkDestroyDescriptorSetLayout( context->GetDevice(), layout, nullptr );
+			}
+		}
+		for( VkSampler sampler : m_staticSamplers )
+		{
+			vkDestroySampler( context->GetDevice(), sampler, nullptr );
+		}
+	}
+	m_pipelineLayout = VK_NULL_HANDLE;
+	m_descriptorSetLayouts.clear();
+	m_staticSamplers.clear();
+	m_bindings.clear();
+
+	for( auto& shader : m_shaders )
+	{
+		shader.reset();
+	}
+	m_registerMap = Tr2RegisterMapAL();
+	m_isValid = false;
+}
+
+bool Tr2ShaderProgramAL::IsValid() const
+{
+	return m_isValid;
+}
+
+const Tr2RegisterMapAL& Tr2ShaderProgramAL::GetRegisterMap() const
+{
+	return m_registerMap;
+}
+
+std::shared_ptr<Tr2ShaderAL> Tr2ShaderProgramAL::GetShader( Tr2RenderContextEnum::ShaderType type ) const
+{
+	if( type < 0 || type >= SHADER_TYPE_COUNT )
+	{
+		return nullptr;
+	}
+	return m_shaders[type];
+}
+
+Tr2ALMemoryType Tr2ShaderProgramAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2ShaderProgramAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2ShaderProgramAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2ShaderProgramALVulkan.h b/trinityal/vulkan/Tr2ShaderProgramALVulkan.h
new file mode 100644
index 00000000..5c747c5e
--- /dev/null
+++ b/trinityal/vulkan/Tr2ShaderProgramALVulkan.h
@@ -0,0 +1,91 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2ShaderProgramAL.h"
+#include "../include/Tr2ShaderAL.h"
+#include "../include/Tr2ResourceSetAL.h"
+#include "VulkanCommon.h"
+
+#include <vector>
+
+namespace TrinityALImpl
+{
+class Tr2ShaderProgramAL : public Tr2DeviceResourceAL<Tr2ShaderProgramAL>
+{
+public:
+	// One entry per resource binding declared by the program's shader
+	// signatures; drives descriptor set updates at draw time.
+	struct BindingInfo
+	{
+		uint32_t descriptorSet;
+		uint32_t binding;
+		uint32_t descriptorCount;
+		VkDescriptorType descriptorType;
+		Tr2RenderContextEnum::ShaderType stage;
+		Tr2ShaderRegisterAL::RegisterType registerType;
+		uint32_t registerIndex;
+		bool isStaticSampler;
+	};
+
+	Tr2ShaderProgramAL();
+	~Tr2ShaderProgramAL();
+
+	ALResult Create( ::Tr2ShaderAL* shaders, size_t count, Tr2PrimaryRenderContextAL& renderContext );
+	void Destroy();
+
+	bool IsValid() const;
+	const Tr2RegisterMapAL& GetRegisterMap() const;
+
+	Tr2ALMemoryType GetMemoryClass() const;
+
+	void Describe( Tr2DeviceResourceDescriptionAL& description ) const;
+	ALResult SetName( const char* name );
+
+	// The shaders bundled into this program, held alive for pipeline
+	// creation. Indexed by Tr2RenderContextEnum::ShaderType.
+	std::shared_ptr<Tr2ShaderAL> GetShader( Tr2RenderContextEnum::ShaderType type ) const;
+
+	// One layout per descriptor set used by the program (index == set number,
+	// densely packed from set 0). See VulkanBindingModel.h: set == HLSL space.
+	const std::vector<VkDescriptorSetLayout>& GetDescriptorSetLayouts() const
+	{
+		return m_descriptorSetLayouts;
+	}
+
+	VkPipelineLayout GetPipelineLayout() const
+	{
+		return m_pipelineLayout;
+	}
+
+	const std::vector<BindingInfo>& GetBindings() const
+	{
+		return m_bindings;
+	}
+
+	// Uniquely identifies this program instance for pipeline cache keys;
+	// pointers cannot be used because allocations are recycled.
+	uint64_t GetUniqueId() const
+	{
+		return m_uniqueId;
+	}
+
+private:
+	ALResult CreateLayouts();
+
+	Tr2RegisterMapAL m_registerMap;
+	std::shared_ptr<Tr2ShaderAL> m_shaders[Tr2RenderContextEnum::SHADER_TYPE_COUNT];
+	std::vector<BindingInfo> m_bindings;
+	std::vector<VkSampler> m_staticSamplers;
+	std::vector<VkDescriptorSetLayout> m_descriptorSetLayouts;
+	VkPipelineLayout m_pipelineLayout;
+	uint64_t m_uniqueId = 0;
+	bool m_isValid;
+
+	friend class Tr2RenderContextAL;
+};
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2SwapChainALVulkan.cpp b/trinityal/vulkan/Tr2SwapChainALVulkan.cpp
new file mode 100644
index 00000000..64ce9832
--- /dev/null
+++ b/trinityal/vulkan/Tr2SwapChainALVulkan.cpp
@@ -0,0 +1,295 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2SwapChainALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "Tr2TextureALVulkan.h"
+#include "VulkanContext.h"
+#include "ALLog.h"
+
+#ifdef TRINITY_VULKAN_WITH_XLIB
+#include <X11/Xlib.h>
+#include <vulkan/vulkan_xlib.h>
+#endif
+
+namespace TrinityALImpl
+{
+
+Tr2SwapChainAL::Tr2SwapChainAL() :
+	m_windowHandle( Tr2WindowHandle() ),
+	m_surface( VK_NULL_HANDLE ),
+	m_swapchain( VK_NULL_HANDLE ),
+	m_acquireSemaphore( VK_NULL_HANDLE ),
+	m_presentSemaphore( VK_NULL_HANDLE ),
+	m_acquireFence( VK_NULL_HANDLE ),
+	m_display( nullptr )
+{
+}
+
+Tr2SwapChainAL::~Tr2SwapChainAL()
+{
+	Destroy();
+}
+
+ALResult Tr2SwapChainAL::CreateSurfaceAndSwapchain( Tr2RenderContextAL& renderContext, uint32_t& width, uint32_t& height )
+{
+#ifdef TRINITY_VULKAN_WITH_XLIB
+	VulkanContext* context = renderContext.GetVulkanContext();
+	VulkanInstance& instance = VulkanInstance::Get();
+	if( !instance.SupportsSurfaces() || m_windowHandle == 0 )
+	{
+		return S_FALSE;
+	}
+
+	Display* display = XOpenDisplay( nullptr );
+	if( !display )
+	{
+		CCP_AL_LOGWARN( "XOpenDisplay failed; falling back to headless presentation" );
+		return S_FALSE;
+	}
+	m_display = display;
+
+	VkXlibSurfaceCreateInfoKHR surfaceCreateInfo = {};
+	surfaceCreateInfo.sType = VK_STRUCTURE_TYPE_XLIB_SURFACE_CREATE_INFO_KHR;
+	surfaceCreateInfo.dpy = display;
+	surfaceCreateInfo.window = (Window)m_windowHandle;
+	VK_CR_RETURN_HR( vkCreateXlibSurfaceKHR( instance.GetInstance(), &surfaceCreateInfo, nullptr, &m_surface ) );
+
+	VkBool32 presentSupported = VK_FALSE;
+	vkGetPhysicalDeviceSurfaceSupportKHR( context->GetPhysicalDevice(), context->GetQueueFamilyIndex(), m_surface, &presentSupported );
+	if( !presentSupported )
+	{
+		CCP_AL_LOGWARN( "Vulkan queue family cannot present to the window; falling back to headless presentation" );
+		DestroySwapchain();
+		return S_FALSE;
+	}
+
+	VkSurfaceCapabilitiesKHR capabilities = {};
+	VK_CR_RETURN_HR( vkGetPhysicalDeviceSurfaceCapabilitiesKHR( context->GetPhysicalDevice(), m_surface, &capabilities ) );
+	width = capabilities.currentExtent.width;
+	height = capabilities.currentExtent.height;
+
+	VkSwapchainCreateInfoKHR swapchainCreateInfo = {};
+	swapchainCreateInfo.sType = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR;
+	swapchainCreateInfo.surface = m_surface;
+	swapchainCreateInfo.minImageCount = std::max( capabilities.minImageCount, 2u );
+	swapchainCreateInfo.imageFormat = VK_FORMAT_B8G8R8A8_UNORM;
+	swapchainCreateInfo.imageColorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR;
+	swapchainCreateInfo.imageExtent = capabilities.currentExtent;
+	swapchainCreateInfo.imageArrayLayers = 1;
+	swapchainCreateInfo.imageUsage = VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;
+	swapchainCreateInfo.imageSharingMode = VK_SHARING_MODE_EXCLUSIVE;
+	swapchainCreateInfo.preTransform = capabilities.currentTransform;
+	swapchainCreateInfo.compositeAlpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
+	swapchainCreateInfo.presentMode = VK_PRESENT_MODE_FIFO_KHR;
+	swapchainCreateInfo.clipped = VK_TRUE;
+	VK_CR_RETURN_HR( vkCreateSwapchainKHR( context->GetDevice(), &swapchainCreateInfo, nullptr, &m_swapchain ) );
+
+	uint32_t imageCount = 0;
+	vkGetSwapchainImagesKHR( context->GetDevice(), m_swapchain, &imageCount, nullptr );
+	m_swapchainImages.resize( imageCount );
+	vkGetSwapchainImagesKHR( context->GetDevice(), m_swapchain, &imageCount, m_swapchainImages.data() );
+
+	VkSemaphoreCreateInfo semaphoreCreateInfo = {};
+	semaphoreCreateInfo.sType = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO;
+	VK_CR_RETURN_HR( vkCreateSemaphore( context->GetDevice(), &semaphoreCreateInfo, nullptr, &m_acquireSemaphore ) );
+	VK_CR_RETURN_HR( vkCreateSemaphore( context->GetDevice(), &semaphoreCreateInfo, nullptr, &m_presentSemaphore ) );
+
+	VkFenceCreateInfo fenceCreateInfo = {};
+	fenceCreateInfo.sType = VK_STRUCTURE_TYPE_FENCE_CREATE_INFO;
+	VK_CR_RETURN_HR( vkCreateFence( context->GetDevice(), &fenceCreateInfo, nullptr, &m_acquireFence ) );
+
+	return S_OK;
+#else
+	(void)renderContext;
+	(void)width;
+	(void)height;
+	return S_FALSE;
+#endif
+}
+
+ALResult Tr2SwapChainAL::Create( Tr2WindowHandle windowHandle, Tr2RenderContextAL& renderContext )
+{
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	Destroy();
+	m_windowHandle = windowHandle;
+
+	// Window-system presentation is optional: without it the swap chain is an
+	// offscreen backbuffer and Present() only pushes work to the GPU. Any
+	// surface/swapchain failure (e.g. a handle that is not a real window)
+	// falls back to headless presentation.
+	uint32_t width = 0;
+	uint32_t height = 0;
+	ALResult surfaceResult = CreateSurfaceAndSwapchain( renderContext, width, height );
+	if( FAILED( surfaceResult ) )
+	{
+		CCP_AL_LOGWARN( "Swap chain surface creation failed (0x%08x); falling back to headless presentation", (unsigned)surfaceResult.GetResult() );
+		DestroySwapchain();
+		surfaceResult = S_FALSE;
+	}
+	if( surfaceResult == S_FALSE || width == 0 || height == 0 )
+	{
+		width = std::max( renderContext.GetDefaultBackBuffer().GetWidth(), 4u );
+		height = std::max( renderContext.GetDefaultBackBuffer().GetHeight(), 4u );
+	}
+
+	return m_backBuffer.Create(
+		Tr2BitmapDimensions( width, height, 1, Tr2RenderContextEnum::PIXEL_FORMAT_B8G8R8A8_UNORM ),
+		Tr2GpuUsage::RENDER_TARGET,
+		renderContext );
+}
+
+void Tr2SwapChainAL::DestroySwapchain()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		vkDeviceWaitIdle( context->GetDevice() );
+		if( m_swapchain != VK_NULL_HANDLE )
+		{
+			vkDestroySwapchainKHR( context->GetDevice(), m_swapchain, nullptr );
+		}
+		if( m_acquireSemaphore != VK_NULL_HANDLE )
+		{
+			vkDestroySemaphore( context->GetDevice(), m_acquireSemaphore, nullptr );
+		}
+		if( m_presentSemaphore != VK_NULL_HANDLE )
+		{
+			vkDestroySemaphore( context->GetDevice(), m_presentSemaphore, nullptr );
+		}
+		if( m_acquireFence != VK_NULL_HANDLE )
+		{
+			vkDestroyFence( context->GetDevice(), m_acquireFence, nullptr );
+		}
+	}
+	if( m_surface != VK_NULL_HANDLE )
+	{
+		vkDestroySurfaceKHR( VulkanInstance::Get().GetInstance(), m_surface, nullptr );
+	}
+#ifdef TRINITY_VULKAN_WITH_XLIB
+	if( m_display )
+	{
+		XCloseDisplay( (Display*)m_display );
+	}
+#endif
+	m_swapchain = VK_NULL_HANDLE;
+	m_acquireSemaphore = VK_NULL_HANDLE;
+	m_presentSemaphore = VK_NULL_HANDLE;
+	m_acquireFence = VK_NULL_HANDLE;
+	m_surface = VK_NULL_HANDLE;
+	m_display = nullptr;
+	m_swapchainImages.clear();
+}
+
+void Tr2SwapChainAL::Destroy()
+{
+	DestroySwapchain();
+	m_backBuffer = ::Tr2TextureAL();
+	m_windowHandle = Tr2WindowHandle();
+}
+
+bool Tr2SwapChainAL::IsValid() const
+{
+	return m_backBuffer.IsValid();
+}
+
+ALResult Tr2SwapChainAL::Present( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = renderContext.GetVulkanContext();
+
+	if( m_swapchain == VK_NULL_HANDLE )
+	{
+		// Headless: nothing to present, just push the work through.
+		return context->Flush();
+	}
+
+	uint32_t imageIndex = 0;
+	VK_CR_RETURN_HR( vkAcquireNextImageKHR( context->GetDevice(), m_swapchain, UINT64_MAX, VK_NULL_HANDLE, m_acquireFence, &imageIndex ) );
+	VK_CR_RETURN_HR( vkWaitForFences( context->GetDevice(), 1, &m_acquireFence, VK_TRUE, UINT64_MAX ) );
+	VK_CR_RETURN_HR( vkResetFences( context->GetDevice(), 1, &m_acquireFence ) );
+
+	// Blit the backbuffer texture into the acquired swapchain image.
+	Tr2TextureAL* backBuffer = m_backBuffer.TrinityALImpl_GetObject();
+	VkImage swapchainImage = m_swapchainImages[imageIndex];
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+
+	VkImageMemoryBarrier toTransfer = {};
+	toTransfer.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+	toTransfer.oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+	toTransfer.newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+	toTransfer.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+	toTransfer.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+	toTransfer.image = swapchainImage;
+	toTransfer.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	toTransfer.subresourceRange.levelCount = 1;
+	toTransfer.subresourceRange.layerCount = 1;
+	toTransfer.dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0, nullptr, 1, &toTransfer );
+
+	VkImageBlit blit = {};
+	blit.srcSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	blit.srcSubresource.layerCount = 1;
+	blit.srcOffsets[1] = { (int32_t)m_backBuffer.GetWidth(), (int32_t)m_backBuffer.GetHeight(), 1 };
+	blit.dstSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	blit.dstSubresource.layerCount = 1;
+	blit.dstOffsets[1] = { (int32_t)GetWidth(), (int32_t)GetHeight(), 1 };
+	vkCmdBlitImage( commandBuffer, backBuffer->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, swapchainImage, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &blit, VK_FILTER_NEAREST );
+
+	VkImageMemoryBarrier toPresent = toTransfer;
+	toPresent.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+	toPresent.newLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+	toPresent.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+	toPresent.dstAccessMask = 0;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, nullptr, 0, nullptr, 1, &toPresent );
+
+	CR_RETURN_HR( context->Flush() );
+
+	VkPresentInfoKHR presentInfo = {};
+	presentInfo.sType = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR;
+	presentInfo.swapchainCount = 1;
+	presentInfo.pSwapchains = &m_swapchain;
+	presentInfo.pImageIndices = &imageIndex;
+	VkResult presentResult = vkQueuePresentKHR( context->GetQueue(), &presentInfo );
+	if( presentResult == VK_SUBOPTIMAL_KHR || presentResult == VK_ERROR_OUT_OF_DATE_KHR )
+	{
+		// The window changed size; the caller is expected to recreate the
+		// swap chain. Presenting again next frame is safe.
+		return S_FALSE;
+	}
+	VK_CR_RETURN_HR( presentResult );
+	return S_OK;
+}
+
+uint32_t Tr2SwapChainAL::GetWidth() const
+{
+	return m_backBuffer.GetWidth();
+}
+
+uint32_t Tr2SwapChainAL::GetHeight() const
+{
+	return m_backBuffer.GetHeight();
+}
+
+void Tr2SwapChainAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2SwapChainAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
