+
+namespace TrinityALImpl
+{
+
+Tr2SwapChainAL::Tr2SwapChainAL() :
+	m_windowHandle( Tr2WindowHandle() ),
+	m_surface( VK_NULL_HANDLE ),
+	m_swapchain( VK_NULL_HANDLE ),
+	m_acquireSemaphore( VK_NULL_HANDLE ),
+	m_presentSemaphore( VK_NULL_HANDLE ),
+	m_acquireFence( VK_NULL_HANDLE ),
+	m_display( nullptr )
+{
+}
+
+Tr2SwapChainAL::~Tr2SwapChainAL()
+{
+	Destroy();
+}
+
+ALResult Tr2SwapChainAL::CreateSurfaceAndSwapchain( Tr2RenderContextAL& renderContext, uint32_t& width, uint32_t& height )
+{
+#ifdef TRINITY_VULKAN_WITH_XLIB
+	VulkanContext* context = renderContext.GetVulkanContext();
+	VulkanInstance& instance = VulkanInstance::Get();
+	if( !instance.SupportsSurfaces() || m_windowHandle == 0 )
+	{
+		return S_FALSE;
+	}
+
+	Display* display = XOpenDisplay( nullptr );
+	if( !display )
+	{
+		CCP_AL_LOGWARN( "XOpenDisplay failed; falling back to headless presentation" );
+		return S_FALSE;
+	}
+	m_display = display;
+
+	VkXlibSurfaceCreateInfoKHR surfaceCreateInfo = {};
+	surfaceCreateInfo.sType = VK_STRUCTURE_TYPE_XLIB_SURFACE_CREATE_INFO_KHR;
+	surfaceCreateInfo.dpy = display;
+	surfaceCreateInfo.window = (Window)m_windowHandle;
+	VK_CR_RETURN_HR( vkCreateXlibSurfaceKHR( instance.GetInstance(), &surfaceCreateInfo, nullptr, &m_surface ) );
+
+	VkBool32 presentSupported = VK_FALSE;
+	vkGetPhysicalDeviceSurfaceSupportKHR( context->GetPhysicalDevice(), context->GetQueueFamilyIndex(), m_surface, &presentSupported );
+	if( !presentSupported )
+	{
+		CCP_AL_LOGWARN( "Vulkan queue family cannot present to the window; falling back to headless presentation" );
+		DestroySwapchain();
+		return S_FALSE;
+	}
+
+	VkSurfaceCapabilitiesKHR capabilities = {};
+	VK_CR_RETURN_HR( vkGetPhysicalDeviceSurfaceCapabilitiesKHR( context->GetPhysicalDevice(), m_surface, &capabilities ) );
+	width = capabilities.currentExtent.width;
+	height = capabilities.currentExtent.height;
+
+	VkSwapchainCreateInfoKHR swapchainCreateInfo = {};
+	swapchainCreateInfo.sType = VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR;
+	swapchainCreateInfo.surface = m_surface;
+	swapchainCreateInfo.minImageCount = std::max( capabilities.minImageCount, 2u );
+	swapchainCreateInfo.imageFormat = VK_FORMAT_B8G8R8A8_UNORM;
+	swapchainCreateInfo.imageColorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR;
+	swapchainCreateInfo.imageExtent = capabilities.currentExtent;
+	swapchainCreateInfo.imageArrayLayers = 1;
+	swapchainCreateInfo.imageUsage = VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;
+	swapchainCreateInfo.imageSharingMode = VK_SHARING_MODE_EXCLUSIVE;
+	swapchainCreateInfo.preTransform = capabilities.currentTransform;
+	swapchainCreateInfo.compositeAlpha = VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR;
+	swapchainCreateInfo.presentMode = VK_PRESENT_MODE_FIFO_KHR;
+	swapchainCreateInfo.clipped = VK_TRUE;
+	VK_CR_RETURN_HR( vkCreateSwapchainKHR( context->GetDevice(), &swapchainCreateInfo, nullptr, &m_swapchain ) );
+
+	uint32_t imageCount = 0;
+	vkGetSwapchainImagesKHR( context->GetDevice(), m_swapchain, &imageCount, nullptr );
+	m_swapchainImages.resize( imageCount );
+	vkGetSwapchainImagesKHR( context->GetDevice(), m_swapchain, &imageCount, m_swapchainImages.data() );
+
+	VkSemaphoreCreateInfo semaphoreCreateInfo = {};
+	semaphoreCreateInfo.sType = VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO;
+	VK_CR_RETURN_HR( vkCreateSemaphore( context->GetDevice(), &semaphoreCreateInfo, nullptr, &m_acquireSemaphore ) );
+	VK_CR_RETURN_HR( vkCreateSemaphore( context->GetDevice(), &semaphoreCreateInfo, nullptr, &m_presentSemaphore ) );
+
+	VkFenceCreateInfo fenceCreateInfo = {};
+	fenceCreateInfo.sType = VK_STRUCTURE_TYPE_FENCE_CREATE_INFO;
+	VK_CR_RETURN_HR( vkCreateFence( context->GetDevice(), &fenceCreateInfo, nullptr, &m_acquireFence ) );
+
+	return S_OK;
+#else
+	(void)renderContext;
+	(void)width;
+	(void)height;
+	return S_FALSE;
+#endif
+}
+
+ALResult Tr2SwapChainAL::Create( Tr2WindowHandle windowHandle, Tr2RenderContextAL& renderContext )
+{
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	Destroy();
+	m_windowHandle = windowHandle;
+
+	// Window-system presentation is optional: without it the swap chain is an
+	// offscreen backbuffer and Present() only pushes work to the GPU. Any
+	// surface/swapchain failure (e.g. a handle that is not a real window)
+	// falls back to headless presentation.
+	uint32_t width = 0;
+	uint32_t height = 0;
+	ALResult surfaceResult = CreateSurfaceAndSwapchain( renderContext, width, height );
+	if( FAILED( surfaceResult ) )
+	{
+		CCP_AL_LOGWARN( "Swap chain surface creation failed (0x%08x); falling back to headless presentation", (unsigned)surfaceResult.GetResult() );
+		DestroySwapchain();
+		surfaceResult = S_FALSE;
+	}
+	if( surfaceResult == S_FALSE || width == 0 || height == 0 )
+	{
+		width = std::max( renderContext.GetDefaultBackBuffer().GetWidth(), 4u );
+		height = std::max( renderContext.GetDefaultBackBuffer().GetHeight(), 4u );
+	}
+
+	return m_backBuffer.Create(
+		Tr2BitmapDimensions( width, height, 1, Tr2RenderContextEnum::PIXEL_FORMAT_B8G8R8A8_UNORM ),
+		Tr2GpuUsage::RENDER_TARGET,
+		renderContext );
+}
+
+void Tr2SwapChainAL::DestroySwapchain()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		vkDeviceWaitIdle( context->GetDevice() );
+		if( m_swapchain != VK_NULL_HANDLE )
+		{
+			vkDestroySwapchainKHR( context->GetDevice(), m_swapchain, nullptr );
+		}
+		if( m_acquireSemaphore != VK_NULL_HANDLE )
+		{
+			vkDestroySemaphore( context->GetDevice(), m_acquireSemaphore, nullptr );
+		}
+		if( m_presentSemaphore != VK_NULL_HANDLE )
+		{
+			vkDestroySemaphore( context->GetDevice(), m_presentSemaphore, nullptr );
+		}
+		if( m_acquireFence != VK_NULL_HANDLE )
+		{
+			vkDestroyFence( context->GetDevice(), m_acquireFence, nullptr );
+		}
+	}
+	if( m_surface != VK_NULL_HANDLE )
+	{
+		vkDestroySurfaceKHR( VulkanInstance::Get().GetInstance(), m_surface, nullptr );
+	}
+#ifdef TRINITY_VULKAN_WITH_XLIB
+	if( m_display )
+	{
+		XCloseDisplay( (Display*)m_display );
+	}
+#endif
+	m_swapchain = VK_NULL_HANDLE;
+	m_acquireSemaphore = VK_NULL_HANDLE;
+	m_presentSemaphore = VK_NULL_HANDLE;
+	m_acquireFence = VK_NULL_HANDLE;
+	m_surface = VK_NULL_HANDLE;
+	m_display = nullptr;
+	m_swapchainImages.clear();
+}
+
+void Tr2SwapChainAL::Destroy()
+{
+	DestroySwapchain();
+	m_backBuffer = ::Tr2TextureAL();
+	m_windowHandle = Tr2WindowHandle();
+}
+
+bool Tr2SwapChainAL::IsValid() const
+{
+	return m_backBuffer.IsValid();
+}
+
+ALResult Tr2SwapChainAL::Present( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = renderContext.GetVulkanContext();
+
+	if( m_swapchain == VK_NULL_HANDLE )
+	{
+		// Headless: nothing to present, just push the work through.
+		return context->Flush();
+	}
+
+	uint32_t imageIndex = 0;
+	VK_CR_RETURN_HR( vkAcquireNextImageKHR( context->GetDevice(), m_swapchain, UINT64_MAX, VK_NULL_HANDLE, m_acquireFence, &imageIndex ) );
+	VK_CR_RETURN_HR( vkWaitForFences( context->GetDevice(), 1, &m_acquireFence, VK_TRUE, UINT64_MAX ) );
+	VK_CR_RETURN_HR( vkResetFences( context->GetDevice(), 1, &m_acquireFence ) );
+
+	// Blit the backbuffer texture into the acquired swapchain image.
+	Tr2TextureAL* backBuffer = m_backBuffer.TrinityALImpl_GetObject();
+	VkImage swapchainImage = m_swapchainImages[imageIndex];
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+
+	VkImageMemoryBarrier toTransfer = {};
+	toTransfer.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+	toTransfer.oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+	toTransfer.newLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+	toTransfer.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+	toTransfer.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+	toTransfer.image = swapchainImage;
+	toTransfer.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	toTransfer.subresourceRange.levelCount = 1;
+	toTransfer.subresourceRange.layerCount = 1;
+	toTransfer.dstAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr, 0, nullptr, 1, &toTransfer );
+
+	VkImageBlit blit = {};
+	blit.srcSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	blit.srcSubresource.layerCount = 1;
+	blit.srcOffsets[1] = { (int32_t)m_backBuffer.GetWidth(), (int32_t)m_backBuffer.GetHeight(), 1 };
+	blit.dstSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	blit.dstSubresource.layerCount = 1;
+	blit.dstOffsets[1] = { (int32_t)GetWidth(), (int32_t)GetHeight(), 1 };
+	vkCmdBlitImage( commandBuffer, backBuffer->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, swapchainImage, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, &blit, VK_FILTER_NEAREST );
+
+	VkImageMemoryBarrier toPresent = toTransfer;
+	toPresent.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL;
+	toPresent.newLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+	toPresent.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+	toPresent.dstAccessMask = 0;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, nullptr, 0, nullptr, 1, &toPresent );
+
+	CR_RETURN_HR( context->Flush() );
+
+	VkPresentInfoKHR presentInfo = {};
+	presentInfo.sType = VK_STRUCTURE_TYPE_PRESENT_INFO_KHR;
+	presentInfo.swapchainCount = 1;
+	presentInfo.pSwapchains = &m_swapchain;
+	presentInfo.pImageIndices = &imageIndex;
+	VkResult presentResult = vkQueuePresentKHR( context->GetQueue(), &presentInfo );
+	if( presentResult == VK_SUBOPTIMAL_KHR || presentResult == VK_ERROR_OUT_OF_DATE_KHR )
+	{
+		// The window changed size; the caller is expected to recreate the
+		// swap chain. Presenting again next frame is safe.
+		return S_FALSE;
+	}
+	VK_CR_RETURN_HR( presentResult );
+	return S_OK;
+}
+
+uint32_t Tr2SwapChainAL::GetWidth() const
+{
+	return m_backBuffer.GetWidth();
+}
+
+uint32_t Tr2SwapChainAL::GetHeight() const
+{
+	return m_backBuffer.GetHeight();
+}
+
+void Tr2SwapChainAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2SwapChainAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
