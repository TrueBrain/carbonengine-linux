diff --git a/trinityal/vulkan/Tr2VideoAdapterInfoALVulkan.cpp b/trinityal/vulkan/Tr2VideoAdapterInfoALVulkan.cpp
new file mode 100644
index 00000000..b702bab7
--- /dev/null
+++ b/trinityal/vulkan/Tr2VideoAdapterInfoALVulkan.cpp
@@ -0,0 +1,164 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2VideoAdapterInfoALVulkan.h"
+#include "Tr2AdapterStructures.h"
+#include "VulkanContext.h"
+
+using namespace Tr2RenderContextEnum;
+using TrinityALImpl::VulkanInstance;
+
+namespace
+{
+
+// Trinity has no display-mode concept on Vulkan yet (that requires either
+// VK_KHR_display or asking the window system). A fixed set of common modes is
+// reported; fullscreen mode switching is handled by the window system.
+const uint32_t COMMON_MODES[][2] = {
+	{ 1280, 720 },
+	{ 1920, 1080 },
+	{ 2560, 1440 },
+	{ 3840, 2160 },
+};
+
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterCount( unsigned& count )
+{
+	count = (unsigned)VulkanInstance::Get().GetPhysicalDevices().size();
+	return count > 0 ? S_OK : E_FAIL;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterInfo( unsigned adapterIndex, Tr2AdapterInfo& info )
+{
+	VkPhysicalDevice physicalDevice = VulkanInstance::Get().GetPhysicalDevice( adapterIndex );
+	if( physicalDevice == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+
+	VkPhysicalDeviceProperties properties = {};
+	vkGetPhysicalDeviceProperties( physicalDevice, &properties );
+
+	info.driver = "vulkan";
+	info.deviceName = properties.deviceName;
+	info.description.assign( info.deviceName.begin(), info.deviceName.end() );
+	info.driverVersion = properties.driverVersion;
+	info.vendorID = properties.vendorID;
+	info.deviceID = properties.deviceID;
+	info.subSystemID = 0;
+	info.revision = 0;
+
+	AdapterGuid id = {};
+	memcpy( &id, properties.pipelineCacheUUID, std::min( sizeof( id ), sizeof( properties.pipelineCacheUUID ) ) );
+	info.deviceIdentifier = id;
+	memset( info.luid, 0, sizeof( info.luid ) );
+	return S_OK;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterMonitor( unsigned, void*& monitor )
+{
+	monitor = nullptr;
+	return S_OK;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterDisplayMode( unsigned adapterIndex, Tr2DisplayModeInfo& mode )
+{
+	if( VulkanInstance::Get().GetPhysicalDevice( adapterIndex ) == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+	mode.format = PIXEL_FORMAT_B8G8R8A8_UNORM;
+	mode.width = 1920;
+	mode.height = 1080;
+	mode.refreshRateNumerator = 60;
+	mode.refreshRateDenominator = 1;
+	mode.scaling = DISPLAY_SCALING_UNSPECIFIED;
+	mode.scanlineOrdering = SCANLINE_ORDER_UNSPECIFIED;
+	return S_OK;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterModeCount( unsigned adapterIndex, Tr2RenderContextEnum::PixelFormat, unsigned& count )
+{
+	if( VulkanInstance::Get().GetPhysicalDevice( adapterIndex ) == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+	count = (unsigned)( sizeof( COMMON_MODES ) / sizeof( COMMON_MODES[0] ) );
+	return S_OK;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterMode( unsigned adapterIndex, Tr2RenderContextEnum::PixelFormat backBufferFormat, unsigned modeIndex, Tr2DisplayModeInfo& mode )
+{
+	if( VulkanInstance::Get().GetPhysicalDevice( adapterIndex ) == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+	if( modeIndex >= sizeof( COMMON_MODES ) / sizeof( COMMON_MODES[0] ) )
+	{
+		return E_INVALIDARG;
+	}
+	mode.format = backBufferFormat;
+	mode.width = COMMON_MODES[modeIndex][0];
+	mode.height = COMMON_MODES[modeIndex][1];
+	mode.refreshRateNumerator = 60;
+	mode.refreshRateDenominator = 1;
+	mode.scaling = DISPLAY_SCALING_UNSPECIFIED;
+	mode.scanlineOrdering = SCANLINE_ORDER_UNSPECIFIED;
+	return S_OK;
+}
+
+ALResult Tr2VideoAdapterInfo::GetAdapterMaxTextureWidth( unsigned adapterIndex, unsigned& maxWidth )
+{
+	VkPhysicalDevice physicalDevice = VulkanInstance::Get().GetPhysicalDevice( adapterIndex );
+	if( physicalDevice == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+	VkPhysicalDeviceProperties properties = {};
+	vkGetPhysicalDeviceProperties( physicalDevice, &properties );
+	maxWidth = properties.limits.maxImageDimension2D;
+	return S_OK;
+}
+
+bool Tr2VideoAdapterInfo::SupportsBackBufferFormat( unsigned adapterIndex, Tr2RenderContextEnum::PixelFormat backBufferFormat )
+{
+	return SupportsRenderTargetFormat( adapterIndex, backBufferFormat );
+}
+
+bool Tr2VideoAdapterInfo::SupportsRenderTargetFormat( unsigned adapterIndex, Tr2RenderContextEnum::PixelFormat format )
+{
+	VkPhysicalDevice physicalDevice = VulkanInstance::Get().GetPhysicalDevice( adapterIndex );
+	if( physicalDevice == VK_NULL_HANDLE )
+	{
+		return false;
+	}
+	VkFormat vkFormat = TrinityALImpl::ToVkFormat( format );
+	if( vkFormat == VK_FORMAT_UNDEFINED )
+	{
+		return false;
+	}
+	VkFormatProperties formatProperties = {};
+	vkGetPhysicalDeviceFormatProperties( physicalDevice, vkFormat, &formatProperties );
+	const VkFormatFeatureFlags features = formatProperties.optimalTilingFeatures;
+	if( TrinityALImpl::IsDepthFormat( vkFormat ) )
+	{
+		return ( features & VK_FORMAT_FEATURE_DEPTH_STENCIL_ATTACHMENT_BIT ) != 0;
+	}
+	return ( features & VK_FORMAT_FEATURE_COLOR_ATTACHMENT_BIT ) != 0;
+}
+
+bool Tr2VideoAdapterInfo::AreAdaptersDifferent( unsigned adapter1, unsigned adapter2 )
+{
+	return adapter1 != adapter2;
+}
+
+ALResult Tr2VideoAdapterInfo::RefreshData()
+{
+	return S_OK;
+}
+
+#endif
