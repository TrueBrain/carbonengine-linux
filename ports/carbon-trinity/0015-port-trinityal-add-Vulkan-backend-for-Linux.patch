diff --git a/trinityal/vulkan/Tr2TextureALVulkan.cpp b/trinityal/vulkan/Tr2TextureALVulkan.cpp
new file mode 100644
index 00000000..f765ae58
--- /dev/null
+++ b/trinityal/vulkan/Tr2TextureALVulkan.cpp
@@ -0,0 +1,791 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2TextureALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+using namespace Tr2RenderContextEnum;
+using Tr2CpuUsage::HasFlag;
+using Tr2GpuUsage::HasBufferFlags;
+using Tr2GpuUsage::IsWritable;
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+VkImageUsageFlags GetImageUsageFlags( Tr2GpuUsage::Type gpuUsage, VkFormat format )
+{
+	VkImageUsageFlags usage = VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::RENDER_TARGET ) )
+	{
+		usage |= VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::DEPTH_STENCIL ) )
+	{
+		usage |= VK_IMAGE_USAGE_DEPTH_STENCIL_ATTACHMENT_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::SHADER_RESOURCE ) )
+	{
+		usage |= VK_IMAGE_USAGE_SAMPLED_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::UNORDERED_ACCESS ) )
+	{
+		usage |= VK_IMAGE_USAGE_STORAGE_BIT;
+	}
+	return usage;
+}
+
+}
+
+Tr2TextureAL::Tr2TextureAL() :
+	m_gpuUsage( Tr2GpuUsage::NONE ),
+	m_cpuUsage( Tr2CpuUsage::NONE ),
+	m_image( VK_NULL_HANDLE ),
+	m_allocation( VK_NULL_HANDLE ),
+	m_imageView( VK_NULL_HANDLE ),
+	m_format( VK_FORMAT_UNDEFINED )
+{
+}
+
+Tr2TextureAL::~Tr2TextureAL()
+{
+	Destroy();
+}
+
+VkImageSubresourceRange Tr2TextureAL::GetFullSubresourceRange() const
+{
+	VkImageSubresourceRange range = {};
+	range.aspectMask = GetFormatAspectFlags( m_format );
+	range.levelCount = VK_REMAINING_MIP_LEVELS;
+	range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+	return range;
+}
+
+ALResult Tr2TextureAL::CreateViews()
+{
+	VulkanContext* context = GetVulkanContext();
+
+	VkImageViewType viewType;
+	switch( m_desc.GetType() )
+	{
+	case TEX_TYPE_1D:
+		viewType = m_desc.GetArraySize() > 1 ? VK_IMAGE_VIEW_TYPE_1D_ARRAY : VK_IMAGE_VIEW_TYPE_1D;
+		break;
+	case TEX_TYPE_3D:
+		viewType = VK_IMAGE_VIEW_TYPE_3D;
+		break;
+	case TEX_TYPE_CUBE:
+		viewType = VK_IMAGE_VIEW_TYPE_CUBE;
+		break;
+	case TEX_TYPE_2D:
+	default:
+		viewType = m_desc.GetArraySize() > 1 ? VK_IMAGE_VIEW_TYPE_2D_ARRAY : VK_IMAGE_VIEW_TYPE_2D;
+		break;
+	}
+
+	VkImageViewCreateInfo viewCreateInfo = {};
+	viewCreateInfo.sType = VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO;
+	viewCreateInfo.image = m_image;
+	viewCreateInfo.viewType = viewType;
+	viewCreateInfo.format = m_format;
+	viewCreateInfo.subresourceRange = GetFullSubresourceRange();
+	// Sampling from a combined depth/stencil image needs a single aspect.
+	if( viewCreateInfo.subresourceRange.aspectMask & VK_IMAGE_ASPECT_DEPTH_BIT )
+	{
+		viewCreateInfo.subresourceRange.aspectMask = VK_IMAGE_ASPECT_DEPTH_BIT;
+	}
+
+	VK_CR_RETURN_HR( vkCreateImageView( context->GetDevice(), &viewCreateInfo, nullptr, &m_imageView ) );
+	return S_OK;
+}
+
+ALResult Tr2TextureAL::Create( const Tr2BitmapDimensions& desc, const Tr2MsaaDesc& msaa, Tr2GpuUsage::Type gpuUsage, Tr2CpuUsage::Type cpuUsage, Tr2SubresourceData* initialData, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	// The validation below mirrors the platform-independent rules the other
+	// backends enforce (see the stub backend).
+	if( HasBufferFlags( gpuUsage ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( msaa.samples > 1 )
+	{
+		if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::UNORDERED_ACCESS ) )
+		{
+			return E_INVALIDARG;
+		}
+		if( cpuUsage != Tr2CpuUsage::NONE )
+		{
+			return E_INVALIDARG;
+		}
+		if( desc.GetType() != TEX_TYPE_2D )
+		{
+			return E_INVALIDARG;
+		}
+	}
+	if( desc.GetType() != TEX_TYPE_2D )
+	{
+		if( desc.GetType() == TEX_TYPE_CUBE )
+		{
+			if( desc.GetArraySize() != 6 )
+			{
+				return E_INVALIDARG;
+			}
+		}
+		else if( desc.GetArraySize() > 1 )
+		{
+			return E_INVALIDARG;
+		}
+	}
+	if( desc.GetType() != TEX_TYPE_2D && Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::DEPTH_STENCIL ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( msaa.samples > 1 && desc.GetTrueMipCount() > 1 )
+	{
+		return E_INVALIDARG;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::RENDER_TARGET ) && HasFlag( cpuUsage, Tr2CpuUsage::WRITE ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::DEPTH_STENCIL ) && cpuUsage != Tr2CpuUsage::NONE )
+	{
+		return E_INVALIDARG;
+	}
+	if( Tr2GpuUsage::HasFlag( gpuUsage, Tr2GpuUsage::DEPTH_STENCIL ) && desc.GetTrueMipCount() > 1 )
+	{
+		return E_INVALIDARG;
+	}
+	if( desc.GetType() == TEX_TYPE_3D && cpuUsage != Tr2CpuUsage::NONE )
+	{
+		return E_INVALIDARG;
+	}
+	if( !IsWritable( gpuUsage ) && !HasFlag( cpuUsage, Tr2CpuUsage::WRITE ) && !initialData )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	VkFormat format = ToVkFormat( desc.GetFormat() );
+	if( format == VK_FORMAT_UNDEFINED )
+	{
+		return E_INVALIDARG;
+	}
+
+	VkImageCreateInfo imageCreateInfo = {};
+	imageCreateInfo.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+	switch( desc.GetType() )
+	{
+	case TEX_TYPE_1D:
+		imageCreateInfo.imageType = VK_IMAGE_TYPE_1D;
+		break;
+	case TEX_TYPE_3D:
+		imageCreateInfo.imageType = VK_IMAGE_TYPE_3D;
+		break;
+	case TEX_TYPE_CUBE:
+		imageCreateInfo.imageType = VK_IMAGE_TYPE_2D;
+		imageCreateInfo.flags |= VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT;
+		break;
+	default:
+		imageCreateInfo.imageType = VK_IMAGE_TYPE_2D;
+		break;
+	}
+	imageCreateInfo.format = format;
+	imageCreateInfo.extent.width = desc.GetWidth();
+	imageCreateInfo.extent.height = desc.GetHeight();
+	imageCreateInfo.extent.depth = desc.GetType() == TEX_TYPE_3D ? desc.GetDepth() : 1;
+	imageCreateInfo.mipLevels = desc.GetTrueMipCount();
+	imageCreateInfo.arrayLayers = desc.GetArraySize();
+	imageCreateInfo.samples = (VkSampleCountFlagBits)std::max( msaa.samples, 1u );
+	imageCreateInfo.tiling = VK_IMAGE_TILING_OPTIMAL;
+	imageCreateInfo.usage = GetImageUsageFlags( gpuUsage, format );
+	imageCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+	imageCreateInfo.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+
+	VK_CR_RETURN_HR( vmaCreateImage( context->GetAllocator(), &imageCreateInfo, &allocationCreateInfo, &m_image, &m_allocation, nullptr ) );
+
+	m_desc = desc;
+	m_msaa = msaa;
+	m_gpuUsage = gpuUsage;
+	m_cpuUsage = cpuUsage;
+	m_format = format;
+
+	ALResult result = CreateViews();
+	if( FAILED( result ) )
+	{
+		Destroy();
+		return result;
+	}
+
+	// Bring-up simplification: images live in VK_IMAGE_LAYOUT_GENERAL so no
+	// per-use layout tracking is needed yet. Moving to tracked, optimal
+	// layouts belongs to the draw-path work.
+	result = context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkImageMemoryBarrier barrier = {};
+		barrier.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+		barrier.oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+		barrier.newLayout = VK_IMAGE_LAYOUT_GENERAL;
+		barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+		barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+		barrier.image = m_image;
+		barrier.subresourceRange = GetFullSubresourceRange();
+		barrier.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+		vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 0, nullptr, 0, nullptr, 1, &barrier );
+	} );
+	if( FAILED( result ) )
+	{
+		Destroy();
+		return result;
+	}
+
+	if( initialData )
+	{
+		uint32_t subresourceIndex = 0;
+		for( uint32_t face = 0; face < desc.GetArraySize(); ++face )
+		{
+			for( uint32_t mip = 0; mip < desc.GetTrueMipCount(); ++mip, ++subresourceIndex )
+			{
+				const Tr2SubresourceData& subresource = initialData[subresourceIndex];
+				if( !subresource.m_sysMem )
+				{
+					continue;
+				}
+				Tr2TextureSubresource region( face, mip );
+				CR_RETURN_HR( UploadSubresource( region, subresource.m_sysMem, subresource.m_sysMemPitch, subresource.m_sysMemSlicePitch ) );
+			}
+		}
+	}
+
+	return S_OK;
+}
+
+ALResult Tr2TextureAL::UploadSubresource( const Tr2TextureSubresource& region, const void* source, uint32_t pitch, uint32_t slicePitch )
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	const uint32_t mip = region.m_startMipLevel;
+	const uint32_t face = region.m_startFace;
+	const uint32_t mipPitch = m_desc.GetMipPitch( mip );
+	const uint32_t rows = std::max( m_desc.GetMipNumRows( mip ), 1u );
+	const uint32_t depth = m_desc.GetType() == TEX_TYPE_3D ? m_desc.GetMipDepth( mip ) : 1;
+	const VkDeviceSize size = (VkDeviceSize)mipPitch * rows * depth;
+
+	VkBuffer staging = VK_NULL_HANDLE;
+	VmaAllocation stagingAllocation = VK_NULL_HANDLE;
+	void* stagingData = nullptr;
+	CR_RETURN_HR( context->CreateStagingBuffer( size, VK_BUFFER_USAGE_TRANSFER_SRC_BIT, staging, stagingAllocation, stagingData ) );
+
+	// Tightly pack the source rows into the staging buffer.
+	const uint8_t* sourceBytes = (const uint8_t*)source;
+	uint8_t* destinationBytes = (uint8_t*)stagingData;
+	for( uint32_t slice = 0; slice < depth; ++slice )
+	{
+		const uint8_t* sliceSource = sourceBytes + (size_t)slice * slicePitch;
+		for( uint32_t row = 0; row < rows; ++row )
+		{
+			memcpy( destinationBytes, sliceSource + (size_t)row * pitch, std::min( pitch, mipPitch ) );
+			destinationBytes += mipPitch;
+		}
+	}
+	vmaFlushAllocation( context->GetAllocator(), stagingAllocation, 0, size );
+
+	ALResult result = context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkBufferImageCopy copy = {};
+		copy.imageSubresource.aspectMask = GetFormatAspectFlags( m_format ) & ~VK_IMAGE_ASPECT_STENCIL_BIT;
+		copy.imageSubresource.mipLevel = mip;
+		copy.imageSubresource.baseArrayLayer = face;
+		copy.imageSubresource.layerCount = 1;
+		copy.imageExtent.width = m_desc.GetMipWidth( mip );
+		copy.imageExtent.height = m_desc.GetMipHeight( mip );
+		copy.imageExtent.depth = depth;
+		vkCmdCopyBufferToImage( commandBuffer, staging, m_image, VK_IMAGE_LAYOUT_GENERAL, 1, &copy );
+	} );
+
+	vmaDestroyBuffer( context->GetAllocator(), staging, stagingAllocation );
+	return result;
+}
+
+VkImageView Tr2TextureAL::GetVkStorageView( uint32_t mip )
+{
+	if( !IsValid() || mip >= m_desc.GetTrueMipCount() )
+	{
+		return VK_NULL_HANDLE;
+	}
+	if( m_storageViews.size() <= mip )
+	{
+		m_storageViews.resize( m_desc.GetTrueMipCount(), VK_NULL_HANDLE );
+	}
+	if( m_storageViews[mip] == VK_NULL_HANDLE )
+	{
+		VulkanContext* context = GetVulkanContext();
+		if( !context || !context->IsValid() )
+		{
+			return VK_NULL_HANDLE;
+		}
+
+		VkImageViewCreateInfo viewCreateInfo = {};
+		viewCreateInfo.sType = VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO;
+		viewCreateInfo.image = m_image;
+		switch( m_desc.GetType() )
+		{
+		case TEX_TYPE_3D:
+			viewCreateInfo.viewType = VK_IMAGE_VIEW_TYPE_3D;
+			break;
+		case TEX_TYPE_CUBE:
+			// Storage access addresses cube maps as 2D arrays.
+			viewCreateInfo.viewType = VK_IMAGE_VIEW_TYPE_2D_ARRAY;
+			break;
+		default:
+			viewCreateInfo.viewType = m_desc.GetArraySize() > 1 ? VK_IMAGE_VIEW_TYPE_2D_ARRAY : VK_IMAGE_VIEW_TYPE_2D;
+			break;
+		}
+		viewCreateInfo.format = m_format;
+		viewCreateInfo.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+		viewCreateInfo.subresourceRange.baseMipLevel = mip;
+		viewCreateInfo.subresourceRange.levelCount = 1;
+		viewCreateInfo.subresourceRange.layerCount = VK_REMAINING_ARRAY_LAYERS;
+		vkCreateImageView( context->GetDevice(), &viewCreateInfo, nullptr, &m_storageViews[mip] );
+	}
+	return m_storageViews[mip];
+}
+
+ALResult Tr2TextureAL::OpenShared( uintptr_t, Tr2GpuUsage::Type, Tr2PrimaryRenderContextAL& )
+{
+	// Cross-API shared textures are not supported on the Vulkan backend yet.
+	return E_FAIL;
+}
+
+void Tr2TextureAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context )
+	{
+		context->DestroyImageViewLater( m_imageView );
+		for( VkImageView storageView : m_storageViews )
+		{
+			context->DestroyImageViewLater( storageView );
+		}
+		context->DestroyImageLater( m_image, m_allocation );
+	}
+	m_storageViews.clear();
+	m_image = VK_NULL_HANDLE;
+	m_allocation = VK_NULL_HANDLE;
+	m_imageView = VK_NULL_HANDLE;
+	m_format = VK_FORMAT_UNDEFINED;
+	m_desc = Tr2BitmapDimensions();
+	m_msaa = Tr2MsaaDesc();
+	m_gpuUsage = Tr2GpuUsage::NONE;
+	m_cpuUsage = Tr2CpuUsage::NONE;
+	m_mapData.clear();
+}
+
+bool Tr2TextureAL::IsValid() const
+{
+	return m_image != VK_NULL_HANDLE;
