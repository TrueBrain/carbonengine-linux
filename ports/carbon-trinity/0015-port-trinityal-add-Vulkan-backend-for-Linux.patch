+ALResult Tr2RenderContextAL::DrawIndexedInstancedIndirect( Tr2BufferAL& argsBuffer, uint32_t offset )
+{
+	if( !argsBuffer.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	CR_RETURN_HR( SetupIndexedDraw( commandBuffer, VK_NULL_HANDLE, 0, VK_INDEX_TYPE_UINT16 ) );
+	// The D3D11 draw-indexed-instanced argument layout matches VkDrawIndexedIndirectCommand.
+	vkCmdDrawIndexedIndirect( commandBuffer, argsBuffer.TrinityALImpl_GetObject()->GetVkBuffer(), offset, 1, 0 );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetupCompute( VkCommandBuffer& commandBuffer )
+{
+	if( !IsValid() || !m_shaderProgram.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	TrinityALImpl::Tr2ShaderProgramAL* program = m_shaderProgram.TrinityALImpl_GetObject();
+	auto computeShader = program->GetShader( COMPUTE_SHADER );
+	if( !computeShader || computeShader->GetVkShaderModule() == VK_NULL_HANDLE )
+	{
+		return E_INVALIDCALL;
+	}
+
+	uint64_t hash = HashFnv1a64( "compute", 7 );
+	const uint64_t programId = program->GetUniqueId();
+	hash = HashFnv1a64( &programId, sizeof( programId ), hash );
+
+	VkPipeline pipeline = m_vulkanContext->GetCachedPipeline( hash );
+	if( pipeline == VK_NULL_HANDLE )
+	{
+		VkComputePipelineCreateInfo pipelineCreateInfo = {};
+		pipelineCreateInfo.sType = VK_STRUCTURE_TYPE_COMPUTE_PIPELINE_CREATE_INFO;
+		pipelineCreateInfo.stage.sType = VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO;
+		pipelineCreateInfo.stage.stage = VK_SHADER_STAGE_COMPUTE_BIT;
+		pipelineCreateInfo.stage.module = computeShader->GetVkShaderModule();
+		pipelineCreateInfo.stage.pName = "main";
+		pipelineCreateInfo.layout = program->GetPipelineLayout();
+
+		VkPipeline newPipeline = VK_NULL_HANDLE;
+		VK_CR_RETURN_HR( vkCreateComputePipelines( m_vulkanContext->GetDevice(), VK_NULL_HANDLE, 1, &pipelineCreateInfo, nullptr, &newPipeline ) );
+		pipeline = m_vulkanContext->AddPipelineToCache( hash, newPipeline );
+	}
+
+	VkDescriptorSet descriptorSet = VK_NULL_HANDLE;
+	CR_RETURN_HR( BuildDescriptorSet( *program, descriptorSet ) );
+
+	commandBuffer = m_vulkanContext->GetCommandBuffer();
+
+	VkMemoryBarrier before = {};
+	before.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	before.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+	before.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT | VK_PIPELINE_STAGE_DRAW_INDIRECT_BIT, 0, 1, &before, 0, nullptr, 0, nullptr );
+
+	vkCmdBindPipeline( commandBuffer, VK_PIPELINE_BIND_POINT_COMPUTE, pipeline );
+	vkCmdBindDescriptorSets( commandBuffer, VK_PIPELINE_BIND_POINT_COMPUTE, program->GetPipelineLayout(), VulkanBindingModel::DESCRIPTOR_SET, 1, &descriptorSet, 0, nullptr );
+	return S_OK;
+}
+
+namespace
+{
+
+void EmitPostDispatchBarrier( VkCommandBuffer commandBuffer )
+{
+	VkMemoryBarrier after = {};
+	after.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	after.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+	after.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 1, &after, 0, nullptr, 0, nullptr );
+}
+
+}
+
+ALResult Tr2RenderContextAL::RunComputeShader( unsigned groupCountX, unsigned groupCountY, unsigned groupCountZ )
+{
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupCompute( commandBuffer ) );
+	vkCmdDispatch( commandBuffer, groupCountX, groupCountY, groupCountZ );
+	EmitPostDispatchBarrier( commandBuffer );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::RunComputeShaderIndirect( Tr2BufferAL& argsBuffer, unsigned offset )
+{
+	if( !argsBuffer.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupCompute( commandBuffer ) );
+	vkCmdDispatchIndirect( commandBuffer, argsBuffer.TrinityALImpl_GetObject()->GetVkBuffer(), offset );
+	EmitPostDispatchBarrier( commandBuffer );
+	return S_OK;
+}
