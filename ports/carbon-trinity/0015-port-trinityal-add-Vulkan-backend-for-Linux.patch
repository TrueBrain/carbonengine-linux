+	{
+		uint32_t vertexCount = 0;
+		uint32_t vertexStride = 0;
+		VkFormat vertexFormat = VK_FORMAT_UNDEFINED;
+		uint32_t indexCount = 0;
+		VkIndexType indexType = VK_INDEX_TYPE_UINT32;
+	};
+
+	ALResult Build( const Tr2RtGeometryAL& geometry, VkBuildAccelerationStructureModeKHR mode );
+
+	VkAccelerationStructureKHR m_accelerationStructure;
+	VkBuffer m_buffer;
+	VmaAllocation m_bufferAllocation;
+	VkBuffer m_scratch;
+	VmaAllocation m_scratchAllocation;
+	VkDeviceAddress m_address;
+	VkDeviceAddress m_scratchAddress;
+	VkDeviceSize m_bufferSize;
+	VkDeviceSize m_scratchSize;
+	GeometryShape m_shape;
+	Tr2RtBlasGeometryFlags::Type m_geometryFlags;
+	Tr2RtBuildFlags::Type m_buildFlags;
+};
+
