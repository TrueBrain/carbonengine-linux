+	PFN_vkGetRayTracingShaderGroupHandlesKHR vkGetRayTracingShaderGroupHandlesKHR = nullptr;
+	PFN_vkCmdTraceRaysKHR vkCmdTraceRaysKHR = nullptr;
+};
