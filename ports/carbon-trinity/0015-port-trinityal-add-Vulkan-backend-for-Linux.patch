+	const Tr2CapsAL& GetCaps() const;
+
+	ALResult BeginScene();
+	ALResult EndScene();
+	ALResult Present();
+
+	bool IsValid();
+
+	void ReleaseDeviceResources();
+
+	ALResult SetStreamSource(
