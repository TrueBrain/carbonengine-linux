+// --------------------------------------------------------------------------------------
+// Draw calls.
+// --------------------------------------------------------------------------------------
+
+ALResult Tr2RenderContextAL::DrawPrimitive( uint32_t startVertex, uint32_t primitiveCount )
+{
+	const uint32_t vertexCount = GetVertexCountForPrimitives( primitiveCount );
+	if( vertexCount == 0 )
+	{
+		return E_INVALIDCALL;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	vkCmdDraw( commandBuffer, vertexCount, 1, startVertex, 0 );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::DrawIndexedPrimitive( uint32_t, uint32_t startIndex, uint32_t primitiveCount, uint32_t )
+{
+	const uint32_t indexCount = GetVertexCountForPrimitives( primitiveCount );
+	if( indexCount == 0 )
+	{
+		return E_INVALIDCALL;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	CR_RETURN_HR( SetupIndexedDraw( commandBuffer, VK_NULL_HANDLE, 0, VK_INDEX_TYPE_UINT16 ) );
+	vkCmdDrawIndexed( commandBuffer, indexCount, 1, startIndex, 0, 0 );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::DrawIndexedInstanced( uint32_t, uint32_t startIndex, uint32_t primitiveCount, uint32_t numInstances )
+{
+	const uint32_t indexCount = GetVertexCountForPrimitives( primitiveCount );
+	if( indexCount == 0 )
+	{
+		return E_INVALIDCALL;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	CR_RETURN_HR( SetupIndexedDraw( commandBuffer, VK_NULL_HANDLE, 0, VK_INDEX_TYPE_UINT16 ) );
+	vkCmdDrawIndexed( commandBuffer, indexCount, numInstances, startIndex, 0, 0 );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::DrawIndexedInstanced(
+	uint32_t indexCountPerInstance,
+	uint32_t instanceCount,
+	uint32_t startIndexLocation,
+	int32_t baseVertexLocation,
+	uint32_t startInstanceLocation )
+{
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	CR_RETURN_HR( SetupIndexedDraw( commandBuffer, VK_NULL_HANDLE, 0, VK_INDEX_TYPE_UINT16 ) );
+	vkCmdDrawIndexed( commandBuffer, indexCountPerInstance, instanceCount, startIndexLocation, baseVertexLocation, startInstanceLocation );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::DrawInstanced(
+	uint32_t vertexCountPerInstance,
+	uint32_t instanceCount,
+	uint32_t startVertexLocation,
+	uint32_t startInstanceLocation )
+{
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	vkCmdDraw( commandBuffer, vertexCountPerInstance, instanceCount, startVertexLocation, startInstanceLocation );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::DrawPrimitiveUP( uint32_t primitiveCount, const void* vertexStreamZeroData, uint32_t vertexStreamZeroStride )
+{
+	if( !vertexStreamZeroData || vertexStreamZeroStride == 0 )
+	{
+		return E_FAIL;
+	}
+	const uint32_t vertexCount = GetVertexCountForPrimitives( primitiveCount );
+	if( vertexCount == 0 )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VkBuffer vertexBuffer = VK_NULL_HANDLE;
+	VkDeviceSize vertexOffset = 0;
+	void* vertexData = nullptr;
+	CR_RETURN_HR( m_vulkanContext->AllocateTransientData( (VkDeviceSize)vertexCount * vertexStreamZeroStride, 4, vertexBuffer, vertexOffset, vertexData ) );
+	memcpy( vertexData, vertexStreamZeroData, (size_t)vertexCount * vertexStreamZeroStride );
+
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( vertexStreamZeroStride, vertexBuffer, vertexOffset, commandBuffer ) );
+	vkCmdDraw( commandBuffer, vertexCount, 1, 0, 0 );
+	return S_OK;
+}
+
+namespace
+{
+
+template <typename IndexType>
+ALResult DrawIndexedUP(
+	Tr2RenderContextAL& renderContext,
+	TrinityALImpl::VulkanContext& context,
+	uint32_t numVertices,
+	uint32_t indexCount,
+	const IndexType* indexData,
+	const void* vertexStreamZeroData,
+	uint32_t vertexStreamZeroStride,
+	const std::function<ALResult( uint32_t, VkBuffer, VkDeviceSize, VkCommandBuffer& )>& setupDraw,
+	const std::function<ALResult( VkCommandBuffer, VkBuffer, VkDeviceSize, VkIndexType )>& setupIndexedDraw )
+{
+	VkBuffer vertexBuffer = VK_NULL_HANDLE;
+	VkDeviceSize vertexOffset = 0;
+	void* vertexUpload = nullptr;
+	CR_RETURN_HR( context.AllocateTransientData( (VkDeviceSize)numVertices * vertexStreamZeroStride, 4, vertexBuffer, vertexOffset, vertexUpload ) );
+	memcpy( vertexUpload, vertexStreamZeroData, (size_t)numVertices * vertexStreamZeroStride );
+
+	VkBuffer indexBuffer = VK_NULL_HANDLE;
+	VkDeviceSize indexOffset = 0;
+	void* indexUpload = nullptr;
+	CR_RETURN_HR( context.AllocateTransientData( (VkDeviceSize)indexCount * sizeof( IndexType ), 4, indexBuffer, indexOffset, indexUpload ) );
+	memcpy( indexUpload, indexData, (size_t)indexCount * sizeof( IndexType ) );
+
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( setupDraw( vertexStreamZeroStride, vertexBuffer, vertexOffset, commandBuffer ) );
+	CR_RETURN_HR( setupIndexedDraw( commandBuffer, indexBuffer, indexOffset, sizeof( IndexType ) == 2 ? VK_INDEX_TYPE_UINT16 : VK_INDEX_TYPE_UINT32 ) );
+	vkCmdDrawIndexed( commandBuffer, indexCount, 1, 0, 0, 0 );
+	return S_OK;
+}
+
+}
+
+ALResult Tr2RenderContextAL::DrawIndexedPrimitiveUP(
+	uint32_t numVertices,
+	uint32_t primitiveCount,
+	const uint32_t* indexData,
+	const void* vertexStreamZeroData,
+	uint32_t vertexStreamZeroStride )
+{
+	if( !indexData || !vertexStreamZeroData )
+	{
+		return E_FAIL;
+	}
+	const uint32_t indexCount = GetVertexCountForPrimitives( primitiveCount );
+	if( indexCount == 0 || !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	return DrawIndexedUP<uint32_t>(
+		*this, *m_vulkanContext, numVertices, indexCount, indexData, vertexStreamZeroData, vertexStreamZeroStride,
+		[this]( uint32_t stride, VkBuffer buffer, VkDeviceSize offset, VkCommandBuffer& commandBuffer ) {
+			return SetupDraw( stride, buffer, offset, commandBuffer );
+		},
+		[this]( VkCommandBuffer commandBuffer, VkBuffer buffer, VkDeviceSize offset, VkIndexType indexType ) {
+			return SetupIndexedDraw( commandBuffer, buffer, offset, indexType );
+		} );
+}
