+VkFormat ToVkVertexAttributeFormat( Tr2VertexDefinition::DataType dataType )
+{
+	const unsigned members = Tr2VertexDefinition::GetDataTypeSizeInMembers( dataType );
+	const bool isUnsigned = ( dataType & Tr2VertexDefinition::DT_UNSIGNED_BIT ) != 0;
+	const bool isNormalized = ( dataType & Tr2VertexDefinition::DT_NORMALIZED_BIT ) != 0;
+
+	switch( dataType & Tr2VertexDefinition::DT_TYPE_MASK )
+	{
+	case Tr2VertexDefinition::DT_INT8:
+	{
+		static const VkFormat snorm[] = { VK_FORMAT_R8_SNORM, VK_FORMAT_R8G8_SNORM, VK_FORMAT_R8G8B8_SNORM, VK_FORMAT_R8G8B8A8_SNORM };
+		static const VkFormat unorm[] = { VK_FORMAT_R8_UNORM, VK_FORMAT_R8G8_UNORM, VK_FORMAT_R8G8B8_UNORM, VK_FORMAT_R8G8B8A8_UNORM };
+		static const VkFormat sint[] = { VK_FORMAT_R8_SINT, VK_FORMAT_R8G8_SINT, VK_FORMAT_R8G8B8_SINT, VK_FORMAT_R8G8B8A8_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R8_UINT, VK_FORMAT_R8G8_UINT, VK_FORMAT_R8G8B8_UINT, VK_FORMAT_R8G8B8A8_UINT };
+		return isNormalized ? ( isUnsigned ? unorm[members - 1] : snorm[members - 1] )
+							: ( isUnsigned ? uint[members - 1] : sint[members - 1] );
+	}
+	case Tr2VertexDefinition::DT_INT16:
+	{
+		static const VkFormat snorm[] = { VK_FORMAT_R16_SNORM, VK_FORMAT_R16G16_SNORM, VK_FORMAT_R16G16B16_SNORM, VK_FORMAT_R16G16B16A16_SNORM };
+		static const VkFormat unorm[] = { VK_FORMAT_R16_UNORM, VK_FORMAT_R16G16_UNORM, VK_FORMAT_R16G16B16_UNORM, VK_FORMAT_R16G16B16A16_UNORM };
+		static const VkFormat sint[] = { VK_FORMAT_R16_SINT, VK_FORMAT_R16G16_SINT, VK_FORMAT_R16G16B16_SINT, VK_FORMAT_R16G16B16A16_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R16_UINT, VK_FORMAT_R16G16_UINT, VK_FORMAT_R16G16B16_UINT, VK_FORMAT_R16G16B16A16_UINT };
+		return isNormalized ? ( isUnsigned ? unorm[members - 1] : snorm[members - 1] )
+							: ( isUnsigned ? uint[members - 1] : sint[members - 1] );
+	}
+	case Tr2VertexDefinition::DT_INT32:
+	{
+		static const VkFormat sint[] = { VK_FORMAT_R32_SINT, VK_FORMAT_R32G32_SINT, VK_FORMAT_R32G32B32_SINT, VK_FORMAT_R32G32B32A32_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R32_UINT, VK_FORMAT_R32G32_UINT, VK_FORMAT_R32G32B32_UINT, VK_FORMAT_R32G32B32A32_UINT };
+		return isUnsigned ? uint[members - 1] : sint[members - 1];
+	}
+	case Tr2VertexDefinition::DT_FLOAT16:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R16_SFLOAT, VK_FORMAT_R16G16_SFLOAT, VK_FORMAT_R16G16B16_SFLOAT, VK_FORMAT_R16G16B16A16_SFLOAT };
+		return sfloat[members - 1];
+	}
+	case Tr2VertexDefinition::DT_FLOAT32:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R32_SFLOAT, VK_FORMAT_R32G32_SFLOAT, VK_FORMAT_R32G32B32_SFLOAT, VK_FORMAT_R32G32B32A32_SFLOAT };
+		return sfloat[members - 1];
+	}
+	}
+	return VK_FORMAT_UNDEFINED;
+}
