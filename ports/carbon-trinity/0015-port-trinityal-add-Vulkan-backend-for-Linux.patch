+ALResult Tr2RenderContextAL::DrawInstancedIndirect( Tr2BufferAL& argsBuffer, uint32_t offset )
+{
+	if( !argsBuffer.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	VkCommandBuffer commandBuffer;
+	CR_RETURN_HR( SetupDraw( 0, VK_NULL_HANDLE, 0, commandBuffer ) );
+	// The D3D11 draw-instanced argument layout matches VkDrawIndirectCommand.
+	vkCmdDrawIndirect( commandBuffer, argsBuffer.TrinityALImpl_GetObject()->GetVkBuffer(), offset, 1, 0 );
+	return S_OK;
+}
