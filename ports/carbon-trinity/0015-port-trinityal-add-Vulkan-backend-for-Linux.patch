+}
+
+VkFormat ToVkVertexAttributeFormat( Tr2VertexDefinition::DataType dataType )
+{
+	const unsigned members = Tr2VertexDefinition::GetDataTypeSizeInMembers( dataType );
+	const bool isUnsigned = ( dataType & Tr2VertexDefinition::DT_UNSIGNED_BIT ) != 0;
+	const bool isNormalized = ( dataType & Tr2VertexDefinition::DT_NORMALIZED_BIT ) != 0;
+
+	switch( dataType & Tr2VertexDefinition::DT_TYPE_MASK )
+	{
+	case Tr2VertexDefinition::DT_INT8:
+	{
+		static const VkFormat snorm[] = { VK_FORMAT_R8_SNORM, VK_FORMAT_R8G8_SNORM, VK_FORMAT_R8G8B8_SNORM, VK_FORMAT_R8G8B8A8_SNORM };
+		static const VkFormat unorm[] = { VK_FORMAT_R8_UNORM, VK_FORMAT_R8G8_UNORM, VK_FORMAT_R8G8B8_UNORM, VK_FORMAT_R8G8B8A8_UNORM };
+		static const VkFormat sint[] = { VK_FORMAT_R8_SINT, VK_FORMAT_R8G8_SINT, VK_FORMAT_R8G8B8_SINT, VK_FORMAT_R8G8B8A8_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R8_UINT, VK_FORMAT_R8G8_UINT, VK_FORMAT_R8G8B8_UINT, VK_FORMAT_R8G8B8A8_UINT };
+		return isNormalized ? ( isUnsigned ? unorm[members - 1] : snorm[members - 1] )
+							: ( isUnsigned ? uint[members - 1] : sint[members - 1] );
+	}
+	case Tr2VertexDefinition::DT_INT16:
+	{
+		static const VkFormat snorm[] = { VK_FORMAT_R16_SNORM, VK_FORMAT_R16G16_SNORM, VK_FORMAT_R16G16B16_SNORM, VK_FORMAT_R16G16B16A16_SNORM };
+		static const VkFormat unorm[] = { VK_FORMAT_R16_UNORM, VK_FORMAT_R16G16_UNORM, VK_FORMAT_R16G16B16_UNORM, VK_FORMAT_R16G16B16A16_UNORM };
+		static const VkFormat sint[] = { VK_FORMAT_R16_SINT, VK_FORMAT_R16G16_SINT, VK_FORMAT_R16G16B16_SINT, VK_FORMAT_R16G16B16A16_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R16_UINT, VK_FORMAT_R16G16_UINT, VK_FORMAT_R16G16B16_UINT, VK_FORMAT_R16G16B16A16_UINT };
+		return isNormalized ? ( isUnsigned ? unorm[members - 1] : snorm[members - 1] )
+							: ( isUnsigned ? uint[members - 1] : sint[members - 1] );
+	}
+	case Tr2VertexDefinition::DT_INT32:
+	{
+		static const VkFormat sint[] = { VK_FORMAT_R32_SINT, VK_FORMAT_R32G32_SINT, VK_FORMAT_R32G32B32_SINT, VK_FORMAT_R32G32B32A32_SINT };
+		static const VkFormat uint[] = { VK_FORMAT_R32_UINT, VK_FORMAT_R32G32_UINT, VK_FORMAT_R32G32B32_UINT, VK_FORMAT_R32G32B32A32_UINT };
+		return isUnsigned ? uint[members - 1] : sint[members - 1];
+	}
+	case Tr2VertexDefinition::DT_FLOAT16:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R16_SFLOAT, VK_FORMAT_R16G16_SFLOAT, VK_FORMAT_R16G16B16_SFLOAT, VK_FORMAT_R16G16B16A16_SFLOAT };
+		return sfloat[members - 1];
+	}
+	case Tr2VertexDefinition::DT_FLOAT32:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R32_SFLOAT, VK_FORMAT_R32G32_SFLOAT, VK_FORMAT_R32G32B32_SFLOAT, VK_FORMAT_R32G32B32A32_SFLOAT };
+		return sfloat[members - 1];
+	}
+	}
+	return VK_FORMAT_UNDEFINED;
+}
+
+// Vertex binding used to feed zeros to shader inputs the bound vertex layout
+// does not provide (all streams live in bindings 0..MAX_STREAMS-1).
+const uint32_t DUMMY_VERTEX_BINDING = 15;
+
+VkFormat GetDummyAttributeFormat( Tr2ShaderPipelineInputAL::Type type, uint32_t dimension )
+{
+	const uint32_t index = std::min( std::max( dimension, 1u ), 4u ) - 1;
+	switch( type )
+	{
+	case Tr2ShaderPipelineInputAL::INT:
+	{
+		static const VkFormat sint[] = { VK_FORMAT_R32_SINT, VK_FORMAT_R32G32_SINT, VK_FORMAT_R32G32B32_SINT, VK_FORMAT_R32G32B32A32_SINT };
+		return sint[index];
+	}
+	case Tr2ShaderPipelineInputAL::UINT:
+	{
+		static const VkFormat uint[] = { VK_FORMAT_R32_UINT, VK_FORMAT_R32G32_UINT, VK_FORMAT_R32G32B32_UINT, VK_FORMAT_R32G32B32A32_UINT };
+		return uint[index];
+	}
+	default:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R32_SFLOAT, VK_FORMAT_R32G32_SFLOAT, VK_FORMAT_R32G32B32_SFLOAT, VK_FORMAT_R32G32B32A32_SFLOAT };
+		return sfloat[index];
+	}
+	}
+}
+
+// Render states that participate in the pipeline hash / creation.
+const RenderState PIPELINE_RENDER_STATES[] = {
+	RS_ZENABLE,
+	RS_ZWRITEENABLE,
+	RS_ZFUNC,
+	RS_CULLMODE,
+	RS_FILLMODE,
+	RS_DEPTH_CLIP_ENABLE,
+	RS_DEPTHBIAS,
+	RS_SLOPESCALEDEPTHBIAS,
+	RS_ALPHABLENDENABLE,
+	RS_SRCBLEND,
+	RS_DESTBLEND,
+	RS_BLENDOP,
+	RS_SEPARATEALPHABLENDENABLE,
+	RS_SRCBLENDALPHA,
+	RS_DESTBLENDALPHA,
+	RS_BLENDOPALPHA,
+	RS_COLORWRITEENABLE,
+	RS_COLORWRITEENABLE1,
+	RS_COLORWRITEENABLE2,
+	RS_COLORWRITEENABLE3,
+	RS_STENCILENABLE,
+	RS_STENCILFAIL,
+	RS_STENCILZFAIL,
+	RS_STENCILPASS,
+	RS_STENCILFUNC,
+	RS_STENCILREF,
+	RS_STENCILMASK,
+	RS_STENCILWRITEMASK,
+	RS_TWOSIDEDSTENCILMODE,
+	RS_CCW_STENCILFAIL,
+	RS_CCW_STENCILZFAIL,
+	RS_CCW_STENCILPASS,
+	RS_CCW_STENCILFUNC,
+};
+
+}
+
+
+Tr2RenderContextAL::Tr2RenderContextAL() :
+	m_events( nullptr ),
+	m_readOnlyDepth( false ),
+	m_topology( TOP_INVALID ),
+	m_indexType( VK_INDEX_TYPE_UINT16 )
+{
+	// D3D9-style render state defaults.
+	memset( m_renderStates, 0, sizeof( m_renderStates ) );
+	m_renderStates[RS_ZENABLE] = 1;
+	m_renderStates[RS_ZWRITEENABLE] = 1;
+	m_renderStates[RS_ZFUNC] = CMP_LESSEQUAL;
+	m_renderStates[RS_CULLMODE] = CULLMODE_CCW;
+	m_renderStates[RS_FILLMODE] = FM_SOLID;
+	m_renderStates[RS_DEPTH_CLIP_ENABLE] = 1;
+	m_renderStates[RS_SRCBLEND] = BM_ONE;
+	m_renderStates[RS_DESTBLEND] = BM_ZERO;
+	m_renderStates[RS_BLENDOP] = BO_ADD;
+	m_renderStates[RS_SRCBLENDALPHA] = BM_ONE;
+	m_renderStates[RS_DESTBLENDALPHA] = BM_ZERO;
+	m_renderStates[RS_BLENDOPALPHA] = BO_ADD;
+	m_renderStates[RS_COLORWRITEENABLE] = 0xf;
+	m_renderStates[RS_COLORWRITEENABLE1] = 0xf;
+	m_renderStates[RS_COLORWRITEENABLE2] = 0xf;
+	m_renderStates[RS_COLORWRITEENABLE3] = 0xf;
+	m_renderStates[RS_STENCILFUNC] = CMP_ALWAYS;
+	m_renderStates[RS_STENCILFAIL] = STENCILOP_KEEP;
+	m_renderStates[RS_STENCILZFAIL] = STENCILOP_KEEP;
+	m_renderStates[RS_STENCILPASS] = STENCILOP_KEEP;
+	m_renderStates[RS_STENCILMASK] = 0xff;
+	m_renderStates[RS_STENCILWRITEMASK] = 0xff;
+	m_renderStates[RS_CCW_STENCILFUNC] = CMP_ALWAYS;
+	m_renderStates[RS_CCW_STENCILFAIL] = STENCILOP_KEEP;
+	m_renderStates[RS_CCW_STENCILZFAIL] = STENCILOP_KEEP;
+	m_renderStates[RS_CCW_STENCILPASS] = STENCILOP_KEEP;
+	m_renderStates[RS_BLENDFACTOR] = 0xffffffff;
+	m_renderStates[RS_MULTISAMPLEANTIALIAS] = 1;
+
+	GetPrimaryRenderContextPointerRef() = this;
+}
+
+Tr2RenderContextAL::~Tr2RenderContextAL()
+{
+	Destroy();
+}
+
+void Tr2RenderContextAL::SetPrimaryRenderContext( Tr2PrimaryRenderContextAL* renderContext )
+{
+	GetPrimaryRenderContextPointerRef() = renderContext;
+}
+
+Tr2PrimaryRenderContextAL& Tr2RenderContextAL::GetPrimaryRenderContext()
+{
+	CCP_ASSERT( GetPrimaryRenderContextPointerRef() );
+	return *GetPrimaryRenderContextPointerRef();
+}
+
+Tr2PrimaryRenderContextAL* Tr2RenderContextAL::GetPrimaryRenderContextPointer()
+{
+	return GetPrimaryRenderContextPointerRef();
+}
+
+TrinityALImpl::VulkanContext* Tr2RenderContextAL::GetVulkanContext() const
+{
+	return m_vulkanContext.get();
+}
+
+void Tr2RenderContextAL::Destroy()
+{
+	ReleaseDeviceResources();
+	m_samplerStateFactory.Clear();
+	if( m_vulkanContext )
+	{
+		TrinityALImpl::SetVulkanContext( nullptr );
+		m_vulkanContext.reset();
+	}
+}
+
+ALResult Tr2RenderContextAL::CreateDevice(
+	uint32_t Adapter,
+	Tr2WindowHandle,
+	const Tr2PresentParametersAL& presentationParameters )
+{
+	Destroy();
+
+	m_vulkanContext.reset( new TrinityALImpl::VulkanContext() );
+	ALResult result = m_vulkanContext->Create( Adapter );
+	if( FAILED( result ) )
+	{
+		m_vulkanContext.reset();
+		return result;
+	}
+	TrinityALImpl::SetVulkanContext( m_vulkanContext.get() );
+
+	CR_RETURN_HR( SetPresentParameters( Adapter, presentationParameters ) );
+
+	if( m_events )
+	{
+		m_events->OnContextCreated( *this );
+	}
+
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetPresentParameters( unsigned, const Tr2PresentParametersAL& presentationParameters )
+{
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	PixelFormat backBufferFormat = presentationParameters.mode.format != PIXEL_FORMAT_UNKNOWN
+		? presentationParameters.mode.format
+		: PIXEL_FORMAT_B8G8R8A8_UNORM;
+
+	CR_RETURN_HR( m_defaultBackBuffer.Create(
+		Tr2BitmapDimensions( presentationParameters.mode.width, presentationParameters.mode.height, 1, backBufferFormat ),
+		Tr2GpuUsage::RENDER_TARGET,
+		Tr2CpuUsage::READ,
+		*this ) );
+
+	SetRenderTarget( m_defaultBackBuffer );
+	SetViewport( Tr2Viewport( presentationParameters.mode.width, presentationParameters.mode.height ) );
+
+	return S_OK;
+}
+
+const Tr2CapsAL& Tr2RenderContextAL::GetCaps() const
+{
+	return m_caps;
+}
+
+ALResult Tr2RenderContextAL::BeginScene()
+{
+	return IsValid() ? S_OK : E_INVALIDCALL;
+}
+
+ALResult Tr2RenderContextAL::EndScene()
+{
+	return IsValid() ? S_OK : E_INVALIDCALL;
+}
+
+ALResult Tr2RenderContextAL::Present()
+{
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	return m_vulkanContext->EndFrame();
+}
+
+bool Tr2RenderContextAL::IsValid()
+{
+	return m_vulkanContext && m_vulkanContext->IsValid();
+}
+
+void Tr2RenderContextAL::ReleaseDeviceResources()
+{
+	for( unsigned i = 0; i != MAX_RENDER_TARGET; ++i )
+	{
+		m_boundRenderTarget[i] = Tr2TextureAL();
+		while( !m_stackRT[i].empty() )
+		{
+			m_stackRT[i].pop();
+		}
+	}
+	while( !m_stackDS.empty() )
+	{
+		m_stackDS.pop();
+	}
+	m_boundDepthStencil = Tr2TextureAL();
+	m_defaultBackBuffer = Tr2TextureAL();
+
+	for( auto& stream : m_streams )
+	{
+		stream = StreamSource();
+	}
+	m_indexBuffer = Tr2BufferAL();
+	m_vertexLayout = Tr2VertexLayoutAL();
+	m_shaderProgram = Tr2ShaderProgramAL();
+	m_resourceSet = Tr2ResourceSetAL();
+	for( auto& stageBuffers : m_constantBuffers )
+	{
+		for( auto& constantBuffer : stageBuffers )
+		{
+			constantBuffer = Tr2ConstantBufferAL();
+		}
+	}
+}
+
+// --------------------------------------------------------------------------------------
+// Draw state.
+// --------------------------------------------------------------------------------------
+
+ALResult Tr2RenderContextAL::SetStreamSource( uint32_t stream, const Tr2BufferAL& buffer, uint32_t offset, uint32_t stride ) throw()
+{
+	if( stream >= MAX_STREAMS )
+	{
+		return E_INVALIDARG;
+	}
+	m_streams[stream].buffer = buffer;
+	m_streams[stream].offset = offset;
+	m_streams[stream].stride = stride;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetIndices( const Tr2BufferAL& buffer ) throw()
+{
+	uint32_t stride = buffer.IsValid() ? buffer.GetDesc().stride : 2;
+	return SetIndices( buffer, stride );
+}
+
+ALResult Tr2RenderContextAL::SetIndices( const Tr2BufferAL& buffer, uint32_t stride ) throw()
+{
+	m_indexBuffer = buffer;
+	m_indexType = stride == 2 ? VK_INDEX_TYPE_UINT16 : VK_INDEX_TYPE_UINT32;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetTopology( long topology )
+{
+	if( topology >= TOP_MAX_TOPOLOGY )
+	{
+		return E_FAIL;
+	}
+	m_topology = (Topology)topology;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetShaderProgram( const Tr2ShaderProgramAL& shaderProgram )
+{
+	m_shaderProgram = shaderProgram;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetResourceSet( const Tr2ResourceSetAL& resourceSet )
+{
+	m_resourceSet = resourceSet;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetVertexLayout( const Tr2VertexLayoutAL& layout )
+{
+	m_vertexLayout = layout;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetRenderState( RenderState state, uint32_t value )
+{
+	if( state >= RS_MAX_STATE )
+	{
+		return E_INVALIDARG;
+	}
+	m_renderStates[state] = value;
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetRenderStates( const uint32_t* stateValuePairs, uint32_t count )
+{
+	for( uint32_t i = 0; i < count; ++i )
+	{
+		CR_RETURN_HR( SetRenderState( (RenderState)stateValuePairs[i * 2], stateValuePairs[i * 2 + 1] ) );
+	}
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetConstants( const Tr2ConstantBufferAL& buffer, ShaderType constantType, uint32_t registerIndex, uint32_t )
+{
+	if( constantType < 0 || constantType >= SHADER_TYPE_COUNT || registerIndex >= MAX_CONSTANT_BUFFER_SLOTS )
+	{
+		return E_INVALIDARG;
+	}
+	m_constantBuffers[constantType][registerIndex] = buffer;
+	return S_OK;
+}
+
+// --------------------------------------------------------------------------------------
+// Pipeline and descriptor set construction.
+// --------------------------------------------------------------------------------------
+
+uint32_t Tr2RenderContextAL::GetVertexCountForPrimitives( uint32_t primitiveCount ) const
+{
+	switch( m_topology )
+	{
+	case TOP_TRIANGLES:
+		return primitiveCount * 3;
+	case TOP_TRIANGLE_STRIP:
+	case TOP_TRIANGLE_FAN:
+		return primitiveCount + 2;
+	case TOP_LINES:
+		return primitiveCount * 2;
+	case TOP_LINE_STRIP:
+		return primitiveCount + 1;
+	case TOP_POINTS:
+		return primitiveCount;
+	default:
+		return 0;
+	}
+}
+
+uint64_t Tr2RenderContextAL::ComputeGraphicsPipelineHash( uint32_t stream0StrideOverride ) const
+{
+	uint64_t hash = HashFnv1a64( "graphics", 8 );
+
+	TrinityALImpl::Tr2ShaderProgramAL* programImpl = m_shaderProgram.TrinityALImpl_GetObject();
+	const uint64_t programId = programImpl ? programImpl->GetUniqueId() : 0;
+	hash = HashFnv1a64( &programId, sizeof( programId ), hash );
+	const TrinityALImpl::Tr2VertexLayoutAL* layoutImpl = m_vertexLayout.m_layout.get();
+	const uint64_t layoutId = layoutImpl ? layoutImpl->GetUniqueId() : 0;
+	hash = HashFnv1a64( &layoutId, sizeof( layoutId ), hash );
+	hash = HashFnv1a64( &m_topology, sizeof( m_topology ), hash );
+	hash = HashFnv1a64( &stream0StrideOverride, sizeof( stream0StrideOverride ), hash );
+
+	for( const auto& stream : m_streams )
+	{
+		hash = HashFnv1a64( &stream.stride, sizeof( stream.stride ), hash );
+	}
+	for( RenderState state : PIPELINE_RENDER_STATES )
+	{
+		hash = HashFnv1a64( &m_renderStates[state], sizeof( uint32_t ), hash );
+	}
+	for( const auto& renderTarget : m_boundRenderTarget )
+	{
+		VkFormat format = renderTarget.IsValid() ? GetTextureImpl( renderTarget )->GetVkFormat() : VK_FORMAT_UNDEFINED;
+		hash = HashFnv1a64( &format, sizeof( format ), hash );
+		uint32_t samples = renderTarget.IsValid() ? renderTarget.GetMsaaDesc().samples : 0;
+		hash = HashFnv1a64( &samples, sizeof( samples ), hash );
+	}
+	VkFormat dsFormat = m_boundDepthStencil.IsValid() ? GetTextureImpl( m_boundDepthStencil )->GetVkFormat() : VK_FORMAT_UNDEFINED;
+	hash = HashFnv1a64( &dsFormat, sizeof( dsFormat ), hash );
+	return hash;
+}
+
+ALResult Tr2RenderContextAL::GetOrCreateGraphicsPipeline( uint32_t stream0StrideOverride, VkPipeline& pipeline )
+{
+	const uint64_t hash = ComputeGraphicsPipelineHash( stream0StrideOverride );
+	pipeline = m_vulkanContext->GetCachedPipeline( hash );
+	if( pipeline != VK_NULL_HANDLE )
+	{
+		return S_OK;
+	}
+
+	if( !m_vulkanContext->SupportsDynamicRendering() )
+	{
+		return E_FAIL;
+	}
+
+	TrinityALImpl::Tr2ShaderProgramAL* program = m_shaderProgram.TrinityALImpl_GetObject();
+	auto vertexShader = program->GetShader( VERTEX_SHADER );
+	auto pixelShader = program->GetShader( PIXEL_SHADER );
+	if( !vertexShader || vertexShader->GetVkShaderModule() == VK_NULL_HANDLE )
+	{
+		CCP_AL_LOGERR( "Cannot create pipeline: vertex shader has no SPIR-V module" );
+		return E_INVALIDCALL;
+	}
+
+	std::vector<VkPipelineShaderStageCreateInfo> stages;
+	{
+		VkPipelineShaderStageCreateInfo stage = {};
+		stage.sType = VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO;
+		stage.stage = VK_SHADER_STAGE_VERTEX_BIT;
+		stage.module = vertexShader->GetVkShaderModule();
+		stage.pName = "main";
+		stages.push_back( stage );
+	}
+	if( pixelShader )
+	{
+		if( pixelShader->GetVkShaderModule() == VK_NULL_HANDLE )
+		{
+			CCP_AL_LOGERR( "Cannot create pipeline: pixel shader has no SPIR-V module" );
+			return E_INVALIDCALL;
+		}
+		VkPipelineShaderStageCreateInfo stage = {};
+		stage.sType = VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO;
+		stage.stage = VK_SHADER_STAGE_FRAGMENT_BIT;
+		stage.module = pixelShader->GetVkShaderModule();
+		stage.pName = "main";
+		stages.push_back( stage );
+	}
+
+	// Vertex input: match the shader's declared inputs against the bound
+	// vertex definition by (usage, usageIndex). The shader signature's
+	// registerIndex is the SPIR-V input location (dxc assigns locations in
+	// declaration order).
+	std::vector<VkVertexInputAttributeDescription> attributes;
+	std::vector<VkVertexInputBindingDescription> bindings;
+	const TrinityALImpl::Tr2VertexLayoutAL* layout = m_vertexLayout.m_layout.get();
+	const Tr2VertexDefinition* definition = layout ? layout->GetDefinition() : nullptr;
+
+	for( const Tr2ShaderPipelineInputAL& input : vertexShader->GetSignature().pipelineInputs )
+	{
+		const Tr2VertexDefinition::Item* item = nullptr;
+		if( definition )
+		{
+			for( const auto& candidate : definition->m_items )
+			{
+				if( candidate.m_usage == input.usage && candidate.m_usageIndex == input.usageIndex )
+				{
+					item = &candidate;
+					break;
+				}
+			}
+		}
+		VkVertexInputAttributeDescription attribute = {};
+		attribute.location = input.registerIndex;
+		uint32_t bindingIndex;
+		if( item )
+		{
+			bindingIndex = item->m_stream;
+			attribute.format = ToVkVertexAttributeFormat( item->m_dataType );
+			attribute.offset = item->m_offset;
+		}
+		else
+		{
+			// The layout does not provide this input; feed constant zeros
+			// from the dummy buffer through a zero-stride binding.
+			bindingIndex = DUMMY_VERTEX_BINDING;
+			attribute.format = GetDummyAttributeFormat( input.type, input.dimension );
+			attribute.offset = 0;
+		}
+		attribute.binding = bindingIndex;
+		attributes.push_back( attribute );
+
+		bool haveBinding = false;
+		for( const auto& binding : bindings )
+		{
+			if( binding.binding == bindingIndex )
+			{
+				haveBinding = true;
+				break;
+			}
+		}
+		if( !haveBinding )
+		{
+			VkVertexInputBindingDescription binding = {};
+			binding.binding = bindingIndex;
+			if( item )
+			{
+				binding.stride = ( item->m_stream == 0 && stream0StrideOverride != 0 )
+					? stream0StrideOverride
+					: m_streams[item->m_stream].stride;
+				binding.inputRate = item->m_instanceStepRate > 0 ? VK_VERTEX_INPUT_RATE_INSTANCE : VK_VERTEX_INPUT_RATE_VERTEX;
+			}
+			else
+			{
+				binding.stride = 0;
+				binding.inputRate = VK_VERTEX_INPUT_RATE_VERTEX;
+			}
+			bindings.push_back( binding );
+		}
+	}
+
+	VkPipelineVertexInputStateCreateInfo vertexInput = {};
+	vertexInput.sType = VK_STRUCTURE_TYPE_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO;
+	vertexInput.vertexBindingDescriptionCount = (uint32_t)bindings.size();
+	vertexInput.pVertexBindingDescriptions = bindings.data();
+	vertexInput.vertexAttributeDescriptionCount = (uint32_t)attributes.size();
+	vertexInput.pVertexAttributeDescriptions = attributes.data();
+
+	VkPipelineInputAssemblyStateCreateInfo inputAssembly = {};
+	inputAssembly.sType = VK_STRUCTURE_TYPE_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO;
+	inputAssembly.topology = ToVkPrimitiveTopology( m_topology );
+	if( inputAssembly.topology == VK_PRIMITIVE_TOPOLOGY_MAX_ENUM )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VkPipelineViewportStateCreateInfo viewportState = {};
+	viewportState.sType = VK_STRUCTURE_TYPE_PIPELINE_VIEWPORT_STATE_CREATE_INFO;
+	viewportState.viewportCount = 1;
+	viewportState.scissorCount = 1;
+
+	VkPipelineRasterizationStateCreateInfo rasterization = {};
+	rasterization.sType = VK_STRUCTURE_TYPE_PIPELINE_RASTERIZATION_STATE_CREATE_INFO;
+	rasterization.depthClampEnable = m_renderStates[RS_DEPTH_CLIP_ENABLE] ? VK_FALSE : VK_TRUE;
+	rasterization.polygonMode = VK_POLYGON_MODE_FILL;
+	if( m_renderStates[RS_FILLMODE] == FM_WIREFRAME && m_vulkanContext->GetDeviceFeatures().fillModeNonSolid )
+	{
+		rasterization.polygonMode = VK_POLYGON_MODE_LINE;
+	}
+	else if( m_renderStates[RS_FILLMODE] == FM_POINT && m_vulkanContext->GetDeviceFeatures().fillModeNonSolid )
+	{
+		rasterization.polygonMode = VK_POLYGON_MODE_POINT;
+	}
+	// Direct3D convention: clockwise-wound triangles are front faces. The
+	// negative-height viewport keeps the winding consistent with D3D.
+	rasterization.frontFace = VK_FRONT_FACE_CLOCKWISE;
+	switch( m_renderStates[RS_CULLMODE] )
+	{
+	case CULLMODE_CW:
+		rasterization.cullMode = VK_CULL_MODE_FRONT_BIT;
+		break;
+	case CULLMODE_CCW:
+		rasterization.cullMode = VK_CULL_MODE_BACK_BIT;
+		break;
+	default:
+		rasterization.cullMode = VK_CULL_MODE_NONE;
+		break;
+	}
+	float depthBias;
+	memcpy( &depthBias, &m_renderStates[RS_DEPTHBIAS], sizeof( depthBias ) );
+	float slopeScaledBias;
+	memcpy( &slopeScaledBias, &m_renderStates[RS_SLOPESCALEDEPTHBIAS], sizeof( slopeScaledBias ) );
+	if( depthBias != 0.0f || slopeScaledBias != 0.0f )
+	{
+		rasterization.depthBiasEnable = VK_TRUE;
+		// D3D-style bias values are normalized to the depth format; scale to
+		// the equivalent constant factor used by Vulkan.
+		rasterization.depthBiasConstantFactor = depthBias * (float)( 1 << 24 );
+		rasterization.depthBiasSlopeFactor = slopeScaledBias;
+	}
+	rasterization.lineWidth = 1.0f;
+
+	uint32_t sampleCount = 1;
+	if( m_boundRenderTarget[0].IsValid() )
+	{
+		sampleCount = std::max( m_boundRenderTarget[0].GetMsaaDesc().samples, 1u );
+	}
+	else if( m_boundDepthStencil.IsValid() )
+	{
+		sampleCount = std::max( m_boundDepthStencil.GetMsaaDesc().samples, 1u );
+	}
+	VkPipelineMultisampleStateCreateInfo multisample = {};
+	multisample.sType = VK_STRUCTURE_TYPE_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO;
+	multisample.rasterizationSamples = (VkSampleCountFlagBits)sampleCount;
+
+	VkPipelineDepthStencilStateCreateInfo depthStencil = {};
+	depthStencil.sType = VK_STRUCTURE_TYPE_PIPELINE_DEPTH_STENCIL_STATE_CREATE_INFO;
+	if( m_boundDepthStencil.IsValid() )
+	{
+		depthStencil.depthTestEnable = m_renderStates[RS_ZENABLE] ? VK_TRUE : VK_FALSE;
+		depthStencil.depthWriteEnable = ( m_renderStates[RS_ZWRITEENABLE] && !m_readOnlyDepth ) ? VK_TRUE : VK_FALSE;
+		depthStencil.depthCompareOp = ToVkCompareOp( (CompareFunc)m_renderStates[RS_ZFUNC] );
+		depthStencil.stencilTestEnable = m_renderStates[RS_STENCILENABLE] ? VK_TRUE : VK_FALSE;
+
+		VkStencilOpState front = {};
+		front.failOp = ToVkStencilOp( m_renderStates[RS_STENCILFAIL] );
+		front.depthFailOp = ToVkStencilOp( m_renderStates[RS_STENCILZFAIL] );
+		front.passOp = ToVkStencilOp( m_renderStates[RS_STENCILPASS] );
+		front.compareOp = ToVkCompareOp( (CompareFunc)m_renderStates[RS_STENCILFUNC] );
+		front.compareMask = m_renderStates[RS_STENCILMASK];
+		front.writeMask = m_renderStates[RS_STENCILWRITEMASK];
+		front.reference = m_renderStates[RS_STENCILREF];
+		depthStencil.front = front;
+		if( m_renderStates[RS_TWOSIDEDSTENCILMODE] )
+		{
+			VkStencilOpState back = front;
+			back.failOp = ToVkStencilOp( m_renderStates[RS_CCW_STENCILFAIL] );
+			back.depthFailOp = ToVkStencilOp( m_renderStates[RS_CCW_STENCILZFAIL] );
+			back.passOp = ToVkStencilOp( m_renderStates[RS_CCW_STENCILPASS] );
+			back.compareOp = ToVkCompareOp( (CompareFunc)m_renderStates[RS_CCW_STENCILFUNC] );
+			depthStencil.back = back;
+		}
+		else
+		{
+			depthStencil.back = front;
+		}
+	}
+
+	// Color attachments and blending.
+	std::vector<VkFormat> colorFormats;
+	std::vector<VkPipelineColorBlendAttachmentState> blendStates;
+	for( uint32_t slot = 0; slot < MAX_RENDER_TARGET; ++slot )
+	{
+		if( !m_boundRenderTarget[slot].IsValid() )
+		{
+			break;
+		}
+		colorFormats.push_back( GetTextureImpl( m_boundRenderTarget[slot] )->GetVkFormat() );
+
+		VkPipelineColorBlendAttachmentState blendState = {};
+		blendState.blendEnable = m_renderStates[RS_ALPHABLENDENABLE] ? VK_TRUE : VK_FALSE;
+		blendState.srcColorBlendFactor = ToVkBlendFactor( m_renderStates[RS_SRCBLEND] );
+		blendState.dstColorBlendFactor = ToVkBlendFactor( m_renderStates[RS_DESTBLEND] );
+		blendState.colorBlendOp = ToVkBlendOp( m_renderStates[RS_BLENDOP] );
+		if( m_renderStates[RS_SEPARATEALPHABLENDENABLE] )
+		{
+			blendState.srcAlphaBlendFactor = ToVkBlendFactor( m_renderStates[RS_SRCBLENDALPHA] );
+			blendState.dstAlphaBlendFactor = ToVkBlendFactor( m_renderStates[RS_DESTBLENDALPHA] );
+			blendState.alphaBlendOp = ToVkBlendOp( m_renderStates[RS_BLENDOPALPHA] );
+		}
+		else
+		{
+			blendState.srcAlphaBlendFactor = blendState.srcColorBlendFactor;
+			blendState.dstAlphaBlendFactor = blendState.dstColorBlendFactor;
+			blendState.alphaBlendOp = blendState.colorBlendOp;
+		}
+		const RenderState writeEnableStates[] = { RS_COLORWRITEENABLE, RS_COLORWRITEENABLE1, RS_COLORWRITEENABLE2, RS_COLORWRITEENABLE3 };
+		uint32_t writeEnable = slot < 4 ? m_renderStates[writeEnableStates[slot]] : m_renderStates[RS_COLORWRITEENABLE];
+		blendState.colorWriteMask = 0;
+		if( writeEnable & COLORWRITEENABLE_RED )
+		{
+			blendState.colorWriteMask |= VK_COLOR_COMPONENT_R_BIT;
+		}
+		if( writeEnable & COLORWRITEENABLE_GREEN )
+		{
+			blendState.colorWriteMask |= VK_COLOR_COMPONENT_G_BIT;
+		}
+		if( writeEnable & COLORWRITEENABLE_BLUE )
+		{
+			blendState.colorWriteMask |= VK_COLOR_COMPONENT_B_BIT;
+		}
+		if( writeEnable & COLORWRITEENABLE_ALPHA )
+		{
+			blendState.colorWriteMask |= VK_COLOR_COMPONENT_A_BIT;
+		}
+		blendStates.push_back( blendState );
+	}
+
+	VkPipelineColorBlendStateCreateInfo colorBlend = {};
+	colorBlend.sType = VK_STRUCTURE_TYPE_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO;
+	colorBlend.attachmentCount = (uint32_t)blendStates.size();
+	colorBlend.pAttachments = blendStates.data();
+
+	const VkDynamicState dynamicStates[] = {
+		VK_DYNAMIC_STATE_VIEWPORT,
+		VK_DYNAMIC_STATE_SCISSOR,
+		VK_DYNAMIC_STATE_BLEND_CONSTANTS,
+	};
+	VkPipelineDynamicStateCreateInfo dynamicState = {};
+	dynamicState.sType = VK_STRUCTURE_TYPE_PIPELINE_DYNAMIC_STATE_CREATE_INFO;
+	dynamicState.dynamicStateCount = (uint32_t)( sizeof( dynamicStates ) / sizeof( dynamicStates[0] ) );
+	dynamicState.pDynamicStates = dynamicStates;
+
+	VkPipelineRenderingCreateInfo renderingCreateInfo = {};
+	renderingCreateInfo.sType = VK_STRUCTURE_TYPE_PIPELINE_RENDERING_CREATE_INFO;
+	renderingCreateInfo.colorAttachmentCount = (uint32_t)colorFormats.size();
+	renderingCreateInfo.pColorAttachmentFormats = colorFormats.data();
+	if( m_boundDepthStencil.IsValid() )
+	{
+		VkFormat dsFormat = GetTextureImpl( m_boundDepthStencil )->GetVkFormat();
+		renderingCreateInfo.depthAttachmentFormat = dsFormat;
+		if( TrinityALImpl::HasStencil( dsFormat ) )
+		{
+			renderingCreateInfo.stencilAttachmentFormat = dsFormat;
+		}
+	}
+
+	VkGraphicsPipelineCreateInfo pipelineCreateInfo = {};
+	pipelineCreateInfo.sType = VK_STRUCTURE_TYPE_GRAPHICS_PIPELINE_CREATE_INFO;
+	pipelineCreateInfo.pNext = &renderingCreateInfo;
+	pipelineCreateInfo.stageCount = (uint32_t)stages.size();
+	pipelineCreateInfo.pStages = stages.data();
+	pipelineCreateInfo.pVertexInputState = &vertexInput;
+	pipelineCreateInfo.pInputAssemblyState = &inputAssembly;
+	pipelineCreateInfo.pViewportState = &viewportState;
+	pipelineCreateInfo.pRasterizationState = &rasterization;
+	pipelineCreateInfo.pMultisampleState = &multisample;
+	pipelineCreateInfo.pDepthStencilState = &depthStencil;
+	pipelineCreateInfo.pColorBlendState = &colorBlend;
+	pipelineCreateInfo.pDynamicState = &dynamicState;
+	pipelineCreateInfo.layout = program->GetPipelineLayout();
+
+	VkPipeline newPipeline = VK_NULL_HANDLE;
+	VK_CR_RETURN_HR( vkCreateGraphicsPipelines( m_vulkanContext->GetDevice(), VK_NULL_HANDLE, 1, &pipelineCreateInfo, nullptr, &newPipeline ) );
+	pipeline = m_vulkanContext->AddPipelineToCache( hash, newPipeline );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::BuildDescriptorSet( TrinityALImpl::Tr2ShaderProgramAL& program, VkDescriptorSet& descriptorSet )
+{
+	descriptorSet = m_vulkanContext->AllocateDescriptorSet( program.GetDescriptorSetLayout() );
+	if( descriptorSet == VK_NULL_HANDLE )
+	{
+		return E_OUTOFMEMORY;
+	}
+
+	const auto& bindings = program.GetBindings();
+	if( bindings.empty() )
+	{
+		return S_OK;
+	}
+
+	TrinityALImpl::Tr2ResourceSetAL* resourceSet = m_resourceSet.IsValid() ? m_resourceSet.m_resourceSet.get() : nullptr;
+
+	// deques keep the info pointers stable while the write list grows.
+	std::deque<VkDescriptorBufferInfo> bufferInfos;
+	std::deque<VkDescriptorImageInfo> imageInfos;
+	std::deque<VkBufferView> bufferViews;
+	std::vector<VkWriteDescriptorSet> writes;
+
+	for( const auto& binding : bindings )
+	{
+		if( binding.isStaticSampler )
+		{
+			continue; // immutable in the layout
+		}
+
+		VkWriteDescriptorSet write = {};
+		write.sType = VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET;
+		write.dstSet = descriptorSet;
+		write.dstBinding = binding.binding;
+		write.descriptorCount = 1;
+		write.descriptorType = binding.descriptorType;
+
+		switch( binding.descriptorType )
+		{
+		case VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER:
+		{
+			VkDescriptorBufferInfo info = {};
+			TrinityALImpl::Tr2ConstantBufferAL* impl = binding.registerIndex < MAX_CONSTANT_BUFFER_SLOTS
+				? m_constantBuffers[binding.stage][binding.registerIndex].TrinityALImpl_GetObject()
+				: nullptr;
+			if( impl && impl->IsValid() && impl->IsOneShot() )
+			{
+				// Snapshot the CPU mirror so this draw sees the contents as
+				// they are right now, regardless of later Locks.
+				const VkDeviceSize alignment = std::max<VkDeviceSize>(
+					m_vulkanContext->GetDeviceProperties().limits.minUniformBufferOffsetAlignment, 16 );
+				void* snapshot = nullptr;
+				CR_RETURN_HR( m_vulkanContext->AllocateTransientData( impl->GetSize(), alignment, info.buffer, info.offset, snapshot ) );
+				memcpy( snapshot, impl->GetMirrorData(), impl->GetSize() );
+				info.range = impl->GetSize();
+			}
+			else if( impl && impl->IsValid() )
+			{
+				info.buffer = impl->GetVkBuffer();
+				info.range = impl->GetSize();
+			}
+			else
+			{
+				info.buffer = m_vulkanContext->GetDummyUniformBuffer();
+				info.range = VK_WHOLE_SIZE;
+			}
+			bufferInfos.push_back( info );
+			write.pBufferInfo = &bufferInfos.back();
+			break;
+		}
+		case VK_DESCRIPTOR_TYPE_SAMPLER:
+		{
+			VkDescriptorImageInfo info = {};
+			::Tr2SamplerStateAL sampler;
+			if( resourceSet && resourceSet->GetSampler( binding.stage, binding.registerIndex, sampler ) && sampler.IsValid() )
+			{
+				info.sampler = sampler.TrinityALImpl_GetObject()->GetVkSampler();
+			}
+			else
+			{
+				info.sampler = m_vulkanContext->GetDummySampler();
+			}
+			imageInfos.push_back( info );
+			write.pImageInfo = &imageInfos.back();
+			break;
+		}
+		case VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE:
+		{
+			VkDescriptorImageInfo info = {};
+			info.imageLayout = VK_IMAGE_LAYOUT_GENERAL;
+			::Tr2TextureAL texture;
+			if( resourceSet && resourceSet->GetSrvTexture( binding.stage, binding.registerIndex, texture ) && texture.IsValid() )
+			{
+				info.imageView = GetTextureImpl( texture )->GetVkImageView();
+			}
+			else
+			{
+				VkImageViewType viewType = VK_IMAGE_VIEW_TYPE_2D;
+				if( binding.registerType == Tr2ShaderRegisterAL::SRV_TEXTURE3D )
+				{
+					viewType = VK_IMAGE_VIEW_TYPE_3D;
+				}
+				else if( binding.registerType == Tr2ShaderRegisterAL::SRV_TEXTURECUBE || binding.registerType == Tr2ShaderRegisterAL::SRV_TEXTURECUBEARRAY )
+				{
+					viewType = VK_IMAGE_VIEW_TYPE_CUBE;
+				}
+				else if( binding.registerType == Tr2ShaderRegisterAL::SRV_TEXTURE2DARRAY || binding.registerType == Tr2ShaderRegisterAL::SRV_TEXTURE2DMSARRAY )
+				{
+					viewType = VK_IMAGE_VIEW_TYPE_2D_ARRAY;
+				}
+				info.imageView = m_vulkanContext->GetDummyImageView( viewType );
+			}
+			imageInfos.push_back( info );
+			write.pImageInfo = &imageInfos.back();
+			break;
+		}
+		case VK_DESCRIPTOR_TYPE_STORAGE_IMAGE:
+		{
+			VkDescriptorImageInfo info = {};
+			info.imageLayout = VK_IMAGE_LAYOUT_GENERAL;
+			::Tr2TextureAL texture;
+			uint32_t mip = 0;
+			if( resourceSet && resourceSet->GetUavTexture( binding.stage, binding.registerIndex, texture, mip ) && texture.IsValid() )
+			{
+				info.imageView = GetTextureImpl( texture )->GetVkStorageView( mip );
+			}
+			else
+			{
+				info.imageView = m_vulkanContext->GetDummyImageView(
+					binding.registerType == Tr2ShaderRegisterAL::UAV_TEXTURE3D ? VK_IMAGE_VIEW_TYPE_3D : VK_IMAGE_VIEW_TYPE_2D );
+			}
+			imageInfos.push_back( info );
+			write.pImageInfo = &imageInfos.back();
+			break;
+		}
+		case VK_DESCRIPTOR_TYPE_STORAGE_BUFFER:
+		{
+			VkDescriptorBufferInfo info = {};
+			::Tr2BufferAL buffer;
+			bool found = false;
+			if( resourceSet )
+			{
+				found = ( binding.registerType == Tr2ShaderRegisterAL::SRV_STRUCTURED_BUFFER )
+					? resourceSet->GetSrvBuffer( binding.stage, binding.registerIndex, buffer )
+					: resourceSet->GetUavBuffer( binding.stage, binding.registerIndex, buffer );
+			}
+			if( found && buffer.IsValid() )
+			{
+				info.buffer = buffer.TrinityALImpl_GetObject()->GetVkBuffer();
+				info.range = VK_WHOLE_SIZE;
+			}
+			else
+			{
+				info.buffer = m_vulkanContext->GetDummyStorageBuffer();
+				info.range = VK_WHOLE_SIZE;
+			}
+			bufferInfos.push_back( info );
+			write.pBufferInfo = &bufferInfos.back();
+			break;
+		}
+		case VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER:
+		case VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER:
+		{
+			VkBufferView view = VK_NULL_HANDLE;
+			::Tr2BufferAL buffer;
+			bool found = false;
+			if( resourceSet )
+			{
+				found = ( binding.descriptorType == VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER )
+					? resourceSet->GetSrvBuffer( binding.stage, binding.registerIndex, buffer )
+					: resourceSet->GetUavBuffer( binding.stage, binding.registerIndex, buffer );
+			}
+			if( found && buffer.IsValid() )
+			{
+				view = buffer.TrinityALImpl_GetObject()->GetVkBufferView();
+			}
+			if( view == VK_NULL_HANDLE )
+			{
+				view = binding.descriptorType == VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER
+					? m_vulkanContext->GetDummyUniformTexelBufferView()
+					: m_vulkanContext->GetDummyStorageTexelBufferView();
+			}
+			bufferViews.push_back( view );
+			write.pTexelBufferView = &bufferViews.back();
+			break;
+		}
+		default:
+			continue;
+		}
+
+		writes.push_back( write );
+	}
+
+	if( !writes.empty() )
+	{
+		vkUpdateDescriptorSets( m_vulkanContext->GetDevice(), (uint32_t)writes.size(), writes.data(), 0, nullptr );
+	}
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetupDraw( uint32_t stream0StrideOverride, VkBuffer stream0Override, VkDeviceSize stream0Offset, VkCommandBuffer& commandBuffer )
+{
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !m_shaderProgram.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !m_boundRenderTarget[0].IsValid() && !m_boundDepthStencil.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	TrinityALImpl::Tr2ShaderProgramAL* program = m_shaderProgram.TrinityALImpl_GetObject();
+
+	VkPipeline pipeline = VK_NULL_HANDLE;
+	CR_RETURN_HR( GetOrCreateGraphicsPipeline( stream0StrideOverride, pipeline ) );
+
+	VkDescriptorSet descriptorSet = VK_NULL_HANDLE;
+	CR_RETURN_HR( BuildDescriptorSet( *program, descriptorSet ) );
+
+	// Assemble the dynamic rendering info for the currently bound targets.
+	VkRenderingAttachmentInfo colorAttachments[MAX_RENDER_TARGET] = {};
+	uint32_t colorCount = 0;
+	uint64_t targetsHash = HashFnv1a64( "targets", 7 );
+	uint32_t width = 0;
+	uint32_t height = 0;
+	for( uint32_t slot = 0; slot < MAX_RENDER_TARGET; ++slot )
+	{
+		if( !m_boundRenderTarget[slot].IsValid() )
+		{
+			break;
+		}
+		TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( m_boundRenderTarget[slot] );
+		VkRenderingAttachmentInfo& attachment = colorAttachments[colorCount++];
+		attachment.sType = VK_STRUCTURE_TYPE_RENDERING_ATTACHMENT_INFO;
+		attachment.imageView = impl->GetVkImageView();
+		attachment.imageLayout = VK_IMAGE_LAYOUT_GENERAL;
+		attachment.loadOp = VK_ATTACHMENT_LOAD_OP_LOAD;
+		attachment.storeOp = VK_ATTACHMENT_STORE_OP_STORE;
+		VkImageView view = attachment.imageView;
+		targetsHash = HashFnv1a64( &view, sizeof( view ), targetsHash );
+		width = impl->GetDesc().GetWidth();
+		height = impl->GetDesc().GetHeight();
+	}
+
+	VkRenderingAttachmentInfo depthAttachment = {};
+	VkRenderingAttachmentInfo stencilAttachment = {};
+	VkRenderingInfo renderingInfo = {};
+	renderingInfo.sType = VK_STRUCTURE_TYPE_RENDERING_INFO;
+	renderingInfo.layerCount = 1;
+	renderingInfo.colorAttachmentCount = colorCount;
+	renderingInfo.pColorAttachments = colorAttachments;
+	if( m_boundDepthStencil.IsValid() )
+	{
+		TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( m_boundDepthStencil );
+		depthAttachment.sType = VK_STRUCTURE_TYPE_RENDERING_ATTACHMENT_INFO;
+		depthAttachment.imageView = impl->GetVkImageView();
+		depthAttachment.imageLayout = VK_IMAGE_LAYOUT_GENERAL;
+		depthAttachment.loadOp = VK_ATTACHMENT_LOAD_OP_LOAD;
+		depthAttachment.storeOp = VK_ATTACHMENT_STORE_OP_STORE;
+		renderingInfo.pDepthAttachment = &depthAttachment;
+		if( TrinityALImpl::HasStencil( impl->GetVkFormat() ) )
+		{
+			stencilAttachment = depthAttachment;
+			renderingInfo.pStencilAttachment = &stencilAttachment;
+		}
+		VkImageView view = depthAttachment.imageView;
+		targetsHash = HashFnv1a64( &view, sizeof( view ), targetsHash );
+		if( width == 0 )
+		{
+			width = impl->GetDesc().GetWidth();
+			height = impl->GetDesc().GetHeight();
+		}
+	}
+	renderingInfo.renderArea.extent = { width, height };
+
+	commandBuffer = m_vulkanContext->BeginRenderingScope( renderingInfo, targetsHash );
+
+	vkCmdBindPipeline( commandBuffer, VK_PIPELINE_BIND_POINT_GRAPHICS, pipeline );
+	vkCmdBindDescriptorSets( commandBuffer, VK_PIPELINE_BIND_POINT_GRAPHICS, program->GetPipelineLayout(), VulkanBindingModel::DESCRIPTOR_SET, 1, &descriptorSet, 0, nullptr );
+
+	// Flipped viewport to match the Direct3D coordinate system.
+	VkViewport viewport = {};
+	viewport.x = m_viewport.m_x;
+	viewport.y = m_viewport.m_y + m_viewport.m_height;
+	viewport.width = m_viewport.m_width;
+	viewport.height = -m_viewport.m_height;
+	viewport.minDepth = m_viewport.m_minZ;
+	viewport.maxDepth = m_viewport.m_maxZ;
+	vkCmdSetViewport( commandBuffer, 0, 1, &viewport );
+
+	VkRect2D scissor = {};
+	scissor.offset.x = (int32_t)m_viewport.m_x;
+	scissor.offset.y = (int32_t)m_viewport.m_y;
+	scissor.extent.width = (uint32_t)m_viewport.m_width;
+	scissor.extent.height = (uint32_t)m_viewport.m_height;
+	vkCmdSetScissor( commandBuffer, 0, 1, &scissor );
+
+	const uint32_t blendFactor = m_renderStates[RS_BLENDFACTOR];
+	const float blendConstants[4] = {
+		( ( blendFactor >> 16 ) & 0xff ) / 255.0f,
+		( ( blendFactor >> 8 ) & 0xff ) / 255.0f,
+		( blendFactor & 0xff ) / 255.0f,
+		( ( blendFactor >> 24 ) & 0xff ) / 255.0f,
+	};
+	vkCmdSetBlendConstants( commandBuffer, blendConstants );
+
+	// Bind the vertex streams the layout uses, and the dummy binding when the
+	// shader declares inputs the layout does not provide.
+	auto vertexShader = program->GetShader( VERTEX_SHADER );
+	const TrinityALImpl::Tr2VertexLayoutAL* layout = m_vertexLayout.m_layout.get();
+	const Tr2VertexDefinition* definition = layout ? layout->GetDefinition() : nullptr;
+	if( vertexShader )
+	{
+		uint32_t boundStreams = 0;
+		bool needsDummyBinding = false;
+		for( const Tr2ShaderPipelineInputAL& input : vertexShader->GetSignature().pipelineInputs )
+		{
+			const Tr2VertexDefinition::Item* item = nullptr;
+			if( definition )
+			{
+				for( const auto& candidate : definition->m_items )
+				{
+					if( candidate.m_usage == input.usage && candidate.m_usageIndex == input.usageIndex )
+					{
+						item = &candidate;
+						break;
+					}
+				}
+			}
+			if( !item )
+			{
+				needsDummyBinding = true;
+				continue;
+			}
+			if( item->m_stream >= MAX_STREAMS || ( boundStreams & ( 1u << item->m_stream ) ) )
+			{
+				continue;
+			}
+			boundStreams |= 1u << item->m_stream;
+
+			VkBuffer vertexBuffer = VK_NULL_HANDLE;
+			VkDeviceSize offset = 0;
+			if( item->m_stream == 0 && stream0Override != VK_NULL_HANDLE )
+			{
+				vertexBuffer = stream0Override;
+				offset = stream0Offset;
+			}
+			else if( m_streams[item->m_stream].buffer.IsValid() )
+			{
+				vertexBuffer = m_streams[item->m_stream].buffer.TrinityALImpl_GetObject()->GetVkBuffer();
+				offset = m_streams[item->m_stream].offset;
+			}
+			if( vertexBuffer != VK_NULL_HANDLE )
+			{
+				vkCmdBindVertexBuffers( commandBuffer, item->m_stream, 1, &vertexBuffer, &offset );
+			}
+		}
+		if( needsDummyBinding )
+		{
+			VkBuffer dummyBuffer = m_vulkanContext->GetDummyUniformBuffer();
+			VkDeviceSize offset = 0;
+			vkCmdBindVertexBuffers( commandBuffer, DUMMY_VERTEX_BINDING, 1, &dummyBuffer, &offset );
+		}
+	}
+
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::SetupIndexedDraw( VkCommandBuffer commandBuffer, VkBuffer indexOverride, VkDeviceSize indexOffset, VkIndexType indexTypeOverride )
+{
+	if( indexOverride != VK_NULL_HANDLE )
+	{
+		vkCmdBindIndexBuffer( commandBuffer, indexOverride, indexOffset, indexTypeOverride );
+		return S_OK;
+	}
+	if( !m_indexBuffer.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	vkCmdBindIndexBuffer( commandBuffer, m_indexBuffer.TrinityALImpl_GetObject()->GetVkBuffer(), 0, m_indexType );
+	return S_OK;
+}
