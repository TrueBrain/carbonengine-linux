@@ -0,0 +1,91 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+#if !defined( _WIN32 ) && !defined( TRINITY_AL_MOBILE ) && ( TRINITY_PLATFORM == TRINITY_VULKAN )
+#include "RenderWindow.h"
+#include "WithWindowFixture.h"
+
+#ifdef TRINITY_TEST_WITH_X11
+#include <X11/Xlib.h>
+
+Display* GetTestDisplay()
+{
+	static Display* s_display = XOpenDisplay( nullptr );
+	return s_display;
+}
+#endif
+
+RenderWindow::RenderWindow( uint32_t width, uint32_t height )
+{
+#ifdef TRINITY_TEST_WITH_X11
+	if( Display* display = GetTestDisplay() )
+	{
+		// override-redirect bypasses the window manager so the window keeps
+		// exactly the geometry the tests ask for.
+		XSetWindowAttributes attributes = {};
+		attributes.override_redirect = True;
+		Window window = XCreateWindow(
+			display, DefaultRootWindow( display ), 0, 0, width, height, 0,
+			CopyFromParent, InputOutput, CopyFromParent, CWOverrideRedirect, &attributes );
+		XMapWindow( display, window );
+		XSync( display, False );
+		m_handle = static_cast<Tr2WindowHandle>( window );
+		return;
+	}
+#endif
+	// Headless fallback: encode the requested size in the fake handle, like
+	// the stub window does.
+	m_handle = static_cast<Tr2WindowHandle>( ( width & 0xffff ) | ( ( height & 0xffff ) << 16 ) );
+}
+
+RenderWindow::~RenderWindow()
+{
+#ifdef TRINITY_TEST_WITH_X11
+	if( Display* display = GetTestDisplay() )
+	{
+		XDestroyWindow( display, static_cast<Window>( m_handle ) );
+		XSync( display, False );
+	}
+#endif
+}
+
+uint32_t RenderWindow::GetClientWidth() const
+{
+#ifdef TRINITY_TEST_WITH_X11
+	if( Display* display = GetTestDisplay() )
+	{
+		XWindowAttributes attributes = {};
+		XGetWindowAttributes( display, static_cast<Window>( m_handle ), &attributes );
+		return (uint32_t)attributes.width;
+	}
+#endif
+	return static_cast<uintptr_t>( m_handle ) & 0xffff;
+}
+
+uint32_t RenderWindow::GetClientHeight() const
+{
+#ifdef TRINITY_TEST_WITH_X11
+	if( Display* display = GetTestDisplay() )
+	{
+		XWindowAttributes attributes = {};
+		XGetWindowAttributes( display, static_cast<Window>( m_handle ), &attributes );
+		return (uint32_t)attributes.height;
+	}
+#endif
+	return ( static_cast<uintptr_t>( m_handle ) >> 16 ) & 0xffff;
+}
+
+bool RenderWindow::Resize( uint32_t width, uint32_t height )
+{
+#ifdef TRINITY_TEST_WITH_X11
+	if( Display* display = GetTestDisplay() )
+	{
+		XResizeWindow( display, static_cast<Window>( m_handle ), width, height );
+		XSync( display, False );
+		return true;
+	}
+#endif
+	return false;
+}
+
+#endif
