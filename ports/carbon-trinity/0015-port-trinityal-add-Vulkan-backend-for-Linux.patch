diff --git a/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp b/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp
new file mode 100644
index 00000000..88e4fb5a
--- /dev/null
+++ b/trinityal/vulkan/Tr2ShaderProgramALVulkan.cpp
@@ -0,0 +1,311 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2ShaderProgramALVulkan.h"
+#include "Tr2ShaderALVulkan.h"
+#include "Tr2SamplerStateALVulkan.h"
+#include "Tr2PrimaryRenderContextVulkan.h"
+#include "VulkanBindingModel.h"
+#include "VulkanContext.h"
+
+#include <atomic>
+
+using namespace Tr2RenderContextEnum;
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+std::atomic<uint64_t> g_nextProgramId( 1 );
+
+VkShaderStageFlags ToVkShaderStage( ShaderType type )
+{
+	switch( type )
+	{
+	case VERTEX_SHADER:
+		return VK_SHADER_STAGE_VERTEX_BIT;
+	case PIXEL_SHADER:
+		return VK_SHADER_STAGE_FRAGMENT_BIT;
+	case COMPUTE_SHADER:
+		return VK_SHADER_STAGE_COMPUTE_BIT;
+	case GEOMETRY_SHADER:
+		return VK_SHADER_STAGE_GEOMETRY_BIT;
+	case HULL_SHADER:
+		return VK_SHADER_STAGE_TESSELLATION_CONTROL_BIT;
+	case DOMAIN_SHADER:
+		return VK_SHADER_STAGE_TESSELLATION_EVALUATION_BIT;
+	default:
+		return 0;
+	}
+}
+
+VkDescriptorType GetSrvDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::SRV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::SRV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE;
+	}
+}
+
+VkDescriptorType GetUavDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::UAV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::UAV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_STORAGE_IMAGE;
+	}
+}
+
+}
+
+Tr2ShaderProgramAL::Tr2ShaderProgramAL() :
+	m_descriptorSetLayout( VK_NULL_HANDLE ),
+	m_pipelineLayout( VK_NULL_HANDLE ),
+	m_isValid( false )
+{
+}
+
+Tr2ShaderProgramAL::~Tr2ShaderProgramAL()
+{
+	Destroy();
+}
+
+ALResult Tr2ShaderProgramAL::Create( ::Tr2ShaderAL* shaders, size_t count, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	if( count == 0 )
+	{
+		return E_INVALIDARG;
+	}
+
+	uint32_t mask = 0;
+	for( size_t i = 0; i < count; ++i )
+	{
+		if( !shaders[i].IsValid() )
+		{
+			return E_INVALIDARG;
+		}
+		uint32_t bit = 1 << shaders[i].GetType();
+		if( ( mask & bit ) != 0 )
+		{
+			return E_INVALIDARG;
+		}
+		mask |= bit;
+		m_shaders[shaders[i].GetType()] = shaders[i].m_shader;
+	}
+
+	m_registerMap = Tr2RegisterMapAL( shaders, count );
+
+	ALResult result = CreateLayouts();
+	if( FAILED( result ) )
+	{
+		Destroy();
+		return result;
+	}
+
+	m_uniqueId = g_nextProgramId++;
+	m_isValid = true;
+	return S_OK;
+}
+
+ALResult Tr2ShaderProgramAL::CreateLayouts()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	// Collect one descriptor binding per register declared in the shader
+	// signatures, following the binding model in VulkanBindingModel.h.
+	std::vector<VkDescriptorSetLayoutBinding> layoutBindings;
+	std::vector<size_t> staticSamplerBindingIndex;
+	m_bindings.clear();
+
+	for( int stageIndex = 0; stageIndex < SHADER_TYPE_COUNT; ++stageIndex )
+	{
+		if( !m_shaders[stageIndex] )
+		{
+			continue;
+		}
+		const ShaderType stage = (ShaderType)stageIndex;
+		const VkShaderStageFlags stageFlags = ToVkShaderStage( stage );
+		const Tr2ShaderSignatureAL& signature = m_shaders[stageIndex]->GetSignature();
+
+		for( const Tr2ShaderRegisterAL& reg : signature.registers )
+		{
+			BindingInfo info = {};
+			info.stage = stage;
+			info.registerType = reg.registerType;
+			info.registerIndex = reg.registerIndex;
+			info.isStaticSampler = false;
+
+			if( reg.registerType == Tr2ShaderRegisterAL::CONSTANT_BUFFER )
+			{
+				info.binding = VulkanBindingModel::GetCbvBinding( stage, reg.registerIndex );
+				info.descriptorType = VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER;
+			}
+			else if( reg.registerType == Tr2ShaderRegisterAL::SAMPLER )
+			{
+				info.binding = VulkanBindingModel::GetSamplerBinding( stage, reg.registerIndex );
+				info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+			}
+			else if( reg.IsSrv() )
+			{
+				info.binding = VulkanBindingModel::GetSrvBinding( stage, reg.registerIndex );
+				info.descriptorType = GetSrvDescriptorType( reg.registerType );
+			}
+			else if( reg.IsUav() )
+			{
+				info.binding = VulkanBindingModel::GetUavBinding( stage, reg.registerIndex );
+				info.descriptorType = GetUavDescriptorType( reg.registerType );
+			}
+			else
+			{
+				continue;
+			}
+
+			VkDescriptorSetLayoutBinding layoutBinding = {};
+			layoutBinding.binding = info.binding;
+			layoutBinding.descriptorType = info.descriptorType;
+			layoutBinding.descriptorCount = 1;
+			layoutBinding.stageFlags = stageFlags;
+			layoutBindings.push_back( layoutBinding );
+			m_bindings.push_back( info );
+		}
+
+		// Static samplers become immutable samplers in the layout.
+		for( const Tr2StaticSamplerAL& staticSampler : signature.samplers )
+		{
+			VkSampler sampler = VK_NULL_HANDLE;
+			CR_RETURN_HR( CreateVkSampler( staticSampler.sampler, sampler ) );
+			m_staticSamplers.push_back( sampler );
+
+			BindingInfo info = {};
+			info.stage = stage;
+			info.registerType = Tr2ShaderRegisterAL::SAMPLER;
+			info.registerIndex = staticSampler.registerIndex;
+			info.isStaticSampler = true;
+			info.binding = VulkanBindingModel::GetSamplerBinding( stage, staticSampler.registerIndex );
+			info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+
+			VkDescriptorSetLayoutBinding layoutBinding = {};
+			layoutBinding.binding = info.binding;
+			layoutBinding.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+			layoutBinding.descriptorCount = 1;
+			layoutBinding.stageFlags = stageFlags;
+			staticSamplerBindingIndex.push_back( layoutBindings.size() );
+			layoutBindings.push_back( layoutBinding );
+			m_bindings.push_back( info );
+		}
+	}
+
+	// Attach the immutable sampler pointers now that m_staticSamplers is
+	// fully populated (its storage will not move anymore).
+	for( size_t i = 0; i < staticSamplerBindingIndex.size(); ++i )
+	{
+		layoutBindings[staticSamplerBindingIndex[i]].pImmutableSamplers = &m_staticSamplers[i];
+	}
+
+	VkDescriptorSetLayoutCreateInfo layoutCreateInfo = {};
+	layoutCreateInfo.sType = VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO;
+	layoutCreateInfo.bindingCount = (uint32_t)layoutBindings.size();
+	layoutCreateInfo.pBindings = layoutBindings.data();
+	VK_CR_RETURN_HR( vkCreateDescriptorSetLayout( context->GetDevice(), &layoutCreateInfo, nullptr, &m_descriptorSetLayout ) );
+
+	VkPipelineLayoutCreateInfo pipelineLayoutCreateInfo = {};
+	pipelineLayoutCreateInfo.sType = VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO;
+	pipelineLayoutCreateInfo.setLayoutCount = 1;
+	pipelineLayoutCreateInfo.pSetLayouts = &m_descriptorSetLayout;
+	VK_CR_RETURN_HR( vkCreatePipelineLayout( context->GetDevice(), &pipelineLayoutCreateInfo, nullptr, &m_pipelineLayout ) );
+
+	return S_OK;
+}
+
+void Tr2ShaderProgramAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		if( m_pipelineLayout != VK_NULL_HANDLE )
+		{
+			vkDestroyPipelineLayout( context->GetDevice(), m_pipelineLayout, nullptr );
+		}
+		if( m_descriptorSetLayout != VK_NULL_HANDLE )
+		{
+			vkDestroyDescriptorSetLayout( context->GetDevice(), m_descriptorSetLayout, nullptr );
+		}
+		for( VkSampler sampler : m_staticSamplers )
+		{
+			vkDestroySampler( context->GetDevice(), sampler, nullptr );
+		}
+	}
+	m_pipelineLayout = VK_NULL_HANDLE;
+	m_descriptorSetLayout = VK_NULL_HANDLE;
+	m_staticSamplers.clear();
+	m_bindings.clear();
+
+	for( auto& shader : m_shaders )
+	{
+		shader.reset();
+	}
+	m_registerMap = Tr2RegisterMapAL();
+	m_isValid = false;
+}
+
+bool Tr2ShaderProgramAL::IsValid() const
+{
+	return m_isValid;
+}
+
+const Tr2RegisterMapAL& Tr2ShaderProgramAL::GetRegisterMap() const
+{
+	return m_registerMap;
+}
+
+std::shared_ptr<Tr2ShaderAL> Tr2ShaderProgramAL::GetShader( Tr2RenderContextEnum::ShaderType type ) const
+{
+	if( type < 0 || type >= SHADER_TYPE_COUNT )
+	{
+		return nullptr;
+	}
+	return m_shaders[type];
+}
+
+Tr2ALMemoryType Tr2ShaderProgramAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2ShaderProgramAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2ShaderProgramAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2ShaderProgramALVulkan.h b/trinityal/vulkan/Tr2ShaderProgramALVulkan.h
new file mode 100644
index 00000000..cf89b186
--- /dev/null
+++ b/trinityal/vulkan/Tr2ShaderProgramALVulkan.h
@@ -0,0 +1,87 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2ShaderProgramAL.h"
+#include "../include/Tr2ShaderAL.h"
+#include "../include/Tr2ResourceSetAL.h"
+#include "VulkanCommon.h"
+
+#include <vector>
+
+namespace TrinityALImpl
+{
+class Tr2ShaderProgramAL : public Tr2DeviceResourceAL<Tr2ShaderProgramAL>
+{
+public:
+	// One entry per resource binding declared by the program's shader
+	// signatures; drives descriptor set updates at draw time.
+	struct BindingInfo
+	{
+		uint32_t binding;
+		VkDescriptorType descriptorType;
+		Tr2RenderContextEnum::ShaderType stage;
+		Tr2ShaderRegisterAL::RegisterType registerType;
+		uint32_t registerIndex;
+		bool isStaticSampler;
+	};
+
+	Tr2ShaderProgramAL();
+	~Tr2ShaderProgramAL();
+
+	ALResult Create( ::Tr2ShaderAL* shaders, size_t count, Tr2PrimaryRenderContextAL& renderContext );
+	void Destroy();
+
+	bool IsValid() const;
+	const Tr2RegisterMapAL& GetRegisterMap() const;
+
+	Tr2ALMemoryType GetMemoryClass() const;
+
+	void Describe( Tr2DeviceResourceDescriptionAL& description ) const;
+	ALResult SetName( const char* name );
+
+	// The shaders bundled into this program, held alive for pipeline
+	// creation. Indexed by Tr2RenderContextEnum::ShaderType.
+	std::shared_ptr<Tr2ShaderAL> GetShader( Tr2RenderContextEnum::ShaderType type ) const;
+
+	VkDescriptorSetLayout GetDescriptorSetLayout() const
+	{
+		return m_descriptorSetLayout;
+	}
+
+	VkPipelineLayout GetPipelineLayout() const
+	{
+		return m_pipelineLayout;
+	}
+
+	const std::vector<BindingInfo>& GetBindings() const
+	{
+		return m_bindings;
+	}
+
+	// Uniquely identifies this program instance for pipeline cache keys;
+	// pointers cannot be used because allocations are recycled.
+	uint64_t GetUniqueId() const
+	{
+		return m_uniqueId;
+	}
+
+private:
+	ALResult CreateLayouts();
+
+	Tr2RegisterMapAL m_registerMap;
+	std::shared_ptr<Tr2ShaderAL> m_shaders[Tr2RenderContextEnum::SHADER_TYPE_COUNT];
+	std::vector<BindingInfo> m_bindings;
+	std::vector<VkSampler> m_staticSamplers;
+	VkDescriptorSetLayout m_descriptorSetLayout;
+	VkPipelineLayout m_pipelineLayout;
+	uint64_t m_uniqueId = 0;
+	bool m_isValid;
+
+	friend class Tr2RenderContextAL;
+};
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2SwapChainALVulkan.cpp b/trinityal/vulkan/Tr2SwapChainALVulkan.cpp
