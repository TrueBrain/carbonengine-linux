+	};
+
+	// Descriptor set construction and graphics/compute pipeline creation.
+	ALResult BuildDescriptorSet( TrinityALImpl::Tr2ShaderProgramAL& program, VkDescriptorSet& descriptorSet );
+	ALResult GetOrCreateGraphicsPipeline( uint32_t stream0StrideOverride, VkPipeline& pipeline );
+	uint64_t ComputeGraphicsPipelineHash( uint32_t stream0StrideOverride ) const;
+	ALResult SetupDraw( uint32_t stream0StrideOverride, VkBuffer stream0Override, VkDeviceSize stream0Offset, VkCommandBuffer& commandBuffer );
+	ALResult SetupIndexedDraw( VkCommandBuffer commandBuffer, VkBuffer indexOverride, VkDeviceSize indexOffset, VkIndexType indexTypeOverride );
+	ALResult SetupCompute( VkCommandBuffer& commandBuffer );
+	uint32_t GetVertexCountForPrimitives( uint32_t primitiveCount ) const;
