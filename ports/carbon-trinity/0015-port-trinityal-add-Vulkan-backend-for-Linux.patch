+// --------------------------------------------------------------------------------------
+// Copies and clears — implemented directly on the transfer path.
+// --------------------------------------------------------------------------------------
+
+ALResult Tr2RenderContextAL::ClearUav( const Tr2BufferAL& buffer, const float values[4] ) throw()
+{
+	uint32_t asUint[4];
+	memcpy( asUint, values, sizeof( asUint ) );
+	return ClearUav( buffer, asUint );
+}
+
+ALResult Tr2RenderContextAL::ClearUav( const Tr2BufferAL& buffer, const uint32_t values[4] ) throw()
+{
+	if( !IsValid() || !buffer.IsValid() )
+	{
+		return E_FAIL;
+	}
+	TrinityALImpl::Tr2BufferAL* impl = buffer.TrinityALImpl_GetObject();
+	VkCommandBuffer commandBuffer = m_vulkanContext->GetCommandBuffer();
+	vkCmdFillBuffer( commandBuffer, impl->GetVkBuffer(), 0, VK_WHOLE_SIZE, values[0] );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::ClearUav( const Tr2TextureAL& texture, uint32_t mip, const float values[4] ) throw()
+{
+	if( !IsValid() || !texture.IsValid() )
+	{
+		return E_FAIL;
+	}
+	TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( texture );
+	VkClearColorValue clearValue = {};
+	memcpy( clearValue.float32, values, sizeof( clearValue.float32 ) );
+	VkImageSubresourceRange range = {};
+	range.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	range.baseMipLevel = mip;
+	range.levelCount = 1;
+	range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+	vkCmdClearColorImage( m_vulkanContext->GetCommandBuffer(), impl->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, &clearValue, 1, &range );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::ClearUav( const Tr2TextureAL& texture, uint32_t mip, const uint32_t values[4] ) throw()
+{
+	if( !IsValid() || !texture.IsValid() )
+	{
+		return E_FAIL;
+	}
+	TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( texture );
+	VkClearColorValue clearValue = {};
+	memcpy( clearValue.uint32, values, sizeof( clearValue.uint32 ) );
+	VkImageSubresourceRange range = {};
+	range.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	range.baseMipLevel = mip;
+	range.levelCount = 1;
+	range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+	vkCmdClearColorImage( m_vulkanContext->GetCommandBuffer(), impl->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, &clearValue, 1, &range );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::CopySubBuffer(
+	Tr2BufferAL& dest,
+	uint32_t destOffset,
+	Tr2BufferAL& src,
+	uint32_t offset,
+	uint32_t length )
+{
+	if( !IsValid() || !dest.IsValid() || !src.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( offset + length > src.GetSize() || destOffset + length > dest.GetSize() )
+	{
+		return E_INVALIDARG;
+	}
+	if( length == 0 )
+	{
+		return S_OK;
+	}
+
+	VkBufferCopy region = {};
+	region.srcOffset = offset;
+	region.dstOffset = destOffset;
+	region.size = length;
+	vkCmdCopyBuffer( m_vulkanContext->GetCommandBuffer(), src.TrinityALImpl_GetObject()->GetVkBuffer(), dest.TrinityALImpl_GetObject()->GetVkBuffer(), 1, &region );
+	return S_OK;
+}
+
+ALResult Tr2RenderContextAL::Clear(
+	uint32_t clearFlags,
+	uint32_t color,
+	float depth,
+	uint32_t stencil,
+	uint32_t slot )
+{
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( slot >= MAX_RENDER_TARGET )
+	{
+		return E_INVALIDARG;
+	}
+
+	if( ( clearFlags & CLEARFLAGS_TARGET ) != 0 && m_boundRenderTarget[slot].IsValid() )
+	{
+		TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( m_boundRenderTarget[slot] );
+		VkClearColorValue clearValue = {};
+		// The color arrives as a D3DCOLOR (ARGB).
+		clearValue.float32[0] = ( ( color >> 16 ) & 0xff ) / 255.0f;
+		clearValue.float32[1] = ( ( color >> 8 ) & 0xff ) / 255.0f;
+		clearValue.float32[2] = ( color & 0xff ) / 255.0f;
+		clearValue.float32[3] = ( ( color >> 24 ) & 0xff ) / 255.0f;
+		VkImageSubresourceRange range = {};
+		range.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+		range.levelCount = VK_REMAINING_MIP_LEVELS;
+		range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+		vkCmdClearColorImage( m_vulkanContext->GetCommandBuffer(), impl->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, &clearValue, 1, &range );
+	}
+
+	if( ( clearFlags & ( CLEARFLAGS_ZBUFFER | CLEARFLAGS_STENCIL ) ) != 0 && m_boundDepthStencil.IsValid() )
+	{
+		TrinityALImpl::Tr2TextureAL* impl = GetTextureImpl( m_boundDepthStencil );
+		VkClearDepthStencilValue clearValue = {};
+		clearValue.depth = depth;
+		clearValue.stencil = stencil;
+		VkImageSubresourceRange range = {};
+		if( ( clearFlags & CLEARFLAGS_ZBUFFER ) != 0 )
+		{
+			range.aspectMask |= VK_IMAGE_ASPECT_DEPTH_BIT;
+		}
+		if( ( clearFlags & CLEARFLAGS_STENCIL ) != 0 && TrinityALImpl::HasStencil( impl->GetVkFormat() ) )
+		{
+			range.aspectMask |= VK_IMAGE_ASPECT_STENCIL_BIT;
+		}
+		range.levelCount = VK_REMAINING_MIP_LEVELS;
+		range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+		if( range.aspectMask != 0 )
+		{
+			vkCmdClearDepthStencilImage( m_vulkanContext->GetCommandBuffer(), impl->GetVkImage(), VK_IMAGE_LAYOUT_GENERAL, &clearValue, 1, &range );
+		}
+	}
+
+	return S_OK;
+}
