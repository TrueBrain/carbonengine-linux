diff --git a/trinityal/vulkan/Tr2BufferALVulkan.cpp b/trinityal/vulkan/Tr2BufferALVulkan.cpp
new file mode 100644
index 00000000..0d235afd
--- /dev/null
+++ b/trinityal/vulkan/Tr2BufferALVulkan.cpp
@@ -0,0 +1,388 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2BufferALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+using Tr2CpuUsage::HasFlag;
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+VkBufferUsageFlags GetBufferUsageFlags( const Tr2BufferDescriptionAL& desc )
+{
+	VulkanContext* context = GetVulkanContext();
+	const bool rayTracing = context && context->SupportsRayTracing();
+
+	VkBufferUsageFlags usage = VK_BUFFER_USAGE_TRANSFER_SRC_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT;
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::VERTEX_BUFFER ) )
+	{
+		usage |= VK_BUFFER_USAGE_VERTEX_BUFFER_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::INDEX_BUFFER ) )
+	{
+		usage |= VK_BUFFER_USAGE_INDEX_BUFFER_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::DRAW_INDIRECT_ARGS ) )
+	{
+		usage |= VK_BUFFER_USAGE_INDIRECT_BUFFER_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::SHADER_RESOURCE ) )
+	{
+		// Typed buffers become texel buffers, structured buffers become storage buffers.
+		usage |= ( desc.format != Tr2RenderContextEnum::PIXEL_FORMAT_UNKNOWN )
+			? VK_BUFFER_USAGE_UNIFORM_TEXEL_BUFFER_BIT
+			: VK_BUFFER_USAGE_STORAGE_BUFFER_BIT;
+		if( rayTracing )
+		{
+			// Any shader-visible buffer may feed an acceleration structure
+			// build, which reads geometry through device addresses.
+			usage |= VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_BUILD_INPUT_READ_ONLY_BIT_KHR |
+				VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+		}
+	}
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::UNORDERED_ACCESS ) )
+	{
+		usage |= ( desc.format != Tr2RenderContextEnum::PIXEL_FORMAT_UNKNOWN )
+			? VK_BUFFER_USAGE_STORAGE_TEXEL_BUFFER_BIT
+			: VK_BUFFER_USAGE_STORAGE_BUFFER_BIT;
+	}
+	if( Tr2GpuUsage::HasFlag( desc.gpuUsage, Tr2GpuUsage::ACCELERATION_STRUCTURE ) && rayTracing )
+	{
+		usage |= VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_STORAGE_BIT_KHR |
+			VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+	}
+	return usage;
+}
+
+}
+
+Tr2BufferAL::Tr2BufferAL() :
+	m_buffer( VK_NULL_HANDLE ),
+	m_allocation( VK_NULL_HANDLE ),
+	m_mappedData( nullptr ),
+	m_bufferView( VK_NULL_HANDLE ),
+	m_accelerationStructure( VK_NULL_HANDLE ),
+	m_readbackBuffer( VK_NULL_HANDLE ),
+	m_readbackAllocation( VK_NULL_HANDLE )
+{
+}
+
+VkDeviceAddress Tr2BufferAL::GetDeviceAddress() const
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->SupportsRayTracing() || m_buffer == VK_NULL_HANDLE )
+	{
+		return 0;
+	}
+	VkBufferDeviceAddressInfo addressInfo = {};
+	addressInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+	addressInfo.buffer = m_buffer;
+	return vkGetBufferDeviceAddress( context->GetDevice(), &addressInfo );
+}
+
+VkBufferView Tr2BufferAL::GetVkBufferView()
+{
+	if( m_bufferView == VK_NULL_HANDLE && IsValid() && m_desc.format != Tr2RenderContextEnum::PIXEL_FORMAT_UNKNOWN )
+	{
+		VulkanContext* context = GetVulkanContext();
+		if( context && context->IsValid() )
+		{
+			VkBufferViewCreateInfo viewCreateInfo = {};
+			viewCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_VIEW_CREATE_INFO;
+			viewCreateInfo.buffer = m_buffer;
+			viewCreateInfo.format = ToVkFormat( m_desc.format );
+			viewCreateInfo.range = VK_WHOLE_SIZE;
+			vkCreateBufferView( context->GetDevice(), &viewCreateInfo, nullptr, &m_bufferView );
+		}
+	}
+	return m_bufferView;
+}
+
+Tr2BufferAL::~Tr2BufferAL()
+{
+	Destroy();
+}
+
+bool Tr2BufferAL::IsHostVisible() const
+{
+	return m_mappedData != nullptr;
+}
+
+ALResult Tr2BufferAL::Create(
+	const Tr2BufferDescriptionAL& desc,
+	const void* initialData,
+	Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( desc.count == 0 )
+	{
+		return E_INVALIDARG;
+	}
+	if( !HasFlag( desc.cpuUsage, Tr2CpuUsage::WRITE ) && !initialData && !Tr2GpuUsage::IsWritable( desc.gpuUsage ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDCALL;
+	}
+
+	const VkDeviceSize size = (VkDeviceSize)desc.count * desc.stride;
+
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = size;
+	bufferCreateInfo.usage = GetBufferUsageFlags( desc );
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	if( desc.cpuUsage != Tr2CpuUsage::NONE )
+	{
+		// CPU-accessible buffers stay persistently mapped; VMA picks BAR/host
+		// memory as appropriate.
+		allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_RANDOM_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+	}
+
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBuffer( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, &m_buffer, &m_allocation, &allocationInfo ) );
+	m_mappedData = allocationInfo.pMappedData;
+	m_desc = desc;
+
+	if( initialData )
+	{
+		if( IsHostVisible() )
+		{
+			memcpy( m_mappedData, initialData, size );
+			vmaFlushAllocation( context->GetAllocator(), m_allocation, 0, size );
+		}
+		else
+		{
+			VkBuffer staging = VK_NULL_HANDLE;
+			VmaAllocation stagingAllocation = VK_NULL_HANDLE;
+			void* stagingData = nullptr;
+			CR_RETURN_HR( context->CreateStagingBuffer( size, VK_BUFFER_USAGE_TRANSFER_SRC_BIT, staging, stagingAllocation, stagingData ) );
+			memcpy( stagingData, initialData, size );
+			vmaFlushAllocation( context->GetAllocator(), stagingAllocation, 0, size );
+
+			ALResult result = context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+				VkBufferCopy region = {};
+				region.size = size;
+				vkCmdCopyBuffer( commandBuffer, staging, m_buffer, 1, &region );
+			} );
+			vmaDestroyBuffer( context->GetAllocator(), staging, stagingAllocation );
+			CR_RETURN_HR( result );
+		}
+	}
+
+	return S_OK;
+}
+
+void Tr2BufferAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context )
+	{
+		context->DestroyBufferViewLater( m_bufferView );
+		context->DestroyBufferLater( m_buffer, m_allocation );
+		context->DestroyBufferLater( m_readbackBuffer, m_readbackAllocation );
+	}
+	m_bufferView = VK_NULL_HANDLE;
+	m_buffer = VK_NULL_HANDLE;
+	m_allocation = VK_NULL_HANDLE;
+	m_mappedData = nullptr;
+	m_accelerationStructure = VK_NULL_HANDLE;
+	m_readbackBuffer = VK_NULL_HANDLE;
+	m_readbackAllocation = VK_NULL_HANDLE;
+	m_desc.count = 0;
+}
+
+bool Tr2BufferAL::IsValid() const
+{
+	return m_buffer != VK_NULL_HANDLE;
+}
+
+Tr2ALMemoryType Tr2BufferAL::GetMemoryClass() const
+{
+	return IsHostVisible() ? AL_MEMORY_MANAGED : AL_MEMORY_VIDEO;
+}
+
+const Tr2BufferDescriptionAL& Tr2BufferAL::GetDesc() const
+{
+	return m_desc;
+}
+
+ALResult Tr2BufferAL::MapForReading( const void*& data, Tr2RenderContextAL& renderContext )
+{
+	return MapForReading( data, 0, GetSize(), renderContext );
+}
+
+ALResult Tr2BufferAL::MapForReading( const void*& data, uint32_t offset, uint32_t size, Tr2RenderContextAL& renderContext )
+{
+	data = nullptr;
+	if( !renderContext.IsValid() || !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( size == 0 || offset + size > GetSize() )
+	{
+		return E_INVALIDARG;
+	}
+	if( !HasFlag( m_desc.cpuUsage, Tr2CpuUsage::READ ) )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDCALL;
+	}
+
+	// Any outstanding GPU writes must land before the CPU reads the memory.
+	CR_RETURN_HR( context->FlushAndWait() );
+
+	if( IsHostVisible() )
+	{
+		vmaInvalidateAllocation( context->GetAllocator(), m_allocation, 0, GetSize() );
+		data = m_mappedData;
+		return S_OK;
+	}
+
+	// Device-local buffer: copy through a readback buffer.
+	if( m_readbackBuffer == VK_NULL_HANDLE )
+	{
+		void* mapped = nullptr;
+		CR_RETURN_HR( context->CreateStagingBuffer( GetSize(), VK_BUFFER_USAGE_TRANSFER_DST_BIT, m_readbackBuffer, m_readbackAllocation, mapped ) );
+	}
+	CR_RETURN_HR( context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkBufferCopy region = {};
+		region.size = GetSize();
+		vkCmdCopyBuffer( commandBuffer, m_buffer, m_readbackBuffer, 1, &region );
+	} ) );
+
+	VmaAllocationInfo allocationInfo = {};
+	vmaGetAllocationInfo( context->GetAllocator(), m_readbackAllocation, &allocationInfo );
+	vmaInvalidateAllocation( context->GetAllocator(), m_readbackAllocation, 0, GetSize() );
+	data = allocationInfo.pMappedData;
+	return S_OK;
+}
+
+void Tr2BufferAL::UnmapForReading( Tr2RenderContextAL& )
+{
+}
+
+ALResult Tr2BufferAL::MapForWriting( void*& data, Tr2RenderContextAL& renderContext )
+{
+	data = nullptr;
+	if( !renderContext.IsValid() || !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !HasFlag( m_desc.cpuUsage, Tr2CpuUsage::WRITE ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !IsHostVisible() )
+	{
+		return E_INVALIDCALL;
+	}
+	data = m_mappedData;
+	return S_OK;
+}
+
+void Tr2BufferAL::UnmapForWriting( Tr2RenderContextAL& )
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && m_allocation != VK_NULL_HANDLE )
+	{
+		vmaFlushAllocation( context->GetAllocator(), m_allocation, 0, GetSize() );
+	}
+}
+
+ALResult Tr2BufferAL::UpdateBuffer( uint32_t offset, uint32_t size, const void* data, Tr2RenderContextAL& renderContext )
+{
+	if( !renderContext.IsValid() || !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( offset + size > GetSize() )
+	{
+		return E_INVALIDARG;
+	}
+	if( !HasFlag( m_desc.cpuUsage, Tr2CpuUsage::WRITE ) || HasFlag( m_desc.cpuUsage, Tr2CpuUsage::WRITE_OFTEN ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( size == 0 )
+	{
+		return S_OK;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDCALL;
+	}
+
+	if( IsHostVisible() )
+	{
+		memcpy( (uint8_t*)m_mappedData + offset, data, size );
+		vmaFlushAllocation( context->GetAllocator(), m_allocation, offset, size );
+		return S_OK;
+	}
+
+	VkBuffer staging = VK_NULL_HANDLE;
+	VmaAllocation stagingAllocation = VK_NULL_HANDLE;
+	void* stagingData = nullptr;
+	CR_RETURN_HR( context->CreateStagingBuffer( size, VK_BUFFER_USAGE_TRANSFER_SRC_BIT, staging, stagingAllocation, stagingData ) );
+	memcpy( stagingData, data, size );
+	vmaFlushAllocation( context->GetAllocator(), stagingAllocation, 0, size );
+
+	ALResult result = context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkBufferCopy region = {};
+		region.dstOffset = offset;
+		region.size = size;
+		vkCmdCopyBuffer( commandBuffer, staging, m_buffer, 1, &region );
+	} );
+	vmaDestroyBuffer( context->GetAllocator(), staging, stagingAllocation );
+	return result;
+}
+
+uint32_t Tr2BufferAL::GetSrvIndexInHeap() const
+{
+	return 0xffffffff;
+}
+
+uint32_t Tr2BufferAL::GetUavIndexInHeap() const
+{
+	return 0xffffffff;
+}
+
+void Tr2BufferAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2BufferAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
