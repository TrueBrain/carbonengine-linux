diff --git a/trinityal/vulkan/Tr2ConstantBufferALVulkan.cpp b/trinityal/vulkan/Tr2ConstantBufferALVulkan.cpp
new file mode 100644
index 00000000..5748f510
--- /dev/null
+++ b/trinityal/vulkan/Tr2ConstantBufferALVulkan.cpp
@@ -0,0 +1,214 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2ConstantBufferALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+Tr2ConstantBufferAL::Tr2ConstantBufferAL() :
+	m_usage( Tr2ConstantUsageAL::REUSABLE ),
+	m_buffer( VK_NULL_HANDLE ),
+	m_allocation( VK_NULL_HANDLE ),
+	m_mappedData( nullptr ),
+	m_size( 0 ),
+	m_isLocked( false )
+{
+}
+
+Tr2ConstantBufferAL::~Tr2ConstantBufferAL()
+{
+	Destroy();
+}
+
+ALResult Tr2ConstantBufferAL::CreateDeviceBuffer( const void* initialData )
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = m_size;
+	bufferCreateInfo.usage = VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT | VK_BUFFER_USAGE_TRANSFER_DST_BIT;
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBuffer( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, &m_buffer, &m_allocation, &allocationInfo ) );
+	m_mappedData = allocationInfo.pMappedData;
+
+	if( initialData )
+	{
+		memcpy( m_mappedData, initialData, m_size );
+		vmaFlushAllocation( context->GetAllocator(), m_allocation, 0, m_size );
+	}
+	return S_OK;
+}
+
+ALResult Tr2ConstantBufferAL::Create( uint32_t size, Tr2ConstantUsageAL::Type usage, const void* initialData, Tr2RenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( size == 0 )
+	{
+		return E_INVALIDARG;
+	}
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( usage == Tr2ConstantUsageAL::IMMUTABLE && !initialData )
+	{
+		return E_INVALIDARG;
+	}
+
+	m_size = size;
+	m_usage = usage;
+
+	if( usage == Tr2ConstantUsageAL::ONE_SHOT )
+	{
+		// ONE_SHOT contents live in a CPU mirror and are snapshotted into
+		// the transient ring buffer at every draw that binds them.
+		m_mirror.resize( "Tr2ConstantBufferAL::m_mirror", size );
+		if( m_mirror.empty() )
+		{
+			m_size = 0;
+			return E_OUTOFMEMORY;
+		}
+		if( initialData )
+		{
+			memcpy( m_mirror.get(), initialData, size );
+		}
+		else
+		{
+			memset( m_mirror.get(), 0, size );
+		}
+		return S_OK;
+	}
+
+	ALResult result = CreateDeviceBuffer( initialData );
+	if( FAILED( result ) )
+	{
+		Destroy();
+	}
+	return result;
+}
+
+void Tr2ConstantBufferAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context )
+	{
+		context->DestroyBufferLater( m_buffer, m_allocation );
+	}
+	m_buffer = VK_NULL_HANDLE;
+	m_allocation = VK_NULL_HANDLE;
+	m_mappedData = nullptr;
+	m_mirror.clear();
+	m_usage = Tr2ConstantUsageAL::REUSABLE;
+	m_size = 0;
+	m_isLocked = false;
+}
+
+ALResult Tr2ConstantBufferAL::Lock( void** data, Tr2RenderContextAL& renderContext )
+{
+	if( !data )
+	{
+		return E_INVALIDARG;
+	}
+	*data = nullptr;
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( m_isLocked )
+	{
+		return E_INVALIDCALL;
+	}
+
+	if( m_usage == Tr2ConstantUsageAL::ONE_SHOT )
+	{
+		m_isLocked = true;
+		*data = m_mirror.get();
+		return S_OK;
+	}
+
+	// WRITE_DISCARD semantics: draws already recorded keep the previous
+	// buffer; the lock writes into a fresh one.
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDCALL;
+	}
+	context->DestroyBufferLater( m_buffer, m_allocation );
+	m_buffer = VK_NULL_HANDLE;
+	m_allocation = VK_NULL_HANDLE;
+	m_mappedData = nullptr;
+	CR_RETURN_HR( CreateDeviceBuffer( nullptr ) );
+
+	m_isLocked = true;
+	*data = m_mappedData;
+	return S_OK;
+}
+
+ALResult Tr2ConstantBufferAL::Unlock( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !m_isLocked )
+	{
+		return E_INVALIDCALL;
+	}
+	m_isLocked = false;
+
+	if( m_usage != Tr2ConstantUsageAL::ONE_SHOT )
+	{
+		VulkanContext* context = GetVulkanContext();
+		if( context && m_allocation != VK_NULL_HANDLE )
+		{
+			vmaFlushAllocation( context->GetAllocator(), m_allocation, 0, m_size );
+		}
+	}
+	return S_OK;
+}
+
+bool Tr2ConstantBufferAL::IsValid() const
+{
+	return m_size > 0 && ( m_usage == Tr2ConstantUsageAL::ONE_SHOT ? !m_mirror.empty() : m_buffer != VK_NULL_HANDLE );
+}
+
+uint32_t Tr2ConstantBufferAL::GetSize() const
+{
+	return m_size;
+}
+
+Tr2ALMemoryType Tr2ConstantBufferAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2ConstantBufferAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2ConstantBufferAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2ConstantBufferALVulkan.h b/trinityal/vulkan/Tr2ConstantBufferALVulkan.h
new file mode 100644
index 00000000..5d05e95d
--- /dev/null
+++ b/trinityal/vulkan/Tr2ConstantBufferALVulkan.h
@@ -0,0 +1,83 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2ConstantBufferAL.h"
+#include "VulkanCommon.h"
+
+namespace TrinityALImpl
+{
+/*
+  Constant buffers follow the DX11 backend's semantics:
+
+  - ONE_SHOT buffers have no GPU buffer of their own. Lock/Unlock write a CPU
+    mirror, and the contents are snapshotted into the frame's transient ring
+    buffer every time a draw binds them, so consecutive Lock/draw pairs each
+    see their own version of the data.
+  - REUSABLE (and IMMUTABLE) buffers own a persistently mapped VkBuffer.
+    Lock has WRITE_DISCARD semantics: it renames to a fresh buffer so draws
+    recorded before the Lock keep reading the previous contents.
+ */
+class Tr2ConstantBufferAL : public Tr2DeviceResourceAL<Tr2ConstantBufferAL>
+{
+public:
+	Tr2ConstantBufferAL();
+	~Tr2ConstantBufferAL();
+
+	ALResult Create( uint32_t size, Tr2ConstantUsageAL::Type usage, const void* initialData, Tr2RenderContextAL& renderContext );
+	void Destroy();
+
+	ALResult Lock( void** data, Tr2RenderContextAL& renderContext );
+	ALResult Unlock( Tr2RenderContextAL& renderContext );
+
+	bool IsValid() const;
+	uint32_t GetSize() const;
+	Tr2ALMemoryType GetMemoryClass() const;
+	void Describe( Tr2DeviceResourceDescriptionAL& description ) const;
+	ALResult SetName( const char* name );
+
+	bool IsOneShot() const
+	{
+		return m_usage == Tr2ConstantUsageAL::ONE_SHOT;
+	}
+
+	// The CPU mirror holding a ONE_SHOT buffer's current contents.
+	const void* GetMirrorData() const
+	{
+		return m_mirror.get();
+	}
+
+	// The current contents as visible to the CPU: the mirror for ONE_SHOT
+	// buffers, the persistently mapped memory otherwise. Used when embedding
+	// local materials into shader binding table records.
+	const void* GetContents() const
+	{
+		return IsOneShot() ? m_mirror.get() : m_mappedData;
+	}
+
+	VkBuffer GetVkBuffer() const
+	{
+		return m_buffer;
+	}
+
+private:
+	Tr2ConstantBufferAL( const Tr2ConstantBufferAL& ) = delete;
+	Tr2ConstantBufferAL& operator=( const Tr2ConstantBufferAL& ) = delete;
+
+	ALResult CreateDeviceBuffer( const void* initialData );
+
+	Tr2ConstantUsageAL::Type m_usage;
+	CcpMallocBuffer m_mirror;
+	VkBuffer m_buffer;
+	VmaAllocation m_allocation;
+	void* m_mappedData;
+	uint32_t m_size;
+	bool m_isLocked;
+
+	friend class Tr2RenderContextAL;
+};
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2FenceALVulkan.cpp b/trinityal/vulkan/Tr2FenceALVulkan.cpp
new file mode 100644
index 00000000..7442ece1
--- /dev/null
+++ b/trinityal/vulkan/Tr2FenceALVulkan.cpp
@@ -0,0 +1,137 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2FenceALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+Tr2FenceAL::Tr2FenceAL() :
+	m_fence( VK_NULL_HANDLE ),
+	m_hasFence( false )
+{
+}
+
+Tr2FenceAL::~Tr2FenceAL()
+{
+	Destroy();
+}
+
+ALResult Tr2FenceAL::Create( Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDARG;
+	}
+
+	VkFenceCreateInfo fenceCreateInfo = {};
+	fenceCreateInfo.sType = VK_STRUCTURE_TYPE_FENCE_CREATE_INFO;
+	VK_CR_RETURN_HR( vkCreateFence( context->GetDevice(), &fenceCreateInfo, nullptr, &m_fence ) );
+	return S_OK;
+}
+
+void Tr2FenceAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( m_fence != VK_NULL_HANDLE && context && context->IsValid() )
+	{
+		vkDestroyFence( context->GetDevice(), m_fence, nullptr );
+	}
+	m_fence = VK_NULL_HANDLE;
+	m_hasFence = false;
+}
+
+bool Tr2FenceAL::IsValid() const
+{
+	return m_fence != VK_NULL_HANDLE;
+}
+
+ALResult Tr2FenceAL::PutFence( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( m_hasFence )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	VK_CR_RETURN_HR( vkResetFences( context->GetDevice(), 1, &m_fence ) );
+	CR_RETURN_HR( context->Flush( m_fence ) );
+	m_hasFence = true;
+	return S_OK;
+}
+
+ALResult Tr2FenceAL::IsReached( bool& isReached, Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !m_hasFence )
+	{
+		isReached = true;
+		return S_OK;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	VkResult result = vkGetFenceStatus( context->GetDevice(), m_fence );
+	if( result == VK_SUCCESS )
+	{
+		isReached = true;
+	}
+	else if( result == VK_NOT_READY )
+	{
+		isReached = false;
+	}
+	else
+	{
+		return VkResultToALResult( result );
+	}
+	return S_OK;
+}
+
+ALResult Tr2FenceAL::Wait( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !m_hasFence )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	VK_CR_RETURN_HR( vkWaitForFences( context->GetDevice(), 1, &m_fence, VK_TRUE, UINT64_MAX ) );
+	m_hasFence = false;
+	return S_OK;
+}
+
+void Tr2FenceAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2FenceAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2FenceALVulkan.h b/trinityal/vulkan/Tr2FenceALVulkan.h
new file mode 100644
index 00000000..c3835a6a
--- /dev/null
+++ b/trinityal/vulkan/Tr2FenceALVulkan.h
@@ -0,0 +1,41 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2FenceAL.h"
+#include "VulkanCommon.h"
+
+namespace TrinityALImpl
+{
+class Tr2FenceAL : public Tr2DeviceResourceAL<Tr2FenceAL>
+{
+public:
+	Tr2FenceAL();
+	~Tr2FenceAL();
+
+	ALResult Create( Tr2PrimaryRenderContextAL& renderContext );
+	void Destroy();
+
+	bool IsValid() const;
+
+	ALResult PutFence( Tr2RenderContextAL& renderContext );
+	ALResult IsReached( bool& isReached, Tr2RenderContextAL& renderContext );
+	ALResult Wait( Tr2RenderContextAL& renderContext );
+
+	Tr2ALMemoryType GetMemoryClass() const
