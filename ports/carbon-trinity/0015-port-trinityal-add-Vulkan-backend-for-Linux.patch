diff --git a/trinityal/vulkan/VulkanBindingModel.h b/trinityal/vulkan/VulkanBindingModel.h
new file mode 100644
index 00000000..7c0d53f4
--- /dev/null
+++ b/trinityal/vulkan/VulkanBindingModel.h
@@ -0,0 +1,70 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../Tr2RenderContextEnum.h"
+
+/*
+  SPIR-V binding model for the Vulkan backend.
+
+  HLSL shaders address resources through per-stage register namespaces
+  (b#, t#, s#, u#). Vulkan uses (descriptor set, binding) pairs that are
+  shared between all stages of a pipeline. This backend flattens the HLSL
+  namespaces into a single descriptor set 0:
+
+      binding = stage * STAGE_STRIDE + classOffset + registerIndex
+
+  where stage is the Tr2RenderContextEnum::ShaderType and classOffset is
+  CBV/SRV/SAMPLER/UAV_OFFSET below.
+
+  Shaders MUST be compiled with dxc using matching shifts, e.g. for a
+  vertex shader (stage 0):
+
+      dxc -spirv -T vs_6_0 -E main
+          -fvk-b-shift   0 0    (stage*128 + 0)
+          -fvk-t-shift  32 0    (stage*128 + 32)
+          -fvk-s-shift  64 0    (stage*128 + 64)
+          -fvk-u-shift  96 0    (stage*128 + 96)
+
+  and for a pixel shader (stage 1) the shifts become 128/160/192/224.
+  Only HLSL register space0 is supported.
+ */
+namespace TrinityALImpl
+{
+namespace VulkanBindingModel
+{
+
+const uint32_t DESCRIPTOR_SET = 0;
+const uint32_t STAGE_STRIDE = 128;
+
+const uint32_t CBV_OFFSET = 0;
+const uint32_t SRV_OFFSET = 32;
+const uint32_t SAMPLER_OFFSET = 64;
+const uint32_t UAV_OFFSET = 96;
+
+inline uint32_t GetCbvBinding( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex )
+{
+	return stage * STAGE_STRIDE + CBV_OFFSET + registerIndex;
+}
+
+inline uint32_t GetSrvBinding( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex )
+{
+	return stage * STAGE_STRIDE + SRV_OFFSET + registerIndex;
+}
+
+inline uint32_t GetSamplerBinding( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex )
+{
+	return stage * STAGE_STRIDE + SAMPLER_OFFSET + registerIndex;
+}
+
+inline uint32_t GetUavBinding( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex )
+{
+	return stage * STAGE_STRIDE + UAV_OFFSET + registerIndex;
+}
+
+}
+}
+
+#endif
diff --git a/trinityal/vulkan/VulkanCommon.cpp b/trinityal/vulkan/VulkanCommon.cpp
new file mode 100644
index 00000000..ebcbe054
