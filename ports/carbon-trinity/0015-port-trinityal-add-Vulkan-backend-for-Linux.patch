+// Vertex binding used to feed zeros to shader inputs the bound vertex layout
+// does not provide (all streams live in bindings 0..MAX_STREAMS-1).
+const uint32_t DUMMY_VERTEX_BINDING = 15;
+
+VkFormat GetDummyAttributeFormat( Tr2ShaderPipelineInputAL::Type type, uint32_t dimension )
+{
+	const uint32_t index = std::min( std::max( dimension, 1u ), 4u ) - 1;
+	switch( type )
+	{
+	case Tr2ShaderPipelineInputAL::INT:
+	{
+		static const VkFormat sint[] = { VK_FORMAT_R32_SINT, VK_FORMAT_R32G32_SINT, VK_FORMAT_R32G32B32_SINT, VK_FORMAT_R32G32B32A32_SINT };
+		return sint[index];
+	}
+	case Tr2ShaderPipelineInputAL::UINT:
+	{
+		static const VkFormat uint[] = { VK_FORMAT_R32_UINT, VK_FORMAT_R32G32_UINT, VK_FORMAT_R32G32B32_UINT, VK_FORMAT_R32G32B32A32_UINT };
+		return uint[index];
+	}
+	default:
+	{
+		static const VkFormat sfloat[] = { VK_FORMAT_R32_SFLOAT, VK_FORMAT_R32G32_SFLOAT, VK_FORMAT_R32G32B32_SFLOAT, VK_FORMAT_R32G32B32A32_SFLOAT };
+		return sfloat[index];
+	}
+	}
+}
