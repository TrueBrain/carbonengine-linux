+// -------------------------------------------------------------
+// Description:
+//   See http://carbon/wiki/Tr2RenderContext
+//
+//   Vulkan render context. Device, resource and synchronisation management
+//   are backed by real Vulkan objects (see VulkanContext); the draw path
+//   tracks state but does not execute draws yet — graphics pipeline creation
+//   is blocked on SPIR-V output from the shader compiler and lands together
+//   with it.
+// -------------------------------------------------------------
+class Tr2RenderContextAL
+{
+public:
+	Tr2RenderContextAL();
+	~Tr2RenderContextAL();
+	void Destroy();
+
+	static void SetPrimaryRenderContext( Tr2PrimaryRenderContextAL* );
