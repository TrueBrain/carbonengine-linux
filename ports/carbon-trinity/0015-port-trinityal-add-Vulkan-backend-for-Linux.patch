+elseif(LINUX)
+
+    if (BUILD_VULKAN)
+        # SPIR-V test shaders are compiled from the DX12 HLSL sources with dxc.
+        # The -fvk-*-shift values must match trinityal/vulkan/VulkanBindingModel.h.
+        find_package(directx-dxc CONFIG REQUIRED)
+
+        if (NOT DIRECTX_DXC_TOOL)
+            message(WARNING "dxc not found (set DXC_PATH); TrinityALTest_vulkan will not be built")
+        else()
+            # Objective-C++ sources are macOS-only.
+            set(_MM_SOURCES ${_SOURCES})
+            list(FILTER _MM_SOURCES INCLUDE REGEX "\\.mm$")
+            set_source_files_properties(${_MM_SOURCES} PROPERTIES HEADER_FILE_ONLY ON)
+
+            ccp_add_executable(TrinityALTest_vulkan ${_SOURCES})
+            target_link_libraries(TrinityALTest_vulkan PRIVATE TrinityAL_vulkan)
+            target_compile_definitions(TrinityALTest_vulkan PRIVATE TRINITY_PLATFORM=TRINITY_VULKAN)
+            set_shared_trinityaltest_properties(TrinityALTest_vulkan)
+
+            # The VMA implementation normally comes from trinity/Tr2VirtualAllocator.cpp;
+            # the AL tests do not link trinity, so provide it here.
+            target_sources(TrinityALTest_vulkan PRIVATE VmaImplementation_Vulkan.cpp)
+
+            # Real test windows (and windowed presentation) when X11 is available.
+            find_package(X11 QUIET)
+            if(X11_FOUND)
+                target_compile_definitions(TrinityALTest_vulkan PRIVATE TRINITY_TEST_WITH_X11)
+                target_link_libraries(TrinityALTest_vulkan PRIVATE X11::X11)
+            endif()
+
+            set(_SHADERS_SPIRV ${_SHADERS_DX12})
+            list(FILTER _SHADERS_SPIRV EXCLUDE REGEX "\\.rsh$") # no raytracing support
+
+            foreach(shaderSource ${_SHADERS_SPIRV})
+                string(REGEX REPLACE "^Shaders.DX12/" "Shaders.SPIRV/" shaderOutput ${shaderSource})
+                string(REGEX REPLACE "h$" ".h" shaderOutput ${shaderOutput})
+                # Stage index from Tr2RenderContextEnum::ShaderType: VS=0, PS=1, CS=2.
+                if(${shaderSource} MATCHES ".*psh$")
+                    set(SHADER_TARGET "-Tps_6_0")
+                    set(STAGE_BASE 128)
+                elseif(${shaderSource} MATCHES ".*vsh$")
+                    set(SHADER_TARGET "-Tvs_6_0")
+                    set(STAGE_BASE 0)
+                else()
+                    set(SHADER_TARGET "-Tcs_6_0")
+                    set(STAGE_BASE 256)
+                endif()
+                math(EXPR SHIFT_B "${STAGE_BASE} + 0")
+                math(EXPR SHIFT_T "${STAGE_BASE} + 32")
+                math(EXPR SHIFT_S "${STAGE_BASE} + 64")
+                math(EXPR SHIFT_U "${STAGE_BASE} + 96")
+                add_custom_command(
+                    OUTPUT ${GENERATED_SOURCES_DIR}/${shaderOutput}
+                    COMMAND ${CMAKE_COMMAND} -E make_directory ${GENERATED_SOURCES_DIR}/Shaders.SPIRV ${GENERATED_SOURCES_DIR}/Shaders.DX12
+                    COMMAND ${DIRECTX_DXC_TOOL} -spirv ${SHADER_TARGET} -Emain
+                            -fvk-b-shift ${SHIFT_B} 0
+                            -fvk-t-shift ${SHIFT_T} 0
+                            -fvk-s-shift ${SHIFT_S} 0
+                            -fvk-u-shift ${SHIFT_U} 0
+                            -Fo ${GENERATED_SOURCES_DIR}/${shaderSource}.spv ${CMAKE_CURRENT_SOURCE_DIR}/${shaderSource}
+                    COMMAND python3 ${CMAKE_CURRENT_SOURCE_DIR}/bin2h.cmd ${GENERATED_SOURCES_DIR}/${shaderSource}.spv ${GENERATED_SOURCES_DIR}/${shaderOutput}
+                    MAIN_DEPENDENCY ${shaderSource}
+                )
+                target_sources(TrinityALTest_vulkan PRIVATE ${GENERATED_SOURCES_DIR}/${shaderOutput})
+            endforeach()
+
+            set_target_properties(TrinityALTest_vulkan PROPERTIES FOLDER "Tests")
+        endif()
+    endif()
+
 endif()
 
 
