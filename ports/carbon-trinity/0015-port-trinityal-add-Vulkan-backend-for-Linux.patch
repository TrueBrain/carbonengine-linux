+
+ALResult Tr2TextureAL::MapForReading( const Tr2TextureSubresource& region, bool synchronize, const void*& data, uint32_t& pitch, Tr2RenderContextAL& renderContext )
+{
+	data = nullptr;
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::READ ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !region.IsValidForBitmap( m_desc ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( !region.IsSingleSubresource() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	const uint32_t mip = region.m_startMipLevel;
+	const uint32_t mipPitch = m_desc.GetMipPitch( mip );
+	const uint32_t rows = std::max( m_desc.GetMipNumRows( mip ), 1u );
+	const size_t size = (size_t)mipPitch * rows;
+
+	if( m_mapData.size() != size )
+	{
+		m_mapData.resize( "Tr2TextureAL::m_mapData", size );
+		if( m_mapData.empty() )
+		{
+			return E_FAIL;
+		}
+	}
+
+	if( synchronize )
+	{
+		CR_RETURN_HR( context->FlushAndWait() );
+	}
+
+	// Read the subresource back through a staging buffer.
+	VkBuffer staging = VK_NULL_HANDLE;
+	VmaAllocation stagingAllocation = VK_NULL_HANDLE;
+	void* stagingData = nullptr;
+	CR_RETURN_HR( context->CreateStagingBuffer( size, VK_BUFFER_USAGE_TRANSFER_DST_BIT, staging, stagingAllocation, stagingData ) );
+
+	ALResult result = context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkBufferImageCopy copy = {};
+		copy.imageSubresource.aspectMask = GetFormatAspectFlags( m_format ) & ~VK_IMAGE_ASPECT_STENCIL_BIT;
+		copy.imageSubresource.mipLevel = mip;
+		copy.imageSubresource.baseArrayLayer = region.m_startFace;
+		copy.imageSubresource.layerCount = 1;
+		copy.imageExtent.width = m_desc.GetMipWidth( mip );
+		copy.imageExtent.height = m_desc.GetMipHeight( mip );
+		copy.imageExtent.depth = 1;
+		vkCmdCopyImageToBuffer( commandBuffer, m_image, VK_IMAGE_LAYOUT_GENERAL, staging, 1, &copy );
+	} );
+
+	if( SUCCEEDED( result ) )
+	{
+		vmaInvalidateAllocation( context->GetAllocator(), stagingAllocation, 0, size );
+		memcpy( m_mapData.get(), stagingData, size );
+	}
+	vmaDestroyBuffer( context->GetAllocator(), staging, stagingAllocation );
+	CR_RETURN_HR( result );
+
+	pitch = mipPitch;
+	data = m_mapData.get();
+	return S_OK;
+}
+
+void Tr2TextureAL::UnmapForReading( Tr2RenderContextAL& )
+{
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::READ_OFTEN ) && !HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE_OFTEN ) )
+	{
+		m_mapData.clear();
+	}
+}
+
+ALResult Tr2TextureAL::MapForWriting( const Tr2TextureSubresource& region, void*& data, uint32_t& pitch, Tr2RenderContextAL& renderContext )
+{
+	data = nullptr;
+
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !region.IsValidForBitmap( m_desc ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( !region.IsSingleSubresource() )
+	{
+		return E_INVALIDARG;
+	}
+	if( region.HasBox() && Tr2RenderContextEnum::IsCompressedFormat( m_desc.GetFormat() ) )
+	{
+		return E_INVALIDARG;
+	}
+
+	const uint32_t mip = region.m_startMipLevel;
+	const uint32_t mipPitch = m_desc.GetMipPitch( mip );
+	const uint32_t rows = std::max( m_desc.GetMipNumRows( mip ), 1u );
+	const size_t size = (size_t)mipPitch * rows;
+
+	if( m_mapData.size() != size )
+	{
+		m_mapData.resize( "Tr2TextureAL::m_mapData", size );
+		if( m_mapData.empty() )
+		{
+			return E_FAIL;
+		}
+	}
+
+	m_mappedRegion = region;
+	pitch = mipPitch;
+	data = m_mapData.get();
+	return S_OK;
+}
+
+void Tr2TextureAL::UnmapForWriting( Tr2RenderContextAL& )
+{
+	if( !m_mapData.empty() )
+	{
+		const uint32_t mip = m_mappedRegion.m_startMipLevel;
+		UploadSubresource( m_mappedRegion, m_mapData.get(), m_desc.GetMipPitch( mip ), (uint32_t)m_mapData.size() );
+	}
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::READ_OFTEN ) && !HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE_OFTEN ) )
+	{
+		m_mapData.clear();
+	}
+}
+
+ALResult Tr2TextureAL::UpdateSubresource( const Tr2TextureSubresource& region, const void* source, uint32_t pitch, uint32_t slicePitch, Tr2RenderContextAL& renderContext )
+{
+	if( HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE_OFTEN ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE ) && !IsWritable( m_gpuUsage ) )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !region.IsValidForBitmap( m_desc ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( !region.IsSingleSubresource() )
+	{
+		return E_INVALIDARG;
+	}
+
+	return UploadSubresource( region, source, pitch, slicePitch );
+}
+
+ALResult Tr2TextureAL::CopySubresourceRegion( const Tr2TextureSubresource& destSubresource, Tr2TextureAL& source, const Tr2TextureSubresource& sourceSubresource, Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !source.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	if( !HasFlag( m_cpuUsage, Tr2CpuUsage::WRITE ) && !IsWritable( m_gpuUsage ) )
+	{
+		return E_INVALIDCALL;
+	}
+
+	Tr2TextureSubresource src = sourceSubresource;
+	Tr2TextureSubresource dst = destSubresource;
+
+	if( !destSubresource.IsSubresourceFull( m_desc ) || !sourceSubresource.IsSubresourceFull( source.m_desc ) )
+	{
+		if( !Crop( src, source.m_desc, dst, m_desc ) )
+		{
+			return E_FAIL;
+		}
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	return context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		std::vector<VkImageCopy> regions;
+		const uint32_t mipCount = std::min( src.GetMipCount(), dst.GetMipCount() );
+		const uint32_t faceCount = std::min( src.GetFaceCount(), dst.GetFaceCount() );
+		for( uint32_t mipIndex = 0; mipIndex < mipCount; ++mipIndex )
+		{
+			const uint32_t srcMip = src.m_startMipLevel + mipIndex;
+			const uint32_t dstMip = dst.m_startMipLevel + mipIndex;
+			VkImageCopy copy = {};
+			copy.srcSubresource.aspectMask = GetFormatAspectFlags( source.m_format );
+			copy.srcSubresource.mipLevel = srcMip;
+			copy.srcSubresource.baseArrayLayer = src.m_startFace;
+			copy.srcSubresource.layerCount = faceCount;
+			copy.dstSubresource.aspectMask = GetFormatAspectFlags( m_format );
+			copy.dstSubresource.mipLevel = dstMip;
+			copy.dstSubresource.baseArrayLayer = dst.m_startFace;
+			copy.dstSubresource.layerCount = faceCount;
+			if( src.HasBox() )
+			{
+				copy.srcOffset = { (int32_t)src.m_box.left, (int32_t)src.m_box.top, (int32_t)src.m_box.front };
+				copy.dstOffset = { (int32_t)dst.m_box.left, (int32_t)dst.m_box.top, (int32_t)dst.m_box.front };
+				copy.extent = { src.GetWidth(), src.GetHeight(), std::max( src.GetDepth(), 1u ) };
+			}
+			else
+			{
+				copy.extent.width = std::min( source.m_desc.GetMipWidth( srcMip ), m_desc.GetMipWidth( dstMip ) );
+				copy.extent.height = std::min( source.m_desc.GetMipHeight( srcMip ), m_desc.GetMipHeight( dstMip ) );
+				copy.extent.depth = std::max( std::min( source.m_desc.GetMipDepth( srcMip ), m_desc.GetMipDepth( dstMip ) ), 1u );
+			}
+			regions.push_back( copy );
+		}
+		vkCmdCopyImage( commandBuffer, source.m_image, VK_IMAGE_LAYOUT_GENERAL, m_image, VK_IMAGE_LAYOUT_GENERAL, (uint32_t)regions.size(), regions.data() );
+	} );
+}
+
+ALResult Tr2TextureAL::GenerateMipMaps( Tr2RenderContextAL& )
+{
+	if( !Tr2GpuUsage::HasFlag( m_gpuUsage, Tr2GpuUsage::RENDER_TARGET ) || !Tr2GpuUsage::HasFlag( m_gpuUsage, Tr2GpuUsage::SHADER_RESOURCE ) )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	return context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		for( uint32_t mip = 1; mip < m_desc.GetTrueMipCount(); ++mip )
+		{
+			VkImageBlit blit = {};
+			blit.srcSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+			blit.srcSubresource.mipLevel = mip - 1;
+			blit.srcSubresource.layerCount = m_desc.GetArraySize();
+			blit.srcOffsets[1] = { (int32_t)m_desc.GetMipWidth( mip - 1 ), (int32_t)m_desc.GetMipHeight( mip - 1 ), 1 };
+			blit.dstSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+			blit.dstSubresource.mipLevel = mip;
+			blit.dstSubresource.layerCount = m_desc.GetArraySize();
+			blit.dstOffsets[1] = { (int32_t)m_desc.GetMipWidth( mip ), (int32_t)m_desc.GetMipHeight( mip ), 1 };
+			vkCmdBlitImage( commandBuffer, m_image, VK_IMAGE_LAYOUT_GENERAL, m_image, VK_IMAGE_LAYOUT_GENERAL, 1, &blit, VK_FILTER_LINEAR );
+
+			VkMemoryBarrier barrier = {};
+			barrier.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+			barrier.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT;
+			barrier.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+			vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 1, &barrier, 0, nullptr, 0, nullptr );
+		}
+	} );
+}
+
+ALResult Tr2TextureAL::Resolve( Tr2TextureAL& destination, Tr2RenderContextAL& renderContext )
+{
+	if( m_msaa.samples <= 1 )
+	{
+		return destination.CopySubresourceRegion( Tr2TextureSubresource(), *this, Tr2TextureSubresource(), renderContext );
+	}
+
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !destination.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	if( !HasFlag( destination.m_cpuUsage, Tr2CpuUsage::WRITE ) && !IsWritable( destination.m_gpuUsage ) )
+	{
+		return E_INVALIDARG;
+	}
+	if( m_desc.GetWidth() != destination.m_desc.GetWidth() || m_desc.GetHeight() != destination.m_desc.GetHeight() )
+	{
+		return E_INVALIDARG;
+	}
+	if( m_desc.GetFormat() != destination.m_desc.GetFormat() )
+	{
+		return E_INVALIDARG;
+	}
+	if( destination.m_msaa.samples > 1 )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_FAIL;
+	}
+
+	return context->ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+		VkImageResolve resolve = {};
+		resolve.srcSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+		resolve.srcSubresource.layerCount = 1;
+		resolve.dstSubresource.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+		resolve.dstSubresource.layerCount = 1;
+		resolve.extent = { m_desc.GetWidth(), m_desc.GetHeight(), 1 };
+		vkCmdResolveImage( commandBuffer, m_image, VK_IMAGE_LAYOUT_GENERAL, destination.m_image, VK_IMAGE_LAYOUT_GENERAL, 1, &resolve );
+	} );
+}
