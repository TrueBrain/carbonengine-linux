+ALResult Tr2ResourceSetAL::Create( const Tr2ResourceSetDescriptionAL& description, const ::Tr2ShaderProgramAL& program, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !program.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	m_description = description;
+	m_isValid = true;
+	return S_OK;
+}
+
+bool Tr2ResourceSetAL::IsValid() const
+{
+	return m_isValid;
+}
+
+bool Tr2ResourceSetAL::GetSrvTexture( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex, ::Tr2TextureAL& texture ) const
+{
+	if( registerIndex >= Tr2RegisterMapAL::MAX_RESOURCES_IN_STAGE )
+	{
+		return false;
+	}
+	uint8_t packedIndex = m_description.m_registerMap.srvs[stage][registerIndex];
+	if( packedIndex == 0xff || !m_description.m_srv )
+	{
+		return false;
+	}
+	const auto& resource = m_description.m_srv[packedIndex];
+	if( resource.type != Tr2ResourceSetDescriptionAL::Resource::TEXTURE )
+	{
+		return false;
+	}
+	texture = resource.texture;
+	return true;
+}
+
+bool Tr2ResourceSetAL::GetSrvBuffer( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex, ::Tr2BufferAL& buffer ) const
+{
+	if( registerIndex >= Tr2RegisterMapAL::MAX_RESOURCES_IN_STAGE )
+	{
+		return false;
+	}
+	uint8_t packedIndex = m_description.m_registerMap.srvs[stage][registerIndex];
+	if( packedIndex == 0xff || !m_description.m_srv )
+	{
+		return false;
+	}
+	const auto& resource = m_description.m_srv[packedIndex];
+	if( resource.type != Tr2ResourceSetDescriptionAL::Resource::BUFFER )
+	{
+		return false;
+	}
+	buffer = resource.buffer;
+	return true;
+}
+
+bool Tr2ResourceSetAL::GetUavTexture( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex, ::Tr2TextureAL& texture, uint32_t& mip ) const
+{
+	if( registerIndex >= Tr2RegisterMapAL::MAX_RESOURCES_IN_STAGE )
+	{
+		return false;
+	}
+	uint8_t packedIndex = m_description.m_registerMap.uavs[stage][registerIndex];
+	if( packedIndex == 0xff || !m_description.m_uav )
+	{
+		return false;
+	}
+	const auto& resource = m_description.m_uav[packedIndex];
+	if( resource.type != Tr2ResourceSetDescriptionAL::Resource::TEXTURE )
+	{
+		return false;
+	}
+	texture = resource.texture;
+	mip = resource.mip;
+	return true;
+}
+
+bool Tr2ResourceSetAL::GetUavBuffer( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex, ::Tr2BufferAL& buffer ) const
+{
+	if( registerIndex >= Tr2RegisterMapAL::MAX_RESOURCES_IN_STAGE )
+	{
+		return false;
+	}
+	uint8_t packedIndex = m_description.m_registerMap.uavs[stage][registerIndex];
+	if( packedIndex == 0xff || !m_description.m_uav )
+	{
+		return false;
+	}
+	const auto& resource = m_description.m_uav[packedIndex];
+	if( resource.type != Tr2ResourceSetDescriptionAL::Resource::BUFFER )
+	{
+		return false;
+	}
+	buffer = resource.buffer;
+	return true;
+}
+
+bool Tr2ResourceSetAL::GetSampler( Tr2RenderContextEnum::ShaderType stage, uint32_t registerIndex, ::Tr2SamplerStateAL& sampler ) const
+{
+	if( registerIndex >= Tr2RegisterMapAL::MAX_RESOURCES_IN_STAGE )
+	{
+		return false;
+	}
+	uint8_t packedIndex = m_description.m_registerMap.samplers[stage][registerIndex];
+	if( packedIndex == 0xff || !m_description.m_samplers )
+	{
+		return false;
+	}
+	const auto& entry = m_description.m_samplers[packedIndex];
+	if( entry.type != Tr2ResourceSetDescriptionAL::Sampler::SAMPLER )
+	{
+		return false;
+	}
+	sampler = entry.sampler;
+	return true;
