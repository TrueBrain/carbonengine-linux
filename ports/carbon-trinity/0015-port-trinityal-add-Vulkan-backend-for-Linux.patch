+
+private:
+	ALResult UploadSubresource( const Tr2TextureSubresource& region, const void* source, uint32_t pitch, uint32_t slicePitch );
+	ALResult CreateViews();
+	VkImageSubresourceRange GetFullSubresourceRange() const;
