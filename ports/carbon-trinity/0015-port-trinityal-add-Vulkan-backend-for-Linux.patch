+#include <vector>
+
+namespace TrinityALImpl
+{
+
+/*
+  Owns the process-wide VkInstance and the enumerated physical devices.
+  This exists separately from VulkanContext because Tr2VideoAdapterInfo has to
+  enumerate adapters before a device (VulkanContext) has been created.
+ */
+class VulkanInstance
+{
+public:
+	static VulkanInstance& Get();
+
+	bool IsValid() const
+	{
+		return m_instance != VK_NULL_HANDLE;
+	}
+
+	VkInstance GetInstance() const
+	{
+		return m_instance;
+	}
+
+	const std::vector<VkPhysicalDevice>& GetPhysicalDevices() const
+	{
+		return m_physicalDevices;
+	}
+
+	VkPhysicalDevice GetPhysicalDevice( uint32_t adapterIndex ) const;
+
+	bool SupportsSurfaces() const
+	{
+		return m_supportsSurfaces;
+	}
+
+private:
+	VulkanInstance();
+	~VulkanInstance();
+	VulkanInstance( const VulkanInstance& ) = delete;
+	VulkanInstance& operator=( const VulkanInstance& ) = delete;
+
+	VkInstance m_instance;
+	std::vector<VkPhysicalDevice> m_physicalDevices;
+	bool m_supportsSurfaces;
+};
+
+/*
+  A VulkanContext is per-device state, similar in spirit to MetalContext: the
+  logical device, its queue, the memory allocator and the command recording /
+  submission machinery live here so that resource classes can share them.
+ */
+class VulkanContext
+{
+public:
+	VulkanContext();
+	~VulkanContext();
+
+	ALResult Create( uint32_t adapterIndex );
+	void Destroy();
+
+	bool IsValid() const
+	{
+		return m_device != VK_NULL_HANDLE;
+	}
+
+	VkPhysicalDevice GetPhysicalDevice() const
+	{
+		return m_physicalDevice;
+	}
+
+	VkDevice GetDevice() const
+	{
+		return m_device;
+	}
+
+	VkQueue GetQueue() const
+	{
+		return m_queue;
+	}
+
+	uint32_t GetQueueFamilyIndex() const
+	{
+		return m_queueFamilyIndex;
+	}
+
+	VmaAllocator GetAllocator() const
+	{
+		return m_allocator;
+	}
+
+	const VkPhysicalDeviceProperties& GetDeviceProperties() const
+	{
+		return m_deviceProperties;
+	}
+
+	const VkPhysicalDeviceFeatures& GetDeviceFeatures() const
+	{
+		return m_deviceFeatures;
+	}
+
+	// Command buffer currently being recorded; begins recording on demand.
+	// Ends any active dynamic rendering scope first, so the returned buffer
+	// is ready for transfer/clear/dispatch commands.
+	VkCommandBuffer GetCommandBuffer();
+
+	// Begins (or continues) a dynamic rendering scope for the given targets
+	// and returns the command buffer to record draws into. `hash` identifies
+	// the attachment configuration; a differing hash restarts the scope.
+	VkCommandBuffer BeginRenderingScope( const VkRenderingInfo& renderingInfo, uint64_t hash );
+	void EndRenderingScope();
+
+	bool SupportsDynamicRendering() const
+	{
+		return m_supportsDynamicRendering;
+	}
+
+	// Descriptor sets live for one frame; the pool is reset when the frame's
+	// work has provably completed.
+	VkDescriptorSet AllocateDescriptorSet( VkDescriptorSetLayout layout );
+
+	// Transient vertex/index data for the DrawUP paths; valid until the next
+	// EndFrame().
+	ALResult AllocateTransientData( VkDeviceSize size, VkDeviceSize alignment, VkBuffer& buffer, VkDeviceSize& offset, void*& data );
+
+	// Fallback resources bound to descriptor slots the application left
+	// empty. All are tiny, zero-filled and created on first use.
+	VkBuffer GetDummyUniformBuffer();
+	VkBuffer GetDummyStorageBuffer();
+	VkBufferView GetDummyUniformTexelBufferView();
+	VkBufferView GetDummyStorageTexelBufferView();
+	VkImageView GetDummyImageView( VkImageViewType viewType );
+	VkSampler GetDummySampler();
+
+	// Pipeline cache shared by graphics and compute pipelines. Add returns
+	// the canonical pipeline for the hash (the given one, or a pre-existing
+	// one, in which case the given pipeline is destroyed).
+	VkPipeline GetCachedPipeline( uint64_t hash );
+	VkPipeline AddPipelineToCache( uint64_t hash, VkPipeline pipeline );
+
+	// Submits the command buffer currently being recorded (if any).
+	// The optional fence is signaled by the submission; if there is nothing
+	// to submit, an empty submission is made so the fence still signals.
+	ALResult Flush( VkFence signalFence = VK_NULL_HANDLE );
+
+	// Submits pending work and blocks until the GPU has finished all of it.
+	ALResult FlushAndWait();
+
+	// Records commands into a one-shot command buffer and waits for completion.
+	// Used for resource uploads and readbacks outside the frame stream.
+	ALResult ImmediateSubmit( const std::function<void( VkCommandBuffer )>& record );
+
+	// Creates a host-visible staging buffer. The caller owns the result and
+	// must destroy it through the allocator (or DestroyBufferLater).
+	ALResult CreateStagingBuffer( VkDeviceSize size, VkBufferUsageFlags usage, VkBuffer& buffer, VmaAllocation& allocation, void*& mappedData );
+
+	// Deferred destruction: resources are destroyed once the GPU is done with
+	// the frame that last used them.
+	void DestroyBufferLater( VkBuffer buffer, VmaAllocation allocation );
+	void DestroyBufferViewLater( VkBufferView view );
+	void DestroyImageLater( VkImage image, VmaAllocation allocation );
+	void DestroyImageViewLater( VkImageView view );
+	void FlushPendingDestroys( bool force );
+
+	uint64_t GetRecordingFrameNumber() const
+	{
+		return m_recordingFrameNumber;
+	}
+
+	uint64_t GetRenderedFrameNumber() const
+	{
+		return m_renderedFrameNumber;
+	}
+
+	// Ends the current frame: submits outstanding work and advances the frame
+	// counters. Called from Tr2RenderContextAL::Present().
+	ALResult EndFrame();
+
+	double GetTimestampPeriod() const
+	{
+		return m_deviceProperties.limits.timestampPeriod;
+	}
+
+	bool SupportsTimestamps() const;
+	bool SupportsPipelineStatistics() const;
+
+private:
+	ALResult SelectQueueFamily();
+	ALResult CreateDescriptorPool();
+	ALResult CreateTransientBuffer();
+	void DestroyDummyResources();
+
+	VkPhysicalDevice m_physicalDevice;
+	VkPhysicalDeviceProperties m_deviceProperties;
+	VkPhysicalDeviceFeatures m_deviceFeatures;
+	VkDevice m_device;
+	VkQueue m_queue;
+	uint32_t m_queueFamilyIndex;
+	VmaAllocator m_allocator;
+
+	VkCommandPool m_commandPool;
+	VkCommandBuffer m_commandBuffer;
+	bool m_isRecording;
+	bool m_supportsDynamicRendering;
+
+	bool m_renderingActive;
+	uint64_t m_renderingHash;
+
+	VkDescriptorPool m_descriptorPool;
+
+	VkBuffer m_transientBuffer;
+	VmaAllocation m_transientAllocation;
+	void* m_transientData;
+	VkDeviceSize m_transientOffset;
+
+	VkBuffer m_dummyBuffer;
+	VmaAllocation m_dummyBufferAllocation;
+	VkBufferView m_dummyUniformTexelView;
+	VkBufferView m_dummyStorageTexelView;
+	VkImage m_dummyImage;
+	VmaAllocation m_dummyImageAllocation;
+	VkImage m_dummyImage3D;
+	VmaAllocation m_dummyImage3DAllocation;
+	std::vector<std::pair<VkImageViewType, VkImageView>> m_dummyImageViews;
+	VkSampler m_dummySampler;
+
+	std::unordered_map<uint64_t, VkPipeline> m_pipelineCache;
+	std::mutex m_pipelineCacheMutex;
+
+	uint64_t m_recordingFrameNumber;
+	uint64_t m_renderedFrameNumber;
+
+	struct PendingDestroy
+	{
+		uint64_t frame;
+		VkBuffer buffer;
+		VmaAllocation allocation;
+		VkImage image;
+		VkImageView view;
+		VkBufferView bufferView;
+	};
+	std::deque<PendingDestroy> m_pendingDestroys;
+	std::mutex m_pendingDestroyMutex;
+	std::mutex m_submitMutex;
+};
+
+// The device context of the (single) primary render context, shared by all
+// resource implementations. Null until Tr2RenderContextAL::CreateDevice().
+VulkanContext* GetVulkanContext();
+void SetVulkanContext( VulkanContext* context );
+
+}
+
+#endif
