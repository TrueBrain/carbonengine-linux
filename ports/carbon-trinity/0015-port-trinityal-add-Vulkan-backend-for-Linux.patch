@@ -0,0 +1,129 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2GpuTimerALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+Tr2GpuTimerAL::Tr2GpuTimerAL() :
+	m_queryPool( VK_NULL_HANDLE ),
+	m_isRunning( false ),
+	m_hasResult( false )
+{
+}
+
+Tr2GpuTimerAL::~Tr2GpuTimerAL()
+{
+	Destroy();
+}
+
+ALResult Tr2GpuTimerAL::Create( Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->SupportsTimestamps() )
+	{
+		return E_FAIL;
+	}
+
+	VkQueryPoolCreateInfo queryPoolCreateInfo = {};
+	queryPoolCreateInfo.sType = VK_STRUCTURE_TYPE_QUERY_POOL_CREATE_INFO;
+	queryPoolCreateInfo.queryType = VK_QUERY_TYPE_TIMESTAMP;
+	queryPoolCreateInfo.queryCount = 2;
+	VK_CR_RETURN_HR( vkCreateQueryPool( context->GetDevice(), &queryPoolCreateInfo, nullptr, &m_queryPool ) );
+
+	return S_OK;
+}
+
+void Tr2GpuTimerAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( m_queryPool != VK_NULL_HANDLE && context && context->IsValid() )
+	{
+		vkDestroyQueryPool( context->GetDevice(), m_queryPool, nullptr );
+	}
+	m_queryPool = VK_NULL_HANDLE;
+	m_isRunning = false;
+	m_hasResult = false;
+}
+
+bool Tr2GpuTimerAL::Begin( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() || m_isRunning )
+	{
+		return false;
+	}
+	VulkanContext* context = GetVulkanContext();
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+	vkCmdResetQueryPool( commandBuffer, m_queryPool, 0, 2 );
+	vkCmdWriteTimestamp( commandBuffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, m_queryPool, 0 );
+	m_isRunning = true;
+	m_hasResult = false;
+	return true;
+}
+
+void Tr2GpuTimerAL::End( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() || !m_isRunning )
+	{
+		return;
+	}
+	VulkanContext* context = GetVulkanContext();
+	vkCmdWriteTimestamp( context->GetCommandBuffer(), VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, m_queryPool, 1 );
+	m_isRunning = false;
+	m_hasResult = true;
+}
+
+float Tr2GpuTimerAL::GetTime( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() || m_isRunning || !m_hasResult )
+	{
+		return 0.0f;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	CR_RETURN_VAL( context->FlushAndWait(), 0.0f );
+
+	uint64_t timestamps[2] = {};
+	VkResult result = vkGetQueryPoolResults(
+		context->GetDevice(), m_queryPool, 0, 2,
+		sizeof( timestamps ), timestamps, sizeof( uint64_t ),
+		VK_QUERY_RESULT_64_BIT | VK_QUERY_RESULT_WAIT_BIT );
+	if( result != VK_SUCCESS )
+	{
+		return 0.0f;
+	}
+
+	const double nanoseconds = (double)( timestamps[1] - timestamps[0] ) * context->GetTimestampPeriod();
+	return (float)( nanoseconds / 1.0e6 ); // milliseconds
+}
+
+bool Tr2GpuTimerAL::IsValid() const
+{
+	return m_queryPool != VK_NULL_HANDLE;
+}
+
+void Tr2GpuTimerAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2GpuTimerAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
+
+#endif
