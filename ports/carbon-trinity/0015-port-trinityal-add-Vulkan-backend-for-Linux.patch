+
+ALResult Tr2PipelineStatsQueryAL::Create( Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->SupportsPipelineStatistics() )
+	{
+		return E_FAIL;
+	}
+
+	VkQueryPoolCreateInfo queryPoolCreateInfo = {};
+	queryPoolCreateInfo.sType = VK_STRUCTURE_TYPE_QUERY_POOL_CREATE_INFO;
+	queryPoolCreateInfo.queryType = VK_QUERY_TYPE_PIPELINE_STATISTICS;
+	queryPoolCreateInfo.queryCount = 1;
+	queryPoolCreateInfo.pipelineStatistics = STATISTIC_FLAGS;
+	VK_CR_RETURN_HR( vkCreateQueryPool( context->GetDevice(), &queryPoolCreateInfo, nullptr, &m_queryPool ) );
+
+	return S_OK;
+}
+
+bool Tr2PipelineStatsQueryAL::IsValid() const
+{
+	return m_queryPool != VK_NULL_HANDLE;
+}
+
+void Tr2PipelineStatsQueryAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( m_queryPool != VK_NULL_HANDLE && context && context->IsValid() )
+	{
+		vkDestroyQueryPool( context->GetDevice(), m_queryPool, nullptr );
+	}
+	m_queryPool = VK_NULL_HANDLE;
+	m_isRunning = false;
+	m_hasResult = false;
+}
+
+ALResult Tr2PipelineStatsQueryAL::Begin( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( m_isRunning )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+	vkCmdResetQueryPool( commandBuffer, m_queryPool, 0, 1 );
+	vkCmdBeginQuery( commandBuffer, m_queryPool, 0, 0 );
+	m_isRunning = true;
+	m_hasResult = false;
+	return S_OK;
+}
+
+ALResult Tr2PipelineStatsQueryAL::End( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !m_isRunning )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	vkCmdEndQuery( context->GetCommandBuffer(), m_queryPool, 0 );
+	m_isRunning = false;
+	m_hasResult = true;
+	return S_OK;
+}
+
+ALResult Tr2PipelineStatsQueryAL::GetStats( Tr2PipelineStatsDataAL& data, Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( m_isRunning || !m_hasResult )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	CR_RETURN_HR( context->FlushAndWait() );
+
+	VK_CR_RETURN_HR( vkGetQueryPoolResults(
+		context->GetDevice(), m_queryPool, 0, 1,
+		sizeof( data.m_values ), data.m_values, sizeof( data.m_values ),
+		VK_QUERY_RESULT_64_BIT | VK_QUERY_RESULT_WAIT_BIT ) );
+	return S_OK;
+}
+
+size_t Tr2PipelineStatsQueryAL::GetValueCount( const Tr2PipelineStatsDataAL& )
+{
+	return Tr2PipelineStatsDataAL::VALUE_COUNT;
+}
+
+const char* Tr2PipelineStatsQueryAL::GetLabel( const Tr2PipelineStatsDataAL&, size_t index )
+{
+	return index < Tr2PipelineStatsDataAL::VALUE_COUNT ? LABELS[index] : "";
+}
+
+const char* Tr2PipelineStatsQueryAL::GetDescription( const Tr2PipelineStatsDataAL&, size_t index )
+{
+	return index < Tr2PipelineStatsDataAL::VALUE_COUNT ? DESCRIPTIONS[index] : "";
+}
+
+::Tr2PipelineStatsQueryAL::Value Tr2PipelineStatsQueryAL::GetValue( const Tr2PipelineStatsDataAL& data, size_t index )
+{
+	return index < Tr2PipelineStatsDataAL::VALUE_COUNT ? data.m_values[index] : 0;
+}
