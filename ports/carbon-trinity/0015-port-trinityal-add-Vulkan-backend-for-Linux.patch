+#include "VulkanCommon.h"
+
+#include <vector>
+
+namespace TrinityALImpl
+{
+class Tr2SwapChainAL : public Tr2DeviceResourceAL<Tr2SwapChainAL>
+{
+public:
+	Tr2SwapChainAL();
+	~Tr2SwapChainAL();
+
+	ALResult Create( Tr2WindowHandle windowHandle, Tr2RenderContextAL& renderContext );
+	void Destroy();
