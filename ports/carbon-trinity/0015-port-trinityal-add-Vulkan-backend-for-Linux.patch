+// Converts a VkResult into the HRESULT-style ALResult used throughout TrinityAL.
+inline ALResult VkResultToALResult( VkResult result )
+{
+	switch( result )
+	{
+	case VK_SUCCESS:
+		return S_OK;
+	case VK_ERROR_OUT_OF_HOST_MEMORY:
+	case VK_ERROR_OUT_OF_DEVICE_MEMORY:
+		return E_OUTOFMEMORY;
+	case VK_ERROR_DEVICE_LOST:
+		return E_DEVICELOST;
+	default:
+		return E_FAIL;
+	}
+}
+
+#define VK_CR_RETURN_HR( x )                                                          \
+	{                                                                                 \
+		VkResult _vkResult = ( x );                                                   \
+		if( _vkResult != VK_SUCCESS )                                                 \
+		{                                                                             \
+			CCP_AL_LOGERR( #x " failed with VkResult %d", (int)_vkResult );           \
+			return TrinityALImpl::VkResultToALResult( _vkResult );                    \
+		}                                                                             \
+	}
+
+// Translates the DXGI-compatible ImageIO pixel format into a VkFormat.
+// Typeless formats resolve to their most common typed equivalent.
+VkFormat ToVkFormat( Tr2RenderContextEnum::PixelFormat format );
+
+// Translates a depth/stencil format, taking device support into account.
+VkFormat ToVkDepthStencilFormat( Tr2RenderContextEnum::DepthStencilFormat format );
+
+VkCompareOp ToVkCompareOp( Tr2RenderContextEnum::CompareFunc compareFunc );
+
+// Creates a VkSampler from an AL sampler description on the current device.
+ALResult CreateVkSampler( const Tr2SamplerDescription& description, VkSampler& sampler );
+VkSamplerAddressMode ToVkSamplerAddressMode( Tr2RenderContextEnum::TextureAddressMode addressMode );
+VkPrimitiveTopology ToVkPrimitiveTopology( Tr2RenderContextEnum::Topology topology );
+
+bool IsDepthFormat( VkFormat format );
+bool HasStencil( VkFormat format );
+VkImageAspectFlags GetFormatAspectFlags( VkFormat format );
+
+}
