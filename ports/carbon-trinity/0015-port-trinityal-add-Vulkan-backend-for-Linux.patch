+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2RtShaderTableAL.h"
+#include "VulkanCommon.h"
+
+namespace TrinityALImpl
+{
+
+/*
+  Shader binding table: one buffer holding the ray generation, miss and hit
+  group records back to back, each region aligned to shaderGroupBaseAlignment.
+
+  A record is the shader group handle followed by the record's local material
+  data. Vulkan has no local root signatures, so unlike DX12 (which stores
+  descriptor GPU addresses) the local constant buffers' contents are copied
+  into the record itself; shaders read them as shaderRecordEXT data. The
+  contents are captured when the table is created.
+ */
+class Tr2RtShaderTableAL : public Tr2DeviceResourceAL<Tr2RtShaderTableAL>
+{
+public:
+	Tr2RtShaderTableAL();
+	~Tr2RtShaderTableAL();
+
+	ALResult Create( const Tr2RtShaderTableDescriptionAL& desc, const ::Tr2RtPipelineStateAL& pipeline, Tr2PrimaryRenderContextAL& renderContext );
+	void Destroy();
+	bool IsValid() const;
+
+	Tr2ALMemoryType GetMemoryClass() const;
+	void Describe( Tr2DeviceResourceDescriptionAL& description ) const;
+
+	// Regions for vkCmdTraceRaysKHR. The ray generation region addresses the
+	// single record matching `name` (zero address when the name is unknown).
+	VkStridedDeviceAddressRegionKHR GetRayGenRegion( const wchar_t* name ) const;
+	VkStridedDeviceAddressRegionKHR GetMissRegion() const;
+	VkStridedDeviceAddressRegionKHR GetHitGroupRegion() const;
+
+private:
+	VkBuffer m_table;
+	VmaAllocation m_tableAllocation;
+	VkDeviceAddress m_tableAddress;
+	VkDeviceSize m_entrySize;
+	Tr2RtShaderTableDescriptionAL m_desc;
+};
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2RtTopLevelAccelerationStructureALVulkan.cpp b/trinityal/vulkan/Tr2RtTopLevelAccelerationStructureALVulkan.cpp
new file mode 100644
index 00000000..9cb44641
--- /dev/null
+++ b/trinityal/vulkan/Tr2RtTopLevelAccelerationStructureALVulkan.cpp
@@ -0,0 +1,338 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2RtTopLevelAccelerationStructureALVulkan.h"
+#include "Tr2RtBottomLevelAccelerationStructureALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "Tr2BufferALVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+VkDeviceSize Align( VkDeviceSize offset, VkDeviceSize alignment )
+{
+	return ( offset + ( alignment - 1 ) ) & ~( alignment - 1 );
+}
+
+VkAccelerationStructureGeometryKHR MakeInstanceGeometry( VkDeviceAddress instanceData )
+{
+	VkAccelerationStructureGeometryKHR geometry = {};
+	geometry.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_GEOMETRY_KHR;
+	geometry.geometryType = VK_GEOMETRY_TYPE_INSTANCES_KHR;
+	geometry.geometry.instances.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_GEOMETRY_INSTANCES_DATA_KHR;
+	geometry.geometry.instances.arrayOfPointers = VK_FALSE;
+	geometry.geometry.instances.data.deviceAddress = instanceData;
+	return geometry;
+}
+
+}
+
+Tr2RtTopLevelAccelerationStructureAL::Tr2RtTopLevelAccelerationStructureAL() :
+	m_accelerationStructure( VK_NULL_HANDLE ),
+	m_scratch( VK_NULL_HANDLE ),
+	m_scratchAllocation( VK_NULL_HANDLE ),
+	m_scratchAddress( 0 ),
+	m_capacity( 0 ),
+	m_buildFlags( Tr2RtBuildFlags::NONE )
+{
+}
+
+Tr2RtTopLevelAccelerationStructureAL::~Tr2RtTopLevelAccelerationStructureAL()
+{
+	Destroy();
+}
+
+ALResult Tr2RtTopLevelAccelerationStructureAL::GetFreeInstanceBuffer( InstanceBuffer*& instanceBuffer )
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	const uint64_t completed = context->GetRenderedFrameNumber();
+	for( auto& entry : m_instanceBuffers )
+	{
+		if( completed >= entry.frameIndex )
+		{
+			entry.frameIndex = context->GetRecordingFrameNumber();
+			instanceBuffer = &entry;
+			return S_OK;
+		}
+	}
+
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = sizeof( VkAccelerationStructureInstanceKHR ) * m_capacity;
+	bufferCreateInfo.usage = VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_BUILD_INPUT_READ_ONLY_BIT_KHR | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+	InstanceBuffer entry = {};
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBuffer( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, &entry.buffer, &entry.allocation, &allocationInfo ) );
+	entry.mappedData = allocationInfo.pMappedData;
+	entry.frameIndex = context->GetRecordingFrameNumber();
+
+	VkBufferDeviceAddressInfo addressInfo = {};
+	addressInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+	addressInfo.buffer = entry.buffer;
+	entry.address = vkGetBufferDeviceAddress( context->GetDevice(), &addressInfo );
+
+	m_instanceBuffers.push_back( entry );
+	instanceBuffer = &m_instanceBuffers.back();
+	return S_OK;
+}
+
+ALResult Tr2RtTopLevelAccelerationStructureAL::UploadInstanceData( const InstanceBuffer& instanceBuffer, const size_t count, const Tr2RtInstanceAL* instances )
+{
+	VulkanContext* context = GetVulkanContext();
+	auto* data = static_cast<VkAccelerationStructureInstanceKHR*>( instanceBuffer.mappedData );
+	for( size_t i = 0; i < count; ++i )
+	{
+		if( !instances[i].blas || !instances[i].blas->IsValid() )
+		{
+			return E_INVALIDARG;
+		}
+		VkAccelerationStructureInstanceKHR instance = {};
+		memcpy( instance.transform.matrix, instances[i].transform, sizeof( instance.transform.matrix ) );
+		instance.instanceCustomIndex = uint32_t( i );
+		instance.mask = 0xff;
+		instance.instanceShaderBindingTableRecordOffset = instances[i].materialIndex;
+		// Front faces are counter-clockwise, matching the other backends; the
+		// FORCE_NON_OPAQUE AL flag has the same encoding as its Vulkan bit.
+		instance.flags = VK_GEOMETRY_INSTANCE_TRIANGLE_FRONT_COUNTERCLOCKWISE_BIT_KHR | VkGeometryInstanceFlagsKHR( instances[i].flags );
+		instance.accelerationStructureReference = instances[i].blas->GetDeviceAddress();
+		memcpy( data + i, &instance, sizeof( instance ) );
+	}
+	vmaFlushAllocation( context->GetAllocator(), instanceBuffer.allocation, 0, sizeof( VkAccelerationStructureInstanceKHR ) * count );
+	return S_OK;
+}
+
+ALResult Tr2RtTopLevelAccelerationStructureAL::Build( const InstanceBuffer& instanceBuffer, const size_t count, VkBuildAccelerationStructureModeKHR mode )
+{
+	VulkanContext* context = GetVulkanContext();
+	const VulkanRayTracingFunctions& functions = context->GetRayTracingFunctions();
+
+	VkAccelerationStructureGeometryKHR geometry = MakeInstanceGeometry( instanceBuffer.address );
+
+	VkAccelerationStructureBuildGeometryInfoKHR buildInfo = {};
+	buildInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_GEOMETRY_INFO_KHR;
+	buildInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_TOP_LEVEL_KHR;
+	buildInfo.flags = ToVkBuildFlags( m_buildFlags );
+	buildInfo.mode = mode;
+	buildInfo.srcAccelerationStructure = mode == VK_BUILD_ACCELERATION_STRUCTURE_MODE_UPDATE_KHR ? m_accelerationStructure : VK_NULL_HANDLE;
+	buildInfo.dstAccelerationStructure = m_accelerationStructure;
+	buildInfo.geometryCount = 1;
+	buildInfo.pGeometries = &geometry;
+	buildInfo.scratchData.deviceAddress = m_scratchAddress;
+
+	VkAccelerationStructureBuildRangeInfoKHR range = {};
+	range.primitiveCount = uint32_t( count );
+	const VkAccelerationStructureBuildRangeInfoKHR* ranges[] = { &range };
+
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+
+	// The referenced bottom level structures (and the host-written instance
+	// data) must be complete before this build consumes them.
+	VkMemoryBarrier before = {};
+	before.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	before.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT | VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	before.dstAccessMask = VK_ACCESS_SHADER_READ_BIT | VK_ACCESS_ACCELERATION_STRUCTURE_READ_BIT_KHR | VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR, 0, 1, &before, 0, nullptr, 0, nullptr );
+
+	functions.vkCmdBuildAccelerationStructuresKHR( commandBuffer, 1, &buildInfo, ranges );
+
+	VkMemoryBarrier after = {};
+	after.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	after.srcAccessMask = VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	after.dstAccessMask = VK_ACCESS_ACCELERATION_STRUCTURE_READ_BIT_KHR;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR, VK_PIPELINE_STAGE_RAY_TRACING_SHADER_BIT_KHR, 0, 1, &after, 0, nullptr, 0, nullptr );
+
+	return S_OK;
+}
+
+ALResult Tr2RtTopLevelAccelerationStructureAL::Create( const size_t count, const Tr2RtInstanceAL* instances, Tr2RtBuildFlags::Type buildFlags, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() || !renderContext.GetCaps().SupportsRaytracing() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( count == 0 )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	const VulkanRayTracingFunctions& functions = context->GetRayTracingFunctions();
+
+	m_capacity = Align( count, 128 );
+	m_buildFlags = buildFlags;
+
+	InstanceBuffer* instanceBuffer = nullptr;
+	CR_RETURN_HR( GetFreeInstanceBuffer( instanceBuffer ) );
+	CR_RETURN_HR( UploadInstanceData( *instanceBuffer, count, instances ) );
+
+	// Size the structure for the full capacity so updates with more instances
+	// (up to the capacity) never outgrow it.
+	VkAccelerationStructureGeometryKHR sizingGeometry = MakeInstanceGeometry( instanceBuffer->address );
+	VkAccelerationStructureBuildGeometryInfoKHR sizingInfo = {};
+	sizingInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_GEOMETRY_INFO_KHR;
+	sizingInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_TOP_LEVEL_KHR;
+	sizingInfo.flags = ToVkBuildFlags( buildFlags );
+	sizingInfo.mode = VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR;
+	sizingInfo.geometryCount = 1;
+	sizingInfo.pGeometries = &sizingGeometry;
+
+	const uint32_t maxInstanceCount = uint32_t( m_capacity );
+	VkAccelerationStructureBuildSizesInfoKHR sizes = {};
+	sizes.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_SIZES_INFO_KHR;
+	functions.vkGetAccelerationStructureBuildSizesKHR( context->GetDevice(), VK_ACCELERATION_STRUCTURE_BUILD_TYPE_DEVICE_KHR, &sizingInfo, &maxInstanceCount, &sizes );
+
+	if( sizes.accelerationStructureSize == 0 )
+	{
+		Destroy();
+		return E_INVALIDCALL;
+	}
+
+	// The structure lives in a Tr2BufferAL so it can be bound as a shader
+	// resource through Tr2ResourceSetDescriptionAL::SetSrv.
+	ALResult hr = m_buffer.Create(
+		Tr2BufferDescriptionAL( 1,
+								uint32_t( Align( sizes.accelerationStructureSize, 256 ) ),
+								Tr2GpuUsage::ACCELERATION_STRUCTURE | Tr2GpuUsage::SHADER_RESOURCE | Tr2GpuUsage::UNORDERED_ACCESS,
+								Tr2CpuUsage::NONE ),
+		nullptr,
+		renderContext );
+	if( FAILED( hr ) || !m_buffer.IsValid() )
+	{
+		Destroy();
+		return FAILED( hr ) ? int(hr) : E_INVALIDCALL;
+	}
+
+	VkAccelerationStructureCreateInfoKHR createInfo = {};
+	createInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_CREATE_INFO_KHR;
+	createInfo.buffer = m_buffer.TrinityALImpl_GetObject()->GetVkBuffer();
+	createInfo.size = m_buffer.TrinityALImpl_GetObject()->GetSize();
+	createInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_TOP_LEVEL_KHR;
+	VK_CR_RETURN_HR( functions.vkCreateAccelerationStructureKHR( context->GetDevice(), &createInfo, nullptr, &m_accelerationStructure ) );
+	m_buffer.TrinityALImpl_GetObject()->SetAccelerationStructure( m_accelerationStructure );
+
+	{
+		const VkDeviceSize scratchAlignment = std::max<VkDeviceSize>( context->GetAccelerationStructureProperties().minAccelerationStructureScratchOffsetAlignment, 1 );
+		VkBufferCreateInfo bufferCreateInfo = {};
+		bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+		bufferCreateInfo.size = Align( std::max( sizes.buildScratchSize, sizes.updateScratchSize ), scratchAlignment );
+		bufferCreateInfo.usage = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+		bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+		VmaAllocationCreateInfo allocationCreateInfo = {};
+		allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+		VK_CR_RETURN_HR( vmaCreateBufferWithAlignment( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, scratchAlignment, &m_scratch, &m_scratchAllocation, nullptr ) );
+
+		VkBufferDeviceAddressInfo addressInfo = {};
+		addressInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+		addressInfo.buffer = m_scratch;
+		m_scratchAddress = vkGetBufferDeviceAddress( context->GetDevice(), &addressInfo );
+	}
+
+	return Build( *instanceBuffer, count, VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR );
+}
+
+// Like on DX12, updates rebuild by default; a refit is only done when the
+// structure was created with ALLOW_UPDATE.
+ALResult Tr2RtTopLevelAccelerationStructureAL::Update( const size_t count, const Tr2RtInstanceAL* instances, Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+	if( m_capacity < count )
+	{
+		return E_INVALIDARG;
+	}
+
+	InstanceBuffer* instanceBuffer = nullptr;
+	CR_RETURN_HR( GetFreeInstanceBuffer( instanceBuffer ) );
+	CR_RETURN_HR( UploadInstanceData( *instanceBuffer, count, instances ) );
+
+	const VkBuildAccelerationStructureModeKHR mode = HasFlag( m_buildFlags, Tr2RtBuildFlags::ALLOW_UPDATE )
+		? VK_BUILD_ACCELERATION_STRUCTURE_MODE_UPDATE_KHR
+		: VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR;
+	return Build( *instanceBuffer, count, mode );
+}
+
+bool Tr2RtTopLevelAccelerationStructureAL::IsValid() const
+{
+	return m_accelerationStructure != VK_NULL_HANDLE;
+}
+
+void Tr2RtTopLevelAccelerationStructureAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		context->DestroyAccelerationStructureLater( m_accelerationStructure );
+		context->DestroyBufferLater( m_scratch, m_scratchAllocation );
+		for( auto& entry : m_instanceBuffers )
+		{
+			context->DestroyBufferLater( entry.buffer, entry.allocation );
+		}
+	}
+	if( m_buffer.IsValid() )
+	{
+		m_buffer.TrinityALImpl_GetObject()->SetAccelerationStructure( VK_NULL_HANDLE );
+	}
+	m_buffer = ::Tr2BufferAL();
+	m_accelerationStructure = VK_NULL_HANDLE;
+	m_scratch = VK_NULL_HANDLE;
+	m_scratchAllocation = VK_NULL_HANDLE;
+	m_scratchAddress = 0;
+	m_instanceBuffers.clear();
+	m_capacity = 0;
+	m_buildFlags = Tr2RtBuildFlags::NONE;
+}
+
+Tr2ALMemoryType Tr2RtTopLevelAccelerationStructureAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2RtTopLevelAccelerationStructureAL::Describe( Tr2DeviceResourceDescriptionAL& description ) const
+{
+	description["type"] = "Tr2RtTopLevelAccelerationStructureAL";
+}
+
+const ::Tr2BufferAL& Tr2RtTopLevelAccelerationStructureAL::GetBuffer() const
+{
+	return m_buffer;
+}
+
+size_t Tr2RtTopLevelAccelerationStructureAL::GetCapacity() const
+{
+	return m_capacity;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2RtTopLevelAccelerationStructureALVulkan.h b/trinityal/vulkan/Tr2RtTopLevelAccelerationStructureALVulkan.h
new file mode 100644
