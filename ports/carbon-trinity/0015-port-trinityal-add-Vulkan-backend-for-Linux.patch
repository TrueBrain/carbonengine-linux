@@ -0,0 +1,1106 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+// Note: the VMA implementation (VMA_IMPLEMENTATION) is provided by
+// trinity/Tr2VirtualAllocator.cpp, which is part of every trinity target.
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+VulkanContext* g_vulkanContext = nullptr;
+
+// Routes VK_LAYER_KHRONOS_validation output (and any other VK_EXT_debug_utils
+// producer) through Trinity's own logger. Without this callback registered,
+// the validation layer has no channel to report spec violations through, even
+// with the layer enabled via VK_INSTANCE_LAYERS.
+VKAPI_ATTR VkBool32 VKAPI_CALL VulkanDebugUtilsCallback(
+	VkDebugUtilsMessageSeverityFlagBitsEXT messageSeverity,
+	VkDebugUtilsMessageTypeFlagsEXT messageType,
+	const VkDebugUtilsMessengerCallbackDataEXT* callbackData,
+	void* userData )
+{
+	(void)messageType;
+	(void)userData;
+	if( messageSeverity & VK_DEBUG_UTILS_MESSAGE_SEVERITY_ERROR_BIT_EXT )
+	{
+		CCP_AL_LOGERR( "[vk-validation] %s", callbackData->pMessage );
+	}
+	else if( messageSeverity & VK_DEBUG_UTILS_MESSAGE_SEVERITY_WARNING_BIT_EXT )
+	{
+		CCP_AL_LOGWARN( "[vk-validation] %s", callbackData->pMessage );
+	}
+	else
+	{
+		CCP_AL_LOGNOTICE( "[vk-validation] %s", callbackData->pMessage );
+	}
+	return VK_FALSE;
+}
+}
+
+VulkanContext* GetVulkanContext()
+{
+	return g_vulkanContext;
+}
+
+void SetVulkanContext( VulkanContext* context )
+{
+	g_vulkanContext = context;
+}
+
+// --------------------------------------------------------------------------------------
+// VulkanInstance
+// --------------------------------------------------------------------------------------
+
+VulkanInstance& VulkanInstance::Get()
+{
+	static VulkanInstance instance;
+	return instance;
+}
+
+VulkanInstance::VulkanInstance() :
+	m_instance( VK_NULL_HANDLE ),
+	m_supportsSurfaces( false )
+{
+	VkApplicationInfo appInfo = {};
+	appInfo.sType = VK_STRUCTURE_TYPE_APPLICATION_INFO;
+	appInfo.pApplicationName = "Trinity";
+	appInfo.pEngineName = "Trinity";
+	appInfo.apiVersion = VK_API_VERSION_1_3;
+
+	uint32_t availableExtensionCount = 0;
+	vkEnumerateInstanceExtensionProperties( nullptr, &availableExtensionCount, nullptr );
+	std::vector<VkExtensionProperties> availableExtensions( availableExtensionCount );
+	vkEnumerateInstanceExtensionProperties( nullptr, &availableExtensionCount, availableExtensions.data() );
+
+	auto hasExtension = [&availableExtensions]( const char* name ) {
+		for( const auto& extension : availableExtensions )
+		{
+			if( strcmp( extension.extensionName, name ) == 0 )
+			{
+				return true;
+			}
+		}
+		return false;
+	};
+
+	std::vector<const char*> extensions;
+	if( hasExtension( VK_KHR_SURFACE_EXTENSION_NAME ) )
+	{
+		extensions.push_back( VK_KHR_SURFACE_EXTENSION_NAME );
+#ifdef TRINITY_VULKAN_WITH_XLIB
+		if( hasExtension( "VK_KHR_xlib_surface" ) )
+		{
+			extensions.push_back( "VK_KHR_xlib_surface" );
+			m_supportsSurfaces = true;
+		}
+#endif
+	}
+	const bool hasDebugUtils = hasExtension( VK_EXT_DEBUG_UTILS_EXTENSION_NAME );
+	if( hasDebugUtils )
+	{
+		extensions.push_back( VK_EXT_DEBUG_UTILS_EXTENSION_NAME );
+	}
+
+	VkInstanceCreateInfo createInfo = {};
+	createInfo.sType = VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO;
+	createInfo.pApplicationInfo = &appInfo;
+	createInfo.enabledExtensionCount = (uint32_t)extensions.size();
+	createInfo.ppEnabledExtensionNames = extensions.data();
+
+	VkResult result = vkCreateInstance( &createInfo, nullptr, &m_instance );
+	if( result != VK_SUCCESS )
+	{
+		CCP_AL_LOGERR( "vkCreateInstance failed with VkResult %d", (int)result );
+		m_instance = VK_NULL_HANDLE;
+		return;
+	}
+
+	if( hasDebugUtils )
+	{
+		auto createMessenger = (PFN_vkCreateDebugUtilsMessengerEXT)vkGetInstanceProcAddr( m_instance, "vkCreateDebugUtilsMessengerEXT" );
+		if( createMessenger )
+		{
+			VkDebugUtilsMessengerCreateInfoEXT messengerInfo = {};
+			messengerInfo.sType = VK_STRUCTURE_TYPE_DEBUG_UTILS_MESSENGER_CREATE_INFO_EXT;
+			messengerInfo.messageSeverity = VK_DEBUG_UTILS_MESSAGE_SEVERITY_ERROR_BIT_EXT |
+				VK_DEBUG_UTILS_MESSAGE_SEVERITY_WARNING_BIT_EXT | VK_DEBUG_UTILS_MESSAGE_SEVERITY_INFO_BIT_EXT;
+			messengerInfo.messageType = VK_DEBUG_UTILS_MESSAGE_TYPE_GENERAL_BIT_EXT |
+				VK_DEBUG_UTILS_MESSAGE_TYPE_VALIDATION_BIT_EXT | VK_DEBUG_UTILS_MESSAGE_TYPE_PERFORMANCE_BIT_EXT;
+			messengerInfo.pfnUserCallback = VulkanDebugUtilsCallback;
+			createMessenger( m_instance, &messengerInfo, nullptr, &m_debugMessenger );
+		}
+	}
+
+	uint32_t deviceCount = 0;
+	vkEnumeratePhysicalDevices( m_instance, &deviceCount, nullptr );
+	m_physicalDevices.resize( deviceCount );
+	vkEnumeratePhysicalDevices( m_instance, &deviceCount, m_physicalDevices.data() );
+
+	if( m_physicalDevices.empty() )
+	{
+		CCP_AL_LOGWARN( "No Vulkan physical devices found" );
+	}
+}
+
+VulkanInstance::~VulkanInstance()
+{
+	// The instance intentionally leaks: it lives for the process lifetime and
+	// destroying it during static teardown races with driver threads.
+}
+
+VkPhysicalDevice VulkanInstance::GetPhysicalDevice( uint32_t adapterIndex ) const
+{
+	if( adapterIndex >= m_physicalDevices.size() )
+	{
+		return VK_NULL_HANDLE;
+	}
+	return m_physicalDevices[adapterIndex];
+}
+
+// --------------------------------------------------------------------------------------
+// VulkanContext
+// --------------------------------------------------------------------------------------
+
+VulkanContext::VulkanContext() :
+	m_physicalDevice( VK_NULL_HANDLE ),
+	m_deviceProperties(),
+	m_deviceFeatures(),
+	m_device( VK_NULL_HANDLE ),
+	m_queue( VK_NULL_HANDLE ),
+	m_queueFamilyIndex( 0 ),
+	m_allocator( VK_NULL_HANDLE ),
+	m_commandPool( VK_NULL_HANDLE ),
+	m_commandBuffer( VK_NULL_HANDLE ),
+	m_isRecording( false ),
+	m_supportsDynamicRendering( false ),
+	m_vkCmdBeginRendering( nullptr ),
+	m_vkCmdEndRendering( nullptr ),
+	m_supportsRayTracing( false ),
+	m_rayTracingFunctions(),
+	m_rayTracingProperties(),
+	m_accelerationStructureProperties(),
+	m_renderingActive( false ),
+	m_renderingHash( 0 ),
+	m_descriptorPool( VK_NULL_HANDLE ),
+	m_transientBuffer( VK_NULL_HANDLE ),
+	m_transientAllocation( VK_NULL_HANDLE ),
+	m_transientData( nullptr ),
+	m_transientOffset( 0 ),
+	m_dummyBuffer( VK_NULL_HANDLE ),
+	m_dummyBufferAllocation( VK_NULL_HANDLE ),
+	m_dummyUniformTexelView( VK_NULL_HANDLE ),
+	m_dummyStorageTexelView( VK_NULL_HANDLE ),
+	m_dummyImage( VK_NULL_HANDLE ),
+	m_dummyImageAllocation( VK_NULL_HANDLE ),
+	m_dummyImage3D( VK_NULL_HANDLE ),
+	m_dummyImage3DAllocation( VK_NULL_HANDLE ),
+	m_dummySampler( VK_NULL_HANDLE ),
+	m_recordingFrameNumber( 1 ),
+	m_renderedFrameNumber( 0 )
+{
+}
+
+VulkanContext::~VulkanContext()
+{
+	Destroy();
+}
+
+ALResult VulkanContext::SelectQueueFamily()
+{
+	uint32_t queueFamilyCount = 0;
+	vkGetPhysicalDeviceQueueFamilyProperties( m_physicalDevice, &queueFamilyCount, nullptr );
+	std::vector<VkQueueFamilyProperties> queueFamilies( queueFamilyCount );
+	vkGetPhysicalDeviceQueueFamilyProperties( m_physicalDevice, &queueFamilyCount, queueFamilies.data() );
+
+	for( uint32_t i = 0; i < queueFamilyCount; ++i )
+	{
+		const VkQueueFlags required = VK_QUEUE_GRAPHICS_BIT | VK_QUEUE_COMPUTE_BIT;
+		if( ( queueFamilies[i].queueFlags & required ) == required )
+		{
+			m_queueFamilyIndex = i;
+			return S_OK;
+		}
+	}
+
+	CCP_AL_LOGERR( "No queue family with graphics+compute support found" );
+	return E_FAIL;
+}
+
+ALResult VulkanContext::Create( uint32_t adapterIndex )
+{
+	Destroy();
+
+	VulkanInstance& instance = VulkanInstance::Get();
+	if( !instance.IsValid() )
+	{
+		return E_FAIL;
+	}
+
+	m_physicalDevice = instance.GetPhysicalDevice( adapterIndex );
+	if( m_physicalDevice == VK_NULL_HANDLE )
+	{
+		return E_INVALIDARG;
+	}
+
+	vkGetPhysicalDeviceProperties( m_physicalDevice, &m_deviceProperties );
+	vkGetPhysicalDeviceFeatures( m_physicalDevice, &m_deviceFeatures );
+
+	CR_RETURN_HR( SelectQueueFamily() );
+
+	float queuePriority = 1.0f;
+	VkDeviceQueueCreateInfo queueCreateInfo = {};
+	queueCreateInfo.sType = VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO;
+	queueCreateInfo.queueFamilyIndex = m_queueFamilyIndex;
+	queueCreateInfo.queueCount = 1;
+	queueCreateInfo.pQueuePriorities = &queuePriority;
+
+	uint32_t availableExtensionCount = 0;
+	vkEnumerateDeviceExtensionProperties( m_physicalDevice, nullptr, &availableExtensionCount, nullptr );
+	std::vector<VkExtensionProperties> availableExtensions( availableExtensionCount );
+	vkEnumerateDeviceExtensionProperties( m_physicalDevice, nullptr, &availableExtensionCount, availableExtensions.data() );
+
+	auto hasExtension = [&availableExtensions]( const char* name ) {
+		for( const auto& extension : availableExtensions )
+		{
+			if( strcmp( extension.extensionName, name ) == 0 )
+			{
+				return true;
+			}
+		}
+		return false;
+	};
+
+	std::vector<const char*> extensions;
+	if( hasExtension( VK_KHR_SWAPCHAIN_EXTENSION_NAME ) )
+	{
+		extensions.push_back( VK_KHR_SWAPCHAIN_EXTENSION_NAME );
+	}
+
+	const bool hasRayTracingExtensions = hasExtension( VK_KHR_ACCELERATION_STRUCTURE_EXTENSION_NAME ) &&
+		hasExtension( VK_KHR_RAY_TRACING_PIPELINE_EXTENSION_NAME ) &&
+		hasExtension( VK_KHR_DEFERRED_HOST_OPERATIONS_EXTENSION_NAME );
+
+	// Below Vulkan 1.3, dynamic rendering is only available as the
+	// VK_KHR_dynamic_rendering extension rather than a core 1.3 feature.
+	const bool hasDynamicRenderingExtension = m_deviceProperties.apiVersion < VK_API_VERSION_1_3 &&
+		hasExtension( VK_KHR_DYNAMIC_RENDERING_EXTENSION_NAME );
+	if( hasDynamicRenderingExtension )
+	{
+		extensions.push_back( VK_KHR_DYNAMIC_RENDERING_EXTENSION_NAME );
+	}
+
+	VkPhysicalDeviceFeatures enabledFeatures = {};
+	enabledFeatures.occlusionQueryPrecise = m_deviceFeatures.occlusionQueryPrecise;
+	enabledFeatures.pipelineStatisticsQuery = m_deviceFeatures.pipelineStatisticsQuery;
+	enabledFeatures.samplerAnisotropy = m_deviceFeatures.samplerAnisotropy;
+	enabledFeatures.fillModeNonSolid = m_deviceFeatures.fillModeNonSolid;
+	enabledFeatures.independentBlend = m_deviceFeatures.independentBlend;
+	enabledFeatures.imageCubeArray = m_deviceFeatures.imageCubeArray;
+
+	// The draw path is built on dynamic rendering (Vulkan 1.3 core); ray
+	// tracing additionally needs buffer device address (Vulkan 1.2 core) and
+	// the acceleration structure / ray tracing pipeline extension features.
+	VkPhysicalDeviceRayTracingPipelineFeaturesKHR supportedRayTracingPipeline = {};
+	supportedRayTracingPipeline.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_RAY_TRACING_PIPELINE_FEATURES_KHR;
+	VkPhysicalDeviceAccelerationStructureFeaturesKHR supportedAccelerationStructure = {};
+	supportedAccelerationStructure.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_ACCELERATION_STRUCTURE_FEATURES_KHR;
+	VkPhysicalDeviceVulkan12Features supported12 = {};
+	supported12.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_2_FEATURES;
+	VkPhysicalDeviceVulkan13Features supported13 = {};
+	supported13.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_3_FEATURES;
+	VkPhysicalDeviceDynamicRenderingFeaturesKHR supportedDynamicRenderingExt = {};
+	supportedDynamicRenderingExt.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DYNAMIC_RENDERING_FEATURES_KHR;
+	VkPhysicalDeviceFeatures2 supported2 = {};
+	supported2.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_FEATURES_2;
+
+	// Chain only the structs the device can know about.
+	auto chainSupported = [&supported2]( auto& features ) {
+		features.pNext = supported2.pNext;
+		supported2.pNext = &features;
+	};
+	if( m_deviceProperties.apiVersion >= VK_API_VERSION_1_3 )
+	{
+		chainSupported( supported13 );
+	}
+	else if( hasDynamicRenderingExtension )
+	{
+		chainSupported( supportedDynamicRenderingExt );
+	}
+	if( m_deviceProperties.apiVersion >= VK_API_VERSION_1_2 )
+	{
+		chainSupported( supported12 );
+	}
+	if( hasRayTracingExtensions )
+	{
+		chainSupported( supportedAccelerationStructure );
+		chainSupported( supportedRayTracingPipeline );
+	}
+	if( m_deviceProperties.apiVersion >= VK_API_VERSION_1_1 )
+	{
+		vkGetPhysicalDeviceFeatures2( m_physicalDevice, &supported2 );
+	}
+
+	m_supportsDynamicRendering = supported13.dynamicRendering == VK_TRUE ||
+		supportedDynamicRenderingExt.dynamicRendering == VK_TRUE;
+	if( !m_supportsDynamicRendering )
+	{
+		CCP_AL_LOGWARN( "Vulkan device does not support dynamic rendering; draws will fail" );
+	}
+	m_supportsRayTracing = hasRayTracingExtensions &&
+		supported12.bufferDeviceAddress == VK_TRUE &&
+		supportedAccelerationStructure.accelerationStructure == VK_TRUE &&
+		supportedRayTracingPipeline.rayTracingPipeline == VK_TRUE;
+
+	VkPhysicalDeviceVulkan13Features enabled13 = {};
+	enabled13.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_3_FEATURES;
+	enabled13.dynamicRendering = VK_TRUE;
+
+	VkPhysicalDeviceDynamicRenderingFeaturesKHR enabledDynamicRenderingExt = {};
+	enabledDynamicRenderingExt.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_DYNAMIC_RENDERING_FEATURES_KHR;
+	enabledDynamicRenderingExt.dynamicRendering = VK_TRUE;
+
+	VkPhysicalDeviceVulkan12Features enabled12 = {};
+	enabled12.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_VULKAN_1_2_FEATURES;
+	VkPhysicalDeviceAccelerationStructureFeaturesKHR enabledAccelerationStructure = {};
+	enabledAccelerationStructure.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_ACCELERATION_STRUCTURE_FEATURES_KHR;
+	VkPhysicalDeviceRayTracingPipelineFeaturesKHR enabledRayTracingPipeline = {};
+	enabledRayTracingPipeline.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_RAY_TRACING_PIPELINE_FEATURES_KHR;
+
+	VkDeviceCreateInfo deviceCreateInfo = {};
+	deviceCreateInfo.sType = VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO;
+
+	auto chainEnabled = [&deviceCreateInfo]( auto& features ) {
+		features.pNext = const_cast<void*>( deviceCreateInfo.pNext );
+		deviceCreateInfo.pNext = &features;
+	};
+	if( m_supportsDynamicRendering )
+	{
+		if( m_deviceProperties.apiVersion >= VK_API_VERSION_1_3 )
+		{
+			chainEnabled( enabled13 );
+		}
+		else
+		{
+			chainEnabled( enabledDynamicRenderingExt );
+		}
+	}
+	if( m_supportsRayTracing )
+	{
+		extensions.push_back( VK_KHR_ACCELERATION_STRUCTURE_EXTENSION_NAME );
+		extensions.push_back( VK_KHR_RAY_TRACING_PIPELINE_EXTENSION_NAME );
+		extensions.push_back( VK_KHR_DEFERRED_HOST_OPERATIONS_EXTENSION_NAME );
+
+		enabled12.bufferDeviceAddress = VK_TRUE;
+		enabledAccelerationStructure.accelerationStructure = VK_TRUE;
+		enabledRayTracingPipeline.rayTracingPipeline = VK_TRUE;
+		chainEnabled( enabled12 );
+		chainEnabled( enabledAccelerationStructure );
+		chainEnabled( enabledRayTracingPipeline );
+	}
+
+	deviceCreateInfo.queueCreateInfoCount = 1;
+	deviceCreateInfo.pQueueCreateInfos = &queueCreateInfo;
+	deviceCreateInfo.enabledExtensionCount = (uint32_t)extensions.size();
+	deviceCreateInfo.ppEnabledExtensionNames = extensions.data();
+	deviceCreateInfo.pEnabledFeatures = &enabledFeatures;
+
+	VK_CR_RETURN_HR( vkCreateDevice( m_physicalDevice, &deviceCreateInfo, nullptr, &m_device ) );
+
+	vkGetDeviceQueue( m_device, m_queueFamilyIndex, 0, &m_queue );
+
+	if( m_supportsDynamicRendering )
+	{
+		// The KHR-suffixed entry points are guaranteed to resolve whether the
+		// driver advertises the core 1.3 feature or only the extension; the
+		// unsuffixed core names are not guaranteed to be exported otherwise.
+		m_vkCmdBeginRendering = (PFN_vkCmdBeginRenderingKHR)vkGetDeviceProcAddr( m_device, "vkCmdBeginRenderingKHR" );
+		m_vkCmdEndRendering = (PFN_vkCmdEndRenderingKHR)vkGetDeviceProcAddr( m_device, "vkCmdEndRenderingKHR" );
+		if( !m_vkCmdBeginRendering )
+		{
+			m_vkCmdBeginRendering = (PFN_vkCmdBeginRenderingKHR)vkGetDeviceProcAddr( m_device, "vkCmdBeginRendering" );
+		}
+		if( !m_vkCmdEndRendering )
+		{
+			m_vkCmdEndRendering = (PFN_vkCmdEndRenderingKHR)vkGetDeviceProcAddr( m_device, "vkCmdEndRendering" );
+		}
+	}
+
+	if( m_supportsRayTracing )
+	{
+		m_accelerationStructureProperties.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_ACCELERATION_STRUCTURE_PROPERTIES_KHR;
+		m_rayTracingProperties.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_RAY_TRACING_PIPELINE_PROPERTIES_KHR;
+		m_rayTracingProperties.pNext = &m_accelerationStructureProperties;
+		VkPhysicalDeviceProperties2 properties2 = {};
+		properties2.sType = VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_PROPERTIES_2;
+		properties2.pNext = &m_rayTracingProperties;
+		vkGetPhysicalDeviceProperties2( m_physicalDevice, &properties2 );
+		m_rayTracingProperties.pNext = nullptr;
+
+		auto load = [this]( const char* name ) {
+			return vkGetDeviceProcAddr( m_device, name );
+		};
+		m_rayTracingFunctions.vkCreateAccelerationStructureKHR = (PFN_vkCreateAccelerationStructureKHR)load( "vkCreateAccelerationStructureKHR" );
+		m_rayTracingFunctions.vkDestroyAccelerationStructureKHR = (PFN_vkDestroyAccelerationStructureKHR)load( "vkDestroyAccelerationStructureKHR" );
+		m_rayTracingFunctions.vkGetAccelerationStructureBuildSizesKHR = (PFN_vkGetAccelerationStructureBuildSizesKHR)load( "vkGetAccelerationStructureBuildSizesKHR" );
+		m_rayTracingFunctions.vkGetAccelerationStructureDeviceAddressKHR = (PFN_vkGetAccelerationStructureDeviceAddressKHR)load( "vkGetAccelerationStructureDeviceAddressKHR" );
+		m_rayTracingFunctions.vkCmdBuildAccelerationStructuresKHR = (PFN_vkCmdBuildAccelerationStructuresKHR)load( "vkCmdBuildAccelerationStructuresKHR" );
+		m_rayTracingFunctions.vkCreateRayTracingPipelinesKHR = (PFN_vkCreateRayTracingPipelinesKHR)load( "vkCreateRayTracingPipelinesKHR" );
+		m_rayTracingFunctions.vkGetRayTracingShaderGroupHandlesKHR = (PFN_vkGetRayTracingShaderGroupHandlesKHR)load( "vkGetRayTracingShaderGroupHandlesKHR" );
+		m_rayTracingFunctions.vkCmdTraceRaysKHR = (PFN_vkCmdTraceRaysKHR)load( "vkCmdTraceRaysKHR" );
+
+		if( !m_rayTracingFunctions.vkCreateAccelerationStructureKHR ||
+			!m_rayTracingFunctions.vkDestroyAccelerationStructureKHR ||
+			!m_rayTracingFunctions.vkGetAccelerationStructureBuildSizesKHR ||
+			!m_rayTracingFunctions.vkGetAccelerationStructureDeviceAddressKHR ||
+			!m_rayTracingFunctions.vkCmdBuildAccelerationStructuresKHR ||
+			!m_rayTracingFunctions.vkCreateRayTracingPipelinesKHR ||
+			!m_rayTracingFunctions.vkGetRayTracingShaderGroupHandlesKHR ||
+			!m_rayTracingFunctions.vkCmdTraceRaysKHR )
+		{
+			CCP_AL_LOGWARN( "Failed to resolve Vulkan ray tracing entry points; ray tracing disabled" );
+			m_supportsRayTracing = false;
+		}
+	}
+
+	VmaAllocatorCreateInfo allocatorCreateInfo = {};
+	allocatorCreateInfo.physicalDevice = m_physicalDevice;
+	allocatorCreateInfo.device = m_device;
+	allocatorCreateInfo.instance = instance.GetInstance();
+	allocatorCreateInfo.vulkanApiVersion = std::min<uint32_t>( m_deviceProperties.apiVersion, VK_API_VERSION_1_3 );
+	if( m_supportsRayTracing )
+	{
+		allocatorCreateInfo.flags |= VMA_ALLOCATOR_CREATE_BUFFER_DEVICE_ADDRESS_BIT;
+	}
+	VK_CR_RETURN_HR( vmaCreateAllocator( &allocatorCreateInfo, &m_allocator ) );
+
+	VkCommandPoolCreateInfo poolCreateInfo = {};
+	poolCreateInfo.sType = VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO;
+	poolCreateInfo.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+	poolCreateInfo.queueFamilyIndex = m_queueFamilyIndex;
+	VK_CR_RETURN_HR( vkCreateCommandPool( m_device, &poolCreateInfo, nullptr, &m_commandPool ) );
+
+	VkCommandBufferAllocateInfo allocateInfo = {};
+	allocateInfo.sType = VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO;
+	allocateInfo.commandPool = m_commandPool;
+	allocateInfo.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+	allocateInfo.commandBufferCount = 1;
+	VK_CR_RETURN_HR( vkAllocateCommandBuffers( m_device, &allocateInfo, &m_commandBuffer ) );
+
+	CR_RETURN_HR( CreateDescriptorPool() );
+	CR_RETURN_HR( CreateTransientBuffer() );
+
+	CCP_AL_LOGNOTICE( "Created Vulkan device on adapter %u: %s", adapterIndex, m_deviceProperties.deviceName );
+	return S_OK;
+}
+
+ALResult VulkanContext::CreateDescriptorPool()
+{
+	std::vector<VkDescriptorPoolSize> poolSizes = {
+		{ VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER, 16384 },
+		{ VK_DESCRIPTOR_TYPE_STORAGE_BUFFER, 4096 },
+		{ VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE, 16384 },
+		{ VK_DESCRIPTOR_TYPE_STORAGE_IMAGE, 4096 },
+		{ VK_DESCRIPTOR_TYPE_SAMPLER, 8192 },
+		{ VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER, 4096 },
+		{ VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER, 4096 },
+	};
+	if( m_supportsRayTracing )
+	{
+		poolSizes.push_back( { VK_DESCRIPTOR_TYPE_ACCELERATION_STRUCTURE_KHR, 1024 } );
+	}
+
+	VkDescriptorPoolCreateInfo poolCreateInfo = {};
+	poolCreateInfo.sType = VK_STRUCTURE_TYPE_DESCRIPTOR_POOL_CREATE_INFO;
+	poolCreateInfo.maxSets = 8192;
+	poolCreateInfo.poolSizeCount = (uint32_t)poolSizes.size();
+	poolCreateInfo.pPoolSizes = poolSizes.data();
+	VK_CR_RETURN_HR( vkCreateDescriptorPool( m_device, &poolCreateInfo, nullptr, &m_descriptorPool ) );
+	return S_OK;
+}
+
+ALResult VulkanContext::CreateTransientBuffer()
+{
+	const VkDeviceSize TRANSIENT_BUFFER_SIZE = 16 * 1024 * 1024;
+
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = TRANSIENT_BUFFER_SIZE;
+	bufferCreateInfo.usage = VK_BUFFER_USAGE_VERTEX_BUFFER_BIT | VK_BUFFER_USAGE_INDEX_BUFFER_BIT | VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT;
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBuffer( m_allocator, &bufferCreateInfo, &allocationCreateInfo, &m_transientBuffer, &m_transientAllocation, &allocationInfo ) );
+	m_transientData = allocationInfo.pMappedData;
+	m_transientOffset = 0;
+	return S_OK;
+}
+
+void VulkanContext::Destroy()
+{
+	if( m_device == VK_NULL_HANDLE )
+	{
+		return;
+	}
+
+	vkDeviceWaitIdle( m_device );
+	FlushPendingDestroys( true );
+	DestroyDummyResources();
+
+	for( auto& entry : m_pipelineCache )
+	{
+		vkDestroyPipeline( m_device, entry.second, nullptr );
+	}
+	m_pipelineCache.clear();
+
+	if( m_transientBuffer != VK_NULL_HANDLE )
+	{
+		vmaDestroyBuffer( m_allocator, m_transientBuffer, m_transientAllocation );
+		m_transientBuffer = VK_NULL_HANDLE;
+		m_transientAllocation = VK_NULL_HANDLE;
+		m_transientData = nullptr;
+		m_transientOffset = 0;
+	}
+	if( m_descriptorPool != VK_NULL_HANDLE )
+	{
+		vkDestroyDescriptorPool( m_device, m_descriptorPool, nullptr );
+		m_descriptorPool = VK_NULL_HANDLE;
+	}
+	if( m_commandPool != VK_NULL_HANDLE )
+	{
+		vkDestroyCommandPool( m_device, m_commandPool, nullptr );
+		m_commandPool = VK_NULL_HANDLE;
+		m_commandBuffer = VK_NULL_HANDLE;
+	}
+	if( m_allocator != VK_NULL_HANDLE )
+	{
+		vmaDestroyAllocator( m_allocator );
+		m_allocator = VK_NULL_HANDLE;
+	}
+	vkDestroyDevice( m_device, nullptr );
+	m_device = VK_NULL_HANDLE;
+	m_queue = VK_NULL_HANDLE;
+	m_physicalDevice = VK_NULL_HANDLE;
+	m_isRecording = false;
+	m_supportsRayTracing = false;
+	m_rayTracingFunctions = VulkanRayTracingFunctions();
+}
+
+VkCommandBuffer VulkanContext::GetCommandBuffer()
+{
+	if( !m_isRecording )
+	{
+		VkCommandBufferBeginInfo beginInfo = {};
+		beginInfo.sType = VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO;
+		beginInfo.flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT;
+		vkBeginCommandBuffer( m_commandBuffer, &beginInfo );
+		m_isRecording = true;
+	}
+	EndRenderingScope();
+	return m_commandBuffer;
+}
+
+VkCommandBuffer VulkanContext::BeginRenderingScope( const VkRenderingInfo& renderingInfo, uint64_t hash )
+{
+	if( m_renderingActive && m_renderingHash == hash )
+	{
+		return m_commandBuffer;
+	}
+
+	// GetCommandBuffer ends any previous scope and emits the barrier that
+	// makes earlier writes (uploads, clears, previous scopes) visible.
+	VkCommandBuffer commandBuffer = GetCommandBuffer();
+
+	VkMemoryBarrier barrier = {};
+	barrier.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	barrier.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+	barrier.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 1, &barrier, 0, nullptr, 0, nullptr );
+
+	m_vkCmdBeginRendering( commandBuffer, &renderingInfo );
+	m_renderingActive = true;
+	m_renderingHash = hash;
+	return commandBuffer;
+}
+
+void VulkanContext::EndRenderingScope()
+{
+	if( !m_renderingActive )
+	{
+		return;
+	}
+	m_vkCmdEndRendering( m_commandBuffer );
+	m_renderingActive = false;
+	m_renderingHash = 0;
+
+	// Make attachment writes visible to whatever comes next (transfers,
+	// readbacks, the next rendering scope).
+	VkMemoryBarrier barrier = {};
+	barrier.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	barrier.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+	barrier.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+	vkCmdPipelineBarrier( m_commandBuffer, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 1, &barrier, 0, nullptr, 0, nullptr );
+}
+
+VkDescriptorSet VulkanContext::AllocateDescriptorSet( VkDescriptorSetLayout layout )
+{
+	VkDescriptorSetAllocateInfo allocateInfo = {};
+	allocateInfo.sType = VK_STRUCTURE_TYPE_DESCRIPTOR_SET_ALLOCATE_INFO;
+	allocateInfo.descriptorPool = m_descriptorPool;
+	allocateInfo.descriptorSetCount = 1;
+	allocateInfo.pSetLayouts = &layout;
+
+	VkDescriptorSet descriptorSet = VK_NULL_HANDLE;
+	VkResult result = vkAllocateDescriptorSets( m_device, &allocateInfo, &descriptorSet );
+	if( result == VK_ERROR_OUT_OF_POOL_MEMORY || result == VK_ERROR_FRAGMENTED_POOL )
+	{
+		// Safe to recycle: submissions currently wait for completion.
+		if( FAILED( FlushAndWait() ) )
+		{
+			return VK_NULL_HANDLE;
+		}
+		vkResetDescriptorPool( m_device, m_descriptorPool, 0 );
+		result = vkAllocateDescriptorSets( m_device, &allocateInfo, &descriptorSet );
+	}
+	return result == VK_SUCCESS ? descriptorSet : VK_NULL_HANDLE;
+}
+
+ALResult VulkanContext::AllocateTransientData( VkDeviceSize size, VkDeviceSize alignment, VkBuffer& buffer, VkDeviceSize& offset, void*& data )
+{
+	VkDeviceSize alignedOffset = ( m_transientOffset + alignment - 1 ) & ~( alignment - 1 );
+
+	VmaAllocationInfo allocationInfo = {};
+	vmaGetAllocationInfo( m_allocator, m_transientAllocation, &allocationInfo );
+	if( alignedOffset + size > allocationInfo.size )
+	{
+		if( size > allocationInfo.size )
+		{
+			return E_OUTOFMEMORY;
+		}
+		// Wrap around; the flush guarantees the GPU is done with earlier data.
+		CR_RETURN_HR( FlushAndWait() );
+		m_transientOffset = 0;
+		alignedOffset = 0;
+	}
+
+	buffer = m_transientBuffer;
+	offset = alignedOffset;
+	data = (uint8_t*)m_transientData + alignedOffset;
+	m_transientOffset = alignedOffset + size;
+	return S_OK;
+}
+
+VkPipeline VulkanContext::GetCachedPipeline( uint64_t hash )
+{
+	std::lock_guard<std::mutex> lock( m_pipelineCacheMutex );
+	auto found = m_pipelineCache.find( hash );
+	return found != m_pipelineCache.end() ? found->second : VK_NULL_HANDLE;
+}
+
+VkPipeline VulkanContext::AddPipelineToCache( uint64_t hash, VkPipeline pipeline )
+{
+	std::lock_guard<std::mutex> lock( m_pipelineCacheMutex );
+	auto inserted = m_pipelineCache.insert( { hash, pipeline } );
+	if( !inserted.second )
+	{
+		// Lost a race; keep and return the existing pipeline.
+		vkDestroyPipeline( m_device, pipeline, nullptr );
+	}
+	return inserted.first->second;
+}
+
+// --------------------------------------------------------------------------------------
+// Dummy resources for descriptor slots the application left unbound.
+// --------------------------------------------------------------------------------------
+
+VkBuffer VulkanContext::GetDummyUniformBuffer()
+{
+	if( m_dummyBuffer == VK_NULL_HANDLE )
+	{
+		VkBufferCreateInfo bufferCreateInfo = {};
+		bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+		bufferCreateInfo.size = 256;
+		bufferCreateInfo.usage = VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT | VK_BUFFER_USAGE_STORAGE_BUFFER_BIT |
+			VK_BUFFER_USAGE_UNIFORM_TEXEL_BUFFER_BIT | VK_BUFFER_USAGE_STORAGE_TEXEL_BUFFER_BIT |
+			VK_BUFFER_USAGE_VERTEX_BUFFER_BIT;
+		bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+		VmaAllocationCreateInfo allocationCreateInfo = {};
+		allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+		allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+		VmaAllocationInfo allocationInfo = {};
+		if( vmaCreateBuffer( m_allocator, &bufferCreateInfo, &allocationCreateInfo, &m_dummyBuffer, &m_dummyBufferAllocation, &allocationInfo ) == VK_SUCCESS )
+		{
+			memset( allocationInfo.pMappedData, 0, 256 );
+			vmaFlushAllocation( m_allocator, m_dummyBufferAllocation, 0, 256 );
+		}
+	}
+	return m_dummyBuffer;
+}
+
+VkBuffer VulkanContext::GetDummyStorageBuffer()
+{
+	return GetDummyUniformBuffer();
+}
+
+VkBufferView VulkanContext::GetDummyUniformTexelBufferView()
+{
+	if( m_dummyUniformTexelView == VK_NULL_HANDLE && GetDummyUniformBuffer() != VK_NULL_HANDLE )
+	{
+		VkBufferViewCreateInfo viewCreateInfo = {};
+		viewCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_VIEW_CREATE_INFO;
+		viewCreateInfo.buffer = m_dummyBuffer;
+		viewCreateInfo.format = VK_FORMAT_R32G32B32A32_SFLOAT;
+		viewCreateInfo.range = VK_WHOLE_SIZE;
+		vkCreateBufferView( m_device, &viewCreateInfo, nullptr, &m_dummyUniformTexelView );
+	}
+	return m_dummyUniformTexelView;
+}
+
+VkBufferView VulkanContext::GetDummyStorageTexelBufferView()
+{
+	if( m_dummyStorageTexelView == VK_NULL_HANDLE && GetDummyUniformBuffer() != VK_NULL_HANDLE )
+	{
+		VkBufferViewCreateInfo viewCreateInfo = {};
+		viewCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_VIEW_CREATE_INFO;
+		viewCreateInfo.buffer = m_dummyBuffer;
+		viewCreateInfo.format = VK_FORMAT_R32G32B32A32_SFLOAT;
+		viewCreateInfo.range = VK_WHOLE_SIZE;
+		vkCreateBufferView( m_device, &viewCreateInfo, nullptr, &m_dummyStorageTexelView );
+	}
+	return m_dummyStorageTexelView;
+}
+
+VkImageView VulkanContext::GetDummyImageView( VkImageViewType viewType )
+{
+	for( const auto& entry : m_dummyImageViews )
+	{
+		if( entry.first == viewType )
+		{
+			return entry.second;
+		}
+	}
+
+	const bool is3D = viewType == VK_IMAGE_VIEW_TYPE_3D;
+	VkImage& image = is3D ? m_dummyImage3D : m_dummyImage;
+	VmaAllocation& allocation = is3D ? m_dummyImage3DAllocation : m_dummyImageAllocation;
+
+	if( image == VK_NULL_HANDLE )
+	{
+		VkImageCreateInfo imageCreateInfo = {};
+		imageCreateInfo.sType = VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO;
+		imageCreateInfo.imageType = is3D ? VK_IMAGE_TYPE_3D : VK_IMAGE_TYPE_2D;
+		imageCreateInfo.flags = is3D ? 0 : VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT;
+		imageCreateInfo.format = VK_FORMAT_R8G8B8A8_UNORM;
+		imageCreateInfo.extent = { 1, 1, 1 };
+		imageCreateInfo.mipLevels = 1;
+		imageCreateInfo.arrayLayers = is3D ? 1 : 6;
+		imageCreateInfo.samples = VK_SAMPLE_COUNT_1_BIT;
+		imageCreateInfo.tiling = VK_IMAGE_TILING_OPTIMAL;
+		imageCreateInfo.usage = VK_IMAGE_USAGE_SAMPLED_BIT | VK_IMAGE_USAGE_STORAGE_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT;
+		imageCreateInfo.initialLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+
+		VmaAllocationCreateInfo allocationCreateInfo = {};
+		allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+		if( vmaCreateImage( m_allocator, &imageCreateInfo, &allocationCreateInfo, &image, &allocation, nullptr ) != VK_SUCCESS )
+		{
+			return VK_NULL_HANDLE;
+		}
+
+		VkImage localImage = image;
+		ImmediateSubmit( [&]( VkCommandBuffer commandBuffer ) {
+			VkImageMemoryBarrier barrier = {};
+			barrier.sType = VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER;
+			barrier.oldLayout = VK_IMAGE_LAYOUT_UNDEFINED;
+			barrier.newLayout = VK_IMAGE_LAYOUT_GENERAL;
+			barrier.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+			barrier.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+			barrier.image = localImage;
+			barrier.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+			barrier.subresourceRange.levelCount = VK_REMAINING_MIP_LEVELS;
+			barrier.subresourceRange.layerCount = VK_REMAINING_ARRAY_LAYERS;
+			barrier.dstAccessMask = VK_ACCESS_MEMORY_READ_BIT | VK_ACCESS_MEMORY_WRITE_BIT;
+			vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, 0, 0, nullptr, 0, nullptr, 1, &barrier );
+
+			VkClearColorValue zero = {};
+			VkImageSubresourceRange range = {};
+			range.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+			range.levelCount = VK_REMAINING_MIP_LEVELS;
+			range.layerCount = VK_REMAINING_ARRAY_LAYERS;
+			vkCmdClearColorImage( commandBuffer, localImage, VK_IMAGE_LAYOUT_GENERAL, &zero, 1, &range );
+		} );
+	}
+
+	VkImageViewCreateInfo viewCreateInfo = {};
+	viewCreateInfo.sType = VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO;
+	viewCreateInfo.image = image;
+	viewCreateInfo.viewType = viewType;
+	viewCreateInfo.format = VK_FORMAT_R8G8B8A8_UNORM;
+	viewCreateInfo.subresourceRange.aspectMask = VK_IMAGE_ASPECT_COLOR_BIT;
+	viewCreateInfo.subresourceRange.levelCount = 1;
+	viewCreateInfo.subresourceRange.layerCount =
+		( viewType == VK_IMAGE_VIEW_TYPE_CUBE || viewType == VK_IMAGE_VIEW_TYPE_CUBE_ARRAY ) ? 6 : 1;
+
+	VkImageView view = VK_NULL_HANDLE;
+	if( vkCreateImageView( m_device, &viewCreateInfo, nullptr, &view ) != VK_SUCCESS )
+	{
+		return VK_NULL_HANDLE;
+	}
+	m_dummyImageViews.push_back( { viewType, view } );
+	return view;
+}
+
+VkSampler VulkanContext::GetDummySampler()
+{
+	if( m_dummySampler == VK_NULL_HANDLE )
+	{
+		VkSamplerCreateInfo samplerCreateInfo = {};
+		samplerCreateInfo.sType = VK_STRUCTURE_TYPE_SAMPLER_CREATE_INFO;
+		samplerCreateInfo.magFilter = VK_FILTER_NEAREST;
+		samplerCreateInfo.minFilter = VK_FILTER_NEAREST;
+		samplerCreateInfo.mipmapMode = VK_SAMPLER_MIPMAP_MODE_NEAREST;
+		samplerCreateInfo.addressModeU = VK_SAMPLER_ADDRESS_MODE_REPEAT;
+		samplerCreateInfo.addressModeV = VK_SAMPLER_ADDRESS_MODE_REPEAT;
+		samplerCreateInfo.addressModeW = VK_SAMPLER_ADDRESS_MODE_REPEAT;
+		samplerCreateInfo.maxLod = VK_LOD_CLAMP_NONE;
+		vkCreateSampler( m_device, &samplerCreateInfo, nullptr, &m_dummySampler );
+	}
+	return m_dummySampler;
+}
+
+void VulkanContext::DestroyDummyResources()
+{
+	for( const auto& entry : m_dummyImageViews )
+	{
+		vkDestroyImageView( m_device, entry.second, nullptr );
+	}
+	m_dummyImageViews.clear();
+	if( m_dummySampler != VK_NULL_HANDLE )
+	{
+		vkDestroySampler( m_device, m_dummySampler, nullptr );
+		m_dummySampler = VK_NULL_HANDLE;
+	}
+	if( m_dummyUniformTexelView != VK_NULL_HANDLE )
+	{
+		vkDestroyBufferView( m_device, m_dummyUniformTexelView, nullptr );
+		m_dummyUniformTexelView = VK_NULL_HANDLE;
+	}
+	if( m_dummyStorageTexelView != VK_NULL_HANDLE )
+	{
+		vkDestroyBufferView( m_device, m_dummyStorageTexelView, nullptr );
+		m_dummyStorageTexelView = VK_NULL_HANDLE;
+	}
+	if( m_dummyImage != VK_NULL_HANDLE )
+	{
+		vmaDestroyImage( m_allocator, m_dummyImage, m_dummyImageAllocation );
+		m_dummyImage = VK_NULL_HANDLE;
+		m_dummyImageAllocation = VK_NULL_HANDLE;
+	}
+	if( m_dummyImage3D != VK_NULL_HANDLE )
+	{
+		vmaDestroyImage( m_allocator, m_dummyImage3D, m_dummyImage3DAllocation );
+		m_dummyImage3D = VK_NULL_HANDLE;
+		m_dummyImage3DAllocation = VK_NULL_HANDLE;
+	}
+	if( m_dummyBuffer != VK_NULL_HANDLE )
+	{
+		vmaDestroyBuffer( m_allocator, m_dummyBuffer, m_dummyBufferAllocation );
+		m_dummyBuffer = VK_NULL_HANDLE;
+		m_dummyBufferAllocation = VK_NULL_HANDLE;
+	}
+}
+
+ALResult VulkanContext::Flush( VkFence signalFence )
+{
+	EndRenderingScope();
+
+	// Make CPU writes to the transient ring (UP draws, ONE_SHOT constant
+	// snapshots) visible to the GPU; a no-op on coherent memory.
+	if( m_transientAllocation != VK_NULL_HANDLE && m_transientOffset > 0 )
+	{
+		vmaFlushAllocation( m_allocator, m_transientAllocation, 0, m_transientOffset );
+	}
+
+	std::lock_guard<std::mutex> lock( m_submitMutex );
+
+	VkSubmitInfo submitInfo = {};
+	submitInfo.sType = VK_STRUCTURE_TYPE_SUBMIT_INFO;
+
+	if( m_isRecording )
+	{
+		VK_CR_RETURN_HR( vkEndCommandBuffer( m_commandBuffer ) );
+		m_isRecording = false;
+		submitInfo.commandBufferCount = 1;
+		submitInfo.pCommandBuffers = &m_commandBuffer;
+		VK_CR_RETURN_HR( vkQueueSubmit( m_queue, 1, &submitInfo, signalFence ) );
+		// Bring-up simplification: wait for the work before reusing the single
+		// command buffer. Replace with a per-frame command buffer ring once the
+		// draw path lands.
+		VK_CR_RETURN_HR( vkQueueWaitIdle( m_queue ) );
+	}
+	else if( signalFence != VK_NULL_HANDLE )
+	{
+		VK_CR_RETURN_HR( vkQueueSubmit( m_queue, 0, nullptr, signalFence ) );
+	}
+
+	return S_OK;
+}
+
+ALResult VulkanContext::FlushAndWait()
+{
+	CR_RETURN_HR( Flush() );
+	VK_CR_RETURN_HR( vkQueueWaitIdle( m_queue ) );
+	return S_OK;
+}
+
+ALResult VulkanContext::ImmediateSubmit( const std::function<void( VkCommandBuffer )>& record )
+{
+	// Uploads and readbacks share the frame command buffer so they are ordered
+	// with any commands already recorded, then everything is flushed.
+	record( GetCommandBuffer() );
+	return FlushAndWait();
+}
+
+ALResult VulkanContext::CreateStagingBuffer( VkDeviceSize size, VkBufferUsageFlags usage, VkBuffer& buffer, VmaAllocation& allocation, void*& mappedData )
+{
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = size;
+	bufferCreateInfo.usage = usage;
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_RANDOM_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBuffer( m_allocator, &bufferCreateInfo, &allocationCreateInfo, &buffer, &allocation, &allocationInfo ) );
+	mappedData = allocationInfo.pMappedData;
+	return S_OK;
+}
+
+void VulkanContext::DestroyBufferLater( VkBuffer buffer, VmaAllocation allocation )
+{
+	if( buffer == VK_NULL_HANDLE )
+	{
+		return;
+	}
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	m_pendingDestroys.push_back( { m_recordingFrameNumber, buffer, allocation, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE } );
+}
+
+void VulkanContext::DestroyBufferViewLater( VkBufferView view )
+{
+	if( view == VK_NULL_HANDLE )
+	{
+		return;
+	}
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	m_pendingDestroys.push_back( { m_recordingFrameNumber, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, view, VK_NULL_HANDLE } );
+}
+
+void VulkanContext::DestroyImageLater( VkImage image, VmaAllocation allocation )
+{
+	if( image == VK_NULL_HANDLE )
+	{
+		return;
+	}
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	m_pendingDestroys.push_back( { m_recordingFrameNumber, VK_NULL_HANDLE, allocation, image, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE } );
+}
+
+void VulkanContext::DestroyImageViewLater( VkImageView view )
+{
+	if( view == VK_NULL_HANDLE )
+	{
+		return;
+	}
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	m_pendingDestroys.push_back( { m_recordingFrameNumber, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, view, VK_NULL_HANDLE, VK_NULL_HANDLE } );
+}
+
+void VulkanContext::DestroyAccelerationStructureLater( VkAccelerationStructureKHR accelerationStructure )
+{
+	if( accelerationStructure == VK_NULL_HANDLE )
+	{
+		return;
+	}
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	m_pendingDestroys.push_back( { m_recordingFrameNumber, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, VK_NULL_HANDLE, accelerationStructure } );
+}
+
+void VulkanContext::FlushPendingDestroys( bool force )
+{
+	std::lock_guard<std::mutex> lock( m_pendingDestroyMutex );
+	while( !m_pendingDestroys.empty() )
+	{
+		const PendingDestroy& pending = m_pendingDestroys.front();
+		if( !force && pending.frame > m_renderedFrameNumber )
+		{
+			break;
+		}
+		if( pending.accelerationStructure != VK_NULL_HANDLE && m_rayTracingFunctions.vkDestroyAccelerationStructureKHR )
+		{
+			m_rayTracingFunctions.vkDestroyAccelerationStructureKHR( m_device, pending.accelerationStructure, nullptr );
+		}
+		if( pending.view != VK_NULL_HANDLE )
+		{
+			vkDestroyImageView( m_device, pending.view, nullptr );
+		}
+		if( pending.bufferView != VK_NULL_HANDLE )
+		{
+			vkDestroyBufferView( m_device, pending.bufferView, nullptr );
+		}
+		if( pending.image != VK_NULL_HANDLE )
+		{
+			vmaDestroyImage( m_allocator, pending.image, pending.allocation );
+		}
+		if( pending.buffer != VK_NULL_HANDLE )
+		{
+			vmaDestroyBuffer( m_allocator, pending.buffer, pending.allocation );
+		}
+		m_pendingDestroys.pop_front();
+	}
+}
+
+ALResult VulkanContext::EndFrame()
+{
+	CR_RETURN_HR( Flush() );
+	// Flush() currently waits for the queue, so everything submitted for this
+	// frame has rendered by the time the counters advance.
+	m_renderedFrameNumber = m_recordingFrameNumber;
+	++m_recordingFrameNumber;
+	FlushPendingDestroys( false );
+
+	// The frame's descriptor sets and transient data are no longer in use.
+	if( m_descriptorPool != VK_NULL_HANDLE )
+	{
+		vkResetDescriptorPool( m_device, m_descriptorPool, 0 );
+	}
+	m_transientOffset = 0;
+	return S_OK;
+}
+
+bool VulkanContext::SupportsTimestamps() const
+{
+	return m_deviceProperties.limits.timestampComputeAndGraphics == VK_TRUE;
+}
+
+bool VulkanContext::SupportsPipelineStatistics() const
+{
+	return m_deviceFeatures.pipelineStatisticsQuery == VK_TRUE;
+}
+
+}
