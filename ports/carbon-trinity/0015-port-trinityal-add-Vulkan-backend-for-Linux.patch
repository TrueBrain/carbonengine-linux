diff --git a/trinityal/vulkan/Tr2RtBottomLevelAccelerationStructureALVulkan.cpp b/trinityal/vulkan/Tr2RtBottomLevelAccelerationStructureALVulkan.cpp
new file mode 100644
index 00000000..f86a9066
--- /dev/null
+++ b/trinityal/vulkan/Tr2RtBottomLevelAccelerationStructureALVulkan.cpp
@@ -0,0 +1,367 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2RtBottomLevelAccelerationStructureALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "Tr2BufferALVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+VkBuildAccelerationStructureFlagsKHR ToVkBuildFlags( Tr2RtBuildFlags::Type buildFlags )
+{
+	VkBuildAccelerationStructureFlagsKHR result = 0;
+	if( HasFlag( buildFlags, Tr2RtBuildFlags::ALLOW_UPDATE ) )
+	{
+		result |= VK_BUILD_ACCELERATION_STRUCTURE_ALLOW_UPDATE_BIT_KHR;
+	}
+	if( HasFlag( buildFlags, Tr2RtBuildFlags::ALLOW_COMPACTION ) )
+	{
+		result |= VK_BUILD_ACCELERATION_STRUCTURE_ALLOW_COMPACTION_BIT_KHR;
+	}
+	if( HasFlag( buildFlags, Tr2RtBuildFlags::PREFER_FAST_TRACE ) )
+	{
+		result |= VK_BUILD_ACCELERATION_STRUCTURE_PREFER_FAST_TRACE_BIT_KHR;
+	}
+	if( HasFlag( buildFlags, Tr2RtBuildFlags::PREFER_FAST_BUILD ) )
+	{
+		result |= VK_BUILD_ACCELERATION_STRUCTURE_PREFER_FAST_BUILD_BIT_KHR;
+	}
+	if( HasFlag( buildFlags, Tr2RtBuildFlags::MINIMIZE_MEMORY ) )
+	{
+		result |= VK_BUILD_ACCELERATION_STRUCTURE_LOW_MEMORY_BIT_KHR;
+	}
+	return result;
+}
+
+namespace
+{
+
+VkDeviceSize Align( VkDeviceSize offset, VkDeviceSize alignment )
+{
+	return ( offset + ( alignment - 1 ) ) & ~( alignment - 1 );
+}
+
+VkIndexType GetIndexType( const Tr2RtIndicesStreamAL& indices )
+{
+	return indices.m_stride == 2 ? VK_INDEX_TYPE_UINT16 : VK_INDEX_TYPE_UINT32;
+}
+
+// Triangle geometry description used both for size queries (where the device
+// addresses are ignored) and for the actual build.
+VkAccelerationStructureGeometryKHR MakeGeometry( const Tr2RtGeometryAL& geometry, Tr2RtBlasGeometryFlags::Type geometryFlags )
+{
+	const Tr2RtPositionStreamAL& positions = geometry.positions;
+	const Tr2RtIndicesStreamAL& indices = geometry.indices;
+
+	VkAccelerationStructureGeometryKHR result = {};
+	result.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_GEOMETRY_KHR;
+	result.geometryType = VK_GEOMETRY_TYPE_TRIANGLES_KHR;
+	result.flags = geometryFlags ? VK_GEOMETRY_OPAQUE_BIT_KHR : 0;
+
+	VkAccelerationStructureGeometryTrianglesDataKHR& triangles = result.geometry.triangles;
+	triangles.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_GEOMETRY_TRIANGLES_DATA_KHR;
+	triangles.vertexFormat = ToVkFormat( positions.m_positionFormat );
+	triangles.vertexStride = positions.m_stride;
+	triangles.maxVertex = positions.m_vertexCount ? positions.m_vertexCount - 1 : 0;
+	triangles.indexType = GetIndexType( indices );
+
+	if( positions.m_vertexBuffer.IsValid() )
+	{
+		triangles.vertexData.deviceAddress = positions.m_vertexBuffer.TrinityALImpl_GetObject()->GetDeviceAddress() +
+			(VkDeviceSize)positions.m_vertexOffset * positions.m_stride + positions.m_positionOffset;
+	}
+	if( indices.m_indexBuffer.IsValid() )
+	{
+		triangles.indexData.deviceAddress = indices.m_indexBuffer.TrinityALImpl_GetObject()->GetDeviceAddress() +
+			(VkDeviceSize)indices.m_indexOffset * indices.m_stride;
+	}
+	return result;
+}
+
+bool ValidGeometryInput( const Tr2RtGeometryAL& geometry )
+{
+	return geometry.positions.IsValid() &&
+		Tr2GpuUsage::HasFlag( geometry.positions.m_vertexBuffer.GetDesc().gpuUsage, Tr2GpuUsage::SHADER_RESOURCE ) &&
+		geometry.indices.IsValid() &&
+		Tr2GpuUsage::HasFlag( geometry.indices.m_indexBuffer.GetDesc().gpuUsage, Tr2GpuUsage::SHADER_RESOURCE );
+}
+
+}
+
+Tr2RtBottomLevelAccelerationStructureAL::Tr2RtBottomLevelAccelerationStructureAL() :
+	m_accelerationStructure( VK_NULL_HANDLE ),
+	m_buffer( VK_NULL_HANDLE ),
+	m_bufferAllocation( VK_NULL_HANDLE ),
+	m_scratch( VK_NULL_HANDLE ),
+	m_scratchAllocation( VK_NULL_HANDLE ),
+	m_address( 0 ),
+	m_scratchAddress( 0 ),
+	m_bufferSize( 0 ),
+	m_scratchSize( 0 ),
+	m_geometryFlags{},
+	m_buildFlags{}
+{
+}
+
+Tr2RtBottomLevelAccelerationStructureAL::~Tr2RtBottomLevelAccelerationStructureAL()
+{
+	Destroy();
+}
+
+ALResult Tr2RtBottomLevelAccelerationStructureAL::Create( const Tr2RtGeometryAL& geometry, const Tr2RtGeometryAL& capacity, Tr2RtBlasGeometryFlags::Type geometryFlags, Tr2RtBuildFlags::Type buildFlags, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() || !renderContext.GetCaps().SupportsRaytracing() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !ValidGeometryInput( geometry ) || !ValidGeometryInput( capacity ) )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	const VulkanRayTracingFunctions& functions = context->GetRayTracingFunctions();
+
+	// Size the structure for the capacity geometry so later updates with up to
+	// that many primitives fit.
+	VkAccelerationStructureGeometryKHR sizingGeometry = MakeGeometry( capacity, geometryFlags );
+
+	VkAccelerationStructureBuildGeometryInfoKHR sizingInfo = {};
+	sizingInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_GEOMETRY_INFO_KHR;
+	sizingInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_BOTTOM_LEVEL_KHR;
+	sizingInfo.flags = ToVkBuildFlags( buildFlags );
+	sizingInfo.mode = VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR;
+	sizingInfo.geometryCount = 1;
+	sizingInfo.pGeometries = &sizingGeometry;
+
+	const uint32_t maxPrimitiveCount = capacity.indices.m_indexCount / 3;
+	VkAccelerationStructureBuildSizesInfoKHR sizes = {};
+	sizes.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_SIZES_INFO_KHR;
+	functions.vkGetAccelerationStructureBuildSizesKHR( context->GetDevice(), VK_ACCELERATION_STRUCTURE_BUILD_TYPE_DEVICE_KHR, &sizingInfo, &maxPrimitiveCount, &sizes );
+
+	if( sizes.accelerationStructureSize == 0 )
+	{
+		return E_INVALIDCALL;
+	}
+
+	// The backing buffer holding the acceleration structure data.
+	{
+		VkBufferCreateInfo bufferCreateInfo = {};
+		bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+		bufferCreateInfo.size = Align( sizes.accelerationStructureSize, 256 );
+		bufferCreateInfo.usage = VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_STORAGE_BIT_KHR | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+		bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+		VmaAllocationCreateInfo allocationCreateInfo = {};
+		allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+		VK_CR_RETURN_HR( vmaCreateBufferWithAlignment( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, 256, &m_buffer, &m_bufferAllocation, nullptr ) );
+		m_bufferSize = bufferCreateInfo.size;
+	}
+
+	VkAccelerationStructureCreateInfoKHR createInfo = {};
+	createInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_CREATE_INFO_KHR;
+	createInfo.buffer = m_buffer;
+	createInfo.size = m_bufferSize;
+	createInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_BOTTOM_LEVEL_KHR;
+	VK_CR_RETURN_HR( functions.vkCreateAccelerationStructureKHR( context->GetDevice(), &createInfo, nullptr, &m_accelerationStructure ) );
+
+	VkAccelerationStructureDeviceAddressInfoKHR addressInfo = {};
+	addressInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_DEVICE_ADDRESS_INFO_KHR;
+	addressInfo.accelerationStructure = m_accelerationStructure;
+	m_address = functions.vkGetAccelerationStructureDeviceAddressKHR( context->GetDevice(), &addressInfo );
+
+	// Scratch memory for the build; kept alive for refits when updates are allowed.
+	{
+		const VkDeviceSize scratchAlignment = std::max<VkDeviceSize>( context->GetAccelerationStructureProperties().minAccelerationStructureScratchOffsetAlignment, 1 );
+		VkBufferCreateInfo bufferCreateInfo = {};
+		bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+		bufferCreateInfo.size = Align( std::max( sizes.buildScratchSize, sizes.updateScratchSize ), scratchAlignment );
+		bufferCreateInfo.usage = VK_BUFFER_USAGE_STORAGE_BUFFER_BIT | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+		bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+		VmaAllocationCreateInfo allocationCreateInfo = {};
+		allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+		VK_CR_RETURN_HR( vmaCreateBufferWithAlignment( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, scratchAlignment, &m_scratch, &m_scratchAllocation, nullptr ) );
+		m_scratchSize = bufferCreateInfo.size;
+
+		VkBufferDeviceAddressInfo scratchAddressInfo = {};
+		scratchAddressInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+		scratchAddressInfo.buffer = m_scratch;
+		m_scratchAddress = vkGetBufferDeviceAddress( context->GetDevice(), &scratchAddressInfo );
+	}
+
+	m_geometryFlags = geometryFlags;
+	m_buildFlags = buildFlags;
+
+	CR_RETURN_HR( Build( geometry, VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR ) );
+
+	if( !HasFlag( buildFlags, Tr2RtBuildFlags::ALLOW_UPDATE ) )
+	{
+		// The scratch buffer is only needed while the recorded build executes.
+		context->DestroyBufferLater( m_scratch, m_scratchAllocation );
+		m_scratch = VK_NULL_HANDLE;
+		m_scratchAllocation = VK_NULL_HANDLE;
+		m_scratchSize = 0;
+	}
+
+	return S_OK;
+}
+
+ALResult Tr2RtBottomLevelAccelerationStructureAL::Build( const Tr2RtGeometryAL& geometry, VkBuildAccelerationStructureModeKHR mode )
+{
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	const VulkanRayTracingFunctions& functions = context->GetRayTracingFunctions();
+
+	VkAccelerationStructureGeometryKHR buildGeometry = MakeGeometry( geometry, m_geometryFlags );
+
+	VkAccelerationStructureBuildGeometryInfoKHR buildInfo = {};
+	buildInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_GEOMETRY_INFO_KHR;
+	buildInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_BOTTOM_LEVEL_KHR;
+	buildInfo.flags = ToVkBuildFlags( m_buildFlags );
+	buildInfo.mode = mode;
+	buildInfo.srcAccelerationStructure = mode == VK_BUILD_ACCELERATION_STRUCTURE_MODE_UPDATE_KHR ? m_accelerationStructure : VK_NULL_HANDLE;
+	buildInfo.dstAccelerationStructure = m_accelerationStructure;
+	buildInfo.geometryCount = 1;
+	buildInfo.pGeometries = &buildGeometry;
+	buildInfo.scratchData.deviceAddress = m_scratchAddress;
+
+	VkAccelerationStructureBuildRangeInfoKHR range = {};
+	range.primitiveCount = geometry.indices.m_indexCount / 3;
+	const VkAccelerationStructureBuildRangeInfoKHR* ranges[] = { &range };
+
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+
+	// Make preceding writes to the vertex/index data visible to the build.
+	VkMemoryBarrier before = {};
+	before.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	before.srcAccessMask = VK_ACCESS_MEMORY_WRITE_BIT;
+	before.dstAccessMask = VK_ACCESS_SHADER_READ_BIT | VK_ACCESS_ACCELERATION_STRUCTURE_READ_BIT_KHR | VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ALL_COMMANDS_BIT, VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR, 0, 1, &before, 0, nullptr, 0, nullptr );
+
+	functions.vkCmdBuildAccelerationStructuresKHR( commandBuffer, 1, &buildInfo, ranges );
+
+	// Make the built structure visible to top level builds and ray traversal.
+	VkMemoryBarrier after = {};
+	after.sType = VK_STRUCTURE_TYPE_MEMORY_BARRIER;
+	after.srcAccessMask = VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	after.dstAccessMask = VK_ACCESS_ACCELERATION_STRUCTURE_READ_BIT_KHR | VK_ACCESS_ACCELERATION_STRUCTURE_WRITE_BIT_KHR;
+	vkCmdPipelineBarrier( commandBuffer, VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR, VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR | VK_PIPELINE_STAGE_RAY_TRACING_SHADER_BIT_KHR, 0, 1, &after, 0, nullptr, 0, nullptr );
+
+	m_shape.vertexCount = geometry.positions.m_vertexCount;
+	m_shape.vertexStride = geometry.positions.m_stride;
+	m_shape.vertexFormat = ToVkFormat( geometry.positions.m_positionFormat );
+	m_shape.indexCount = geometry.indices.m_indexCount;
+	m_shape.indexType = GetIndexType( geometry.indices );
+	return S_OK;
+}
+
+ALResult Tr2RtBottomLevelAccelerationStructureAL::Update( const Tr2RtGeometryAL& geometry, Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || m_scratch == VK_NULL_HANDLE )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !renderContext.IsValid() || !ValidGeometryInput( geometry ) )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	const bool rebuild = m_shape.vertexCount != geometry.positions.m_vertexCount ||
+		m_shape.vertexStride != geometry.positions.m_stride ||
+		m_shape.vertexFormat != ToVkFormat( geometry.positions.m_positionFormat ) ||
+		m_shape.indexCount != geometry.indices.m_indexCount ||
+		m_shape.indexType != GetIndexType( geometry.indices );
+
+	if( rebuild )
+	{
+		// The new shape must fit within the buffers sized at creation.
+		VkAccelerationStructureGeometryKHR sizingGeometry = MakeGeometry( geometry, m_geometryFlags );
+		VkAccelerationStructureBuildGeometryInfoKHR sizingInfo = {};
+		sizingInfo.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_GEOMETRY_INFO_KHR;
+		sizingInfo.type = VK_ACCELERATION_STRUCTURE_TYPE_BOTTOM_LEVEL_KHR;
+		sizingInfo.flags = ToVkBuildFlags( m_buildFlags );
+		sizingInfo.mode = VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR;
+		sizingInfo.geometryCount = 1;
+		sizingInfo.pGeometries = &sizingGeometry;
+
+		const uint32_t primitiveCount = geometry.indices.m_indexCount / 3;
+		VkAccelerationStructureBuildSizesInfoKHR sizes = {};
+		sizes.sType = VK_STRUCTURE_TYPE_ACCELERATION_STRUCTURE_BUILD_SIZES_INFO_KHR;
+		context->GetRayTracingFunctions().vkGetAccelerationStructureBuildSizesKHR( context->GetDevice(), VK_ACCELERATION_STRUCTURE_BUILD_TYPE_DEVICE_KHR, &sizingInfo, &primitiveCount, &sizes );
+
+		if( sizes.accelerationStructureSize == 0 || sizes.accelerationStructureSize > m_bufferSize || sizes.buildScratchSize > m_scratchSize )
+		{
+			return E_INVALIDARG;
+		}
+	}
+
+	return Build( geometry, rebuild ? VK_BUILD_ACCELERATION_STRUCTURE_MODE_BUILD_KHR : VK_BUILD_ACCELERATION_STRUCTURE_MODE_UPDATE_KHR );
+}
+
+ALResult Tr2RtBottomLevelAccelerationStructureAL::CompactBlas( Tr2PrimaryRenderContextAL& )
+{
+	// Compaction is not implemented (the DX12 backend does not implement it
+	// either); the uncompacted structure remains fully functional.
+	return S_OK;
+}
+
+void Tr2RtBottomLevelAccelerationStructureAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		context->DestroyAccelerationStructureLater( m_accelerationStructure );
+		context->DestroyBufferLater( m_buffer, m_bufferAllocation );
+		context->DestroyBufferLater( m_scratch, m_scratchAllocation );
+	}
+	m_accelerationStructure = VK_NULL_HANDLE;
+	m_buffer = VK_NULL_HANDLE;
+	m_bufferAllocation = VK_NULL_HANDLE;
+	m_scratch = VK_NULL_HANDLE;
+	m_scratchAllocation = VK_NULL_HANDLE;
+	m_address = 0;
+	m_scratchAddress = 0;
+	m_bufferSize = 0;
+	m_scratchSize = 0;
+	m_shape = GeometryShape();
+}
+
+bool Tr2RtBottomLevelAccelerationStructureAL::IsValid() const
+{
+	return m_accelerationStructure != VK_NULL_HANDLE;
+}
+
+Tr2ALMemoryType Tr2RtBottomLevelAccelerationStructureAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2RtBottomLevelAccelerationStructureAL::Describe( Tr2DeviceResourceDescriptionAL& description ) const
+{
+	description["type"] = "Tr2RtBottomLevelAccelerationStructureAL";
+}
+
+}
+
+#endif
