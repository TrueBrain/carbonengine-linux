diff --git a/trinityal/vulkan/Tr2OcclusionQueryALVulkan.cpp b/trinityal/vulkan/Tr2OcclusionQueryALVulkan.cpp
new file mode 100644
index 00000000..e7b4f008
--- /dev/null
+++ b/trinityal/vulkan/Tr2OcclusionQueryALVulkan.cpp
@@ -0,0 +1,152 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2OcclusionQueryALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+
+namespace TrinityALImpl
+{
+
+Tr2OcclusionQueryAL::Tr2OcclusionQueryAL() :
+	m_queryPool( VK_NULL_HANDLE ),
+	m_isRunning( false ),
+	m_hasResult( false )
+{
+}
+
+Tr2OcclusionQueryAL::~Tr2OcclusionQueryAL()
+{
+	Destroy();
+}
+
+ALResult Tr2OcclusionQueryAL::Create( Tr2RenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context )
+	{
+		return E_INVALIDARG;
+	}
+
+	VkQueryPoolCreateInfo queryPoolCreateInfo = {};
+	queryPoolCreateInfo.sType = VK_STRUCTURE_TYPE_QUERY_POOL_CREATE_INFO;
+	queryPoolCreateInfo.queryType = VK_QUERY_TYPE_OCCLUSION;
+	queryPoolCreateInfo.queryCount = 1;
+	VK_CR_RETURN_HR( vkCreateQueryPool( context->GetDevice(), &queryPoolCreateInfo, nullptr, &m_queryPool ) );
+
+	return S_OK;
+}
+
+bool Tr2OcclusionQueryAL::IsValid() const
+{
+	return m_queryPool != VK_NULL_HANDLE;
+}
+
+void Tr2OcclusionQueryAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( m_queryPool != VK_NULL_HANDLE && context && context->IsValid() )
+	{
+		vkDestroyQueryPool( context->GetDevice(), m_queryPool, nullptr );
+	}
+	m_queryPool = VK_NULL_HANDLE;
+	m_isRunning = false;
+	m_hasResult = false;
+}
+
+ALResult Tr2OcclusionQueryAL::Begin( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( m_isRunning )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	VkCommandBuffer commandBuffer = context->GetCommandBuffer();
+	vkCmdResetQueryPool( commandBuffer, m_queryPool, 0, 1 );
+	const VkQueryControlFlags flags = context->GetDeviceFeatures().occlusionQueryPrecise ? VK_QUERY_CONTROL_PRECISE_BIT : 0;
+	vkCmdBeginQuery( commandBuffer, m_queryPool, 0, flags );
+	m_isRunning = true;
+	m_hasResult = false;
+	return S_OK;
+}
+
+ALResult Tr2OcclusionQueryAL::End( Tr2RenderContextAL& renderContext )
+{
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( !m_isRunning )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	vkCmdEndQuery( context->GetCommandBuffer(), m_queryPool, 0 );
+	m_isRunning = false;
+	m_hasResult = true;
+	return S_OK;
+}
+
+ALResult Tr2OcclusionQueryAL::GetPixelCount( Tr2RenderContextAL& renderContext, uint32_t& count, ::Tr2OcclusionQueryAL::WaitMode waitMode )
+{
+	count = 0;
+	if( !IsValid() || !renderContext.IsValid() )
+	{
+		return E_FAIL;
+	}
+	if( m_isRunning || !m_hasResult )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	CR_RETURN_HR( context->Flush() );
+
+	VkQueryResultFlags flags = VK_QUERY_RESULT_64_BIT;
+	if( waitMode == ::Tr2OcclusionQueryAL::WAIT )
+	{
+		flags |= VK_QUERY_RESULT_WAIT_BIT;
+	}
+
+	uint64_t result = 0;
+	VkResult queryResult = vkGetQueryPoolResults(
+		context->GetDevice(), m_queryPool, 0, 1,
+		sizeof( result ), &result, sizeof( result ), flags );
+	if( queryResult == VK_NOT_READY )
+	{
+		return S_FALSE;
+	}
+	VK_CR_RETURN_HR( queryResult );
+
+	count = (uint32_t)std::min<uint64_t>( result, std::numeric_limits<uint32_t>::max() );
+	return S_OK;
+}
+
+void Tr2OcclusionQueryAL::Describe( Tr2DeviceResourceDescriptionAL& ) const
+{
+}
+
+ALResult Tr2OcclusionQueryAL::SetName( const char* )
+{
+	return S_OK;
+}
+
+}
