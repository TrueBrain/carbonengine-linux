diff --git a/trinityal/vulkan/Tr2RtPipelineStateALVulkan.cpp b/trinityal/vulkan/Tr2RtPipelineStateALVulkan.cpp
new file mode 100644
index 00000000..14235c00
--- /dev/null
+++ b/trinityal/vulkan/Tr2RtPipelineStateALVulkan.cpp
@@ -0,0 +1,573 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2RtPipelineStateALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanBindingModel.h"
+#include "VulkanContext.h"
+#include "../ALLog.h"
+
+#include <deque>
+#include <string>
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+const VkShaderStageFlags RAY_TRACING_STAGES = VK_SHADER_STAGE_RAYGEN_BIT_KHR | VK_SHADER_STAGE_MISS_BIT_KHR |
+	VK_SHADER_STAGE_CLOSEST_HIT_BIT_KHR | VK_SHADER_STAGE_ANY_HIT_BIT_KHR |
+	VK_SHADER_STAGE_INTERSECTION_BIT_KHR | VK_SHADER_STAGE_CALLABLE_BIT_KHR;
+
+std::string ToUtf8( const std::wstring& name )
+{
+	// Entry point names are plain identifiers; a narrowing copy suffices.
+	std::string result;
+	result.reserve( name.size() );
+	for( wchar_t c : name )
+	{
+		result.push_back( char( c ) );
+	}
+	return result;
+}
+
+// ------------------------------------------------------------------
+// Minimal SPIR-V introspection: entry point execution models (to classify
+// exports as raygen/miss/hit shaders) and the descriptor bindings holding
+// acceleration structures (to type the descriptor set layout correctly).
+// ------------------------------------------------------------------
+
+struct SpirvEntryPoint
+{
+	uint32_t executionModel;
+	std::string name;
+};
+
+struct SpirvModuleInfo
+{
+	std::vector<SpirvEntryPoint> entryPoints;
+	std::vector<uint32_t> accelerationStructureBindings;
+};
+
+const uint32_t SPIRV_MAGIC = 0x07230203;
+const uint16_t OP_ENTRY_POINT = 15;
+const uint16_t OP_TYPE_ARRAY = 28;
+const uint16_t OP_TYPE_POINTER = 32;
+const uint16_t OP_VARIABLE = 59;
+const uint16_t OP_DECORATE = 71;
+const uint16_t OP_TYPE_ACCELERATION_STRUCTURE_KHR = 5341;
+const uint32_t DECORATION_BINDING = 33;
+
+const uint32_t EXECUTION_MODEL_RAY_GENERATION_KHR = 5313;
+const uint32_t EXECUTION_MODEL_INTERSECTION_KHR = 5314;
+const uint32_t EXECUTION_MODEL_ANY_HIT_KHR = 5315;
+const uint32_t EXECUTION_MODEL_CLOSEST_HIT_KHR = 5316;
+const uint32_t EXECUTION_MODEL_MISS_KHR = 5317;
+const uint32_t EXECUTION_MODEL_CALLABLE_KHR = 5318;
+
+bool ParseSpirv( const void* bytecode, size_t size, SpirvModuleInfo& info )
+{
+	if( !bytecode || size < 20 || ( size % 4 ) != 0 )
+	{
+		return false;
+	}
+	const uint32_t* words = static_cast<const uint32_t*>( bytecode );
+	const size_t wordCount = size / 4;
+	if( words[0] != SPIRV_MAGIC )
+	{
+		return false;
+	}
+
+	std::vector<uint32_t> accelerationStructureTypes;
+	std::vector<uint32_t> accelerationStructurePointers;
+	std::vector<uint32_t> accelerationStructureVariables;
+	std::vector<std::pair<uint32_t, uint32_t>> bindings; // id -> binding
+
+	for( size_t at = 5; at < wordCount; )
+	{
+		const uint32_t instruction = words[at];
+		const uint16_t opcode = uint16_t( instruction & 0xffff );
+		const uint16_t length = uint16_t( instruction >> 16 );
+		if( length == 0 || at + length > wordCount )
+		{
+			return false;
+		}
+
+		switch( opcode )
+		{
+		case OP_ENTRY_POINT:
+			if( length >= 4 )
+			{
+				SpirvEntryPoint entryPoint;
+				entryPoint.executionModel = words[at + 1];
+				entryPoint.name = reinterpret_cast<const char*>( &words[at + 3] );
+				info.entryPoints.push_back( entryPoint );
+			}
+			break;
+		case OP_DECORATE:
+			if( length >= 4 && words[at + 2] == DECORATION_BINDING )
+			{
+				bindings.push_back( { words[at + 1], words[at + 3] } );
+			}
+			break;
+		case OP_TYPE_ACCELERATION_STRUCTURE_KHR:
+			if( length >= 2 )
+			{
+				accelerationStructureTypes.push_back( words[at + 1] );
+			}
+			break;
+		case OP_TYPE_ARRAY:
+			// Treat arrays of acceleration structures as the element type.
+			if( length >= 3 &&
+				std::find( accelerationStructureTypes.begin(), accelerationStructureTypes.end(), words[at + 2] ) != accelerationStructureTypes.end() )
+			{
+				accelerationStructureTypes.push_back( words[at + 1] );
+			}
+			break;
+		case OP_TYPE_POINTER:
+			if( length >= 4 &&
+				std::find( accelerationStructureTypes.begin(), accelerationStructureTypes.end(), words[at + 3] ) != accelerationStructureTypes.end() )
+			{
+				accelerationStructurePointers.push_back( words[at + 1] );
+			}
+			break;
+		case OP_VARIABLE:
+			if( length >= 4 &&
+				std::find( accelerationStructurePointers.begin(), accelerationStructurePointers.end(), words[at + 1] ) != accelerationStructurePointers.end() )
+			{
+				accelerationStructureVariables.push_back( words[at + 2] );
+			}
+			break;
+		default:
+			break;
+		}
+		at += length;
+	}
+
+	for( const auto& binding : bindings )
+	{
+		if( std::find( accelerationStructureVariables.begin(), accelerationStructureVariables.end(), binding.first ) != accelerationStructureVariables.end() )
+		{
+			info.accelerationStructureBindings.push_back( binding.second );
+		}
+	}
+	return !info.entryPoints.empty();
+}
+
+VkShaderStageFlagBits ToStageFlag( uint32_t executionModel )
+{
+	switch( executionModel )
+	{
+	case EXECUTION_MODEL_RAY_GENERATION_KHR:
+		return VK_SHADER_STAGE_RAYGEN_BIT_KHR;
+	case EXECUTION_MODEL_INTERSECTION_KHR:
+		return VK_SHADER_STAGE_INTERSECTION_BIT_KHR;
+	case EXECUTION_MODEL_ANY_HIT_KHR:
+		return VK_SHADER_STAGE_ANY_HIT_BIT_KHR;
+	case EXECUTION_MODEL_CLOSEST_HIT_KHR:
+		return VK_SHADER_STAGE_CLOSEST_HIT_BIT_KHR;
+	case EXECUTION_MODEL_MISS_KHR:
+		return VK_SHADER_STAGE_MISS_BIT_KHR;
+	case EXECUTION_MODEL_CALLABLE_KHR:
+		return VK_SHADER_STAGE_CALLABLE_BIT_KHR;
+	default:
+		return VkShaderStageFlagBits( 0 );
+	}
+}
+
+VkDescriptorType GetSrvDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::SRV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_UNIFORM_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::SRV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_SAMPLED_IMAGE;
+	}
+}
+
+VkDescriptorType GetUavDescriptorType( Tr2ShaderRegisterAL::RegisterType registerType )
+{
+	switch( registerType )
+	{
+	case Tr2ShaderRegisterAL::UAV_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_TEXEL_BUFFER;
+	case Tr2ShaderRegisterAL::UAV_STRUCTURED_BUFFER:
+		return VK_DESCRIPTOR_TYPE_STORAGE_BUFFER;
+	default:
+		return VK_DESCRIPTOR_TYPE_STORAGE_IMAGE;
+	}
+}
+
+}
+
+Tr2RtPipelineStateAL::Tr2RtPipelineStateAL() :
+	m_pipeline( VK_NULL_HANDLE ),
+	m_pipelineLayout( VK_NULL_HANDLE ),
+	m_descriptorSetLayout( VK_NULL_HANDLE ),
+	m_groupHandleSize( 0 )
+{
+}
+
+Tr2RtPipelineStateAL::~Tr2RtPipelineStateAL()
+{
+	Destroy();
+}
+
+ALResult Tr2RtPipelineStateAL::CreateLayouts( const Tr2ShaderSignatureAL& globalSignature, const std::vector<uint32_t>& accelerationStructureBindings )
+{
+	VulkanContext* context = GetVulkanContext();
+
+	// The global signature is bound with the compute stage's slice of the
+	// binding model: DispatchRays consumes constants and resources the caller
+	// registered for Tr2RenderContextEnum::COMPUTE_SHADER.
+	const Tr2RenderContextEnum::ShaderType stage = Tr2RenderContextEnum::COMPUTE_SHADER;
+
+	std::vector<VkDescriptorSetLayoutBinding> layoutBindings;
+	std::vector<size_t> staticSamplerBindingIndex;
+
+	for( const Tr2ShaderRegisterAL& reg : globalSignature.registers )
+	{
+		Tr2ShaderProgramAL::BindingInfo info = {};
+		info.stage = stage;
+		info.registerType = reg.registerType;
+		info.registerIndex = reg.registerIndex;
+		info.isStaticSampler = false;
+
+		if( reg.registerType == Tr2ShaderRegisterAL::CONSTANT_BUFFER )
+		{
+			info.binding = VulkanBindingModel::GetCbvBinding( stage, reg.registerIndex );
+			info.descriptorType = VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER;
+		}
+		else if( reg.registerType == Tr2ShaderRegisterAL::SAMPLER )
+		{
+			info.binding = VulkanBindingModel::GetSamplerBinding( stage, reg.registerIndex );
+			info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+		}
+		else if( reg.IsSrv() )
+		{
+			info.binding = VulkanBindingModel::GetSrvBinding( stage, reg.registerIndex );
+			info.descriptorType = GetSrvDescriptorType( reg.registerType );
+			// RaytracingAccelerationStructure registers look like plain SRV
+			// buffers in the signature; the SPIR-V knows the real type.
+			if( std::find( accelerationStructureBindings.begin(), accelerationStructureBindings.end(), info.binding ) != accelerationStructureBindings.end() )
+			{
+				info.descriptorType = VK_DESCRIPTOR_TYPE_ACCELERATION_STRUCTURE_KHR;
+			}
+		}
+		else if( reg.IsUav() )
+		{
+			info.binding = VulkanBindingModel::GetUavBinding( stage, reg.registerIndex );
+			info.descriptorType = GetUavDescriptorType( reg.registerType );
+		}
+		else
+		{
+			continue;
+		}
+
+		VkDescriptorSetLayoutBinding layoutBinding = {};
+		layoutBinding.binding = info.binding;
+		layoutBinding.descriptorType = info.descriptorType;
+		layoutBinding.descriptorCount = 1;
+		layoutBinding.stageFlags = RAY_TRACING_STAGES;
+		layoutBindings.push_back( layoutBinding );
+		m_bindings.push_back( info );
+	}
+
+	for( const Tr2StaticSamplerAL& staticSampler : globalSignature.samplers )
+	{
+		VkSampler sampler = VK_NULL_HANDLE;
+		CR_RETURN_HR( CreateVkSampler( staticSampler.sampler, sampler ) );
+		m_staticSamplers.push_back( sampler );
+
+		Tr2ShaderProgramAL::BindingInfo info = {};
+		info.stage = stage;
+		info.registerType = Tr2ShaderRegisterAL::SAMPLER;
+		info.registerIndex = staticSampler.registerIndex;
+		info.isStaticSampler = true;
+		info.binding = VulkanBindingModel::GetSamplerBinding( stage, staticSampler.registerIndex );
+		info.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+
+		VkDescriptorSetLayoutBinding layoutBinding = {};
+		layoutBinding.binding = info.binding;
+		layoutBinding.descriptorType = VK_DESCRIPTOR_TYPE_SAMPLER;
+		layoutBinding.descriptorCount = 1;
+		layoutBinding.stageFlags = RAY_TRACING_STAGES;
+		staticSamplerBindingIndex.push_back( layoutBindings.size() );
+		layoutBindings.push_back( layoutBinding );
+		m_bindings.push_back( info );
+	}
+
+	for( size_t i = 0; i < staticSamplerBindingIndex.size(); ++i )
+	{
+		layoutBindings[staticSamplerBindingIndex[i]].pImmutableSamplers = &m_staticSamplers[i];
+	}
+
+	VkDescriptorSetLayoutCreateInfo layoutCreateInfo = {};
+	layoutCreateInfo.sType = VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO;
+	layoutCreateInfo.bindingCount = (uint32_t)layoutBindings.size();
+	layoutCreateInfo.pBindings = layoutBindings.data();
+	VK_CR_RETURN_HR( vkCreateDescriptorSetLayout( context->GetDevice(), &layoutCreateInfo, nullptr, &m_descriptorSetLayout ) );
+
+	VkPipelineLayoutCreateInfo pipelineLayoutCreateInfo = {};
+	pipelineLayoutCreateInfo.sType = VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO;
+	pipelineLayoutCreateInfo.setLayoutCount = 1;
+	pipelineLayoutCreateInfo.pSetLayouts = &m_descriptorSetLayout;
+	VK_CR_RETURN_HR( vkCreatePipelineLayout( context->GetDevice(), &pipelineLayoutCreateInfo, nullptr, &m_pipelineLayout ) );
+
+	return S_OK;
+}
+
+ALResult Tr2RtPipelineStateAL::CreateRtPipelineState( const Tr2RtPipelineStateDescriptionAL& desc, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() || !renderContext.GetCaps().SupportsRaytracing() )
+	{
+		return E_INVALIDCALL;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	const VulkanRayTracingFunctions& functions = context->GetRayTracingFunctions();
+
+	m_localSignatures = desc.m_localSignatures;
+
+	// One stage per export; pName storage must stay stable until creation.
+	std::deque<std::string> entryPointNames;
+	std::vector<VkPipelineShaderStageCreateInfo> stages;
+	std::vector<VkRayTracingShaderGroupCreateInfoKHR> groups;
+	std::vector<uint32_t> accelerationStructureBindings;
+
+	// exportName -> stage index + execution model, for hit group resolution.
+	struct ExportedStage
+	{
+		uint32_t stageIndex;
+		VkShaderStageFlagBits stage;
+		uint32_t localSignature;
+	};
+	std::map<std::wstring, ExportedStage> exportedStages;
+
+	for( const auto& shader : desc.m_shaders )
+	{
+		if( !shader.bytecode.bytecode || shader.bytecode.size == 0 )
+		{
+			return E_INVALIDARG;
+		}
+
+		SpirvModuleInfo moduleInfo;
+		if( !ParseSpirv( shader.bytecode.bytecode, shader.bytecode.size, moduleInfo ) )
+		{
+			CCP_AL_LOGERR( "Tr2RtPipelineStateAL: shader bytecode is not a SPIR-V library" );
+			return E_INVALIDARG;
+		}
+		accelerationStructureBindings.insert( accelerationStructureBindings.end(),
+											  moduleInfo.accelerationStructureBindings.begin(),
+											  moduleInfo.accelerationStructureBindings.end() );
+
+		VkShaderModuleCreateInfo moduleCreateInfo = {};
+		moduleCreateInfo.sType = VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO;
+		moduleCreateInfo.codeSize = shader.bytecode.size;
+		moduleCreateInfo.pCode = static_cast<const uint32_t*>( shader.bytecode.bytecode );
+		VkShaderModule module = VK_NULL_HANDLE;
+		VK_CR_RETURN_HR( vkCreateShaderModule( context->GetDevice(), &moduleCreateInfo, nullptr, &module ) );
+		m_modules.push_back( module );
+
+		for( const auto& name : shader.names )
+		{
+			const std::string entryPoint = ToUtf8( name.name );
+			uint32_t executionModel = 0;
+			for( const auto& moduleEntryPoint : moduleInfo.entryPoints )
+			{
+				if( moduleEntryPoint.name == entryPoint )
+				{
+					executionModel = moduleEntryPoint.executionModel;
+					break;
+				}
+			}
+			const VkShaderStageFlagBits stageFlag = ToStageFlag( executionModel );
+			if( stageFlag == 0 )
+			{
+				CCP_AL_LOGERR( "Tr2RtPipelineStateAL: entry point \"%s\" not found or not a ray tracing shader", entryPoint.c_str() );
+				return E_INVALIDARG;
+			}
+
+			entryPointNames.push_back( entryPoint );
+
+			VkPipelineShaderStageCreateInfo stage = {};
+			stage.sType = VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO;
+			stage.stage = stageFlag;
+			stage.module = module;
+			stage.pName = entryPointNames.back().c_str();
+			exportedStages[name.exportName] = { uint32_t( stages.size() ), stageFlag, shader.localSignature };
+			stages.push_back( stage );
+
+			// Ray generation, miss and callable shaders get their own group;
+			// hit shaders are only reachable through hit groups.
+			if( stageFlag == VK_SHADER_STAGE_RAYGEN_BIT_KHR || stageFlag == VK_SHADER_STAGE_MISS_BIT_KHR || stageFlag == VK_SHADER_STAGE_CALLABLE_BIT_KHR )
+			{
+				VkRayTracingShaderGroupCreateInfoKHR group = {};
+				group.sType = VK_STRUCTURE_TYPE_RAY_TRACING_SHADER_GROUP_CREATE_INFO_KHR;
+				group.type = VK_RAY_TRACING_SHADER_GROUP_TYPE_GENERAL_KHR;
+				group.generalShader = uint32_t( stages.size() - 1 );
+				group.closestHitShader = VK_SHADER_UNUSED_KHR;
+				group.anyHitShader = VK_SHADER_UNUSED_KHR;
+				group.intersectionShader = VK_SHADER_UNUSED_KHR;
+
+				m_shaderInfoForName[name.exportName] = { uint32_t( groups.size() ), shader.localSignature };
+				groups.push_back( group );
+			}
+		}
+	}
+
+	for( const auto& hitGroup : desc.m_hitGroups )
+	{
+		auto resolve = [&exportedStages]( const std::wstring& name, VkShaderStageFlagBits expected, uint32_t& stageIndex ) {
+			if( name.empty() )
+			{
+				stageIndex = VK_SHADER_UNUSED_KHR;
+				return true;
+			}
+			auto found = exportedStages.find( name );
+			if( found == exportedStages.end() || found->second.stage != expected )
+			{
+				return false;
+			}
+			stageIndex = found->second.stageIndex;
+			return true;
+		};
+
+		VkRayTracingShaderGroupCreateInfoKHR group = {};
+		group.sType = VK_STRUCTURE_TYPE_RAY_TRACING_SHADER_GROUP_CREATE_INFO_KHR;
+		group.generalShader = VK_SHADER_UNUSED_KHR;
+		if( !resolve( hitGroup.closestHit, VK_SHADER_STAGE_CLOSEST_HIT_BIT_KHR, group.closestHitShader ) ||
+			!resolve( hitGroup.anyHit, VK_SHADER_STAGE_ANY_HIT_BIT_KHR, group.anyHitShader ) ||
+			!resolve( hitGroup.intersection, VK_SHADER_STAGE_INTERSECTION_BIT_KHR, group.intersectionShader ) )
+		{
+			CCP_AL_LOGERR( "Tr2RtPipelineStateAL: hit group references an unknown shader export" );
+			return E_INVALIDARG;
+		}
+		group.type = group.intersectionShader != VK_SHADER_UNUSED_KHR
+			? VK_RAY_TRACING_SHADER_GROUP_TYPE_PROCEDURAL_HIT_GROUP_KHR
+			: VK_RAY_TRACING_SHADER_GROUP_TYPE_TRIANGLES_HIT_GROUP_KHR;
+
+		m_shaderInfoForName[hitGroup.exportName] = { uint32_t( groups.size() ), hitGroup.localSignature };
+		groups.push_back( group );
+	}
+
+	if( stages.empty() || groups.empty() )
+	{
+		return E_INVALIDARG;
+	}
+
+	CR_RETURN_HR( CreateLayouts( desc.m_globalSignature, accelerationStructureBindings ) );
+
+	VkRayTracingPipelineCreateInfoKHR pipelineCreateInfo = {};
+	pipelineCreateInfo.sType = VK_STRUCTURE_TYPE_RAY_TRACING_PIPELINE_CREATE_INFO_KHR;
+	pipelineCreateInfo.stageCount = (uint32_t)stages.size();
+	pipelineCreateInfo.pStages = stages.data();
+	pipelineCreateInfo.groupCount = (uint32_t)groups.size();
+	pipelineCreateInfo.pGroups = groups.data();
+	pipelineCreateInfo.maxPipelineRayRecursionDepth = 1;
+	pipelineCreateInfo.layout = m_pipelineLayout;
+	VK_CR_RETURN_HR( functions.vkCreateRayTracingPipelinesKHR( context->GetDevice(), VK_NULL_HANDLE, VK_NULL_HANDLE, 1, &pipelineCreateInfo, nullptr, &m_pipeline ) );
+
+	// The shader modules are compiled into the pipeline and no longer needed.
+	for( VkShaderModule module : m_modules )
+	{
+		vkDestroyShaderModule( context->GetDevice(), module, nullptr );
+	}
+	m_modules.clear();
+
+	m_groupHandleSize = context->GetRayTracingProperties().shaderGroupHandleSize;
+	m_groupHandles.resize( size_t( groups.size() ) * m_groupHandleSize );
+	VK_CR_RETURN_HR( functions.vkGetRayTracingShaderGroupHandlesKHR( context->GetDevice(), m_pipeline, 0, (uint32_t)groups.size(), m_groupHandles.size(), m_groupHandles.data() ) );
+
+	return S_OK;
+}
+
+void Tr2RtPipelineStateAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		for( VkShaderModule module : m_modules )
+		{
+			vkDestroyShaderModule( context->GetDevice(), module, nullptr );
+		}
+		if( m_pipeline != VK_NULL_HANDLE )
+		{
+			vkDestroyPipeline( context->GetDevice(), m_pipeline, nullptr );
+		}
+		if( m_pipelineLayout != VK_NULL_HANDLE )
+		{
+			vkDestroyPipelineLayout( context->GetDevice(), m_pipelineLayout, nullptr );
+		}
+		if( m_descriptorSetLayout != VK_NULL_HANDLE )
+		{
+			vkDestroyDescriptorSetLayout( context->GetDevice(), m_descriptorSetLayout, nullptr );
+		}
+		for( VkSampler sampler : m_staticSamplers )
+		{
+			vkDestroySampler( context->GetDevice(), sampler, nullptr );
+		}
+	}
+	m_modules.clear();
+	m_pipeline = VK_NULL_HANDLE;
+	m_pipelineLayout = VK_NULL_HANDLE;
+	m_descriptorSetLayout = VK_NULL_HANDLE;
+	m_staticSamplers.clear();
+	m_bindings.clear();
+	m_groupHandles.clear();
+	m_groupHandleSize = 0;
+	m_shaderInfoForName.clear();
+	m_localSignatures.clear();
+}
+
+bool Tr2RtPipelineStateAL::IsValid() const
+{
+	return m_pipeline != VK_NULL_HANDLE;
+}
+
+Tr2ALMemoryType Tr2RtPipelineStateAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2RtPipelineStateAL::Describe( Tr2DeviceResourceDescriptionAL& description ) const
+{
+	description["type"] = "Tr2RtPipelineStateAL";
+}
+
+const Tr2RtPipelineStateAL::ShaderInfo* Tr2RtPipelineStateAL::GetShaderInfo( const wchar_t* name ) const
+{
+	auto found = m_shaderInfoForName.find( name );
+	if( found == m_shaderInfoForName.end() )
+	{
+		return nullptr;
+	}
+	return &found->second;
+}
+
+const uint8_t* Tr2RtPipelineStateAL::GetGroupHandle( uint32_t groupIndex ) const
+{
+	const size_t offset = size_t( groupIndex ) * m_groupHandleSize;
+	if( m_groupHandleSize == 0 || offset + m_groupHandleSize > m_groupHandles.size() )
+	{
+		return nullptr;
+	}
+	return m_groupHandles.data() + offset;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2RtPipelineStateALVulkan.h b/trinityal/vulkan/Tr2RtPipelineStateALVulkan.h
new file mode 100644
index 00000000..35e2872f
--- /dev/null
+++ b/trinityal/vulkan/Tr2RtPipelineStateALVulkan.h
@@ -0,0 +1,101 @@
+// Copyright © 2026 CCP ehf.
+
+#pragma once
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "../include/Tr2RtPipelineStateAL.h"
+#include "Tr2ShaderProgramALVulkan.h"
+#include "VulkanCommon.h"
+
+#include <map>
+#include <vector>
+
+namespace TrinityALImpl
+{
+
+/*
+  Ray tracing pipeline built from SPIR-V libraries (dxc -T lib_6_3 -spirv).
+
+  Shader stages are classified by parsing the modules' OpEntryPoint execution
+  models, so the caller only provides export/entry point names like on DX12.
+  Ray generation, miss and callable exports each become a GENERAL shader
+  group; the description's hit groups become TRIANGLES/PROCEDURAL groups.
+
+  The global signature is laid out with the compute stage's bindings of
+  VulkanBindingModel (matching how DispatchRays sources constants and
+  resources bound for Tr2RenderContextEnum::COMPUTE_SHADER). Local signatures
+  have no Vulkan equivalent of DX12 local root signatures; their constant
+  buffers are embedded into the shader binding table records instead (see
+  Tr2RtShaderTableAL), which shaders access as shaderRecordEXT data.
+ */
+class Tr2RtPipelineStateAL : public Tr2DeviceResourceAL<Tr2RtPipelineStateAL>
+{
+public:
+	static const uint32_t NO_SIGNATURE = 0xffffffff;
+
+	struct ShaderInfo
+	{
+		uint32_t groupIndex;
+		uint32_t localSignature; // index into GetLocalSignatures(), or NO_SIGNATURE
+	};
+
+	Tr2RtPipelineStateAL();
+	~Tr2RtPipelineStateAL();
+
+	ALResult CreateRtPipelineState( const Tr2RtPipelineStateDescriptionAL& desc, Tr2PrimaryRenderContextAL& renderContext );
+	void Destroy();
+	bool IsValid() const;
+
+	Tr2ALMemoryType GetMemoryClass() const;
+	void Describe( Tr2DeviceResourceDescriptionAL& description ) const;
+
+	const ShaderInfo* GetShaderInfo( const wchar_t* name ) const;
+	const std::vector<Tr2ShaderSignatureAL>& GetLocalSignatures() const
+	{
+		return m_localSignatures;
+	}
+
+	// The shader group handle to copy into a shader binding table record.
+	const uint8_t* GetGroupHandle( uint32_t groupIndex ) const;
+
+	VkPipeline GetPipeline() const
+	{
+		return m_pipeline;
+	}
+
+	VkPipelineLayout GetPipelineLayout() const
+	{
+		return m_pipelineLayout;
+	}
+
+	VkDescriptorSetLayout GetDescriptorSetLayout() const
+	{
+		return m_descriptorSetLayout;
+	}
+
+	// Global signature bindings, in the same form the graphics/compute
+	// programs use so descriptor set construction can be shared.
+	const std::vector<Tr2ShaderProgramAL::BindingInfo>& GetBindings() const
+	{
+		return m_bindings;
+	}
+
+private:
+	ALResult CreateLayouts( const Tr2ShaderSignatureAL& globalSignature, const std::vector<uint32_t>& accelerationStructureBindings );
+
+	VkPipeline m_pipeline;
+	VkPipelineLayout m_pipelineLayout;
+	VkDescriptorSetLayout m_descriptorSetLayout;
+	std::vector<VkShaderModule> m_modules;
+	std::vector<VkSampler> m_staticSamplers;
+	std::vector<Tr2ShaderProgramAL::BindingInfo> m_bindings;
+	std::vector<uint8_t> m_groupHandles;
+	uint32_t m_groupHandleSize;
+	std::map<std::wstring, ShaderInfo> m_shaderInfoForName;
+	std::vector<Tr2ShaderSignatureAL> m_localSignatures;
+};
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2RtShaderTableALVulkan.cpp b/trinityal/vulkan/Tr2RtShaderTableALVulkan.cpp
new file mode 100644
index 00000000..30f5daf1
--- /dev/null
+++ b/trinityal/vulkan/Tr2RtShaderTableALVulkan.cpp
@@ -0,0 +1,280 @@
+// Copyright © 2026 CCP ehf.
+
+#include "StdAfx.h"
+
+#if TRINITY_PLATFORM == TRINITY_VULKAN
+
+#include "Tr2RtShaderTableALVulkan.h"
+#include "Tr2RtPipelineStateALVulkan.h"
+#include "Tr2ConstantBufferALVulkan.h"
+#include "Tr2RenderContextVulkan.h"
+#include "VulkanContext.h"
+#include "../ALLog.h"
+
+#include <algorithm>
+
+namespace TrinityALImpl
+{
+
+namespace
+{
+
+VkDeviceSize Align( VkDeviceSize offset, VkDeviceSize alignment )
+{
+	return ( offset + ( alignment - 1 ) ) & ~( alignment - 1 );
+}
+
+// Registers of a local signature that carry constant buffers, in ascending
+// register order; this fixes the layout of the record's embedded data.
+std::vector<uint32_t> LocalConstantBufferRegisters( const Tr2ShaderSignatureAL& signature )
+{
+	std::vector<uint32_t> registers;
+	for( const auto& reg : signature.registers )
+	{
+		if( reg.registerType == Tr2ShaderRegisterAL::CONSTANT_BUFFER )
+		{
+			registers.push_back( reg.registerIndex );
+		}
+	}
+	std::sort( registers.begin(), registers.end() );
+	return registers;
+}
+
+}
+
+Tr2RtShaderTableAL::Tr2RtShaderTableAL() :
+	m_table( VK_NULL_HANDLE ),
+	m_tableAllocation( VK_NULL_HANDLE ),
+	m_tableAddress( 0 ),
+	m_entrySize( 0 )
+{
+}
+
+Tr2RtShaderTableAL::~Tr2RtShaderTableAL()
+{
+	Destroy();
+}
+
+ALResult Tr2RtShaderTableAL::Create( const Tr2RtShaderTableDescriptionAL& desc, const ::Tr2RtPipelineStateAL& pipeline, Tr2PrimaryRenderContextAL& renderContext )
+{
+	Destroy();
+
+	if( !renderContext.IsValid() )
+	{
+		return E_INVALIDCALL;
+	}
+	if( !pipeline.IsValid() )
+	{
+		return E_INVALIDARG;
+	}
+
+	VulkanContext* context = GetVulkanContext();
+	if( !context || !context->IsValid() || !context->SupportsRayTracing() )
+	{
+		return E_INVALIDCALL;
+	}
+	const Tr2RtPipelineStateAL* pipelineImpl = pipeline.TrinityALImpl_GetObject();
+
+	const uint32_t handleSize = context->GetRayTracingProperties().shaderGroupHandleSize;
+	const uint32_t baseAlignment = std::max( context->GetRayTracingProperties().shaderGroupBaseAlignment, 1u );
+
+	const auto& localSignatures = pipelineImpl->GetLocalSignatures();
+
+	// The record's local data: the signature's constant buffers embedded in
+	// ascending register order, each 16-byte aligned. Sizes come from the
+	// materials, so scan every record to find the table-wide entry stride.
+	auto recordDataSize = [&]( const wchar_t* name, const Tr2RtLocalMaterialDescriptionAL& material, VkDeviceSize& size ) -> ALResult {
+		size = 0;
+		auto shaderInfo = pipelineImpl->GetShaderInfo( name );
+		if( !shaderInfo )
+		{
+			return E_INVALIDARG;
+		}
+		if( shaderInfo->localSignature == Tr2RtPipelineStateAL::NO_SIGNATURE )
+		{
+			return S_OK;
+		}
+		for( uint32_t registerIndex : LocalConstantBufferRegisters( localSignatures[shaderInfo->localSignature] ) )
+		{
+			if( registerIndex >= sizeof( material.m_constants ) / sizeof( material.m_constants[0] ) )
+			{
+				return E_INVALIDARG;
+			}
+			const Tr2ConstantBufferAL* cb = material.m_constants[registerIndex] ? material.m_constants[registerIndex]->TrinityALImpl_GetObject() : nullptr;
+			if( cb && cb->IsValid() )
+			{
+				size = Align( size, 16 ) + cb->GetSize();
+			}
+		}
+		return S_OK;
+	};
+
+	VkDeviceSize maxDataSize = 0;
+	auto scanRecords = [&]( const auto& records ) -> ALResult {
+		for( const auto& record : records )
+		{
+			VkDeviceSize size = 0;
+			CR_RETURN_HR( recordDataSize( record.name, record.material, size ) );
+			maxDataSize = std::max( maxDataSize, size );
+		}
+		return S_OK;
+	};
+	CR_RETURN_HR( scanRecords( desc.m_rayGenNames ) );
+	CR_RETURN_HR( scanRecords( desc.m_missNames ) );
+	CR_RETURN_HR( scanRecords( desc.m_hitGroupNames ) );
+
+	// A stride that is a multiple of the base alignment keeps every region
+	// start aligned with records laid out back to back.
+	m_entrySize = Align( handleSize + maxDataSize, baseAlignment );
+	const size_t recordCount = desc.m_rayGenNames.size() + desc.m_missNames.size() + desc.m_hitGroupNames.size();
+	const VkDeviceSize tableSize = m_entrySize * recordCount;
+	if( tableSize == 0 )
+	{
+		return E_INVALIDARG;
+	}
+
+	VkBufferCreateInfo bufferCreateInfo = {};
+	bufferCreateInfo.sType = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO;
+	bufferCreateInfo.size = tableSize;
+	bufferCreateInfo.usage = VK_BUFFER_USAGE_SHADER_BINDING_TABLE_BIT_KHR | VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT;
+	bufferCreateInfo.sharingMode = VK_SHARING_MODE_EXCLUSIVE;
+
+	VmaAllocationCreateInfo allocationCreateInfo = {};
+	allocationCreateInfo.usage = VMA_MEMORY_USAGE_AUTO;
+	allocationCreateInfo.flags = VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT | VMA_ALLOCATION_CREATE_MAPPED_BIT;
+
+	VmaAllocationInfo allocationInfo = {};
+	VK_CR_RETURN_HR( vmaCreateBufferWithAlignment( context->GetAllocator(), &bufferCreateInfo, &allocationCreateInfo, baseAlignment, &m_table, &m_tableAllocation, &allocationInfo ) );
+
+	VkBufferDeviceAddressInfo addressInfo = {};
+	addressInfo.sType = VK_STRUCTURE_TYPE_BUFFER_DEVICE_ADDRESS_INFO;
+	addressInfo.buffer = m_table;
+	m_tableAddress = vkGetBufferDeviceAddress( context->GetDevice(), &addressInfo );
+
+	uint8_t* tableData = static_cast<uint8_t*>( allocationInfo.pMappedData );
+	memset( tableData, 0, tableSize );
+
+	auto fillRecord = [&]( uint8_t* recordData, const wchar_t* name, const Tr2RtLocalMaterialDescriptionAL& material ) -> ALResult {
+		auto shaderInfo = pipelineImpl->GetShaderInfo( name );
+		if( !shaderInfo )
+		{
+			return E_INVALIDARG;
+		}
+		const uint8_t* handle = pipelineImpl->GetGroupHandle( shaderInfo->groupIndex );
+		if( !handle )
+		{
+			return E_INVALIDARG;
+		}
+		memcpy( recordData, handle, handleSize );
+
+		if( shaderInfo->localSignature == Tr2RtPipelineStateAL::NO_SIGNATURE )
+		{
+			return S_OK;
+		}
+		VkDeviceSize offset = 0;
+		for( uint32_t registerIndex : LocalConstantBufferRegisters( localSignatures[shaderInfo->localSignature] ) )
+		{
+			const Tr2ConstantBufferAL* cb = material.m_constants[registerIndex] ? material.m_constants[registerIndex]->TrinityALImpl_GetObject() : nullptr;
+			if( cb && cb->IsValid() && cb->GetContents() )
+			{
+				offset = Align( offset, 16 );
+				memcpy( recordData + handleSize + offset, cb->GetContents(), cb->GetSize() );
+				offset += cb->GetSize();
+			}
+		}
+		return S_OK;
+	};
+
+	for( const auto& record : desc.m_rayGenNames )
+	{
+		CR_RETURN_HR( fillRecord( tableData, record.name, record.material ) );
+		tableData += m_entrySize;
+	}
+	for( const auto& record : desc.m_missNames )
+	{
+		CR_RETURN_HR( fillRecord( tableData, record.name, record.material ) );
+		tableData += m_entrySize;
+	}
+	for( const auto& record : desc.m_hitGroupNames )
+	{
+		CR_RETURN_HR( fillRecord( tableData, record.name, record.material ) );
+		tableData += m_entrySize;
+	}
+	vmaFlushAllocation( context->GetAllocator(), m_tableAllocation, 0, tableSize );
+
+	m_desc = desc;
+	return S_OK;
+}
+
+void Tr2RtShaderTableAL::Destroy()
+{
+	VulkanContext* context = GetVulkanContext();
+	if( context && context->IsValid() )
+	{
+		context->DestroyBufferLater( m_table, m_tableAllocation );
+	}
+	m_table = VK_NULL_HANDLE;
+	m_tableAllocation = VK_NULL_HANDLE;
+	m_tableAddress = 0;
+	m_entrySize = 0;
+	m_desc = Tr2RtShaderTableDescriptionAL();
+}
+
+bool Tr2RtShaderTableAL::IsValid() const
+{
+	return m_table != VK_NULL_HANDLE;
+}
+
+Tr2ALMemoryType Tr2RtShaderTableAL::GetMemoryClass() const
+{
+	return AL_MEMORY_MANAGED;
+}
+
+void Tr2RtShaderTableAL::Describe( Tr2DeviceResourceDescriptionAL& description ) const
+{
+	description["type"] = "Tr2RtShaderTableAL";
+}
+
+VkStridedDeviceAddressRegionKHR Tr2RtShaderTableAL::GetRayGenRegion( const wchar_t* name ) const
+{
+	VkStridedDeviceAddressRegionKHR region = {};
+	for( size_t i = 0; i < m_desc.m_rayGenNames.size(); ++i )
+	{
+		if( wcscmp( m_desc.m_rayGenNames[i].name, name ) == 0 )
+		{
+			region.deviceAddress = m_tableAddress + i * m_entrySize;
+			region.stride = m_entrySize;
+			region.size = m_entrySize;
+			break;
+		}
+	}
+	return region;
+}
+
+VkStridedDeviceAddressRegionKHR Tr2RtShaderTableAL::GetMissRegion() const
+{
+	VkStridedDeviceAddressRegionKHR region = {};
+	if( !m_desc.m_missNames.empty() )
+	{
+		region.deviceAddress = m_tableAddress + m_desc.m_rayGenNames.size() * m_entrySize;
+		region.stride = m_entrySize;
+		region.size = m_entrySize * m_desc.m_missNames.size();
+	}
+	return region;
+}
+
+VkStridedDeviceAddressRegionKHR Tr2RtShaderTableAL::GetHitGroupRegion() const
+{
+	VkStridedDeviceAddressRegionKHR region = {};
+	if( !m_desc.m_hitGroupNames.empty() )
+	{
+		region.deviceAddress = m_tableAddress + ( m_desc.m_rayGenNames.size() + m_desc.m_missNames.size() ) * m_entrySize;
+		region.stride = m_entrySize;
+		region.size = m_entrySize * m_desc.m_hitGroupNames.size();
+	}
+	return region;
+}
+
+}
+
+#endif
diff --git a/trinityal/vulkan/Tr2RtShaderTableALVulkan.h b/trinityal/vulkan/Tr2RtShaderTableALVulkan.h
