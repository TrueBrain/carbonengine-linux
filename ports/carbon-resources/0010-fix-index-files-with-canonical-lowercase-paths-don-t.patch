From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Patric Stout <github@truebrain.nl>
Date: Sat, 4 Jul 2026 14:04:29 +0200
Subject: [PATCH 10/10] fix: index-files with canonical-lowercase paths don't
 work on case-sensitive filesystems

As a workaround, for these instances, implement a case-insensitive
lookup to find the files back.
---
 src/PatchResourceGroupImpl.cpp     |  2 +-
 src/ResourceInfo/ResourceInfo.cpp  |  8 ++---
 tests/src/ResourcesTestFixture.cpp |  6 +++-
 tools/include/ResourceTools.h      |  5 +++
 tools/src/ResourceTools.cpp        | 52 ++++++++++++++++++++++++++++++
 5 files changed, 67 insertions(+), 6 deletions(-)

diff --git a/src/PatchResourceGroupImpl.cpp b/src/PatchResourceGroupImpl.cpp
index 01e7b8a..f3ba95b 100644
--- a/src/PatchResourceGroupImpl.cpp
+++ b/src/PatchResourceGroupImpl.cpp
@@ -702,7 +702,7 @@ Result PatchResourceGroup::PatchResourceGroupImpl::Apply( const PatchApplyParams
         int i = 0;
 		for( const auto& path : *m_removedResources.GetValue() )
 		{
-			auto toRemove = std::filesystem::absolute( params.resourcesToPatchDestinationSettings.basePath / path );
+			auto toRemove = std::filesystem::absolute( ResourceTools::ResolveCaseInsensitivePath( params.resourcesToPatchDestinationSettings.basePath, path ) );
 
             if (removingFilesStatusSettings.RequiresStatusUpdates())
             {
